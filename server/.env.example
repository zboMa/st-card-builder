###############################################################################
# ST Card Builder — API 环境变量模板（复制为 server/.env 后填写）
# 本文件可提交到 Git；真实密钥/ID 只写在服务器或本地的 .env（勿提交）。
###############################################################################

# ---------- 服务与对外地址 ----------
# API 监听端口（本机；前面通常有 Nginx/Caddy 反代）
PORT=8787

# 用户端前端完整 Origin（无尾斜杠）。OAuth 成功后默认跳回这里。
# 本地示例：http://localhost:4321
# 生产示例：https://card.taojiu.love
PUBLIC_APP_URL=http://localhost:4321

# Express session 签名密钥。生产必须换成足够长的随机串（勿用默认值）。
SESSION_SECRET=change-me-to-a-long-random-string

# Cookie 是否仅 HTTPS 发送。本地 http 用 false；生产 HTTPS 必须 true。
COOKIE_SECURE=false

# ---------- CouchDB ----------
# 数据库地址（无尾斜杠）。Docker Compose 默认本机 5984。
COUCHDB_URL=http://127.0.0.1:5984
# Couch 管理员用户名/密码（用于建库、写分享库/管理库；勿提交真实生产密码到 Git）
COUCHDB_USER=admin
COUCHDB_PASSWORD=

# ---------- Discord OAuth（正式登录）----------
# 在 Discord 开发者后台 → 你的 Application → OAuth2 中获取。
# CLIENT_ID：公开的应用客户端 ID。
DISCORD_CLIENT_ID=
# CLIENT_SECRET：应用密钥，仅服务端持有，泄露等于别人能冒充你的应用。
DISCORD_CLIENT_SECRET=
# 授权完成后的回调 URL，必须与 Discord 后台「Redirects」里登记的字符串完全一致。
# 本地：http://localhost:8787/api/auth/discord/callback
# 生产（API 域名）：https://card-api.taojiu.love/api/auth/discord/callback
DISCORD_REDIRECT_URI=http://localhost:8787/api/auth/discord/callback
# 门禁用的 Discord 服务器（Guild）雪花 ID。右键服务器图标 → 复制服务器 ID（需开开发者模式）。
DISCORD_GUILD_ID=
# 允许登录的身份组 ID，多个用英文逗号分隔。用户至少拥有其中一个角色。
# 右键身份组 → 复制身份组 ID。
DISCORD_REQUIRED_ROLE_IDS=

# ---------- 登录策略 ----------
# true：校验用户是否在 DISCORD_GUILD_ID 中且具备 REQUIRED_ROLE_IDS 之一。
#       若开启校验但 Guild/Role 都留空 → 拒绝所有正式 Discord 注册（防误开）。
# false：OAuth 成功即可登录，不查服务器/身份组（仅建议本地调试）。
AUTH_ENFORCE_DISCORD_MEMBERSHIP=false

# true：允许「调试用户名」登录（/api/auth/dev-login）。生产务必 false。
DEV_LOGIN_ENABLED=false

# ---------- 管理端白名单 ----------
# 可进入 /admin（或管理域名）的 Discord 用户雪花 ID。
# 纯数字，多个用英文逗号分隔；不要加 discord_ 前缀。
# 获取：Discord 开发者模式 → 右键自己 → 复制用户 ID。
# 例：ADMIN_DISCORD_IDS=111111111111111111,222222222222222222
ADMIN_DISCORD_IDS=
