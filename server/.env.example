PORT=8787
PUBLIC_APP_URL=http://localhost:4321
SESSION_SECRET=change-me-to-a-long-random-string

COUCHDB_URL=http://127.0.0.1:5984
COUCHDB_USER=admin
COUCHDB_PASSWORD=adminpass

# Discord OAuth（正式登录）
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:8787/api/auth/discord/callback
DISCORD_GUILD_ID=
# 逗号分隔；留空 + AUTH_ENFORCE_DISCORD_MEMBERSHIP=true → 拒绝所有正式注册
DISCORD_REQUIRED_ROLE_IDS=

# false：不校验服务器/身份组；true：必须满足 Guild+Role（二者皆空则拒绝）
AUTH_ENFORCE_DISCORD_MEMBERSHIP=false

# 调试登录（临时用户名）；生产务必 false
DEV_LOGIN_ENABLED=true
