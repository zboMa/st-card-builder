###############################################################################
# ST Card Builder — API 环境变量模板（复制为 server/.env 后填写）
# 本文件可提交到 Git；真实密钥/ID 只写在服务器或本地的 .env（勿提交）。
###############################################################################

# ---------- 服务与对外地址 ----------
# API 监听端口（本机；前面通常有 Nginx/Caddy 反代）
PORT=8787

# 用户端前端完整 Origin（无尾斜杠）。OAuth 无 return_to 时默认跳回这里。
# 本地示例：http://localhost:4321
# 生产示例：https://card.taojiu.love
PUBLIC_APP_URL=http://localhost:4321

# 管理端前端 Origin（无尾斜杠）。生产独立站点，如 https://card-admin.taojiu.love
# 本地可留空或另起端口；须加入 CORS / return_to 白名单。
PUBLIC_ADMIN_URL=

# 对外 API Origin（无尾斜杠）。前端 Discord 登录入口、分享链接、插件对接。
# 本地可留空（前端走同源 /api 代理）；生产务必填 HTTPS API 域名。
# 生产示例：https://card-api.taojiu.love
PUBLIC_API_URL=

# 额外允许的 CORS Origin（逗号分隔）。SillyTavern 本机端口已默认放宽；
# 若酒馆跑在其它域名/端口，在此追加完整 Origin。
# 例：CORS_ORIGINS=https://st.example.com,http://192.168.1.10:8000
CORS_ORIGINS=

# Express session 签名密钥。生产必须换成足够长的随机串（勿用默认值）。
SESSION_SECRET=change-me-to-a-long-random-string

# Cookie 是否仅 HTTPS 发送。本地 http 用 false；生产 HTTPS 必须 true。
COOKIE_SECURE=false

# Session Cookie Domain（可选）。主站与管理端共用登录时设为父域，如 .taojiu.love
# 留空则 Cookie 仅绑定 API 主机名。
SESSION_COOKIE_DOMAIN=

# ---------- CouchDB ----------
# 数据库地址（无尾斜杠）。与 API 同机时用本机回环（部署脚本只对本机 URL 自动拉起）。
# 生产同机示例：http://127.0.0.1:5984
# 勿写 docker 内网主机名 couchdb（API 跑在宿主机 systemd，解析不到）。
COUCHDB_URL=http://127.0.0.1:5984
# Couch 管理员用户名/密码（用于建库、写分享库/管理库；勿提交真实生产密码到 Git）
COUCHDB_USER=admin
COUCHDB_PASSWORD=

# 部署时若 Couch 不可达：true=同机 Docker 自动拉起；false=仅校验，失败即中止部署。
# 无 Docker 时无论此项为何，自动拉起都会失败并中止部署。
COUCH_AUTO_PROVISION=true

# ---------- Discord OAuth（正式登录）----------
# 在 Discord 开发者后台 → 你的 Application → OAuth2 中获取。
# CLIENT_ID：公开的应用客户端 ID。
DISCORD_CLIENT_ID=
# CLIENT_SECRET：应用密钥，仅服务端持有，泄露等于别人能冒充你的应用。
DISCORD_CLIENT_SECRET=
# 授权完成后的回调 URL，必须与 Discord 后台「Redirects」里登记的字符串完全一致。
# 本地：http://localhost:8787/api/auth/discord/callback
# 生产（API 域名）：https://card-api.taojiu.love/api/auth/discord/callback
DISCORD_REDIRECT_URI=http://localhost:8787/api/auth/discord/callback
# 门禁用的 Discord 服务器（Guild）雪花 ID。右键服务器图标 → 复制服务器 ID（需开开发者模式）。
DISCORD_GUILD_ID=
# 允许登录的身份组 ID，多个用英文逗号分隔。用户至少拥有其中一个角色。
# 右键身份组 → 复制身份组 ID。
DISCORD_REQUIRED_ROLE_IDS=

# ---------- 登录策略 ----------
# true：校验用户是否在 DISCORD_GUILD_ID 中且具备 REQUIRED_ROLE_IDS 之一。
#       若开启校验但 Guild/Role 都留空 → 拒绝所有正式 Discord 注册（防误开）。
# false：OAuth 成功即可登录，不查服务器/身份组（仅建议本地调试）。
AUTH_ENFORCE_DISCORD_MEMBERSHIP=false

# true：允许「调试用户名」登录（/api/auth/dev-login）。生产务必 false。
DEV_LOGIN_ENABLED=false

# ---------- 管理端白名单 ----------
# 运维管理员（读写）：可禁用用户、停分享、吊销 Token、触发备份。
# 纯数字 Discord 雪花 ID，多个用英文逗号分隔；不要加 discord_ 前缀。
# 获取：Discord 开发者模式 → 右键自己 → 复制用户 ID。
# 例：ADMIN_DISCORD_IDS=111111111111111111,222222222222222222
ADMIN_DISCORD_IDS=

# 只读管理员：可看仪表盘/列表，不可写操作。
# 例：ADMIN_READONLY_DISCORD_IDS=333333333333333333
ADMIN_READONLY_DISCORD_IDS=

# 是否允许管理端「执行逻辑备份」（调用 scripts/backup-couch.sh）。生产按需 true。
ADMIN_BACKUP_ENABLED=false
# 备份输出目录（绝对路径）；留空则用 server/backups/
ADMIN_BACKUP_DIR=
