{
  "name": "st-card-builder",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && node scripts/pack-frontends.mjs",
    "build:astro": "astro build",
    "pack:frontends": "node scripts/pack-frontends.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "test": "node --test tests/**/*.test.mjs",
    "server": "npm --prefix server start",
    "server:dev": "npm --prefix server run dev",
    "server:test": "npm --prefix server test",
    "couch": "docker compose up -d couchdb"
  },
  "dependencies": {
    "@antv/g-camera-api": "^2.0.45",
    "@antv/g6": "^5.1.1",
    "astro": "^5.17.1",
    "events": "^3.3.0",
    "pouchdb-browser": "^9.0.0"
  }
}
