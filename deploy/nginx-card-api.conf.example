# ST Card Builder — API 站点 Nginx 示例（card-api.taojiu.love）
#
# 作用：
#   /api/*   → Node API :8787
#   /couch/* → 本机 CouchDB :5984（浏览器 Pouch 复制；剥离 /couch 前缀）
#
# 用法：
#   1. 复制到服务器，按域名/证书路径改 server_name、ssl_certificate
#   2. 确认 server/.env：
#        PUBLIC_API_URL=https://card-api.taojiu.love
#        PUBLIC_COUCH_URL=https://card-api.taojiu.love/couch
#        COUCHDB_URL=http://127.0.0.1:5984
#   3. nginx -t && systemctl reload nginx
#
# 说明：
#   - COUCHDB_URL 仅给 API 进程用（本机），千万不要把 127.0.0.1 发给浏览器
#   - 未单独设 PUBLIC_COUCH_URL 时，API 会默认用 {PUBLIC_API_URL}/couch

server {
  listen 443 ssl http2;
  listen [::]:443 ssl http2;
  server_name card-api.taojiu.love;

  # ssl_certificate     /etc/letsencrypt/live/card-api.taojiu.love/fullchain.pem;
  # ssl_certificate_key /etc/letsencrypt/live/card-api.taojiu.love/privkey.pem;

  client_max_body_size 50m;

  # ---------- Express API ----------
  location /api/ {
    proxy_pass http://127.0.0.1:8787;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header Cookie $http_cookie;
  }

  # ---------- CouchDB（浏览器同步）----------
  # 请求 https://card-api…/couch/userdb-…/_local/…
  # 转到 http://127.0.0.1:5984/userdb-…/_local/…
  location /couch/ {
    # 预检：主站/管理端跨域打 Couch
    if ($request_method = OPTIONS) {
      add_header Access-Control-Allow-Origin $http_origin always;
      add_header Access-Control-Allow-Credentials true always;
      add_header Access-Control-Allow-Methods "GET, PUT, POST, DELETE, HEAD, OPTIONS" always;
      add_header Access-Control-Allow-Headers "Authorization, Content-Type, Accept, Origin, If-Match, If-None-Match" always;
      add_header Access-Control-Max-Age 86400 always;
      add_header Content-Length 0;
      add_header Content-Type text/plain;
      return 204;
    }

    proxy_pass http://127.0.0.1:5984/;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header Authorization $http_authorization;
    proxy_pass_header Authorization;

    # 复制流量可能较大，关闭缓冲更稳
    proxy_buffering off;
    proxy_request_buffering off;
    client_max_body_size 50m;

    # 浏览器从主站 Origin 跨域访问本 API 域下的 /couch
    add_header Access-Control-Allow-Origin $http_origin always;
    add_header Access-Control-Allow-Credentials true always;
    add_header Access-Control-Allow-Methods "GET, PUT, POST, DELETE, HEAD, OPTIONS" always;
    add_header Access-Control-Allow-Headers "Authorization, Content-Type, Accept, Origin, If-Match, If-None-Match" always;
    add_header Access-Control-Expose-Headers "ETag, Content-Type, Content-Length, Server, Location" always;
  }

  location = / {
    return 204;
  }
}

server {
  listen 80;
  listen [::]:80;
  server_name card-api.taojiu.love;
  return 301 https://$host$request_uri;
}
