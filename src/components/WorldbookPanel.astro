---
---
<div class="panel area-worldbook">
  <!-- 标题行右上：小号操作按钮；下方仅搜索 + 列表 -->
  <div class="wb-panel-head">
    <h2>世界书条目</h2>
    <div class="wb-head-actions">
      <button id="btnOpenWbAiSingle" class="btn btn-ai wb-ai-open-btn" type="button" title="AI 单条生成">单条生成</button>
      <button id="btnOpenWbAiOrganize" class="btn wb-ai-open-btn" type="button" title="AI 智能整理">智能整理</button>
      <button id="btnOpenWbAiKeygen" class="btn wb-ai-open-btn" type="button" title="AI 补全触发词">补全触发词</button>
      <button id="btnCreateEntry" class="btn btn-add wb-entry-create-btn" type="button">新建</button>
    </div>
  </div>

  <!-- 搜索筛选（结果为单列紧凑命中列表） -->
  <div class="wb-toolbar">
    <div class="wb-search-wrap">
      <div class="wb-search-bar">
        <span class="wb-search-icon" aria-hidden="true">🔍</span>
        <input type="text" id="wbSearchInput" class="wb-search-input" placeholder="搜索标题 / 触发词 / 内容..." autocomplete="off" />
        <button id="wbSearchClear" class="wb-search-clear" title="清空" type="button" style="display:none;">✕</button>
      </div>
      <div class="wb-search-scope">
        <label class="wb-scope-tag"><input type="checkbox" id="wbScopeTitle" checked /><span>标题</span></label>
        <label class="wb-scope-tag"><input type="checkbox" id="wbScopeKeys" checked /><span>触发词</span></label>
        <label class="wb-scope-tag"><input type="checkbox" id="wbScopeContent" checked /><span>内容</span></label>
        <span id="wbSearchCount" class="wb-search-count"></span>
      </div>
      <div id="wbSearchResults" class="wb-search-results" style="display:none;"></div>
    </div>
  </div>

  <!-- AI 执行状态与整理预览（弹窗确认后在此展示） -->
  <div id="organizeStatus" class="organize-status-bar" style="display:none;"></div>
  <div id="keygenStatus" class="organize-status-bar" style="display:none;"></div>
  <div id="organizePreview" class="organize-preview-container" style="display: none;"></div>

  <!-- AI 单条生成配置弹窗 -->
  <div id="wbModalSingle" class="wb-modal" hidden aria-hidden="true">
    <div class="wb-modal-backdrop" data-wb-modal-close="wbModalSingle"></div>
    <div class="wb-modal-dialog" role="dialog" aria-modal="true" aria-labelledby="wbModalSingleTitle">
      <div class="wb-modal-head">
        <strong id="wbModalSingleTitle">AI 单条生成</strong>
        <span class="wb-modal-tip">自动叠加，读取已有词条保持连贯</span>
      </div>
      <div class="wb-modal-body">
        <div class="wb-ai-row">
          <input type="text" id="wbSinglePrompt" placeholder="定向要求(可选)，如：写一把专属武器..." />
        </div>
        <div class="wb-ai-checks">
          <label class="wb-ai-check"><input type="checkbox" id="wbIncludeCharData" />高级：参考主角名与描述（默认关，两管道隔离）</label>
          <label class="wb-ai-check"><input type="checkbox" id="wbIncludeOtherEntries" checked />融合【已有世界书条目】</label>
        </div>
      </div>
      <div class="wb-modal-actions">
        <button type="button" class="btn wb-modal-cancel" data-wb-modal-close="wbModalSingle">取消</button>
        <button id="btnAiSingleWb" class="btn btn-ai wb-ai-action" type="button">生成 1 条</button>
      </div>
    </div>
  </div>

  <!-- AI 智能整理配置弹窗 -->
  <div id="wbModalOrganize" class="wb-modal" hidden aria-hidden="true">
    <div class="wb-modal-backdrop" data-wb-modal-close="wbModalOrganize"></div>
    <div class="wb-modal-dialog" role="dialog" aria-modal="true" aria-labelledby="wbModalOrganizeTitle">
      <div class="wb-modal-head">
        <strong id="wbModalOrganizeTitle">AI 智能整理</strong>
        <span class="wb-modal-tip">优化插入位置 · 深度 · 顺序 · 概率</span>
      </div>
      <div class="wb-modal-body">
        <p class="wb-modal-desc">将对当前全部世界书条目做参数分析，完成后在列表上方展示预览，确认后再应用。</p>
      </div>
      <div class="wb-modal-actions">
        <button type="button" class="btn wb-modal-cancel" data-wb-modal-close="wbModalOrganize">取消</button>
        <button id="btnAiOrganize" class="btn wb-ai-action" type="button">一键整理</button>
      </div>
    </div>
  </div>

  <!-- AI 补全触发词配置弹窗 -->
  <div id="wbModalKeygen" class="wb-modal" hidden aria-hidden="true">
    <div class="wb-modal-backdrop" data-wb-modal-close="wbModalKeygen"></div>
    <div class="wb-modal-dialog" role="dialog" aria-modal="true" aria-labelledby="wbModalKeygenTitle">
      <div class="wb-modal-head">
        <strong id="wbModalKeygenTitle">AI 补全触发词</strong>
        <span class="wb-modal-tip">批量补全更自然的触发词</span>
      </div>
      <div class="wb-modal-body">
        <p class="wb-modal-desc">将按批次为全部条目生成/补全触发词，结果直接写回各条目。</p>
      </div>
      <div class="wb-modal-actions">
        <button type="button" class="btn wb-modal-cancel" data-wb-modal-close="wbModalKeygen">取消</button>
        <button id="btnAiGenerateKeys" class="btn wb-ai-action" type="button">一键补触发词</button>
      </div>
    </div>
  </div>

  <!-- 条目新建/编辑：居中弹窗（列表仅折叠预览） -->
  <div id="wbModalEdit" class="wb-modal" hidden aria-hidden="true">
    <div class="wb-modal-backdrop" data-wb-modal-close="wbModalEdit"></div>
    <div class="wb-modal-dialog wb-modal-dialog-lg" role="dialog" aria-modal="true" aria-labelledby="wbModalEditTitle">
      <div class="wb-modal-head">
        <strong id="wbModalEditTitle">编辑世界书条目</strong>
        <span class="wb-modal-tip" id="wbModalEditTip">保存后写回列表 · Esc / 遮罩关闭</span>
      </div>
      <div class="wb-modal-body wb-modal-body-scroll" id="wbModalEditBody"></div>
      <div class="wb-modal-actions">
        <button type="button" class="btn wb-modal-cancel" data-wb-modal-close="wbModalEdit">取消</button>
        <button id="btnWbModalSave" class="btn btn-add wb-ai-action" type="button">保存</button>
      </div>
    </div>
  </div>

  <!-- 条目列表占满剩余高度，内部滚动 -->
  <div id="entriesList" class="wb-entries-list" aria-live="polite"></div>
</div>

<style>
  /* 标题行：左标题 右小号操作横排 */
  .wb-panel-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    margin-bottom: 8px;
    flex-wrap: wrap;
  }
  .wb-panel-head h2 {
    margin: 0;
    flex-shrink: 0;
  }
  .wb-head-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: flex-end;
    gap: 5px;
    margin-left: auto;
  }
  /* 小号横排：三 AI + 新建 */
  .wb-ai-open-btn,
  .wb-entry-create-btn {
    width: auto !important;
    margin: 0 !important;
    padding: 4px 8px !important;
    font-size: 0.66rem !important;
    line-height: 1.2 !important;
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* 搜索区独占下方工具条 */
  .wb-toolbar {
    margin-bottom: 8px;
  }
  .wb-search-wrap {
    padding: 8px 10px;
    border-radius: 8px;
    background: var(--color-surface-inset);
    border: 1px solid var(--color-accent-border);
  }
  .wb-search-bar {
    display: flex;
    align-items: center;
    gap: 6px;
    background: rgba(8, 12, 28, 0.55);
    border: 1px solid rgba(71, 85, 105, 0.4);
    border-radius: 8px;
    padding: 0 8px;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .wb-search-bar:focus-within {
    border-color: var(--color-accent-border);
    box-shadow: 0 0 0 2px var(--color-accent-soft);
  }
  .wb-search-icon { font-size: 0.82rem; opacity: 0.7; }
  .wb-search-input {
    flex: 1;
    background: transparent !important;
    border: none !important;
    outline: none !important;
    box-shadow: none !important;
    color: var(--color-text-secondary);
    font-size: 0.8rem;
    padding: 7px 0 !important;
    font-family: inherit;
    min-width: 0;
    border-radius: 0;
  }
  .wb-search-input::placeholder { color: var(--color-text-muted); }
  .wb-search-clear {
    background: rgba(71, 85, 105, 0.4);
    border: none;
    color: var(--color-text-muted);
    width: 20px;
    height: 20px;
    border-radius: 50%;
    cursor: pointer;
    font-size: 0.68rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
    flex-shrink: 0;
  }
  .wb-search-clear:hover {
    background: rgba(100, 116, 139, 0.6);
    color: var(--color-text);
  }
  .wb-search-scope {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: 6px;
    flex-wrap: wrap;
  }
  .wb-scope-tag {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 2px 8px;
    border-radius: 6px;
    background: rgba(30, 41, 59, 0.6);
    border: 1px solid rgba(71, 85, 105, 0.4);
    font-size: 0.68rem;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all 0.2s ease;
    user-select: none;
    margin: 0;
    font-weight: normal;
  }
  .wb-scope-tag:hover {
    border-color: var(--color-accent-border);
    color: var(--color-text-secondary);
  }
  .wb-scope-tag input { display: none; }
  .wb-scope-tag:has(input:checked) {
    background: var(--color-accent-soft);
    border-color: var(--color-accent-border);
    color: #c7d2fe;
  }
  .wb-search-count {
    margin-left: auto;
    font-size: 0.66rem;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  /* 单列紧凑命中列表（非双列预览卡） */
  .wb-search-results {
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin-top: 8px;
    max-height: 220px;
    overflow-y: auto;
    padding-right: 2px;
  }
  .wb-search-empty {
    text-align: center;
    color: var(--color-text-muted);
    font-size: 0.74rem;
    padding: 10px 8px;
  }
  .wb-search-hit {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 6px 8px;
    border-radius: 6px;
    border: 1px solid transparent;
    background: var(--color-surface-inset);
    cursor: pointer;
    transition: border-color 0.15s ease, background 0.15s ease;
    min-width: 0;
  }
  .wb-search-hit:hover,
  .wb-search-hit:focus-visible {
    border-color: var(--color-accent-border);
    background: rgba(30, 41, 59, 0.85);
    outline: none;
  }
  .wb-search-hit-main {
    display: flex;
    align-items: center;
    gap: 6px;
    min-width: 0;
    flex-wrap: wrap;
  }
  .wb-search-hit-title {
    font-size: 0.76rem;
    font-weight: 700;
    color: var(--color-text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    min-width: 0;
    max-width: 100%;
  }
  .wb-search-hit-fields {
    font-size: 0.62rem;
    color: var(--color-text-muted);
    white-space: nowrap;
  }
  .wb-search-hit-fields strong {
    color: var(--color-accent-hover);
    font-weight: 600;
  }
  .wb-search-hit-snippet {
    font-size: 0.68rem;
    color: var(--color-text-muted);
    line-height: 1.35;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .wb-search-hit mark {
    background: rgba(251, 191, 36, 0.28);
    color: #fde68a;
    padding: 0 2px;
    border-radius: 3px;
    font-weight: 600;
  }

  /* AI 配置：真弹窗（fixed 全屏遮罩；打开时挂到 body） */
  .wb-modal[hidden] { display: none !important; }
  .wb-modal {
    position: fixed;
    inset: 0;
    z-index: 9200;
    display: grid;
    place-items: center;
    padding: 18px;
  }
  :global(body.wb-modal-open) {
    overflow: hidden;
  }
  .wb-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(2, 6, 23, 0.66);
    backdrop-filter: blur(6px);
  }
  .wb-modal-dialog {
    position: relative;
    z-index: 1;
    width: min(480px, 100%);
    border-radius: 12px;
    border: 1px solid var(--color-accent-border);
    background: linear-gradient(145deg, rgba(15, 23, 42, 0.98), rgba(7, 12, 24, 0.98));
    box-shadow: 0 20px 56px rgba(0, 0, 0, 0.45);
    overflow: hidden;
  }
  .wb-modal-dialog-lg { width: min(640px, 100%); }
  .wb-modal-body-scroll {
    max-height: min(62vh, 520px);
    overflow-y: auto;
  }
  .wb-modal-head {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 14px 16px 10px;
    border-bottom: 1px solid var(--color-accent-soft);
  }
  .wb-modal-head strong {
    font-size: 0.9rem;
    color: var(--color-text);
  }
  .wb-modal-tip {
    font-size: 0.68rem;
    color: var(--color-text-muted);
  }
  .wb-modal-body {
    padding: 12px 16px 8px;
  }
  .wb-modal-desc {
    margin: 0;
    font-size: 0.78rem;
    line-height: 1.55;
    color: var(--color-text-muted);
  }
  .wb-modal-actions {
    display: flex;
    justify-content: flex-end;
    gap: 8px;
    padding: 12px 16px 14px;
    border-top: 1px solid rgba(51, 65, 85, 0.45);
  }
  .wb-modal-cancel {
    width: auto !important;
    margin: 0 !important;
    padding: 8px 12px !important;
    font-size: 0.78rem !important;
    background: linear-gradient(135deg, var(--color-surface-elevated), var(--color-surface));
  }
  .wb-ai-row {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .wb-ai-row input[type="text"] {
    flex: 1;
    min-width: 0;
  }
  .wb-ai-action {
    width: auto !important;
    margin: 0 !important;
    padding: 8px 12px !important;
    font-size: 0.78rem !important;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .wb-ai-checks {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 10px;
    flex-wrap: wrap;
  }
  .wb-ai-check {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.74rem;
    font-weight: normal;
    cursor: pointer;
  }

  /* 列表占满剩余高度；条目不参与压缩 */
  .wb-entries-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .wb-entries-empty {
    margin: auto 0;
    padding: 24px 14px;
    text-align: center;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    border: 1px dashed var(--color-accent-border);
    border-radius: 8px;
    background: var(--color-accent-soft);
  }

  @media (max-width: 720px) {
    .wb-panel-head {
      align-items: flex-start;
    }
    .wb-head-actions {
      width: 100%;
      justify-content: flex-start;
    }
  }
</style>
