---
/** 角色卡管理：预览卡片网格 / 新建 / 导入导出 / 切换 / 删除（存储逻辑仍在 index 草稿系统） */
---
<div class="panel area-card-manager">
  <div class="card-manager-header">
    <div class="card-manager-heading">
      <h2>角色卡管理</h2>
      <p class="ui-panel-lead card-manager-tip">本地多卡草稿箱；时间旁云标表示未上云 / 未同步 / 已同步。未同步时「⋯」左侧可快捷上云；完整导出、分享与云端仍在「⋯」内。</p>
    </div>
    <!-- 右上角：仅新建 + 导入；导出在每张预览卡底部 -->
    <div class="card-manager-toolbar">
      <button type="button" id="btnNewDraft" class="btn btn-add btn-sm">新建</button>
      <button type="button" id="btnImportCard" class="btn btn-fetch btn-sm">导入</button>
      <input type="file" id="importCardInput" accept=".json,.png" style="display:none;" />
    </div>
  </div>

  <div id="importStatusBar" class="card-manager-import-status" style="display:none;"></div>

  <div class="card-manager-filters" id="cardManagerFilters">
    <div class="card-manager-filter-search">
      <div class="ui-search-bar wb-search-bar">
        <span class="ui-search-icon wb-search-icon" aria-hidden="true">🔍</span>
        <input type="search" id="cardManagerSearch" class="ui-search-input wb-search-input" placeholder="搜索角色名…" autocomplete="off" aria-label="搜索角色卡" />
        <button type="button" id="cardManagerSearchClear" class="ui-search-clear wb-search-clear" hidden title="清空" aria-label="清空搜索">✕</button>
      </div>
    </div>
    <div class="card-manager-tag-bar" id="cardManagerTagBar">
      <button type="button" id="btnCardTagPicker" class="card-manager-tag-picker-btn" title="多选标签筛选" aria-label="打开标签筛选" aria-haspopup="listbox" aria-expanded="false">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><path d="M20.6 13.1 12.7 21a2 2 0 0 1-2.8 0L3 14.1V4h10.1l7.5 7.5a2 2 0 0 1 0 1.6z"/><circle cx="7.5" cy="8.5" r="1.2"/></svg>
      </button>
      <div class="card-manager-tag-scroll" id="cardManagerTagScroll" aria-label="标签筛选"></div>
      <button type="button" id="btnCardTagClear" class="card-manager-tag-clear" hidden>清除筛选</button>
    </div>
    <div id="cardManagerTagPopup" class="card-manager-tag-popup" hidden role="listbox" aria-multiselectable="true" aria-label="全部标签"></div>
  </div>

  <!-- 检查结果缓存节点（视觉已迁到卡片角标，此处保持隐藏供逻辑/测试） -->
  <div id="exportChecklistBox" class="export-checklist-bar" hidden aria-hidden="true">
    <span id="exportChecklistSummary" class="export-checklist-bar__summary"></span>
  </div>

  <div id="exportChecklistModal" class="export-checklist-modal" hidden aria-hidden="true">
    <div class="export-checklist-modal__backdrop ui-modal-backdrop" data-export-checklist-close></div>
    <div class="ui-modal-dialog export-checklist-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="exportChecklistModalTitle">
      <div class="export-checklist-modal__head">
        <h3 id="exportChecklistModalTitle">导出前检查</h3>
        <div class="export-checklist-modal__head-actions">
          <button type="button" id="btnRefreshExportChecklist" class="btn btn-ghost btn-inline">刷新</button>
          <button type="button" class="btn-icon btn-icon--sm" data-export-checklist-close aria-label="关闭">×</button>
        </div>
      </div>
      <p id="exportChecklistModalSummary" class="ui-hint export-checklist-modal__lead"></p>
      <ul id="exportChecklistItems" class="export-checklist-items"></ul>
    </div>
  </div>

  <div id="cardManagerList" class="card-manager-list" aria-live="polite"></div>
</div>

<style is:global>
  .card-manager-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 14px;
  }

  .card-manager-heading h2 {
    margin-bottom: 0;
  }

  .card-manager-tip {
    /* 视觉由 .ui-panel-lead 接管；保留类名兼容测试 */
  }

  .card-manager-toolbar {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: flex-end;
    flex-shrink: 0;
  }

  .card-manager-toolbar .btn {
    width: auto;
    min-width: 0;
    margin: 0;
    padding: 6px 12px;
    font-size: 0.78rem;
  }

  .card-manager-import-status {
    padding: 8px 12px;
    font-size: 0.78rem;
    border-radius: 8px;
    margin-bottom: 12px;
  }

  .export-checklist-bar[hidden] {
    display: none !important;
  }

  .export-checklist-modal[hidden] {
    display: none !important;
  }
  .export-checklist-modal {
    position: fixed;
    inset: 0;
    z-index: 9200;
    display: grid;
    place-items: center;
    padding: 16px;
  }
  .export-checklist-modal__backdrop {
    position: absolute;
    inset: 0;
  }
  .export-checklist-modal__dialog {
    position: relative;
    z-index: 1;
    width: min(440px, 100%);
    max-height: min(70vh, 520px);
    display: flex;
    flex-direction: column;
    padding: 14px 16px;
  }
  .export-checklist-modal__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    margin-bottom: 8px;
  }
  .export-checklist-modal__head h3 {
    margin: 0;
    font-size: 0.9rem;
  }
  .export-checklist-modal__head-actions {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .export-checklist-modal__lead {
    margin: 0 0 10px;
  }
  .export-checklist-items {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
    overflow-y: auto;
    min-height: 0;
  }
  .export-checklist-items li {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 8px;
    font-size: 0.74rem;
    line-height: 1.4;
    padding: 6px 8px;
    border-radius: 8px;
    background: rgba(148, 163, 184, 0.08);
  }
  .export-checklist-items li.is-critical {
    background: rgba(239, 68, 68, 0.1);
    color: #fecaca;
  }
  .export-checklist-items li.is-warning {
    background: rgba(245, 158, 11, 0.1);
    color: #fde68a;
  }
  .export-checklist-items .export-checklist-jump {
    flex-shrink: 0;
    font-size: 0.7rem;
    color: var(--color-accent-hover);
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
    text-decoration: underline;
  }

  /* 预览卡片网格：默认一行 4 列，窄屏递减 */
  .card-manager-list {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
  }

  @media (max-width: 1200px) {
    .card-manager-list {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 900px) {
    .card-manager-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .card-manager-list {
      grid-template-columns: minmax(0, 1fr);
    }
  }

  .card-manager-empty {
    grid-column: 1 / -1;
    margin: 8px auto;
    max-width: 28rem;
    width: calc(100% - 24px);
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--color-text-muted);
    padding: 28px 18px;
    text-align: center;
    border: 1px dashed var(--color-accent-border);
    border-radius: 10px;
    background: var(--color-accent-soft);
    line-height: 1.55;
  }

  .card-manager-item {
    display: flex;
    flex-direction: column;
    border-radius: 10px;
    border: 1px solid var(--color-accent-border);
    background: var(--color-surface-inset);
    cursor: pointer;
    overflow: hidden;
    transition: border-color 0.15s ease, background 0.15s ease;
  }

  .card-manager-item:hover {
    border-color: var(--color-accent-border);
    background: var(--color-accent-soft);
  }

  .card-manager-item.is-active {
    border-color: oklch(72% 0.14 155 / 0.45);
    background: var(--color-success-soft);
    box-shadow: inset 0 0 0 1px oklch(72% 0.14 155 / 0.2);
  }

  .card-manager-cover {
    position: relative;
    aspect-ratio: 3 / 4;
    background: var(--color-paper-deep);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    cursor: pointer;
  }

  .card-manager-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .card-manager-cover-placeholder {
    font-size: 0.72rem;
    color: var(--color-text-muted);
  }

  .card-manager-badge,
  .card-manager-version-badge,
  .card-manager-check-badge {
    padding: 2px 7px;
    font-size: 0.65rem;
    font-weight: 600;
    line-height: 1.25;
    border-radius: var(--radius-sm);
    background: var(--color-paper-deep);
    display: inline-flex;
    align-items: center;
    gap: 3px;
    max-width: 100%;
  }

  .card-manager-badge {
    color: var(--color-success);
    border: 1px solid oklch(72% 0.14 155 / 0.4);
  }

  .card-manager-cover-badges {
    position: absolute;
    top: 8px;
    right: 8px;
    display: flex;
    align-items: center;
    gap: 4px;
    z-index: 2;
    flex-wrap: wrap;
    justify-content: flex-end;
    max-width: calc(100% - 16px);
  }

  .card-manager-version-badge {
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border-subtle);
    font-variant-numeric: tabular-nums;
  }

  .card-manager-check-badge {
    cursor: pointer;
    border: 1px solid rgba(248, 113, 113, 0.45);
    color: #fecaca;
    background: rgba(127, 29, 29, 0.72);
    font-variant-numeric: tabular-nums;
  }
  .card-manager-check-badge.is-warning {
    border-color: rgba(245, 158, 11, 0.45);
    color: #fde68a;
    background: rgba(120, 53, 15, 0.72);
  }
  .card-manager-check-badge:hover {
    filter: brightness(1.08);
  }
  .card-manager-check-badge svg {
    width: 11px;
    height: 11px;
    flex-shrink: 0;
  }

  .card-manager-cover-overlay {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 1;
    padding: 28px 10px 10px;
    background: linear-gradient(180deg, transparent 0%, rgba(2, 6, 23, 0.55) 28%, rgba(2, 6, 23, 0.92) 100%);
    pointer-events: none;
  }
  .card-manager-cover-overlay > * {
    pointer-events: auto;
  }

  .card-manager-item-name {
    display: block;
    width: 100%;
    margin: 0;
    padding: 0;
    border: none;
    background: transparent;
    text-align: left;
    font: inherit;
    font-size: 0.88rem;
    font-weight: 650;
    color: #f8fafc;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    cursor: pointer;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.45);
  }
  .card-manager-item-name:hover {
    color: var(--color-accent-hover);
  }

  .card-manager-item-meta {
    margin-top: 3px;
    font-size: 0.68rem;
    color: rgba(226, 232, 240, 0.82);
    line-height: 1.35;
  }

  .card-cloud-status {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.05rem;
    height: 1.05rem;
    margin-left: 4px;
    vertical-align: -0.15em;
    border-radius: 999px;
  }
  .card-cloud-status svg {
    width: 0.92rem;
    height: 0.92rem;
  }
  .card-cloud-status.is-local {
    color: rgba(148, 163, 184, 0.95);
  }
  .card-cloud-status.is-dirty {
    color: #fbbf24;
    background: rgba(245, 158, 11, 0.14);
  }
  .card-cloud-status.is-synced {
    color: #34d399;
    background: rgba(16, 185, 129, 0.14);
  }

  .card-manager-item-actions {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    justify-content: space-between;
    gap: 4px;
    padding: var(--space-1) var(--space-2);
    border-top: 1px solid var(--color-border-subtle);
    background: var(--color-surface-inset);
    min-height: 40px;
    overflow-x: auto;
    scrollbar-width: thin;
    position: relative;
  }

  .card-manager-item-actions__group {
    display: flex;
    align-items: center;
    gap: 4px;
    flex-shrink: 0;
  }

  .card-manager-item-actions__group--end {
    margin-left: auto;
  }

  .card-more-popover {
    position: fixed;
    z-index: 9600;
    width: 220px;
    max-height: min(70vh, 480px);
    overflow-y: auto;
    border: 1px solid var(--color-border-subtle);
    border-radius: 12px;
    background: rgba(8, 12, 24, 0.96);
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.45);
    padding: 6px 0;
    backdrop-filter: blur(10px);
  }

  .card-more-section {
    padding: 4px 0;
  }

  .card-more-section__title {
    padding: 4px 12px 6px;
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--color-text-muted);
    text-transform: uppercase;
  }

  .card-more-item {
    display: block;
    width: 100%;
    text-align: left;
    border: 0;
    background: transparent;
    color: var(--color-text-secondary);
    font: inherit;
    font-size: 0.78rem;
    font-weight: 600;
    padding: 8px 12px;
    cursor: pointer;
  }
  .card-more-item:hover:not(:disabled) {
    background: rgba(99, 102, 241, 0.12);
    color: #f8fafc;
  }
  .card-more-item:disabled {
    opacity: 0.42;
    cursor: not-allowed;
  }

  .card-more-divider {
    height: 1px;
    margin: 4px 0;
    background: rgba(51, 65, 85, 0.7);
  }

  .card-more-hint {
    margin: 0;
    padding: 4px 12px 8px;
    font-size: 0.66rem;
    color: var(--color-text-muted);
    line-height: 1.4;
  }

  .card-manager-item-share {
    display: none;
  }

  .card-manager-filters {
    position: relative;
    margin-bottom: 12px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    z-index: 40;
  }
  .card-manager-filter-search .ui-search-bar {
    width: 100%;
  }
  .card-manager-tag-bar {
    display: flex;
    align-items: center;
    gap: 6px;
    min-width: 0;
  }
  .card-manager-tag-picker-btn {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    display: grid;
    place-items: center;
    border-radius: 8px;
    border: 1px solid var(--color-border-subtle);
    background: var(--color-surface-elevated);
    color: var(--color-text-secondary);
    cursor: pointer;
  }
  .card-manager-tag-picker-btn:hover,
  .card-manager-tag-picker-btn[aria-expanded="true"] {
    border-color: var(--color-accent-border);
    color: var(--color-accent);
  }
  .card-manager-tag-scroll {
    display: flex;
    align-items: center;
    gap: 6px;
    overflow-x: auto;
    min-width: 0;
    flex: 1;
    padding: 2px 0;
    scrollbar-width: thin;
  }
  .card-manager-tag-chip {
    flex-shrink: 0;
    border: 1px solid var(--color-border-subtle);
    background: var(--color-surface-inset);
    color: var(--color-text-muted);
    border-radius: 999px;
    padding: 3px 10px;
    font-size: 0.7rem;
    cursor: pointer;
    white-space: nowrap;
  }
  .card-manager-tag-chip.is-active {
    border-color: var(--color-accent-border);
    background: var(--color-accent-soft);
    color: var(--color-accent-hover);
  }
  .card-manager-tag-clear {
    flex-shrink: 0;
    border: none;
    background: transparent;
    color: var(--color-text-muted);
    font-size: 0.7rem;
    cursor: pointer;
    text-decoration: underline;
    padding: 0 2px;
  }
  .card-manager-tag-popup {
    position: absolute;
    left: 0;
    top: calc(100% + 4px);
    z-index: 50;
    width: min(240px, 100%);
    max-height: min(70vh, 360px);
    overflow-x: hidden;
    overflow-y: auto;
    padding: 6px 0;
    border-radius: 10px;
    border: 1px solid var(--color-accent-border);
    background: var(--color-surface-elevated);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.35);
    display: flex;
    flex-direction: column;
    flex-wrap: nowrap;
    gap: 0;
  }
  .card-manager-tag-popup.is-fixed-portal {
    position: fixed;
    z-index: 9550;
    top: 0;
    left: 0;
    width: min(240px, calc(100vw - 16px));
  }
  .card-manager-tag-popup[hidden] {
    display: none !important;
  }
  .card-manager-tag-option {
    display: block;
    width: 100%;
    text-align: left;
    border: 0;
    background: transparent;
    color: var(--color-text-secondary);
    font: inherit;
    font-size: 0.78rem;
    font-weight: 600;
    padding: 8px 12px;
    cursor: pointer;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .card-manager-tag-option:hover {
    background: rgba(99, 102, 241, 0.12);
    color: #f8fafc;
  }
  .card-manager-tag-option.is-active {
    background: var(--color-accent-soft);
    color: var(--color-accent-hover);
  }
  .card-manager-tag-popup-empty {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    padding: 8px 12px;
  }

  .card-manager-import-status.is-error {
    color: var(--color-danger);
  }

  .card-mgr-icon {
    flex-shrink: 0;
  }

  .card-mgr-icon--cloud:hover:not(:disabled) {
    border-color: var(--color-accent-border);
    color: var(--color-accent-hover);
  }

  .card-mgr-icon--danger:hover:not(:disabled) {
    border-color: oklch(62% 0.18 25 / 0.45);
    background: oklch(62% 0.18 25 / 0.12);
    color: var(--color-danger);
  }

  .card-mgr-icon--export:hover:not(:disabled) {
    border-color: var(--color-accent-border);
    color: var(--color-accent-hover);
  }

  @media (max-width: 720px) {
    .card-manager-header {
      flex-direction: column;
      align-items: stretch;
    }

    .card-manager-toolbar {
      justify-content: flex-start;
    }
  }
</style>

<script is:inline>
(function() {
  // 导入入口在本面板；导出 JSON/PNG 由 index 绑到各卡底部（导出该卡，不含小说）
  var importStatusBar = document.getElementById('importStatusBar');
  var btnImportCard = document.getElementById('btnImportCard');
  var importCardInput = document.getElementById('importCardInput');
  if (!btnImportCard || !importCardInput) return;

  btnImportCard.addEventListener('click', function() {
    importCardInput.value = '';
    importCardInput.click();
  });

  importCardInput.addEventListener('change', function(e) {
    var file = e.target.files[0];
    if (!file) return;
    var ext = file.name.split('.').pop().toLowerCase();
    if (ext === 'json') importFromJSON(file);
    else if (ext === 'png') importFromPNG(file);
    else showImportStatus('❌ 不支持的文件格式，请选择 .json 或 .png', 'error');
  });

  function importFromJSON(file) {
    showImportStatus('⏳ 解析 JSON...', 'info');
    var reader = new FileReader();
    reader.onload = function(ev) {
      try {
        applyImportedCard(JSON.parse(ev.target.result), file.name);
      } catch (err) {
        showImportStatus('❌ JSON 解析失败：' + err.message, 'error');
      }
    };
    reader.readAsText(file);
  }

  function importFromPNG(file) {
    showImportStatus('⏳ 解析 PNG 元数据...', 'info');
    var reader = new FileReader();
    reader.onload = function(ev) {
      try {
        var bytes = new Uint8Array(ev.target.result);
        var charaB64 = extractPNGCharaChunk(bytes);
        if (!charaB64) {
          showImportStatus('❌ 未找到角色数据，该 PNG 可能不是酒馆卡片', 'error');
          return;
        }
        var jsonStr = decodeURIComponent(escape(atob(charaB64)));
        var json = JSON.parse(jsonStr);
        var dataUrl = URL.createObjectURL(file);
        var img = new Image();
        img.onload = function() {
          var cv = document.createElement('canvas');
          cv.width = img.width;
          cv.height = img.height;
          cv.getContext('2d').drawImage(img, 0, 0);
          var base64 = cv.toDataURL('image/png');
          URL.revokeObjectURL(dataUrl);
          if (window.__setImportedAvatar__) window.__setImportedAvatar__(base64);
          applyImportedCard(json, file.name);
        };
        img.onerror = function() {
          URL.revokeObjectURL(dataUrl);
          applyImportedCard(json, file.name);
        };
        img.src = dataUrl;
      } catch (err) {
        showImportStatus('❌ PNG 解析失败：' + err.message, 'error');
      }
    };
    reader.readAsArrayBuffer(file);
  }

  function extractPNGCharaChunk(bytes) {
    var i = 8;
    while (i < bytes.length - 12) {
      var length =
        (bytes[i] << 24 | bytes[i + 1] << 16 |
          bytes[i + 2] << 8 | bytes[i + 3]) >>> 0;
      var type = String.fromCharCode(bytes[i + 4], bytes[i + 5], bytes[i + 6], bytes[i + 7]);
      if (type === 'tEXt') {
        var data = bytes.slice(i + 8, i + 8 + length);
        var nullPos = data.indexOf(0);
        if (nullPos < 0) { i += 12 + length; continue; }
        var keyword = '';
        for (var k = 0; k < nullPos; k++) keyword += String.fromCharCode(data[k]);
        if (keyword === 'chara') {
          var value = '';
          for (var v = nullPos + 1; v < data.length; v++) value += String.fromCharCode(data[v]);
          return value;
        }
      }
      if (type === 'IEND') break;
      i += 12 + length;
    }
    return null;
  }

  function applyImportedCard(json, filename) {
    try {
      var normalized = normalizeCardJSON(json);
      if (!normalized) {
        showImportStatus('❌ 无法识别卡片格式，请确认是支持的角色卡文件', 'error');
        return;
      }
      if (window.applyJSONFromEditor) window.applyJSONFromEditor(normalized);
      if (window.updatePreviewPanel) window.updatePreviewPanel(normalized);
      var charName = (normalized.data && normalized.data.name) || normalized.name || '未知角色';
      showImportStatus(
        '✅ 已导入「' + charName + '」← ' + filename + '（记得检查各字段后再导出）',
        'success'
      );
    } catch (err) {
      showImportStatus('❌ 应用失败：' + err.message, 'error');
    }
  }

  function normalizeCardJSON(json) {
    if (json && json.spec === 'chara_card_v3' && json.data) return json;
    if (json && json.data && json.data.name) {
      json.spec = json.spec || 'chara_card_v3';
      json.spec_version = json.spec_version || '3.0';
      return json;
    }
    if (json && json.name) {
      return {
        name: json.name || '',
        description: json.description || '',
        personality: json.personality || '',
        scenario: json.scenario || '',
        first_mes: json.first_mes || '',
        mes_example: json.mes_example || '',
        creatorcomment: json.creatorcomment || '',
        avatar: 'none',
        talkativeness: '0.5',
        fav: false,
        tags: json.tags || [],
        spec: 'chara_card_v3',
        spec_version: '3.0',
        data: {
          name: json.name || '',
          description: json.description || '',
          personality: json.personality || '',
          scenario: json.scenario || '',
          first_mes: json.first_mes || '',
          mes_example: json.mes_example || '',
          creator_notes: json.creatorcomment || '',
          system_prompt: '',
          post_history_instructions: '',
          tags: json.tags || [],
          creator: '',
          character_version: (json.character_version || (json.data && json.data.character_version) || '1.0'),
          alternate_greetings: json.alternate_greetings || [],
          extensions: { world: '', regex_scripts: [] },
          character_book: json.character_book || { name: '', entries: [] },
        }
      };
    }
    return null;
  }

  function showImportStatus(msg, type) {
    if (!importStatusBar) return;
    var colors = {
      info: { color: 'var(--color-accent-hover)', bg: 'rgba(56,189,248,0.08)', border: 'rgba(56,189,248,0.2)' },
      success: { color: 'var(--color-success)', bg: 'rgba(16,185,129,0.08)', border: 'rgba(16,185,129,0.2)' },
      error: { color: 'var(--color-danger)', bg: 'rgba(239,68,68,0.08)', border: 'rgba(239,68,68,0.2)' },
    };
    var c = colors[type] || colors.info;
    importStatusBar.style.cssText =
      'display:block;padding:8px 12px;font-size:0.78rem;border-radius:8px;margin-bottom:12px;' +
      'color:' + c.color + ';background:' + c.bg + ';border-left:3px solid ' + c.border + ';';
    importStatusBar.textContent = msg;
    if (type === 'success') {
      setTimeout(function() { importStatusBar.style.display = 'none'; }, 5000);
    }
  }
})();
</script>
