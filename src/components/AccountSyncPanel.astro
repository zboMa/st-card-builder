---
/**
 * 账户与云同步：未登录门禁 + 邮箱注册/登录（可选 Discord）/ 调试登录 / 手动同步
 */
---
<div class="panel" id="accountSyncPanel">
  <div id="accountLoginGate" class="auth-login-screen auth-login-screen--embed" aria-live="polite">
    <div class="auth-login-ambient" aria-hidden="true"></div>
    <div class="auth-login-panel">
      <div class="auth-login-mark" aria-hidden="true"></div>
      <p class="auth-login-brand">啊哈哈哈制卡器</p>
      <p class="auth-login-kicker">账户</p>
      <h1 class="auth-login-title">登录后继续</h1>
      <p class="auth-login-lead">登录后可在多端同步你的草稿与进度。</p>

      <div id="emailAuthBox" class="auth-login-email" hidden>
        <div class="auth-login-tabs" role="tablist" aria-label="登录或注册">
          <button type="button" class="auth-login-tab is-active" data-auth-tab="login" id="tabAuthLogin">登录</button>
          <button type="button" class="auth-login-tab" data-auth-tab="register" id="tabAuthRegister">注册</button>
        </div>

        <form id="formEmailLogin" class="auth-login-form" autocomplete="on">
          <label for="emailLoginEmail">邮箱</label>
          <input id="emailLoginEmail" name="email" type="email" required autocomplete="username" placeholder="you@example.com" />
          <label for="emailLoginPassword">密码</label>
          <input id="emailLoginPassword" name="password" type="password" required autocomplete="current-password" placeholder="至少 8 位" />
          <button type="submit" class="btn btn-primary auth-login-cta" id="btnEmailLogin">登录</button>
        </form>

        <form id="formEmailRegister" class="auth-login-form" autocomplete="on" hidden>
          <label for="emailRegEmail">邮箱</label>
          <input id="emailRegEmail" name="email" type="email" required autocomplete="username" placeholder="you@example.com" />
          <label for="emailRegPassword">密码</label>
          <input id="emailRegPassword" name="password" type="password" required minlength="8" autocomplete="new-password" placeholder="至少 8 位" />
          <label for="emailRegInvite">邀请码</label>
          <input id="emailRegInvite" name="inviteCode" type="text" required autocomplete="off" placeholder="请输入邀请码" />
          <button type="submit" class="btn btn-primary auth-login-cta" id="btnEmailRegister">注册并登录</button>
        </form>
      </div>

      <a id="btnDiscordLogin" class="btn btn-primary auth-login-cta" href="#" hidden>
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M20.317 4.37a19.8 19.8 0 0 0-4.885-1.515.07.07 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.3 18.3 0 0 0-5.487 0 12.6 12.6 0 0 0-.617-1.25.08.08 0 0 0-.079-.037A19.7 19.7 0 0 0 3.677 4.37a.09.09 0 0 0-.04.04C.533 9.047-.32 13.58.099 18.057a.08.08 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.08.08 0 0 0 .084-.028 14 14 0 0 0 1.226-1.994.08.08 0 0 0-.041-.106 13.1 13.1 0 0 1-1.872-.892.08.08 0 0 1-.008-.128c.126-.094.252-.192.372-.292a.07.07 0 0 1 .078-.01c3.928 1.793 8.18 1.793 12.062 0a.07.07 0 0 1 .079.01c.12.098.246.198.373.292a.08.08 0 0 1-.006.127 12.3 12.3 0 0 1-1.873.892.08.08 0 0 0-.041.107c.36.698.772 1.363 1.225 1.993a.08.08 0 0 0 .084.028 19.8 19.8 0 0 0 6.002-3.03.08.08 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.06.06 0 0 0-.04-.04zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>
        使用 Discord 登录
      </a>
      <p id="authStatusTip" class="auth-login-tip" role="status"></p>
      <div id="devLoginBox" class="auth-login-dev" style="display:none;">
        <label for="devLoginName">调试登录（仅开发环境）</label>
        <div class="ui-row" style="gap:8px;">
          <input id="devLoginName" type="text" placeholder="输入用户名后进入" style="flex:1;min-width:140px;" />
          <button type="button" id="btnDevLogin" class="btn btn-fetch">进入</button>
        </div>
      </div>
    </div>
  </div>

  <div id="accountSessionBody" class="account-session" hidden>
    <header class="account-session-head">
      <div>
        <p class="account-session-kicker">账户</p>
        <h2 class="account-session-title">账户与云端</h2>
        <p class="account-session-lead">登录后可手动同步草稿到云端；未登录仍可完整离线使用。</p>
      </div>
      <button type="button" id="btnAuthLogout" class="btn btn-ghost btn-inline">退出登录</button>
    </header>

    <section class="account-session-card" aria-labelledby="accountIdentityTitle">
      <h3 id="accountIdentityTitle" class="account-session-card-title">登录身份</h3>
      <p id="authUserLine" class="account-session-identity">—</p>
      <p id="authUserMeta" class="account-session-meta"></p>
    </section>

    <section class="account-session-card" aria-labelledby="accountSyncTitle">
      <div class="account-session-card-top">
        <div>
          <h3 id="accountSyncTitle" class="account-session-card-title">云端数据</h3>
          <p class="account-session-meta">角色卡（含头像、小说工坊、创作进度）以完整卡包保存。点「刷新云端列表」拉取索引并处理离线队列；卡包上云请在卡管理对单卡点「同步上云」。打开某张云端卡时自动下载完整数据。</p>
        </div>
        <button type="button" id="btnManualSync" class="btn btn-primary btn-inline">刷新云端列表</button>
      </div>
      <label class="account-sync-switch" for="autoSyncToggle">
        <span class="account-sync-switch__text">
          <span class="account-sync-switch__label">自动对齐云端</span>
          <span class="account-sync-switch__hint">开启后定时拉取云端列表并刷新离线队列；不上传本地卡包</span>
        </span>
        <input type="checkbox" id="autoSyncToggle" class="account-sync-switch__input" role="switch" />
        <span class="account-sync-switch__track" aria-hidden="true"><span class="account-sync-switch__thumb"></span></span>
      </label>
      <div class="account-session-sync-row">
        <span id="syncStatusLine" class="account-session-sync-status">尚未对齐</span>
        <span id="syncCountdownLine" class="account-session-sync-eta" hidden></span>
      </div>
      <div id="syncTip" class="account-session-tip" role="status"></div>
    </section>

    <section class="account-session-card" aria-labelledby="accountPrefsTitle">
      <h3 id="accountPrefsTitle" class="account-session-card-title">用户配置</h3>
      <p class="account-session-meta">
        提示词覆盖、当前打开卡等界面偏好。登录后本地一改即防抖保存到云端，无需点「刷新云端列表」。
      </p>
      <div id="userPrefsSyncTip" class="account-session-tip" role="status"></div>
    </section>

    <section class="account-session-card" aria-labelledby="accountApiConfigTitle">
      <div class="account-session-secrets" id="aiSecretsSyncBox" style="margin-top:0;padding-top:0;border-top:none;">
        <h3 id="accountApiConfigTitle" class="account-session-card-title">AI API 配置</h3>
        <p class="account-session-meta">
          主动同步完整 API 配置（接口地址、密钥、模型、Embedding、联网搜索、NSFW/引擎选项等）。用自设口令本地加密后上传；服务端只存密文，新设备需同一口令解密。口令不会上传。不随「立即同步」自动推送。
        </p>
        <label class="account-session-secrets-label" for="aiSecretsPassphrase">同步口令（至少 6 位）</label>
        <input
          type="password"
          id="aiSecretsPassphrase"
          class="account-session-secrets-input"
          placeholder="用于加密/解密云端 API 配置"
          autocomplete="new-password"
        />
        <div class="account-session-secrets-actions">
          <button type="button" id="btnUploadAiSecrets" class="btn btn-ghost btn-inline">加密同步到云端</button>
          <button type="button" id="btnDownloadAiSecrets" class="btn btn-ghost btn-inline">拉取并解密到本地</button>
          <button type="button" id="btnClearCloudAiSecrets" class="btn btn-ghost btn-inline">清除云端 API 配置</button>
        </div>
        <div id="aiSecretsSyncTip" class="account-session-tip" role="status"></div>
      </div>
    </section>
  </div>
</div>

<style is:global>
  @import '../styles/auth-login.css';

  .account-session {
    width: 100%;
    max-width: none;
  }

  .account-session-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 20px;
  }

  .account-session-kicker {
    margin: 0 0 6px;
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-text-label);
  }

  .account-session-title {
    margin: 0 0 6px;
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .account-session-lead {
    margin: 0;
    font-size: 0.85rem;
    line-height: 1.55;
    color: var(--color-text-muted);
  }

  .account-session-card {
    margin-bottom: 12px;
    padding: 16px 18px;
    border-radius: var(--radius-lg, 14px);
    border: 1px solid var(--color-border-subtle);
    background:
      linear-gradient(180deg, oklch(76% 0.095 310 / 0.05), transparent 42%),
      var(--color-surface-inset, transparent);
  }

  .account-session-card-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 12px;
  }

  .account-session-card-title {
    margin: 0 0 4px;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .account-session-identity {
    margin: 0;
    font-size: 1rem;
    font-weight: 560;
    color: var(--color-text);
    word-break: break-word;
  }

  .account-session-meta {
    margin: 6px 0 0;
    font-size: 0.78rem;
    line-height: 1.45;
    color: var(--color-text-muted);
  }

  .account-session-sync-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
  }

  .account-sync-switch {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin: 12px 0 14px;
    padding: 10px 12px;
    border-radius: 10px;
    border: 1px solid var(--color-border-subtle);
    background: var(--color-surface-inset, transparent);
    cursor: pointer;
    user-select: none;
  }
  .account-sync-switch__text {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }
  .account-sync-switch__label {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-text);
  }
  .account-sync-switch__hint {
    font-size: 0.72rem;
    line-height: 1.4;
    color: var(--color-text-muted);
  }
  .account-sync-switch__input {
    position: absolute;
    opacity: 0;
    width: 1px;
    height: 1px;
    pointer-events: none;
  }
  .account-sync-switch__track {
    position: relative;
    flex-shrink: 0;
    width: 42px;
    height: 24px;
    border-radius: 999px;
    background: oklch(28% 0.02 285);
    border: 1px solid var(--color-border-subtle);
    transition: background 0.18s ease, border-color 0.18s ease;
  }
  .account-sync-switch__thumb {
    position: absolute;
    top: 2px;
    left: 2px;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: oklch(88% 0.02 285);
    transition: transform 0.18s ease;
  }
  .account-sync-switch__input:checked + .account-sync-switch__track {
    background: oklch(42% 0.1 155);
    border-color: oklch(62% 0.12 155 / 0.55);
  }
  .account-sync-switch__input:checked + .account-sync-switch__track .account-sync-switch__thumb {
    transform: translateX(18px);
  }
  .account-sync-switch__input:focus-visible + .account-sync-switch__track {
    outline: 2px solid var(--color-focus-ring, oklch(72% 0.12 305));
    outline-offset: 2px;
  }

  .account-session-sync-status {
    font-size: 0.82rem;
    color: var(--color-text-secondary);
  }

  .account-session-sync-status.is-err {
    color: var(--color-danger, oklch(72% 0.16 25));
  }

  .account-session-sync-eta {
    font-size: 0.82rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    color: oklch(72% 0.16 145);
  }

  .account-session-tip {
    margin-top: 10px;
    font-size: 0.78rem;
    line-height: 1.45;
    color: var(--color-text-muted);
  }

  .account-session-tip:empty {
    display: none;
  }

  .account-session-tip.is-err {
    color: var(--color-danger, oklch(72% 0.16 25));
  }

  .account-session-secrets {
    margin-top: 16px;
    padding-top: 14px;
    border-top: 1px solid var(--color-border-subtle);
  }

  .account-session-secrets-title {
    margin: 0 0 4px;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .account-session-secrets-label {
    display: block;
    margin: 12px 0 6px;
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .account-session-secrets-input {
    width: 100%;
    max-width: 420px;
    box-sizing: border-box;
    padding: 8px 10px;
    border-radius: 10px;
    border: 1px solid var(--color-border-subtle);
    background: var(--color-surface-inset, transparent);
    color: var(--color-text);
    font-size: 0.85rem;
  }

  .account-session-secrets-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 10px;
  }

  .account-session-head .btn-inline,
  .account-session-card-top .btn-inline,
  .account-session-secrets-actions .btn-inline {
    flex-shrink: 0;
  }
</style>

<script>
  import { initAccountSyncPanel } from '../lib/sync/accountSyncPanelBoot.mjs';
  initAccountSyncPanel();
</script>
