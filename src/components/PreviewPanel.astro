---
---
<div class="code-window area-preview" id="cyberWindow">
  <div class="code-header">
    <span style="font-weight: 600; color: var(--color-text-secondary); font-size: 0.9rem;">JSON 实时追踪</span>
    <div style="display: flex; gap: 8px; align-items: center;">
      <div style="display: flex; align-items: center; gap: 4px; margin-right: 8px;">
        <input type="checkbox" id="toggleAnnotations" checked />
        <label for="toggleAnnotations" style="font-size: 0.72rem; color: var(--color-text-muted); cursor: pointer; white-space: nowrap; margin: 0; font-weight: normal;">注释</label>
      </div>
      <div style="display: flex; align-items: center; gap: 4px; margin-right: 8px;">
        <input type="checkbox" id="toggleEditMode" />
        <label for="toggleEditMode" style="font-size: 0.72rem; color: var(--color-text-muted); cursor: pointer; white-space: nowrap; margin: 0; font-weight: normal;">编辑</label>
      </div>
    </div>
  </div>

  <!-- 校验结果栏（导入/导出入口已迁至「角色卡管理」） -->
  <div id="validationBar" style="display: none;"></div>

  <!-- 内容区 -->
  <div class="code-content-wrapper" id="codeContentWrapper">
    <div id="annotatedPreview"></div>
  </div>
</div>

<script>
  import { initPreviewPanel } from '../lib/card-builder/previewPanelBoot.mjs';
  initPreviewPanel();
</script>
