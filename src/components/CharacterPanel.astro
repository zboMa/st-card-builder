---
/** 角色设定：编辑当前卡主角字段；多卡切换在「角色卡管理」；成人配置见侧栏「成人配置」 */
---
<div class="panel area-character">
  <div class="panel-header character-panel-head">
    <h2>角色设定</h2>
    <span class="ui-hint ui-hint--inline" style="margin-left:8px;">主角卡面 · 与世界书分管道</span>
    <div class="panel-header__end">
      <button type="button" id="btnOpenAiEngine" class="btn btn-toolbar">AI 引擎</button>
      <span id="saveIndicator" class="panel-header__badge character-saved" style="display: none;">已保存</span>
    </div>
  </div>

  <!-- 头像上传 -->
  <div class="avatar-upload">
    <div class="avatar-upload__preview">
      <span id="avatarPlaceholder" class="avatar-upload__placeholder">无图</span>
      <img id="avatarImg" class="avatar-upload__img" style="display: none;" alt="avatar" />
    </div>
    <div class="avatar-upload__meta">
      <label class="avatar-upload__label">上传头像（将嵌入 PNG 卡片）</label>
      <input type="file" id="charImageInput" accept="image/*" />
    </div>
  </div>

  <!-- 基础信息；开场白已迁至「开场白」模块 -->
  <div class="grid-2">
    <div class="form-group">
      <label>角色名 (Name)</label>
      <input type="text" id="charName" placeholder="角色名称" />
    </div>
    <div class="form-group">
      <label>世界书名 (Worldbook)</label>
      <input type="text" id="wbName" placeholder="世界书名称" />
    </div>
  </div>

  <div class="form-group">
    <label for="characterVersion">卡片版本 (character_version)</label>
    <div class="character-version-row">
      <input type="text" id="characterVersion" value="1.0" readonly tabindex="-1" title="仅可通过右侧按钮升级；SillyTavern data.character_version" />
      <button type="button" id="btnBumpVersionMajor" class="btn btn-sm btn-ghost" title="大版本 +1，小版本归零">升级大版本</button>
      <button type="button" id="btnBumpVersionMinor" class="btn btn-sm btn-ghost" title="小版本 +1">升级小版本</button>
    </div>
    <span class="ui-hint ui-hint--inline">酒馆字段；发布/分享按此版本固化。不可手改，请用按钮升级。</span>
  </div>

  <!-- 角色标签：对接 ST tags / data.tags -->
  <div class="form-group char-tags-group">
    <div class="char-tags-label-row">
      <label for="charTagInput">角色标签 (Tags)</label>
      <span class="ui-hint ui-hint--inline char-tags-tip">ST tags / data.tags</span>
    </div>
    <div class="form-section char-tags-section">
      <div id="charTagsList" class="chip-list char-tags-list" aria-live="polite"></div>
      <div class="char-tags-add-row">
        <input type="text" id="charTagInput" class="char-tag-input" placeholder="输入标签，回车添加" autocomplete="off" />
        <button type="button" id="btnAddCharTag" class="btn btn-sm">添加</button>
        <button type="button" id="btnAiGenCharTags" class="btn btn-sm btn-ai-tag">AI 生成</button>
      </div>
    </div>
    <span id="charTagsAiTip" class="ui-status-tip char-tags-ai-tip" role="status" aria-live="polite"></span>
  </div>

  <div class="character-adult-hint-block">
    <p class="ui-hint character-adult-hint">
      本页只编辑<strong>主角</strong>卡面字段（名、描述、标签、版本等），不会写入世界书人物档案。
      世界观预设、载体框架、口味、姿势语言、情趣话风、NTL、恶堕请到「世界与限定」配置——那些内容不进主角 Description。
    </p>
    <button type="button" id="btnGotoWorldLimitsFromCharacter" class="ai-engine-link-btn">去「世界与限定」配置</button>
  </div>

  <hr class="divider" />

  <div class="form-group">
    <label>角色描述 (Description)</label>
    <textarea id="charDesc" style="min-height: 130px;" placeholder="主角的外貌、性格、背景故事（请勿写入 NSFW / 恶堕分期）..."></textarea>
  </div>

  <p class="ui-hint character-greetings-hint">主开场白与备选开场请到侧栏「开场白」模块编辑。</p>

  <hr class="divider" />

  <div class="form-group">
    <label>作者注释 (Creator Notes)</label>
    <textarea id="creatorNotes" placeholder="给使用者的说明..."></textarea>
  </div>
</div>

<style is:global>
  .panel-header__end {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-shrink: 0;
  }
  .character-adult-hint {
    margin: 4px 0 0;
    line-height: 1.45;
  }
  .character-adult-hint-block {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 4px;
    margin: 4px 0 0;
  }
  .character-version-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
  }
  .character-version-row #characterVersion {
    flex: 0 1 120px;
    min-width: 88px;
    max-width: 160px;
    opacity: 0.92;
    cursor: default;
  }
  .character-version-row .btn {
    width: auto;
    min-width: 0;
    margin: 0;
    padding: 6px 10px;
    font-size: 0.78rem;
  }
  /* 与 AI 引擎跳转按钮同款 */
  .ai-engine-link-btn {
    font-size: 0.68rem;
    padding: 2px 0;
    border: none;
    background: transparent;
    color: var(--color-accent);
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .char-tags-add-row {
    display: flex;
    gap: 6px;
    align-items: center;
    flex-wrap: wrap;
  }
  .char-tag-input {
    flex: 1;
    min-width: 100px;
    padding: 5px 8px;
    font-size: 0.78rem;
  }
  .char-tags-add-row .btn {
    width: auto;
    min-width: 0;
    margin: 0;
    flex-shrink: 0;
  }
  .btn-ai-tag {
    background: var(--color-accent-soft);
    border-color: var(--color-accent-border);
    color: var(--color-accent-hover);
  }
  .btn-ai-tag:hover {
    background: oklch(76% 0.095 310 / 0.16);
    border-color: var(--color-accent);
    color: var(--color-text);
  }
</style>

<script>
  import {
    bumpCharacterVersionMajor,
    bumpCharacterVersionMinor,
  } from '../lib/card-builder/cardRelease.mjs';

  function applyVersion(next) {
    var el = document.getElementById('characterVersion');
    if (!el) return;
    el.value = next;
    el.dispatchEvent(new Event('input', { bubbles: true }));
    el.dispatchEvent(new Event('change', { bubbles: true }));
  }

  document.getElementById('btnBumpVersionMajor')?.addEventListener('click', function() {
    var el = document.getElementById('characterVersion');
    applyVersion(bumpCharacterVersionMajor(el && el.value));
  });
  document.getElementById('btnBumpVersionMinor')?.addEventListener('click', function() {
    var el = document.getElementById('characterVersion');
    applyVersion(bumpCharacterVersionMinor(el && el.value));
  });
  document.getElementById('btnGotoWorldLimitsFromCharacter')?.addEventListener('click', function() {
    location.hash = 'adult-config';
  });
</script>
