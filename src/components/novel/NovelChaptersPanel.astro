---
/** 拆章：标题行右上操作；检索列表；自动拆章进弹窗配置后开始 */
---
<div class="panel novel-workshop-panel novel-chapters-panel" data-novel-panel="chapters">
  <div class="novel-panel-head">
    <h2>拆章 <span id="novelChapterCount" class="novel-panel-count">0 章</span></h2>
    <div class="novel-head-actions" aria-label="拆章操作">
      <button id="btnChDelete" type="button" class="btn btn-delete novel-btn-sm">删除所选</button>
      <button id="btnChExport" type="button" class="btn btn-fetch novel-btn-sm">导出选中</button>
      <button id="btnChDisable" type="button" class="btn btn-fetch novel-btn-sm">禁用所选</button>
      <button id="btnChEnable" type="button" class="btn btn-fetch novel-btn-sm">启用所选</button>
      <button id="btnChMerge" type="button" class="btn btn-fetch novel-btn-sm">合并所选</button>
      <button id="btnNovelSplitChapters" type="button" class="btn btn-ai novel-btn-sm">自动拆章</button>
    </div>
  </div>
  <p class="novel-panel-tip ui-pref-tip">按标题 / 空行 / 字数切分章节；结果供小说分析、人物列表、世界书条目与文风蒸馏使用。点击标题或预览图标打开正文弹窗。</p>
  <p id="novelChapterGate" class="novel-gate-hint" style="display:none;"></p>
  <div id="novelChapterStatus" class="novel-status-text"></div>

  <div class="novel-chapters-body">
    <div class="wb-toolbar novel-wb-toolbar novel-wb-search-only">
      <div class="wb-search-wrap">
        <div class="wb-search-bar">
          <span class="wb-search-icon" aria-hidden="true">🔍</span>
          <input type="text" id="novelChapterSearchInput" class="wb-search-input" placeholder="搜索章节标题..." autocomplete="off" />
          <button id="novelChapterSearchClear" class="wb-search-clear" title="清空" type="button" style="display:none;">✕</button>
        </div>
      </div>
    </div>
    <div id="novelChapterList" class="novel-chapter-list" aria-live="polite"></div>
  </div>
</div>

<!-- 自动拆章配置 -->
<div id="novelModalSplit" class="novel-modal" hidden aria-hidden="true">
  <div class="novel-modal-backdrop" data-novel-modal-close="novelModalSplit"></div>
  <div class="novel-modal-dialog" role="dialog" aria-modal="true" aria-labelledby="novelModalSplitTitle">
    <div class="novel-modal-head">
      <strong id="novelModalSplitTitle">自动拆章</strong>
      <span class="novel-modal-tip">配置规则后开始拆分 · Esc / 遮罩关闭</span>
    </div>
    <div class="novel-modal-body">
      <div class="grid-2">
        <div class="form-group">
          <label for="novelChapterSplitMode">拆分规则</label>
          <select id="novelChapterSplitMode">
            <option value="title">章节标题优先</option>
            <option value="blank">空行分段</option>
            <option value="size">按单片字数</option>
          </select>
        </div>
        <div class="form-group">
          <label for="novelChunkSize">单片字数</label>
          <select id="novelChunkSize">
            <option value="4000">4,000 字</option>
            <option value="8000" selected>8,000 字</option>
            <option value="12000">12,000 字</option>
            <option value="16000">16,000 字</option>
            <option value="24000">24,000 字</option>
            <option value="32000">32,000 字</option>
            <option value="48000">48,000 字</option>
            <option value="64000">64,000 字</option>
          </select>
        </div>
      </div>
      <p class="novel-modal-desc ui-pref-tip">将按规则重新切分全文；已有章节列表会被覆盖。</p>
    </div>
    <div class="novel-modal-actions">
      <button type="button" class="btn novel-modal-cancel" data-novel-modal-close="novelModalSplit">取消</button>
      <button type="button" class="btn btn-ai" id="btnNovelSplitConfirm">开始拆分</button>
    </div>
  </div>
</div>

<!-- 章节正文：居中遮罩弹窗（打开时挂到 body） -->
<div id="novelModalChapter" class="novel-modal" hidden aria-hidden="true">
  <div class="novel-modal-backdrop" data-novel-modal-close="novelModalChapter"></div>
  <div class="novel-modal-dialog novel-modal-dialog-lg" role="dialog" aria-modal="true" aria-labelledby="novelModalChapterTitle">
    <div class="novel-modal-head">
      <strong id="novelModalChapterTitle">章节预览</strong>
      <span class="novel-modal-tip">只读预览 · Esc / 遮罩关闭</span>
    </div>
    <div class="novel-modal-body">
      <pre id="novelModalChapterBody" class="novel-modal-pre"></pre>
    </div>
    <div class="novel-modal-actions">
      <button type="button" class="btn novel-modal-cancel" data-novel-modal-close="novelModalChapter">关闭</button>
    </div>
  </div>
</div>

<!-- 章节重命名 -->
<div id="novelModalChapterRename" class="novel-modal" hidden aria-hidden="true">
  <div class="novel-modal-backdrop" data-novel-modal-close="novelModalChapterRename"></div>
  <div class="novel-modal-dialog" role="dialog" aria-modal="true" aria-labelledby="novelModalChapterRenameTitle">
    <div class="novel-modal-head">
      <strong id="novelModalChapterRenameTitle">重命名章节</strong>
      <span class="novel-modal-tip">修改标题后保存 · Esc / 遮罩关闭</span>
    </div>
    <div class="novel-modal-body">
      <div class="form-group">
        <label for="novelChapterRenameInput">新标题</label>
        <input type="text" id="novelChapterRenameInput" placeholder="例如：第一章 系统激活" autocomplete="off" />
      </div>
    </div>
    <div class="novel-modal-actions">
      <button type="button" class="btn novel-modal-cancel" data-novel-modal-close="novelModalChapterRename">取消</button>
      <button type="button" class="btn btn-ai" id="btnNovelChapterRenameConfirm">保存</button>
    </div>
  </div>
</div>
