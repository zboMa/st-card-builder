---
/** 人物列表：分析结果展示/编辑；扫描为可选降级路径 */
---
<div class="panel novel-workshop-panel novel-extract-panel novel-characters-panel" data-novel-panel="characters">
  <h2>人物列表</h2>
  <p class="novel-panel-tip">
    展示分析或扫描得到的<strong>人物结果</strong>。推荐在「小说分析」统一抽取后于此查看、「丰满所选」/同步；
    也可在本页用「扫描全书」走降级路径。有实体走丰满（RAG）；无实体时行内仍可用 AI 扩展。
    点标题打开档案；可同步到角色设定或世界书。
  </p>
  <p id="novelCharGate" class="novel-gate-hint" style="display:none;"></p>

  <div class="novel-extract-body">
    <div class="novel-extract-controls">
      <div class="grid-3">
        <div class="form-group">
          <label for="novelCharShardMode">扫描分片方式（降级）</label>
          <select id="novelCharShardMode">
            <option value="chars" selected>按字数</option>
            <option value="chapters">按章节</option>
          </select>
        </div>
        <div class="form-group" id="novelCharChunkSizeWrap">
          <label for="novelCharChunkSize">分片字数</label>
          <select id="novelCharChunkSize">
            <option value="4000">4,000 字</option>
            <option value="8000" selected>8,000 字</option>
            <option value="12000">12,000 字</option>
            <option value="16000">16,000 字</option>
            <option value="24000">24,000 字</option>
            <option value="32000">32,000 字</option>
            <option value="48000">48,000 字</option>
            <option value="64000">64,000 字</option>
          </select>
        </div>
        <div class="form-group" id="novelCharChaptersPerShardWrap" hidden>
          <label for="novelCharChaptersPerShard">分片章节数</label>
          <input id="novelCharChaptersPerShard" type="number" min="1" step="1" value="1" />
        </div>
        <div class="form-group">
          <label for="novelCharConflictPolicy">同步冲突策略</label>
          <select id="novelCharConflictPolicy">
            <option value="merge">合并</option>
            <option value="overwrite">覆盖</option>
            <option value="skip">跳过</option>
          </select>
        </div>
      </div>
      <div class="form-group">
        <label for="novelCharManual">手动添加角色（用原文准确称呼，多个用逗号 / 空格分隔）</label>
        <div class="novel-toolbar" style="margin-bottom:0;">
          <input id="novelCharManual" type="text" placeholder="如：小李, 小王, 小张" style="flex:1;" />
          <button id="btnCharAdd" type="button" class="btn btn-add novel-btn-sm">添加</button>
        </div>
      </div>
      <div class="novel-toolbar">
        <button id="btnCharScan" type="button" class="btn novel-btn-sm" title="降级：仅扫描人名">扫描全书</button>
        <button id="btnCharEnrichSelected" type="button" class="btn btn-ai novel-btn-sm" title="按原文丰满所选人物（RAG）">丰满所选</button>
        <button id="btnCharMerge" type="button" class="btn btn-fetch novel-btn-sm">合并所选</button>
        <button id="btnCharClear" type="button" class="btn btn-fetch novel-btn-sm">清空列表</button>
        <button id="btnSyncCharsSelected" type="button" class="btn btn-fetch novel-btn-sm">同步所选 → 角色设定</button>
        <button id="btnSyncCharsWb" type="button" class="btn btn-fetch novel-btn-sm">同步所选 → 世界书</button>
        <label class="novel-switch"><input id="novelScanIdentity" type="checkbox" /><span>扫描时附带身份说明</span></label>
        <label class="novel-switch"><input id="novelSplitStage" type="checkbox" /><span>按人物阶段拆分</span></label>
      </div>
      <div id="novelCharStatus" class="novel-status-text"></div>
    </div>

    <div id="novelCharGrid" class="novel-entity-list" aria-live="polite"></div>
  </div>
</div>

<!-- 人物档案：居中遮罩弹窗 -->
<div id="novelModalProfile" class="novel-modal" hidden aria-hidden="true">
  <div class="novel-modal-backdrop" data-novel-modal-close="novelModalProfile"></div>
  <div class="novel-modal-dialog novel-modal-dialog-lg" role="dialog" aria-modal="true" aria-labelledby="novelModalProfileTitle">
    <div class="novel-modal-head">
      <strong id="novelModalProfileTitle">人物档案</strong>
      <span class="novel-modal-tip">附录1 JSON 可编辑 · Esc / 遮罩关闭</span>
    </div>
    <div class="novel-modal-body">
      <div class="form-group">
        <label for="novelCharAliases">别名（逗号分隔，用于原文召回）</label>
        <input id="novelCharAliases" type="text" />
      </div>
      <div class="form-group">
        <label for="novelCharProfileJson">档案 JSON</label>
        <textarea id="novelCharProfileJson" class="novel-modal-textarea" rows="16"></textarea>
      </div>
    </div>
    <div class="novel-modal-actions">
      <button type="button" class="btn novel-modal-cancel" data-novel-modal-close="novelModalProfile">取消</button>
      <button type="button" class="btn btn-add" id="btnNovelProfileSave">保存</button>
    </div>
  </div>
</div>

<div id="novelModalExpandConfirm" class="novel-modal" hidden aria-hidden="true">
  <div class="novel-modal-backdrop" data-novel-modal-close="novelModalExpandConfirm"></div>
  <div class="novel-modal-dialog novel-modal-dialog-lg" role="dialog" aria-modal="true" aria-labelledby="novelModalExpandTitle">
    <div class="novel-modal-head">
      <strong id="novelModalExpandTitle">确认 AI 扩展</strong>
      <span class="novel-modal-tip" id="novelModalExpandTip">将使用以下原文摘录</span>
    </div>
    <div class="novel-modal-body">
      <pre id="novelModalExpandBody" class="novel-modal-pre"></pre>
    </div>
    <div class="novel-modal-actions">
      <button type="button" class="btn novel-modal-cancel" data-novel-modal-close="novelModalExpandConfirm">取消</button>
      <button type="button" class="btn btn-ai" id="btnNovelExpandConfirmOk">确认扩展</button>
    </div>
  </div>
</div>
