---
/** AI 引擎弹窗：三阶段提示词 + 一键生成（世界观预设在「世界与限定」） */
---
<div id="aiEngineModal" class="ai-engine-modal" hidden aria-hidden="true">
  <div class="ai-engine-modal__backdrop ui-modal-backdrop" data-ai-engine-close aria-hidden="true"></div>
  <div class="ui-modal-dialog ai-engine-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="aiEngineModalTitle">
    <div class="ai-engine-modal__head">
      <div>
        <h2 id="aiEngineModalTitle">AI 引擎</h2>
        <p class="ai-engine-modal__tip">API / 模型请到「配置 → AI 配置」。世界观预设与载体框架在「世界与限定」。</p>
      </div>
      <button type="button" id="btnCloseAiEngine" class="btn-icon btn-icon--sm" aria-label="关闭 AI 引擎">×</button>
    </div>

    <div class="ai-engine-modal__body area-ai">
      <div class="ai-engine-section ai-engine-wv-summary">
        <div class="ai-engine-section__label">当前世界观</div>
        <p class="ai-engine-wv-summary__text">
          <span id="aiWorldviewSummary">未选择预设</span>
          <button type="button" id="btnAiEngineGotoWorldLimits" class="ai-engine-link-btn">去「世界与限定」配置</button>
        </p>
      </div>

      <div class="ai-engine-section">
        <div class="ai-engine-section__label">阶段提示词</div>
        <div class="form-group ai-engine-stage">
          <label class="ai-stage-label ai-stage-label--char" for="aiPrompt">[1] 角色设定</label>
          <textarea id="aiPrompt" placeholder="例如：额外要求——她是底层黑客，性格冷淡但护短..." rows="2"></textarea>
        </div>
        <div class="form-group ai-engine-stage">
          <label class="ai-stage-label ai-stage-label--wb" for="wbPrompt">[2] 世界书方向</label>
          <p class="ai-engine-field-hint ai-engine-field-hint--tight">写清本轮世界书的<strong>工作重心</strong>（人物 / 地点 / 势力 / 器物…）与<strong>自定义侧重</strong>；与上方世界观预设叠加，冲突时以本框为准。</p>
          <textarea id="wbPrompt" placeholder="例如：优先写人物关系网与两处关键场所；自定义：少写宏大史诗，多写可触发的日常器物与规矩。" rows="2"></textarea>
        </div>
        <div class="form-group ai-engine-stage">
          <label class="ai-stage-label ai-stage-label--greeting" for="greetingPrompt">[3] 开场白</label>
          <textarea id="greetingPrompt" placeholder="例如：雨夜巷口初遇，用第二人称、带环境描写与角色小动作..." rows="2"></textarea>
          <p class="ai-engine-field-hint">留空则按角色与世界书自动构思。</p>
        </div>
      </div>

      <div class="ai-engine-section ai-engine-skeleton-box">
        <div class="ai-engine-section__label">生成选项</div>
        <div class="ai-engine-mode-row">
          <label class="ai-stage-label ai-stage-label--wb ai-stage-label--sm" for="aiEngineGenMode">模式</label>
          <select id="aiEngineGenMode" aria-label="AI 引擎生成模式">
            <option value="full" selected>完整（大纲→逐条丰满）</option>
            <option value="skeleton">仅骨架</option>
          </select>
        </div>
        <p class="ai-engine-field-hint ai-engine-field-hint--tight" id="aiEngineModeHint">
          默认先出大纲再逐条写满。可选「仅骨架」节省时间。
        </p>
        <label class="ai-engine-pause-row" for="aiEnginePauseAfterOutline">
          <input type="checkbox" id="aiEnginePauseAfterOutline" />
          <span>大纲完成后暂停（再点「继续丰满」）</span>
        </label>
        <div class="ai-engine-wb-count-row" role="group" aria-label="世界书条数">
          <span class="ai-engine-field-hint ai-engine-field-hint--tight">世界书条数</span>
          <div class="ai-engine-skeleton-count">
            <input type="number" id="wbSkeletonCount" value="10" min="1" max="30" aria-label="世界书条数" />
            <span class="ai-engine-field-hint">条</span>
          </div>
          <div class="ai-engine-skeleton-pills">
            <button type="button" class="ui-pill-btn wb-count-btn" data-count="6">6</button>
            <button type="button" class="ui-pill-btn wb-count-btn" data-count="10">10</button>
            <button type="button" class="ui-pill-btn wb-count-btn" data-count="13">13</button>
            <button type="button" class="ui-pill-btn wb-count-btn" data-count="16">16</button>
            <button type="button" class="ui-pill-btn wb-count-btn" data-count="20">20</button>
          </div>
        </div>
      </div>

      <div class="ai-engine-actions">
        <button type="button" id="btnAiGenerate" class="btn btn-ai ai-engine-gen-btn">一键完整生成</button>
        <button type="button" id="btnAiContinueEnrich" class="btn btn-fetch ai-engine-continue-btn" hidden>继续：按大纲逐条丰满</button>
      </div>

      <div id="hackerOverlay" style="display: none;">
        <div id="hackerCanvas"></div>
        <div id="hackerStatus">
          <div id="hackerPhase"></div>
          <div id="hackerProgress"></div>
          <div id="hackerDetail"></div>
        </div>
      </div>

      <div id="aiStatus" class="status-text"></div>
    </div>
  </div>
</div>

<style>
  .ai-engine-modal[hidden] { display: none !important; }
  .ai-engine-modal {
    position: fixed;
    inset: 0;
    z-index: 9200;
    display: grid;
    place-items: center;
    padding: 18px;
  }
  :global(body.ai-engine-modal-open) {
    overflow: hidden;
  }
  .ai-engine-modal__backdrop {
    position: absolute;
    inset: 0;
  }
  .ai-engine-modal__backdrop.ui-modal-backdrop,
  .ai-engine-modal__backdrop {
    background: var(--color-overlay);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }
  .ai-engine-modal__dialog {
    position: relative;
    z-index: 1;
    width: min(560px, 100%);
    max-height: min(90vh, 860px);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .ai-engine-modal__head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    padding: 12px 14px 8px;
    border-bottom: 1px solid var(--color-border-subtle);
    flex-shrink: 0;
  }
  .ai-engine-modal__head h2 {
    margin: 0 0 4px;
    font-size: 0.95rem;
    border-bottom: none;
    padding: 0;
  }
  .ai-engine-modal__tip {
    font-size: 0.68rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.45;
    max-width: 36em;
  }
  .ai-engine-modal__body {
    padding: 10px 14px 14px;
    overflow-y: auto;
    flex: 1;
    min-height: 0;
  }
  .ai-engine-section {
    margin-bottom: 12px;
    padding-bottom: 10px;
    border-bottom: 1px dashed var(--color-border);
  }
  .ai-engine-section:last-of-type {
    border-bottom: none;
  }
  .ai-engine-section__label {
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
    margin-bottom: 6px;
  }
  .ai-engine-wv-summary__text {
    margin: 0;
    font-size: 0.72rem;
    color: var(--color-text);
    line-height: 1.45;
  }
  .ai-engine-wv-summary__text .ai-engine-link-btn {
    display: inline;
    margin-left: 0.35em;
    vertical-align: baseline;
  }
  .ai-engine-link-btn {
    font-size: 0.68rem;
    padding: 2px 0;
    border: none;
    background: transparent;
    color: var(--color-accent);
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .ai-engine-stage {
    margin-bottom: 8px;
  }
  .ai-stage-label {
    display: block;
    font-weight: 600;
    font-size: 0.74rem;
    margin-bottom: 3px;
  }
  .ai-stage-label--char { color: var(--color-accent-hover); }
  .ai-stage-label--wb { color: var(--color-success); }
  .ai-stage-label--greeting { color: var(--color-accent-hover); }
  .ai-stage-label--sm { font-size: 0.72rem; margin: 0 0 3px 0; }
  .ai-engine-field-hint {
    font-size: 0.65rem;
    color: var(--color-text-muted);
    margin: 4px 0 0;
    line-height: 1.4;
  }
  .ai-engine-field-hint--tight { margin: 0; }
  .ai-engine-skeleton-box {
    background: rgba(16, 185, 129, 0.05);
    border: 1px dashed rgba(16, 185, 129, 0.28);
    border-radius: 8px;
    padding: 8px 10px;
    border-bottom: 1px dashed rgba(16, 185, 129, 0.28);
  }
  .ai-engine-mode-row {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-bottom: 6px;
  }
  .ai-engine-mode-row select {
    width: 100%;
    padding: 4px 8px;
    border-radius: 6px;
    border: 1px solid rgba(16, 185, 129, 0.35);
    background: var(--color-surface, #0f1419);
    color: var(--color-text);
    font-size: 0.78rem;
  }
  .ai-engine-pause-row {
    display: flex;
    align-items: flex-start;
    gap: 6px;
    font-size: 0.7rem;
    color: var(--color-text-muted);
    margin: 6px 0 8px;
    cursor: pointer;
  }
  .ai-engine-pause-row input { margin-top: 2px; }
  .ai-engine-wb-count-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px 10px;
  }
  .ai-engine-skeleton-count {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-shrink: 0;
  }
  .ai-engine-skeleton-count input[type="number"] {
    width: 44px;
    text-align: center;
    padding: 3px 4px;
    font-size: 0.8rem;
    font-weight: 600;
    border-radius: 6px;
    border: 1px solid rgba(16, 185, 129, 0.3);
  }
  .ai-engine-skeleton-pills {
    display: flex;
    flex: 1 1 auto;
    gap: 4px;
    min-width: 0;
  }
  .ai-engine-skeleton-pills .wb-count-btn {
    flex: 1;
    font-size: 0.68rem;
    padding: 3px 0;
    min-height: 0;
  }
  .ai-engine-actions {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-top: 4px;
  }
  .ai-engine-gen-btn,
  .ai-engine-continue-btn {
    width: 100%;
    font-size: 0.8rem !important;
    padding: 7px 12px !important;
  }
  .ai-engine-continue-btn[hidden] {
    display: none !important;
  }

  .ai-engine-modal__body textarea,
  .ai-engine-modal__body input[type="number"] {
    color: var(--color-text);
    background-color: var(--color-surface-elevated);
    border-color: var(--color-border);
  }
  .ai-engine-modal__body textarea {
    min-height: 0;
    font-size: 0.78rem;
    padding: 6px 8px;
    border-radius: 6px;
  }
  .ai-engine-modal__body textarea::placeholder {
    color: var(--color-text-muted);
    opacity: 1;
  }
  .ai-engine-modal__body textarea:focus,
  .ai-engine-modal__body input[type="number"]:focus {
    background-color: oklch(28% 0.024 288);
  }

  #hackerOverlay {
    position: relative;
    margin-top: 10px;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--color-accent-border);
    background: #050510;
    min-height: 140px;
  }
  #hackerCanvas {
    position: absolute;
    inset: 0;
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    font-size: 0.65rem;
    line-height: 1.2;
    color: var(--color-accent-soft);
    overflow: hidden;
    white-space: pre-wrap;
    word-break: break-all;
    padding: 8px;
    pointer-events: none;
  }
  #hackerStatus {
    position: relative;
    z-index: 2;
    padding: 16px 12px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 140px;
    gap: 10px;
  }
  #hackerPhase {
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--color-accent-hover);
    text-shadow: 0 0 20px rgba(139, 92, 246, 0.5);
    text-align: center;
    animation: hackerGlow 1.5s ease-in-out infinite;
  }
  #hackerProgress {
    width: 80%;
    max-width: 240px;
    height: 4px;
    background: var(--color-accent-soft);
    border-radius: 99px;
    overflow: hidden;
    position: relative;
  }
  #hackerProgress::after {
    content: '';
    position: absolute;
    top: 0; left: 0;
    height: 100%;
    width: var(--progress, 0%);
    background: var(--color-accent-strong);
    border-radius: 99px;
    transition: width 0.4s ease;
    box-shadow: 0 0 12px rgba(139, 92, 246, 0.5);
  }
  #hackerDetail {
    font-size: 0.68rem;
    color: var(--color-text-muted);
    text-align: center;
    font-family: 'JetBrains Mono', monospace;
    min-height: 1.2em;
  }
  @keyframes hackerGlow {
    0%, 100% { text-shadow: 0 0 20px rgba(139, 92, 246, 0.5); }
    50% { text-shadow: 0 0 40px rgba(139, 92, 246, 0.8), 0 0 80px var(--color-accent-border); }
  }
  #hackerOverlay::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, rgba(139, 92, 246, 0.5), transparent);
    animation: hackerScan 2s linear infinite;
    pointer-events: none;
    z-index: 3;
  }
  @keyframes hackerScan {
    0% { top: 0; opacity: 1; }
    100% { top: 100%; opacity: 0.2; }
  }
</style>

<script is:inline>
(function() {
  var modal = document.getElementById('aiEngineModal');
  if (!modal) return;

  function openAiEngineModal() {
    modal.hidden = false;
    modal.setAttribute('aria-hidden', 'false');
    document.body.classList.add('ai-engine-modal-open');
    if (typeof window.__refreshAiEngineWorldviewSummary__ === 'function') {
      window.__refreshAiEngineWorldviewSummary__();
    }
    if (typeof window.__syncAiContinueEnrichBtn__ === 'function') {
      window.__syncAiContinueEnrichBtn__();
    }
    var ta = document.getElementById('aiPrompt');
    if (ta) setTimeout(function() { ta.focus(); }, 80);
  }

  function closeAiEngineModal() {
    modal.hidden = true;
    modal.setAttribute('aria-hidden', 'true');
    document.body.classList.remove('ai-engine-modal-open');
  }

  window.__openAiEngineModal__ = openAiEngineModal;
  window.__closeAiEngineModal__ = closeAiEngineModal;

  var closeBtn = document.getElementById('btnCloseAiEngine');
  if (closeBtn) closeBtn.addEventListener('click', closeAiEngineModal);

  modal.querySelectorAll('[data-ai-engine-close]').forEach(function(el) {
    el.addEventListener('click', closeAiEngineModal);
  });

  var openBtn = document.getElementById('btnOpenAiEngine');
  if (openBtn) openBtn.addEventListener('click', openAiEngineModal);

  var gotoBtn = document.getElementById('btnAiEngineGotoWorldLimits');
  if (gotoBtn) {
    gotoBtn.addEventListener('click', function() {
      closeAiEngineModal();
      location.hash = 'adult-config';
    });
  }

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && !modal.hidden) closeAiEngineModal();
  });
})();
</script>
