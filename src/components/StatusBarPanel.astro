---
---
<div class="panel sb-panel novel-workshop-panel">
  <div class="novel-hero">
    <div class="novel-hero-badge">NOVEL LORE WORKSHOP V2</div>
    <div class="novel-hero-main">
      <div class="novel-hero-copy">
        <h2>📚 小说转角色卡/世界书工坊</h2>
        <p>基于新版 facts-only schema，并行抽取高质量设定，并在应用前提供草稿预览和严格校验。</p>
      </div>
    </div>
    <div class="novel-stats" id="novelStatsBar">
      <span class="novel-stat-chip">等待导入文本</span>
    </div>
  </div>

  <section class="novel-card novel-import-dock">
    <div class="novel-card-head">
      <strong>原始资料</strong>
      <span>支持按章节自动切片并行处理</span>
    </div>
    <div class="novel-card-body">
      <label id="novelDropzone" class="novel-dropzone" for="novelSourceFile">
        <span class="novel-dropzone-icon">📥</span>
        <span class="novel-dropzone-title">点击或拖拽导入小说文件</span>
        <span class="novel-dropzone-subtitle">适合 txt / md / json</span>
      </label>
      <div class="novel-upload-row">
        <label class="novel-upload-btn" for="novelSourceFile">选择文件</label>
        <input id="novelSourceFile" type="file" accept=".txt,.md,.json" style="display:none;" />
        <span id="novelFileHint" class="novel-upload-hint">支持 txt / md / json</span>
        <button id="btnNovelClearFile" type="button" class="novel-upload-clear" style="display:none;">清空文件</button>
      </div>
      <div id="novelFileSummary" class="novel-file-summary" style="display:none;"></div>
      <div class="novel-source-layout">
        <div class="novel-editor-block">
          <div class="novel-editor-head">
            <label for="novelSourceText">手动补充文本</label>
          </div>
          <textarea id="novelSourceText" class="novel-textarea novel-source-text" placeholder="贴入章节原文、人物设定表等。"></textarea>
        </div>
        <div class="novel-editor-block">
          <div class="novel-editor-head">
            <label for="novelContextText">补充说明 (AI Context)</label>
          </div>
          <textarea id="novelContextText" class="novel-textarea novel-context-text" placeholder="例如：优先抽取男主设定，忽略路人。"></textarea>
        </div>
      </div>
    </div>
  </section>

  <div class="novel-grid">
    <section class="novel-card novel-config-card">
      <div class="novel-card-head">
        <strong>处理配置</strong>
        <span>并行与质量控制</span>
      </div>
      <div class="novel-card-body">
        <div class="grid-2" style="margin-bottom: 12px;">
          <div class="form-group" style="margin-bottom: 0;">
            <label>处理模式</label>
            <select id="novelNarrativeMode">
              <option value="story">剧情延续</option>
              <option value="worldbuilding">世界观重建</option>
            </select>
          </div>
          <div class="form-group" style="margin-bottom: 0;">
            <label>单片字数</label>
            <select id="novelChunkSize">
              <option value="4000">4,000 字</option>
              <option value="8000" selected>8,000 字</option>
              <option value="12000">12,000 字</option>
            </select>
          </div>
        </div>

        <div class="grid-2" style="margin-bottom: 12px;">
          <div class="form-group" style="margin-bottom: 0;">
            <label>并行任务数</label>
            <input id="novelConcurrency" type="number" min="1" step="1" value="3" />
          </div>
          <div class="form-group" style="margin-bottom: 0;">
            <label style="display:flex; align-items:center; gap:8px;">
              <input id="novelStrictQuality" type="checkbox" />
              <span>严格质量检查</span>
            </label>
          </div>
        </div>

        <div class="novel-focus-wrap">
          <label class="novel-focus-label">输出类别</label>
          <div id="novelFocusTags" class="novel-focus-tags"></div>
        </div>

        <div class="novel-action-stack">
          <button id="btnNovelGenerate" class="btn novel-primary-btn">🧬 生成世界书草稿</button>
          <button id="btnNovelReset" class="btn novel-secondary-btn">重置任务</button>
        </div>
        <div id="novelStatusText" class="status-text novel-status-text"></div>
        
        <div id="novelTaskQueue" class="novel-task-queue" style="display:none; margin-top:12px;">
            <div class="novel-queue-head">
                <span>任务队列进度</span>
                <span id="novelQueueProgress">0/0</span>
            </div>
            <div id="novelQueueList" class="novel-queue-list"></div>
        </div>
      </div>
    </section>
  </div>

  <section id="novelDraftPreview" class="novel-manager" style="display:none;">
    <div class="novel-manager-head">
      <div>
        <strong>🧭 世界书草稿预览</strong>
        <p id="novelDraftSummaryText">检查并应用生成的草稿条目。</p>
      </div>
      <div class="novel-manager-actions" style="display:flex; flex-direction:column; gap:8px;">
        <button id="btnApplyAll" class="btn novel-sync-btn">应用全部有效</button>
        <button id="btnApplyGreen" class="btn novel-sync-btn" style="color:#34d399; border-color:#34d39940;">仅应用实体(绿灯)</button>
        <button id="btnApplyBlue" class="btn novel-sync-btn" style="color:#60a5fa; border-color:#60a5fa40;">仅应用规则(蓝灯)</button>
        <button id="btnApplySelected" class="btn novel-sync-btn">应用选中条目</button>
        <button id="btnUndoApply" class="btn novel-secondary-btn" style="display:none;">撤销本次注入</button>
        <button id="btnCancelDraft" class="btn novel-secondary-btn">取消</button>
      </div>
    </div>
    
    <div class="novel-preview-shell">
      <div class="novel-preview-head">
        <strong>条目预览</strong>
        <span id="novelEntityCount">0 个条目</span>
      </div>
      <div id="novelEntityPreview" class="novel-entity-preview"></div>
    </div>
  </section>
</div>

<style is:global>
  .novel-workshop-panel {
    border-color: rgba(56, 189, 248, 0.18);
    background:
      radial-gradient(circle at top right, rgba(56, 189, 248, 0.12), transparent 34%),
      radial-gradient(circle at bottom left, rgba(245, 158, 11, 0.08), transparent 38%),
      linear-gradient(180deg, rgba(13, 18, 32, 0.96), rgba(15, 23, 37, 0.94));
  }

  .novel-hero {
    position: relative;
    overflow: hidden;
    margin-bottom: 16px;
    padding: 16px 18px 14px;
    border: 1px solid rgba(56, 189, 248, 0.18);
    border-radius: 14px;
    background:
      linear-gradient(135deg, rgba(8, 47, 73, 0.34), rgba(17, 24, 39, 0.72)),
      radial-gradient(circle at 10% 20%, rgba(34, 211, 238, 0.12), transparent 24%);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }

  .novel-hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 12px;
    padding: 4px 10px;
    border-radius: 999px;
    border: 1px solid rgba(103, 232, 249, 0.26);
    background: rgba(8, 47, 73, 0.4);
    color: #67e8f9;
    font-size: 0.62rem;
    font-weight: 800;
    letter-spacing: 0.14em;
  }

  .novel-hero-main {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
  }

  .novel-hero-copy h2 {
    margin: 0 0 6px;
    border: 0;
    padding: 0;
    color: #e0f2fe;
    font-size: 1.08rem;
  }

  .novel-hero-copy p {
    margin: 0;
    color: #94a3b8;
    font-size: 0.74rem;
    line-height: 1.55;
  }

  .novel-stats {
    position: relative;
    z-index: 1;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 14px;
  }

  .novel-stat-chip {
    display: inline-flex;
    align-items: center;
    min-height: 26px;
    padding: 4px 10px;
    border-radius: 999px;
    border: 1px solid rgba(51, 65, 85, 0.72);
    background: rgba(2, 6, 23, 0.44);
    color: #cbd5e1;
    font-size: 0.68rem;
    font-weight: 700;
  }

  .novel-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 14px;
  }

  .novel-import-dock {
    margin-bottom: 14px;
  }

  .novel-card {
    border: 1px solid rgba(71, 85, 105, 0.64);
    border-radius: 14px;
    background: linear-gradient(180deg, rgba(15, 23, 42, 0.76), rgba(2, 6, 23, 0.58));
    overflow: hidden;
  }

  .novel-card-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 11px 14px;
    border-bottom: 1px solid rgba(51, 65, 85, 0.66);
    background: rgba(15, 23, 42, 0.72);
  }

  .novel-card-head strong {
    color: #e2e8f0;
    font-size: 0.82rem;
  }

  .novel-card-head span {
    color: #64748b;
    font-size: 0.62rem;
    font-weight: 700;
    white-space: normal;
    text-align: right;
  }

  .novel-card-body {
    padding: 14px;
  }

  .novel-upload-row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 12px;
  }

  .novel-dropzone {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    min-height: 100px;
    margin-bottom: 12px;
    padding: 18px 16px;
    border-radius: 14px;
    border: 1px dashed rgba(56, 189, 248, 0.36);
    background:
      radial-gradient(circle at top, rgba(56, 189, 248, 0.1), transparent 46%),
      linear-gradient(180deg, rgba(8, 47, 73, 0.26), rgba(15, 23, 42, 0.52));
    cursor: pointer;
    text-align: center;
    transition: border-color 0.2s ease, background 0.2s ease, transform 0.2s ease;
  }

  .novel-dropzone:hover,
  .novel-dropzone.is-dragover {
    border-color: rgba(125, 211, 252, 0.72);
    background:
      radial-gradient(circle at top, rgba(56, 189, 248, 0.18), transparent 46%),
      linear-gradient(180deg, rgba(8, 47, 73, 0.42), rgba(15, 23, 42, 0.68));
    transform: translateY(-1px);
  }

  .novel-dropzone-icon {
    font-size: 1.8rem;
    line-height: 1;
    filter: drop-shadow(0 0 12px rgba(56, 189, 248, 0.24));
  }

  .novel-dropzone-title {
    color: #e0f2fe;
    font-size: 0.88rem;
    font-weight: 800;
    letter-spacing: 0.02em;
  }

  .novel-dropzone-subtitle {
    color: #94a3b8;
    font-size: 0.7rem;
    line-height: 1.5;
    max-width: 380px;
  }

  .novel-upload-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 32px;
    padding: 0 12px;
    border-radius: 8px;
    border: 1px solid rgba(56, 189, 248, 0.28);
    background: rgba(8, 47, 73, 0.42);
    color: #7dd3fc;
    font-size: 0.74rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .novel-upload-btn:hover {
    background: rgba(14, 116, 144, 0.38);
    color: #e0f2fe;
  }

  .novel-upload-hint {
    color: #64748b;
    font-size: 0.68rem;
  }

  .novel-upload-clear {
    min-height: 32px;
    padding: 0 10px;
    border-radius: 8px;
    border: 1px solid rgba(248, 113, 113, 0.24);
    background: rgba(127, 29, 29, 0.16);
    color: #fca5a5;
    font-size: 0.72rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .novel-upload-clear:hover {
    background: rgba(127, 29, 29, 0.3);
    color: #fecaca;
  }

  .novel-file-summary {
    margin-bottom: 12px;
    padding: 12px 13px;
    border-radius: 12px;
    border: 1px solid rgba(56, 189, 248, 0.16);
    background: linear-gradient(135deg, rgba(8, 47, 73, 0.22), rgba(15, 23, 42, 0.52));
  }

  .novel-file-summary strong {
    display: block;
    color: #e0f2fe;
    font-size: 0.78rem;
    line-height: 1.4;
  }

  .novel-file-summary span {
    display: block;
    margin-top: 5px;
    color: #94a3b8;
    font-size: 0.68rem;
    line-height: 1.5;
  }

  .novel-textarea {
    min-height: 80px;
    resize: vertical;
    background: linear-gradient(180deg, rgba(2, 6, 23, 0.7), rgba(15, 23, 42, 0.82));
    border-color: rgba(56, 189, 248, 0.16);
  }

  .novel-source-layout {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .novel-editor-block {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .novel-editor-head {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .novel-editor-head label {
    margin: 0;
    color: #dbeafe;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .novel-focus-wrap {
    margin-bottom: 14px;
  }

  .novel-focus-label {
    display: block;
    margin-bottom: 8px;
    color: #94a3b8;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .novel-focus-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .novel-focus-tag {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 30px;
    padding: 0 12px;
    border-radius: 999px;
    border: 1px solid rgba(71, 85, 105, 0.74);
    background: rgba(15, 23, 42, 0.58);
    color: #94a3b8;
    font-size: 0.72rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .novel-focus-tag:hover {
    border-color: rgba(56, 189, 248, 0.34);
    color: #cbd5e1;
  }

  .novel-focus-tag.active {
    border-color: rgba(245, 158, 11, 0.38);
    background: linear-gradient(135deg, rgba(146, 64, 14, 0.34), rgba(12, 74, 110, 0.28));
    color: #fcd34d;
    box-shadow: 0 0 0 1px rgba(245, 158, 11, 0.08);
  }

  .novel-action-stack {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .novel-primary-btn {
    width: 100%;
    margin: 0;
    background: linear-gradient(135deg, #f59e0b, #0ea5e9);
    color: #fff;
    box-shadow: 0 10px 24px rgba(14, 165, 233, 0.12);
  }

  .novel-secondary-btn,
  .novel-sync-btn {
    width: 100%;
    margin: 0;
    background: rgba(15, 23, 42, 0.68);
    border: 1px solid rgba(71, 85, 105, 0.78);
    color: #cbd5e1;
  }

  .novel-secondary-btn:hover,
  .novel-sync-btn:hover {
    background: rgba(30, 41, 59, 0.82);
    color: #e2e8f0;
  }

  .novel-status-text {
    min-height: 22px;
    margin-top: 10px;
    font-size: 0.76rem;
  }

  .novel-manager {
    margin-top: 16px;
    padding: 15px 16px 16px;
    border: 1px solid rgba(56, 189, 248, 0.18);
    border-radius: 14px;
    background:
      linear-gradient(180deg, rgba(15, 23, 42, 0.84), rgba(2, 6, 23, 0.72)),
      radial-gradient(circle at top left, rgba(245, 158, 11, 0.08), transparent 28%);
  }

  .novel-manager-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 14px;
  }

  .novel-manager-head strong {
    color: #e2e8f0;
    font-size: 0.9rem;
  }

  .novel-manager-head p {
    margin: 5px 0 0;
    color: #94a3b8;
    font-size: 0.72rem;
    line-height: 1.5;
  }

  .novel-manager-actions {
    min-width: 180px;
  }

  .novel-preview-shell {
    padding: 12px;
    border-radius: 12px;
    border: 1px solid rgba(51, 65, 85, 0.72);
    background: rgba(2, 6, 23, 0.3);
  }

  .novel-preview-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    margin-bottom: 12px;
  }

  .novel-preview-head strong {
    color: #e2e8f0;
    font-size: 0.82rem;
  }

  .novel-preview-head span {
    color: #64748b;
    font-size: 0.68rem;
    font-weight: 700;
  }

  .novel-entity-preview {
    display: grid;
    grid-template-columns: 1fr;
    gap: 10px;
    max-height: 400px;
    overflow-y: auto;
  }

  .novel-entity-card {
    min-width: 0;
    padding: 11px 12px;
    border-radius: 12px;
    border: 1px solid rgba(56, 189, 248, 0.14);
    background: linear-gradient(180deg, rgba(15, 23, 42, 0.7), rgba(2, 6, 23, 0.48));
    display: flex;
    gap: 12px;
  }

  .novel-entity-card.green {
    border-color: rgba(52, 211, 153, 0.3);
  }
  .novel-entity-card.blue {
    border-color: rgba(96, 165, 250, 0.3);
  }
  .novel-entity-card.has-warning {
    border-color: rgba(248, 113, 113, 0.5);
  }

  .novel-entity-card input[type="checkbox"] {
    margin-top: 4px;
  }

  .novel-entity-content {
    flex: 1;
  }

  .novel-entity-card strong {
    display: block;
    margin-bottom: 5px;
    color: #e0f2fe;
    font-size: 0.78rem;
    line-height: 1.4;
    word-break: break-word;
  }

  .novel-entity-meta {
    display: inline-flex;
    align-items: center;
    min-height: 22px;
    margin-bottom: 6px;
    padding: 0 8px;
    border-radius: 999px;
    border: 1px solid rgba(245, 158, 11, 0.18);
    background: rgba(120, 53, 15, 0.2);
    color: #fcd34d;
    font-size: 0.62rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .novel-entity-card p {
    margin: 0 0 6px 0;
    color: #94a3b8;
    font-size: 0.7rem;
    line-height: 1.5;
    word-break: break-word;
  }
  
  .novel-entity-keys {
    font-size: 0.65rem;
    color: #64748b;
  }

  .novel-entity-warning {
    font-size: 0.65rem;
    color: #f87171;
    margin-top: 4px;
  }

  .novel-queue-list {
      display: flex;
      flex-direction: column;
      gap: 6px;
      max-height: 200px;
      overflow-y: auto;
  }
  .novel-queue-item {
      display: flex;
      justify-content: space-between;
      padding: 6px 10px;
      border-radius: 6px;
      background: rgba(2, 6, 23, 0.4);
      font-size: 0.7rem;
      color: #94a3b8;
  }
  .novel-queue-item.running { color: #60a5fa; background: rgba(96, 165, 250, 0.1); }
  .novel-queue-item.success { color: #34d399; background: rgba(52, 211, 153, 0.1); }
  .novel-queue-item.failed { color: #f87171; background: rgba(248, 113, 113, 0.1); }
  
  @media (max-width: 720px) {
    .novel-manager-head {
      flex-direction: column;
    }
    .novel-manager-actions {
      width: 100%;
      min-width: 0;
    }
  }
</style>

<script is:inline>
(function () {
  var STORAGE_KEY = 'novelWorkshopV2';
  var DRAFT_KEY = 'novelWorkshopDraftV2';
  var SNAPSHOT_KEY = 'novelWorkshopSnapshotV2';
  
  var FOCUS_OPTIONS = [
    { id: 'character', label: '人物' },
    { id: 'location', label: '地点' },
    { id: 'faction', label: '势力' },
    { id: 'item', label: '物品' },
    { id: 'rule', label: '规则' },
    { id: 'event', label: '事件' },
    { id: 'relation', label: '关系' }
  ];

  var state = {
    sourceText: '',
    contextText: '',
    narrativeMode: 'story',
    chunkSize: 8000,
    concurrency: 3,
    strictQuality: false,
    focus: ['character', 'location', 'faction', 'item', 'rule'],
    tasks: [],
    signature: '',
    drafts: []
  };

  var importedFileText = '';
  var importedFileMeta = null;

  var sourceTextEl = document.getElementById('novelSourceText');
  var contextTextEl = document.getElementById('novelContextText');
  var sourceFileEl = document.getElementById('novelSourceFile');
  var dropzoneEl = document.getElementById('novelDropzone');
  var fileHintEl = document.getElementById('novelFileHint');
  var fileSummaryEl = document.getElementById('novelFileSummary');
  var btnClearFileEl = document.getElementById('btnNovelClearFile');
  
  var narrativeModeEl = document.getElementById('novelNarrativeMode');
  var chunkSizeEl = document.getElementById('novelChunkSize');
  var concurrencyEl = document.getElementById('novelConcurrency');
  var strictQualityEl = document.getElementById('novelStrictQuality');
  var focusTagsEl = document.getElementById('novelFocusTags');
  
  var btnGenerateEl = document.getElementById('btnNovelGenerate');
  var btnResetEl = document.getElementById('btnNovelReset');
  var statusTextEl = document.getElementById('novelStatusText');
  var statsBarEl = document.getElementById('novelStatsBar');
  
  var taskQueueEl = document.getElementById('novelTaskQueue');
  var queueProgressEl = document.getElementById('novelQueueProgress');
  var queueListEl = document.getElementById('novelQueueList');

  var draftPreviewEl = document.getElementById('novelDraftPreview');
  var entityPreviewEl = document.getElementById('novelEntityPreview');
  var entityCountEl = document.getElementById('novelEntityCount');
  
  var btnApplyAll = document.getElementById('btnApplyAll');
  var btnApplyGreen = document.getElementById('btnApplyGreen');
  var btnApplyBlue = document.getElementById('btnApplyBlue');
  var btnApplySelected = document.getElementById('btnApplySelected');
  var btnUndoApply = document.getElementById('btnUndoApply');
  var btnCancelDraft = document.getElementById('btnCancelDraft');

  function saveState() {
    try { localStorage.setItem(STORAGE_KEY, JSON.stringify(state)); } catch(e){}
  }
  function loadState() {
    try { 
        var s = JSON.parse(localStorage.getItem(STORAGE_KEY)); 
        if(s) state = Object.assign(state, s);
    } catch(e){}
    renderAll();
  }

  function hashString(str) {
    var hash = 0;
    for (var i = 0; i < str.length; i++) {
      hash = ((hash << 5) - hash) + str.charCodeAt(i);
      hash |= 0;
    }
    return String(hash >>> 0);
  }

  function renderFocusTags() {
    focusTagsEl.innerHTML = FOCUS_OPTIONS.map(function(opt) {
      var active = state.focus.indexOf(opt.id) >= 0;
      return '<button type="button" class="novel-focus-tag' + (active ? ' active' : '') + '" data-focus="' + opt.id + '">' + opt.label + '</button>';
    }).join('');
    focusTagsEl.querySelectorAll('button').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var id = btn.getAttribute('data-focus');
        var idx = state.focus.indexOf(id);
        if(idx >= 0) state.focus.splice(idx, 1);
        else state.focus.push(id);
        saveState();
        renderFocusTags();
      });
    });
  }

  function escapeHtml(text) {
    return String(text || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function renderQueue() {
      if(state.tasks.length === 0) {
          taskQueueEl.style.display = 'none';
          return;
      }
      taskQueueEl.style.display = 'block';
      var done = state.tasks.filter(t => t.status === 'success' || t.status === 'failed').length;
      queueProgressEl.textContent = done + '/' + state.tasks.length;
      
      queueListEl.innerHTML = state.tasks.map(t => {
          return '<div class="novel-queue-item ' + t.status + '">' + 
                 '<span>Chunk ' + t.chunk_id + '</span>' + 
                 '<span>' + (t.status === 'running' ? '处理中...' : t.status === 'success' ? '完成' : t.status === 'failed' ? '失败' : '等待中') + '</span>' +
                 '</div>';
      }).join('');
  }

  function renderDrafts() {
      if(!state.drafts || state.drafts.length === 0) {
          draftPreviewEl.style.display = 'none';
          return;
      }
      draftPreviewEl.style.display = 'block';
      entityCountEl.textContent = state.drafts.length + ' 个条目';
      
      entityPreviewEl.innerHTML = state.drafts.map((d, i) => {
          var colorClass = d.layer === 'blue' ? 'blue' : 'green';
          var warningClass = d.warnings && d.warnings.length > 0 ? 'has-warning' : '';
          var warningsHtml = d.warnings ? '<div class="novel-entity-warning">' + escapeHtml(d.warnings.join('; ')) + '</div>' : '';
          return '<div class="novel-entity-card ' + colorClass + ' ' + warningClass + '">' +
                 '<input type="checkbox" class="draft-checkbox" data-index="' + i + '" checked />' +
                 '<div class="novel-entity-content">' +
                 '<span class="novel-entity-meta">' + escapeHtml(d.category) + '</span>' +
                 '<strong>' + escapeHtml(d.name) + '</strong>' +
                 '<p>' + escapeHtml(d.content).substring(0, 100) + '...</p>' +
                 '<div class="novel-entity-keys">Keys: ' + escapeHtml(d.keys.join(', ')) + '</div>' +
                 warningsHtml +
                 '</div></div>';
      }).join('');
  }

  function renderAll() {
      sourceTextEl.value = state.sourceText;
      contextTextEl.value = state.contextText;
      narrativeModeEl.value = state.narrativeMode;
      chunkSizeEl.value = state.chunkSize;
      concurrencyEl.value = state.concurrency;
      strictQualityEl.checked = state.strictQuality;
      
      if (importedFileText) {
          fileSummaryEl.style.display = 'block';
          fileSummaryEl.innerHTML = '<strong>' + escapeHtml(importedFileMeta.name) + '</strong><span>' + importedFileText.length + ' 字符</span>';
          btnClearFileEl.style.display = 'inline-block';
      } else {
          fileSummaryEl.style.display = 'none';
          btnClearFileEl.style.display = 'none';
      }
      
      renderFocusTags();
      renderQueue();
      renderDrafts();
      
      if(localStorage.getItem(SNAPSHOT_KEY)) {
          btnUndoApply.style.display = 'block';
      } else {
          btnUndoApply.style.display = 'none';
      }
  }

  function syncInputs() {
      state.sourceText = sourceTextEl.value;
      state.contextText = contextTextEl.value;
      state.narrativeMode = narrativeModeEl.value;
      state.chunkSize = parseInt(chunkSizeEl.value) || 8000;
      state.concurrency = Math.max(1, parseInt(concurrencyEl.value) || 3);
      state.strictQuality = strictQualityEl.checked;
      saveState();
  }
  
  [sourceTextEl, contextTextEl, narrativeModeEl, chunkSizeEl, concurrencyEl, strictQualityEl].forEach(el => {
      el.addEventListener('change', syncInputs);
      el.addEventListener('input', syncInputs);
  });

  sourceFileEl.addEventListener('change', function(e) {
      var f = e.target.files[0];
      if(!f) return;
      var reader = new FileReader();
      reader.onload = function(ev) {
          importedFileText = ev.target.result;
          importedFileMeta = { name: f.name };
          renderAll();
      };
      reader.readAsText(f);
  });

  btnClearFileEl.addEventListener('click', function() {
      importedFileText = '';
      importedFileMeta = null;
      sourceFileEl.value = '';
      renderAll();
  });

  function splitText(text, size) {
      var chunks = [];
      var parts = text.split(/(?=第[^\n]{1,20}[章节卷回部篇])|(?=chapter\s+\d+)/i);
      var current = "";
      parts.forEach(p => {
          if(p.length > size) {
              if(current) { chunks.push(current); current = ""; }
              for(var i=0; i<p.length; i+=size) chunks.push(p.substring(i, i+size));
          } else {
              if(current.length + p.length > size) {
                  chunks.push(current);
                  current = p;
              } else {
                  current += p;
              }
          }
      });
      if(current) chunks.push(current);
      return chunks;
  }

  function cleanKeys(keys, name) {
      var blacklist = ['他','她','它','那个','这个','这','那','什么'];
      var res = [];
      (keys || []).concat([name]).forEach(k => {
          if(!k) return;
          var ks = String(k).trim();
          if(ks.length > 0 && ks.length < 50 && blacklist.indexOf(ks) < 0 && res.indexOf(ks) < 0) {
              res.push(ks);
          }
      });
      return res;
  }
  
  function validateDraft(entry) {
      var warnings = [];
      if(state.focus.indexOf(entry.category) < 0) warnings.push('未勾选的类别: ' + entry.category);
      if(!entry.name) warnings.push('缺失名称');
      if(!entry.content) warnings.push('缺失内容');
      if(state.strictQuality && entry.content && entry.content.length < 20) warnings.push('内容过短');
      return warnings;
  }

  async function callAI(promptText) {
      var apiUrlEl = document.getElementById('apiUrl');
      var apiKeyEl = document.getElementById('apiKey');
      var modelEl = document.getElementById('modelSelect');
      if (!apiUrlEl || !modelEl || !modelEl.value) throw new Error('未配置AI模型');
      
      var res = await fetch(apiUrlEl.value.replace(/\/$/, '') + '/chat/completions', {
          method: 'POST',
          headers: {
              'Content-Type': 'application/json',
              'Authorization': 'Bearer ' + (apiKeyEl ? apiKeyEl.value.trim() : '')
          },
          body: JSON.stringify({
              model: modelEl.value,
              messages: [{role: 'user', content: promptText}],
              temperature: 0.2
          })
      });
      if(!res.ok) {
          if(res.status === 429) throw new Error('429');
          throw new Error('HTTP ' + res.status);
      }
      var data = await res.json();
      var text = data.choices[0].message.content;
      try {
          var fence = text.match(/```(?:json)?\s*([\s\S]*?)```/i);
          if(fence) return JSON.parse(fence[1]);
          var first = text.indexOf('{');
          var last = text.lastIndexOf('}');
          if(first >= 0 && last > first) return JSON.parse(text.slice(first, last + 1));
          return JSON.parse(text);
      } catch(e) {
          throw new Error('JSON 解析失败');
      }
  }

  async function processQueue() {
      var pending = state.tasks.filter(t => t.status === 'pending' || t.status === 'failed');
      var running = state.tasks.filter(t => t.status === 'running').length;
      
      while(pending.length > 0 && running < state.concurrency) {
          var task = pending.shift();
          task.status = 'running';
          task.attempts = (task.attempts || 0) + 1;
          running++;
          renderQueue();
          
          (async function(t) {
              try {
                  var prompt = "Extract novel facts in strictly JSON format: { \"facts\": [ { \"category\": \"character/location/faction/item/rule\", \"name\": \"...\", \"aspect\": \"...\", \"content\": \"...\", \"keys\": [\"...\"] } ] }\n\n" + 
                               "Focus: " + state.focus.join(',') + "\n" +
                               "Mode: " + state.narrativeMode + "\n" +
                               "Context: " + state.contextText + "\n" +
                               "Text:\n" + t.text;
                  var result = await callAI(prompt);
                  t.result = result;
                  t.status = 'success';
              } catch(e) {
                  t.status = 'failed';
                  t.error = e.message;
                  if(e.message === '429') {
                      await new Promise(r => setTimeout(r, 2000));
                  }
              }
              saveState();
              renderQueue();
              processQueue();
          })(task);
      }
      
      if(pending.length === 0 && state.tasks.every(t => t.status === 'success' || t.status === 'failed')) {
          btnGenerateEl.disabled = false;
          btnGenerateEl.textContent = '合并为世界书草稿';
          statusTextEl.textContent = '提取完成，点击合并';
      }
  }

  btnGenerateEl.addEventListener('click', async function() {
      syncInputs();
      var fullText = (importedFileText + '\n' + state.sourceText).trim();
      if(!fullText) return alert('没有文本');
      
      var sig = hashString(fullText + state.chunkSize + state.narrativeMode + state.focus.join(','));
      if(state.signature !== sig) {
          state.signature = sig;
          var chunks = splitText(fullText, state.chunkSize);
          state.tasks = chunks.map((c, i) => ({
              chunk_id: i,
              text: c,
              status: 'pending',
              result: null
          }));
          state.drafts = [];
          saveState();
      }
      
      if(state.tasks.some(t => t.status === 'pending' || t.status === 'failed')) {
          btnGenerateEl.disabled = true;
          btnGenerateEl.textContent = '处理中...';
          processQueue();
      } else {
          // Merge
          btnGenerateEl.disabled = true;
          btnGenerateEl.textContent = '合并中...';
          var allFacts = [];
          state.tasks.forEach(t => {
              if(t.result && t.result.facts) allFacts = allFacts.concat(t.result.facts);
          });
          
          try {
              var prompt = "Merge and deduplicate these facts into a unified novel-worldbook-draft-v1 JSON: { \"entries\": [ { \"category\": \"...\", \"layer\": \"green/blue\", \"name\": \"...\", \"aspect\": \"...\", \"content\": \"...\", \"keys\": [\"...\"] } ] }\n\n" +
                           "Facts:\n" + JSON.stringify(allFacts);
              var result = await callAI(prompt);
              if(result && result.entries) {
                  state.drafts = result.entries.map(e => {
                      e.keys = cleanKeys(e.keys, e.name);
                      e.layer = e.category === 'rule' ? 'blue' : 'green';
                      e.enabled = true;
                      e.strategy = e.category === 'rule' ? 'constant' : 'selective';
                      e.comment = '[小说' + e.category + '] ' + e.name;
                      e.warnings = validateDraft(e);
                      return e;
                  });
                  saveState();
                  renderAll();
                  statusTextEl.textContent = '生成完毕，请在下方预览';
              }
          } catch(e) {
              alert('合并失败: ' + e.message);
          }
          btnGenerateEl.disabled = false;
          btnGenerateEl.textContent = '重新合并';
      }
  });

  btnResetEl.addEventListener('click', function() {
      state.tasks = [];
      state.drafts = [];
      state.signature = '';
      saveState();
      renderAll();
  });

  function applyDrafts(filterFn) {
      if (!window.__getWorldbookEntries__ || !window.__setWorldbookEntries__) return alert('环境不支持');
      
      var current = window.__getWorldbookEntries__();
      localStorage.setItem(SNAPSHOT_KEY, JSON.stringify(current));
      
      var kept = current.filter(e => !String(e.comment || '').startsWith('[小说'));
      
      var checkboxes = document.querySelectorAll('.draft-checkbox');
      var toAdd = [];
      checkboxes.forEach((cb, idx) => {
          if(cb.checked) {
              var d = state.drafts[idx];
              if(filterFn(d)) {
                  toAdd.push({
                      comment: d.comment,
                      content: d.content,
                      keys: d.keys,
                      strategy: d.strategy,
                      position: 4,
                      depth: d.layer === 'blue' ? 2 : 4,
                      role: 0,
                      order: 800,
                      prob: 100,
                      enabled: true
                  });
              }
          }
      });
      
      window.__setWorldbookEntries__(kept.concat(toAdd));
      if(window.dispatchEvent) {
          window.dispatchEvent(new Event('worldbook-changed'));
          window.dispatchEvent(new Event('card-builder-data-changed'));
      }
      alert('已应用 ' + toAdd.length + ' 个条目');
      renderAll();
  }

  btnApplyAll.addEventListener('click', () => applyDrafts(d => !d.warnings || d.warnings.length === 0));
  btnApplyGreen.addEventListener('click', () => applyDrafts(d => d.layer === 'green' && (!d.warnings || d.warnings.length === 0)));
  btnApplyBlue.addEventListener('click', () => applyDrafts(d => d.layer === 'blue' && (!d.warnings || d.warnings.length === 0)));
  btnApplySelected.addEventListener('click', () => applyDrafts(d => true));
  
  btnUndoApply.addEventListener('click', function() {
      var snap = localStorage.getItem(SNAPSHOT_KEY);
      if(snap && window.__setWorldbookEntries__) {
          window.__setWorldbookEntries__(JSON.parse(snap));
          localStorage.removeItem(SNAPSHOT_KEY);
          if(window.dispatchEvent) {
              window.dispatchEvent(new Event('worldbook-changed'));
              window.dispatchEvent(new Event('card-builder-data-changed'));
          }
          alert('已撤销');
          renderAll();
      }
  });

  btnCancelDraft.addEventListener('click', function() {
      state.drafts = [];
      saveState();
      renderAll();
  });

  loadState();
})();
</script>
