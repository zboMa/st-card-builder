---
/**
 * 状态栏：紧凑分步配置 + 大预览；排版=一对一视觉主题；覆盖 MVU 后注入
 * 左栏：标题→说明→选项→细节→固定底栏（上一步次要 / 下一步主色同行）
 */
---
<div class="panel statusbar-panel" id="statusbarPanel">
  <div class="panel-header statusbar-panel-head">
    <div>
      <h2>状态栏</h2>
      <p class="ui-hint ui-hint--inline statusbar-panel-head__sub">人数 → 预设 → 生成（覆盖 MVU）→ 排版 → 预览并注入</p>
    </div>
  </div>

  <nav class="sb-steps ui-step-pills" aria-label="设计步骤">
    <button type="button" class="ui-step-pill sb-step is-active" data-sb-step="1"><span>1</span>人数</button>
    <button type="button" class="ui-step-pill sb-step" data-sb-step="2"><span>2</span>预设</button>
    <button type="button" class="ui-step-pill sb-step" data-sb-step="3"><span>3</span>生成</button>
    <button type="button" class="ui-step-pill sb-step" data-sb-step="4"><span>4</span>排版</button>
  </nav>

  <div class="sb-layout">
    <!-- 左：分步配置（内容可滚 + 底栏固定） -->
    <div class="sb-config">
      <!-- Step 1 人数 -->
      <section class="sb-card sb-stage" data-sb-stage="1">
        <div class="sb-stage-body">
          <h3>人数</h3>
          <p class="sb-tip">单人用当前卡角色；多人从世界书识别后勾选。</p>
          <!-- 分段控件：单人｜多人 -->
          <div class="sb-seg" id="sbCastRow" role="radiogroup" aria-label="人数模式">
            <label class="sb-seg-item">
              <input type="radio" name="sbCast" value="single" checked />
              <span>单人</span>
            </label>
            <label class="sb-seg-item">
              <input type="radio" name="sbCast" value="multi" />
              <span>多人</span>
            </label>
          </div>

          <div id="sbSingleBox" class="sb-cast-box">
            <p class="sb-tip">主视角取自角色设定面板的角色名。</p>
            <div class="sb-char-pill" id="sbSingleChar">（未填角色名）</div>
          </div>

          <div id="sbMultiBox" class="sb-cast-box" hidden>
            <!-- 工具行：左说明 | 中「只识别女」独立勾选 | 右「AI 识别」；flex+gap，禁 absolute 叠层 -->
            <div class="sb-tool-row sb-cast-toolbar">
              <span class="sb-tip-inline">勾选入选人物</span>
              <label class="sb-check-inline" for="sbFemaleOnly" title="默认只识别女角色">
                <input type="checkbox" id="sbFemaleOnly" checked />
                <span>只识别女</span>
              </label>
              <button type="button" class="btn sb-tool-btn" id="sbBtnScanChars">AI 识别</button>
            </div>
            <div id="sbCharList" class="sb-char-list"></div>
            <div class="sb-field-inline">
              <label class="sb-label-inline" for="sbMainName">主视角</label>
              <select id="sbMainName"></select>
            </div>
          </div>
          <div id="sbStatus1" class="sb-status"></div>
        </div>
        <div class="sb-footer">
          <span class="sb-footer-spacer" aria-hidden="true"></span>
          <button type="button" class="btn btn-primary sb-footer-btn" id="sbBtnNext1">下一步</button>
        </div>
      </section>

      <!-- Step 2 预设 -->
      <section class="sb-card sb-stage" data-sb-stage="2" hidden>
        <div class="sb-stage-body">
          <h3>预设</h3>
          <p class="sb-tip">选题材预设，再按需微调模块。</p>
          <label class="sb-check-inline sb-nsfw-inline">
            <input type="checkbox" id="sbNsfw" />
            <span>NSFW（开则显示身体模块）</span>
          </label>
          <div id="sbPresetGrid" class="sb-preset-grid"></div>
          <div class="sb-field sb-field-tight">
            <div class="sb-card-head">
              <label class="sb-label" style="margin:0">模块开关</label>
              <button type="button" class="btn btn-ghost btn-sm" id="sbBtnResetModules">重置</button>
            </div>
            <div id="sbModuleGrid" class="sb-module-grid"></div>
          </div>
          <div id="sbStatus2" class="sb-status"></div>
        </div>
        <div class="sb-footer">
          <button type="button" class="btn btn-ghost sb-footer-btn" id="sbBtnBack2">上一步</button>
          <button type="button" class="btn btn-primary sb-footer-btn" id="sbBtnNext2">下一步</button>
        </div>
      </section>

      <!-- Step 3 生成：先生成 MVU 变量，再选排版 -->
      <section class="sb-card sb-stage" data-sb-stage="3" hidden>
        <div class="sb-stage-body">
          <h3>生成</h3>
          <p class="sb-tip">将<strong>覆盖</strong>当前 MVU；变量设计完成后，下一步选择排版样式。可经任务中心停止。</p>
          <div class="sb-field sb-field-tight">
            <label class="sb-label" for="sbExtra">额外要求（可选）</label>
            <textarea id="sbExtra" rows="2" placeholder="如：强调契约进度、隐藏体力条…"></textarea>
          </div>
          <div id="sbGenSummary" class="sb-hint" hidden></div>
          <div class="sb-tool-row">
            <span class="sb-tip-inline">生成变量设计（覆盖 MVU）</span>
            <button type="button" class="btn sb-tool-btn" id="sbBtnGenerate">生成并覆盖 MVU</button>
          </div>
          <ul class="sb-checklist" id="sbChecklist"></ul>
          <div id="sbStatus3" class="sb-status"></div>
        </div>
        <div class="sb-footer">
          <button type="button" class="btn btn-ghost sb-footer-btn" id="sbBtnBack3">上一步</button>
          <button type="button" class="btn btn-primary sb-footer-btn" id="sbBtnNext3">下一步</button>
        </div>
      </section>

      <!-- Step 4 排版：预设主题或自定义 AI 排版，底栏注入 -->
      <section class="sb-card sb-stage" data-sb-stage="4" hidden>
        <div class="sb-stage-body">
          <h3>排版</h3>
          <p class="sb-tip">每套 = 完整视觉方案；按人数过滤。选「自定义」可按描述 AI 生成排版。</p>
          <div id="sbLayoutGrid" class="sb-layout-grid"></div>
          <div id="sbCustomBox" class="sb-custom-box" hidden>
            <div class="sb-seg sb-custom-mode" role="radiogroup" aria-label="自定义模式">
              <label class="sb-seg-item">
                <input type="radio" name="sbCustomMode" value="base" checked />
                <span>基于现有主题</span>
              </label>
              <label class="sb-seg-item">
                <input type="radio" name="sbCustomMode" value="scratch" />
                <span>从零描述</span>
              </label>
            </div>
            <div id="sbCustomBaseRow" class="sb-field sb-field-tight">
              <label class="sb-label" for="sbCustomBase">基准主题</label>
              <select id="sbCustomBase"></select>
            </div>
            <div class="sb-field sb-field-tight">
              <label class="sb-label" for="sbCustomPrompt">排版描述</label>
              <textarea id="sbCustomPrompt" rows="3" placeholder="如：赛博 HUD 风格，左侧角色头像，右侧属性条…"></textarea>
            </div>
            <div class="sb-tool-row">
              <span class="sb-tip-inline">基于已生成变量与 MVU 规则</span>
              <button type="button" class="btn sb-tool-btn" id="sbBtnCustomGenerate">生成排版</button>
              <button type="button" class="btn sb-tool-btn" id="sbBtnCustomRegenerate" hidden>再次修改</button>
            </div>
          </div>
          <div id="sbStatus4" class="sb-status"></div>
        </div>
        <div class="sb-footer">
          <button type="button" class="btn btn-ghost sb-footer-btn" id="sbBtnBack4">上一步</button>
          <button type="button" class="btn btn-primary sb-footer-btn" id="sbBtnInject" disabled>注入状态栏</button>
        </div>
      </section>
    </div>

    <!-- 右：预览（占比更大） -->
    <section class="sb-preview-pane sb-card">
      <div class="sb-card-head">
        <h3>预览</h3>
        <button type="button" class="btn btn-ghost btn-sm" id="sbBtnRefreshPreview">刷新</button>
      </div>
      <p class="sb-tip" id="sbPreviewHint">预览随排版方案 + 模块联动（勾选模块即时重绘）</p>
      <iframe id="sbPreviewFrame" class="sb-preview-frame" title="状态栏预览" sandbox="allow-same-origin"></iframe>
      <details class="sb-code-details">
        <summary>查看注入脚本</summary>
        <pre id="sbSnippetCode" class="sb-code"></pre>
      </details>
    </section>
  </div>
</div>

<style is:global>
  /* 壳层对齐夜庭 token；30 套预览主题仍在 statusBarThemes/ */
  .statusbar-panel {
    border-color: var(--color-accent-border);
    background:
      radial-gradient(circle at top right, var(--color-accent-soft), transparent 42%),
      var(--color-glass);
  }
  .statusbar-panel-head__sub {
    margin: 2px 0 0;
    display: block;
  }

  .sb-steps { margin-bottom: var(--space-2); }

  .sb-layout {
    display: grid;
    grid-template-columns: minmax(280px, 36%) minmax(0, 1fr);
    gap: var(--space-2);
    align-items: stretch;
  }
  @media (max-width: 960px) {
    .sb-layout { grid-template-columns: 1fr; }
  }

  .sb-config { min-width: 0; display: flex; flex-direction: column; }
  .sb-card {
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-md);
    padding: var(--space-3);
    background: var(--color-surface-inset);
    box-shadow: var(--shadow-inset);
  }
  .sb-stage {
    display: flex; flex-direction: column;
    min-height: min(62vh, 560px);
    max-height: min(72vh, 680px);
    padding: 0;
    overflow: hidden;
  }
  .sb-stage[hidden] { display: none !important; }
  .sb-stage-body {
    flex: 1; min-height: 0; overflow-y: auto;
    padding: var(--space-3) var(--space-3) var(--space-2);
  }
  .sb-stage h3 {
    margin: 0 0 4px;
    font-size: 0.84rem;
    color: var(--color-text);
  }
  .sb-card-head {
    display: flex; align-items: center; justify-content: space-between;
    gap: var(--space-2); margin-bottom: var(--space-2);
  }
  .sb-card-head h3 { margin: 0; }

  .sb-footer {
    display: flex; align-items: center; justify-content: space-between;
    gap: var(--space-2); flex-shrink: 0;
    padding: var(--space-2) var(--space-3);
    border-top: 1px solid var(--color-border-subtle);
    background: var(--color-surface-inset);
  }
  .sb-footer-spacer { flex: 1; }
  .sb-footer-btn {
    height: 36px !important; min-height: 36px !important; max-height: 40px !important;
    padding: 0 14px !important; font-size: 0.76rem !important;
    line-height: 1 !important; white-space: nowrap; width: auto !important;
  }
  .sb-footer .btn-primary { margin-left: auto; }

  .sb-field { margin-bottom: var(--space-2); }
  .sb-field-tight { margin-bottom: var(--space-2); }
  .sb-label {
    display: block; margin-bottom: 4px;
    color: var(--color-text-muted); font-size: 0.7rem; font-weight: 700;
  }
  .sb-field-inline {
    display: flex; align-items: center; gap: var(--space-2); margin-top: var(--space-2);
  }
  .sb-label-inline {
    flex-shrink: 0; color: var(--color-text-muted); font-size: 0.7rem; font-weight: 700;
  }
  .sb-field-inline select { flex: 1; min-width: 0; }
  .statusbar-panel select,
  .statusbar-panel textarea {
    width: 100%; border-radius: var(--radius-sm);
    border: 1px solid var(--color-border-subtle);
    background: var(--color-surface-input); color: var(--color-text);
    padding: 6px 8px; font: inherit; font-size: 0.76rem;
  }

  .sb-seg {
    display: grid; grid-template-columns: 1fr 1fr; gap: 2px;
    margin-bottom: var(--space-2); padding: 3px; border-radius: var(--radius-sm);
    border: 1px solid var(--color-border-subtle);
    background: var(--color-surface-inset);
  }
  .sb-seg-item {
    position: relative; display: flex; align-items: center; justify-content: center;
    padding: 7px 8px; border-radius: 7px; cursor: pointer;
    color: var(--color-text-muted); font-size: 0.76rem; font-weight: 700;
    transition: background var(--dur-fast) var(--ease-out), color var(--dur-fast) var(--ease-out);
  }
  .sb-seg-item input {
    position: absolute; opacity: 0; width: 0; height: 0; pointer-events: none;
  }
  .sb-seg-item:has(input:checked) {
    background: var(--color-accent-soft);
    color: var(--color-accent-hover);
    box-shadow: inset 0 0 0 1px var(--color-accent-border);
  }

  .sb-tool-row {
    display: flex; flex-wrap: wrap; align-items: center;
    gap: var(--space-2); margin-bottom: var(--space-2); min-height: 32px;
  }
  .sb-cast-toolbar {
    display: flex; flex-wrap: wrap; align-items: center; gap: var(--space-2);
  }
  .sb-cast-toolbar .sb-tip-inline { flex: 1 1 4em; min-width: 0; }
  .sb-cast-toolbar .sb-check-inline,
  .sb-cast-toolbar .sb-tool-btn { flex: 0 0 auto; }
  .sb-tip-inline {
    color: var(--color-text-muted); font-size: 0.68rem; white-space: nowrap;
    overflow: hidden; text-overflow: ellipsis; min-width: 0; flex: 1;
  }
  .sb-tool-btn {
    flex-shrink: 0; width: auto !important; height: 32px !important;
    padding: 0 12px !important; margin: 0 !important;
    font-size: 0.72rem !important; font-weight: 700 !important;
    position: static !important; overflow: visible !important;
  }
  .sb-check-inline {
    display: inline-flex; align-items: center; gap: 4px;
    color: var(--color-text-secondary); font-size: 0.68rem; cursor: pointer; white-space: nowrap;
    position: static; margin: 0;
  }
  .sb-check-inline input { accent-color: var(--color-accent); }
  .sb-nsfw-inline {
    margin-bottom: var(--space-2); padding: 4px 0;
    border: 0; background: transparent;
  }
  .sb-nsfw-inline input { accent-color: var(--color-accent); }

  .sb-hint {
    margin: 0 0 var(--space-2); padding: 6px 8px; border-radius: var(--radius-sm);
    border: 1px solid oklch(78% 0.12 85 / 0.35);
    background: var(--color-warning-soft); color: var(--color-warning);
    font-size: 0.7rem; line-height: 1.4;
  }
  .sb-status {
    margin-top: var(--space-2); min-height: 1.1em;
    font-size: 0.7rem; color: var(--color-text-muted);
  }
  .sb-status.is-ok { color: var(--color-success); }
  .sb-status.is-warn { color: var(--color-warning); }
  .sb-status.is-err { color: var(--color-danger); }
  .sb-status.is-info { color: var(--color-accent-hover); }
  .sb-tip {
    margin: 0 0 var(--space-2); color: var(--color-text-muted);
    font-size: 0.68rem; line-height: 1.4;
  }

  .sb-char-pill {
    display: inline-block; padding: 4px 10px; border-radius: var(--radius-pill);
    border: 1px solid var(--color-accent-border);
    background: var(--color-accent-soft); color: var(--color-accent-hover); font-size: 0.78rem;
  }
  .sb-char-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 6px;
    max-height: 220px;
    overflow-y: auto;
    margin-bottom: var(--space-2);
  }
  .sb-char-card {
    display: flex; align-items: flex-start; gap: 6px;
    min-width: 0; padding: 6px 8px; border-radius: var(--radius-sm);
    border: 1px solid var(--color-border-subtle);
    background: var(--color-surface-inset);
    font-size: 0.72rem; color: var(--color-text-secondary); cursor: pointer;
    transition: border-color var(--dur-fast) var(--ease-out),
      background var(--dur-fast) var(--ease-out), opacity var(--dur-fast) var(--ease-out);
  }
  .sb-char-card input { margin-top: 2px; flex-shrink: 0; accent-color: var(--color-accent); }
  .sb-char-card-body { min-width: 0; flex: 1; }
  .sb-char-card strong {
    display: block; color: var(--color-text); font-weight: 700;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .sb-char-card small {
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
    overflow: hidden; color: var(--color-text-muted); font-size: 0.62rem; line-height: 1.35; margin-top: 2px;
  }
  .sb-char-card:has(input:checked) {
    border-color: var(--color-accent-border);
    background: var(--color-accent-soft);
  }
  .sb-char-card:has(input:not(:checked)) { opacity: 0.58; }

  .sb-preset-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
    gap: 6px; margin-bottom: var(--space-2); max-height: 200px; overflow-y: auto;
  }
  .sb-preset-btn {
    text-align: left; padding: 8px; border-radius: var(--radius-sm);
    border: 1px solid var(--color-border-subtle);
    background: var(--color-surface-inset); color: var(--color-text-secondary);
    font: inherit; font-size: 0.7rem; cursor: pointer;
    transition: border-color var(--dur-fast) var(--ease-out), background var(--dur-fast) var(--ease-out);
  }
  .sb-preset-btn strong {
    display: block; color: var(--color-text); margin-bottom: 2px; font-size: 0.72rem;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .sb-preset-btn small {
    display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical;
    overflow: hidden; color: var(--color-text-muted); font-size: 0.62rem;
  }
  .sb-preset-btn.is-active {
    border-color: var(--color-accent-border);
    background: var(--color-accent-soft); color: var(--color-accent-hover);
    box-shadow: inset 0 0 0 1px var(--color-accent-border);
  }
  .sb-preset-btn.is-nsfw { border-color: oklch(72% 0.14 305 / 0.4); }

  .sb-layout-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(112px, 1fr));
    gap: 6px; max-height: 280px; overflow-y: auto; margin-bottom: var(--space-2);
  }
  .sb-layout-btn {
    display: flex; align-items: flex-start; gap: 6px;
    text-align: left; padding: 7px 8px; border-radius: var(--radius-sm);
    border: 1px solid var(--color-border-subtle);
    background: var(--color-surface-inset); color: var(--color-text-secondary);
    font: inherit; font-size: 0.68rem; cursor: pointer;
    transition: border-color var(--dur-fast) var(--ease-out), background var(--dur-fast) var(--ease-out);
  }
  .sb-layout-dot {
    flex-shrink: 0; width: 8px; height: 8px; margin-top: 4px;
    border-radius: 50%; background: var(--sb-accent, var(--color-text-muted));
    box-shadow: 0 0 0 1px var(--color-border-subtle);
  }
  .sb-layout-meta { min-width: 0; flex: 1; }
  .sb-layout-btn strong {
    display: block; color: var(--color-text); margin-bottom: 2px; font-size: 0.7rem;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .sb-layout-btn small {
    display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical;
    overflow: hidden; color: var(--color-text-muted); font-size: 0.58rem;
  }
  .sb-layout-btn.is-active {
    border-color: var(--color-accent-border);
    background: var(--color-accent-soft); color: var(--color-accent-hover);
    box-shadow: inset 0 0 0 1px var(--color-accent-border);
  }
  .sb-layout-btn.is-multi { border-style: dashed; }
  .sb-layout-btn.is-custom { border-style: dotted; border-color: oklch(72% 0.18 305 / 0.45); }

  .sb-custom-box {
    margin-top: var(--space-2);
    padding: var(--space-2);
    border: 1px dashed oklch(72% 0.18 305 / 0.35);
    border-radius: var(--radius-md);
    background: oklch(72% 0.08 305 / 0.06);
  }
  .sb-custom-mode { margin-bottom: var(--space-2); }

  .sb-module-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(110px, 1fr)); gap: 4px;
    max-height: 200px; overflow-y: auto;
  }
  .sb-mod {
    display: flex; align-items: center; gap: 6px;
    padding: 4px 6px; border-radius: var(--radius-sm);
    border: 1px solid var(--color-border-subtle);
    background: var(--color-surface-inset); font-size: 0.68rem;
    color: var(--color-text-muted); cursor: pointer;
  }
  .sb-mod:has(input:checked) {
    border-color: oklch(72% 0.14 155 / 0.4);
    color: var(--color-success);
    background: var(--color-success-soft);
  }
  .sb-mod.is-nsfw { border-style: dashed; border-color: oklch(72% 0.14 305 / 0.35); }

  .sb-preview-pane { min-height: 420px; }
  .sb-preview-frame {
    width: 100%; min-height: 380px; height: min(62vh, 640px);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-md); background: var(--color-paper-deep); margin-bottom: var(--space-2);
  }
  .sb-code-details { margin-bottom: 2px; color: var(--color-text-muted); font-size: 0.7rem; }
  .sb-code {
    margin: var(--space-2) 0 0; max-height: 120px; overflow: auto;
    padding: 8px 10px; border-radius: var(--radius-sm);
    background: var(--color-paper-deep);
    border: 1px solid var(--color-border-subtle);
    color: var(--color-warning); font-size: 0.64rem; white-space: pre-wrap;
    font-family: var(--font-mono);
  }
  .sb-checklist {
    margin: var(--space-2) 0 0; padding-left: 16px;
    color: var(--color-text-secondary); font-size: 0.74rem; line-height: 1.55;
  }
  @media (prefers-reduced-motion: reduce) {
    .sb-seg-item, .sb-char-card, .sb-preset-btn, .sb-layout-btn { transition: none; }
  }
</style>

