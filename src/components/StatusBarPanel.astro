  });

  dropzoneEl.addEventListener('drop', function(event) {
    var file = event.dataTransfer && event.dataTransfer.files && event.dataTransfer.files[0];
    handleTextFile(file);
  });

  btnResetEl.addEventListener('click', function() {
    state = createDefaultState();
    importedFileText = '';
    importedFileMeta = null;
    sourceFileEl.value = '';
    workflowRunState = { phase: 'idle', extractionDone: 0, extractionTotal: 0, mergeDone: 0, mergeTotal: 0 };
    clearRawState();
    clearCheckpoint();
    persistState();
    renderAll();
    setStatus('已重置小说世界书工坊。', '#64748b');
  });

  btnSyncVariablesEl.addEventListener('click', function() {
    if (!state.generatedEntries.length) return;
    try {
      var result = syncVariablesToMvu('已按当前阶段与标记同步 MVU 世界书控制变量');
      setStatus('✅ 已同步到 MVU：' + result.count + ' 个变量', '#34d399');
    } catch (err) {
      setStatus('❌ 同步失败：' + err.message, '#f87171');
    }
  });

  btnGenerateEl.addEventListener('click', async function() {
    syncInputsIntoState();
    if (!importedFileText && !state.sourceText) {
      setStatus('❌ 先导入小说文件或补一段手动摘录，再开始生成。', '#f87171');
      return;
    }
    if (!state.focus.length) {
      setStatus('❌ 至少选一个抽取重点。', '#f87171');
      return;
    }
    try {
      assertWorkflowAffordable(buildCallEstimate());
    } catch (err) {
      setStatus('❌ ' + err.message, '#f87171');
      return;
    }

    btnGenerateEl.disabled = true;
    btnGenerateEl.textContent = '⏳ 正在生成小说世界书包...';
    setStatus('🧬 正在让 AI 整理实体、条目与门控变量...', '#38bdf8');

    try {
      var previousEntries = state.generatedEntries.slice();
      var pkg = await runChunkedWorkflow(previousEntries);
      applyWorkshopPackageSnapshot(pkg, previousEntries);
      var result = syncVariablesToMvu('已根据小说世界书工坊生成新的 MVU 管理变量');
      workflowRunState = { phase: 'done', extractionDone: 0, extractionTotal: 0, mergeDone: 0, mergeTotal: 0 };
      renderAll();
      setStatus('✅ 小说世界书包已注入：' + state.generatedEntries.length + ' 条条目，' + result.count + ' 个变量', '#34d399');
    } catch (err) {
      workflowRunState = { phase: 'idle', extractionDone: 0, extractionTotal: 0, mergeDone: 0, mergeTotal: 0 };
      renderAll();
      setStatus('❌ 生成失败：' + err.message, '#f87171');
    } finally {
      btnGenerateEl.disabled = false;
      btnGenerateEl.textContent = '🧬 生成并注入小说世界书';
    }
  });

  window.addEventListener('card-builder-data-changed', loadFromExtension);

  loadState(getWorkshopStateFromExtension());
})();
</script>
