  function buildChunkExtractPrompt(chunkText, chunkIndex, chunkTotal) {
    var gateMode = state.gateMode;
    var focusText = state.focus.map(categoryLabel).join('、');
    var localBudget = Math.max(1, Number(state.entryBudget) || 18);
    return {
      system: buildPromptEnvelope([
        '你是小说知识抽取器，负责从单个小说片段中抽取实体与世界书候选，不要输出解释。',
        '你只处理当前片段，但要尽量给出稳定命名、别名、关系和公开/阶段性信息。',
        '如果片段里出现明显剧透信息，在门控允许时放到更晚阶段或 required_flags。',
        '不要总结整段剧情，只抽取后续合并需要的实体事实、关系变化和世界规则。',
        '只输出严格 JSON 对象，不要包裹 markdown。'
      ]),
      user: buildPromptEnvelope([
        '【当前任务】第 ' + chunkIndex + ' / ' + chunkTotal + ' 片知识抽取',
        '【整理模式】' + narrativeModeLabel(state.narrativeMode),
        '【门控模式】' + gateMode,
        '【抽取重点】' + focusText,
        '【单片预算】最多 ' + localBudget + ' 条候选 entries',
        '',
        buildExtractionRules(),
        '',
        buildNarrativeModeRules(),
        '【补充说明】',
        state.contextText || '无',
        '',
        '【片段原文】',
        chunkText,
        '',
        '【输出格式】',
        buildFinalOutputFormat(localBudget)
      ])
    };
