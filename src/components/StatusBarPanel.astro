<script is:inline>
(function () {
  var STORAGE_KEY = 'novelWorkshop';
  var RAW_STORAGE_PREFIX = 'novelWorkshopRaw::';
  var CHECKPOINT_PREFIX = 'novelWorkshopCheckpoint::';
  var DEFAULT_CHUNK_CHAR_LIMIT = 20000;
  var DEFAULT_SAFE_PROMPT_TOKENS = 50000;
  var LONG_CONTEXT_SAFE_PROMPT_TOKENS = 1000000;
  var MERGE_BATCH_SIZE = 6;
  var MAX_WORKFLOW_CALLS = 80;
  var DEFAULT_STAGE_ORDER = ['公开', '前期', '中期', '后期', '终局'];
  var FOCUS_OPTIONS = [
    { id: 'character', label: '人物' },
    { id: 'location', label: '地点' },
    { id: 'faction', label: '势力' },
    { id: 'rule', label: '规则' },
    { id: 'item', label: '物品' }
