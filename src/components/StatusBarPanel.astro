  function buildMergePrompt(packages, options) {
    var opts = options || {};
    var finalPass = !!opts.finalPass;
    var budgetHint = finalPass ? 0 : Math.max(state.entryBudget, Math.min(48, packages.length * 8));
    var normalizedPackages = (packages || []).map(function(pkg) {
      return {
        summary: String(pkg && pkg.summary || '').trim().slice(0, 120),
        stage_order: uniqueStrings((pkg && (pkg.stage_order || pkg.stageOrder)) || []),
        reveal_flags: Array.isArray(pkg && (pkg.reveal_flags || pkg.revealFlags)) ? (pkg.reveal_flags || pkg.revealFlags) : [],
        entity_index: Array.isArray(pkg && (pkg.entity_index || pkg.entityIndex)) ? (pkg.entity_index || pkg.entityIndex) : [],
        variables: Array.isArray(pkg && pkg.variables) ? pkg.variables : [],
        entries: Array.isArray(pkg && pkg.entries) ? pkg.entries : []
      };
    });
    var sections = [
      '【当前任务】' + (finalPass ? '最终合并并生成完整世界书包' : '中间合并去重'),
      '【整理模式】' + narrativeModeLabel(state.narrativeMode),
      '【门控模式】' + state.gateMode,
      '【合并要求】只做去重、统一 entity_id、整理阶段与触发词；不要把有效 entries 压缩到固定数量。合并时要主动补全 keys，保留同一实体的别名、称号、简称和关系称呼。',
      buildNarrativeModeRules(),
      '【补充说明】',
      state.contextText || '无',
      ''
    ];
    if (finalPass) {
      sections.push('【现有知识包摘要】');
      sections.push(JSON.stringify(buildExistingPackageSummary()));
      sections.push('');
    }
    sections.push('【待合并 JSON 包】');
    sections.push(JSON.stringify(normalizedPackages));
    sections.push('');
    sections.push('【输出格式】');
    sections.push(buildFinalOutputFormat(budgetHint));
    return {
      system: buildPromptEnvelope([
        '你是小说知识包合并器，负责把多个局部 JSON 包合并成一个去重后的统一快照。',
        '必须合并重复人物、地点、势力和规则，不要保留重复实体。',
        '如果后面的包补充了旧实体的新信息，应该并入同一 entity_id。',
        '合并时优先保留高信息密度条目，删除章节流水账，但不要过度删除触发词；同一实体的有效别名、称号、简称要合并进 keys。',
        '只输出严格 JSON 对象，不要包裹 markdown。'
      ]),
      user: buildPromptEnvelope(sections)
    };
  }

  function extractJsonObject(raw) {
    var text = String(raw || '').trim();
    try { return JSON.parse(text); } catch (err) {}
    var fence = text.match(/```(?:json)?\s*([\s\S]*?)```/i);
    if (fence && fence[1]) {
      try { return JSON.parse(fence[1].trim()); } catch (err) {}
    }
    var first = text.indexOf('{');
    var last = text.lastIndexOf('}');
    if (first >= 0 && last > first) return JSON.parse(text.slice(first, last + 1));
    throw new Error('AI 返回中没有有效 JSON 对象');
  }

  function assertWorkflowAffordable(estimate) {
    if (!estimate || !estimate.totalCalls) return;
    if (estimate.totalCalls > MAX_WORKFLOW_CALLS) {
      throw new Error(
        '当前预计需要 ' + formatNumber(estimate.totalCalls) + ' 次调用，超过发布版安全上限 ' +
        MAX_WORKFLOW_CALLS + ' 次。请提高“单次分片字数”、减少原文范围，或先按卷/章节分批生成。'
      );
    }
  }

  function normalizeApiErrorMessage(status, message) {
    var text = String(message || '').trim();
    var lower = text.toLowerCase();
    if (lower.indexOf('prohibited_content') >= 0 || lower.indexOf('request blocked by gemini api') >= 0) {
      return 'Gemini 安全策略拦截了本次小说内容。请减少露骨性描写、未成年相关、极端暴力/自残等片段，或改用更适合长篇创作整理的模型后重试。';
    }
    if (status === 400 && lower.indexOf('safety') >= 0) {
      return '模型安全策略拒绝了本次请求。建议先缩小导入范围，删去高风险描写，或换用其他模型。';
    }
    if (status === 429) return '接口限流或额度不足，请稍后再试，或降低分片并发/调用频率。';
    return text;
  }

  function getSafePromptTokenLimit(modelName) {
    var name = String(modelName || '').toLowerCase();
    if (name.indexOf('gemini') >= 0) return LONG_CONTEXT_SAFE_PROMPT_TOKENS;
    if (name.indexOf('deepseek') >= 0) return 120000;
    if (name.indexOf('claude-3') >= 0 || name.indexOf('claude-sonnet-4') >= 0 || name.indexOf('claude-opus-4') >= 0) return 180000;
    if (name.indexOf('gpt-4.1') >= 0 || name.indexOf('gpt-4o') >= 0 || name.indexOf('o3') >= 0 || name.indexOf('o4') >= 0) return 120000;
    return DEFAULT_SAFE_PROMPT_TOKENS;
  }

  function estimatePromptTokens(prompt) {
    return estimateTokenCount((prompt && prompt.system) || '') + estimateTokenCount((prompt && prompt.user) || '');
  }

  function getSelectedModelName() {
    var modelEl = document.getElementById('modelSelect');
    return modelEl ? String(modelEl.value || '').trim() : '';
  }

  function selectMergeGroup(pending) {
    var packages = Array.isArray(pending) ? pending : [];
    if (packages.length < 2) {
      return {
        group: packages.slice(),
        finalPass: packages.length <= 1,
        promptTokens: 0,
        safePromptTokenLimit: getSafePromptTokenLimit(getSelectedModelName())
      };
    }
    var safePromptTokenLimit = getSafePromptTokenLimit(getSelectedModelName());
    var softLimit = Math.max(12000, Math.floor(safePromptTokenLimit * 0.82));
    var maxGroupSize = Math.min(MERGE_BATCH_SIZE, packages.length);
    var lightest = null;
    for (var size = maxGroupSize; size >= 2; size--) {
      var group = packages.slice(0, size);
      var finalPass = size === packages.length;
      var prompt = buildMergePrompt(group, { finalPass: finalPass });
      var promptTokens = estimatePromptTokens(prompt);
      if (!lightest || promptTokens < lightest.promptTokens) {
        lightest = {
          group: group,
          finalPass: finalPass,
          promptTokens: promptTokens,
          safePromptTokenLimit: safePromptTokenLimit
        };
      }
      if (promptTokens <= softLimit) {
        return {
          group: group,
          finalPass: finalPass,
          promptTokens: promptTokens,
          safePromptTokenLimit: safePromptTokenLimit
        };
      }
    }
    throw new Error(
      '合并阶段最小 2 包仍预计约 ' + formatNumber(lightest ? lightest.promptTokens : 0) +
      ' tokens，已经逼近当前模型安全阈值 ' + formatNumber(safePromptTokenLimit) +
      '。请把“单次分片字数”继续调低，建议先降到 ' +
      formatNumber(Math.max(4000, Math.floor((Number(state.chunkCharLimit) || DEFAULT_CHUNK_CHAR_LIMIT) * 0.6))) +
      ' 字左右后重新生成。'
    );
  }

  async function requestChatJson(prompt) {
    var apiUrlEl = document.getElementById('apiUrl');
    var apiKeyEl = document.getElementById('apiKey');
    var modelEl = document.getElementById('modelSelect');
    if (!apiUrlEl || !apiKeyEl || !modelEl || !modelEl.value) {
      throw new Error('请先在 AI 引擎里配置接口并选择模型');
    }
    var promptTokens = estimatePromptTokens(prompt);
    var safePromptTokenLimit = getSafePromptTokenLimit(modelEl.value);
    if (promptTokens > safePromptTokenLimit) {
      throw new Error(
        '当前单次请求预计约 ' + formatNumber(promptTokens) + ' tokens，已经超过工坊安全阈值 ' +
        formatNumber(safePromptTokenLimit) + '。请先把“单次分片字数”调低后再试。'
      );
    }
    var headers = { 'Content-Type': 'application/json' };
    var key = apiKeyEl.value.trim();
    if (key) headers.Authorization = 'Bearer ' + key;
    var res = await fetch(apiUrlEl.value.replace(/\/$/, '') + '/chat/completions', {
      method: 'POST',
      headers: headers,
      body: JSON.stringify({
        model: modelEl.value,
        messages: [
          { role: 'system', content: prompt.system },
          { role: 'user', content: prompt.user }
        ],
        temperature: 0.2
      })
    });
    if (!res.ok) {
      var errText = '';
      var errMessage = '';
      try { errText = await res.text(); } catch (err) {}
      if (errText) {
        try {
          var errJson = JSON.parse(errText);
          if (errJson && errJson.error) {
            errMessage = errJson.error.message || JSON.stringify(errJson.error);
          }
        } catch (err) {}
        if (!errMessage) errMessage = errText.replace(/\s+/g, ' ').trim().slice(0, 240);
      }
      if (!errMessage && res.status >= 500) {
        errMessage = '接口服务异常';
      }
      errMessage = normalizeApiErrorMessage(res.status, errMessage);
      if (res.status >= 500 && promptTokens > 30000) {
        errMessage += (errMessage ? '；' : '') + '当前请求体偏大，建议下调“单次分片字数”';
      }
      throw new Error('HTTP ' + res.status + (errMessage ? '：' + errMessage : ''));
    }
    var data = await res.json();
    var raw = data && data.choices && data.choices[0] && data.choices[0].message ? data.choices[0].message.content : '';
    return extractJsonObject(raw);
  }

  async function requestWorkshopPackage() {
    return requestChatJson(buildDirectPrompt(getCombinedSourceText()));
  }

  async function requestChunkPackage(chunkText, chunkIndex, chunkTotal) {
    return requestChatJson(buildChunkExtractPrompt(chunkText, chunkIndex, chunkTotal));
  }

  async function requestMergedPackage(packages, options) {
    return requestChatJson(buildMergePrompt(packages, options));
  }

  async function runChunkedWorkflow(previousEntries) {
    var source = getCombinedSourceText();
    var chunks = splitTextIntoChunks(source, Number(state.chunkCharLimit) || DEFAULT_CHUNK_CHAR_LIMIT);
    if (!chunks.length) throw new Error('没有可处理的小说资料');
    assertWorkflowAffordable(buildCallEstimate());
    var signature = buildWorkflowSignature(source, chunks);
    if (chunks.length === 1) {
      workflowRunState = { phase: 'extract', extractionDone: 0, extractionTotal: 1, mergeDone: 0, mergeTotal: 0 };
      setStatus('🧬 当前资料较短，直接单次生成世界书包...', '#38bdf8');
      renderAll();
      var direct = await requestWorkshopPackage();
      workflowRunState = { phase: 'inject', extractionDone: 1, extractionTotal: 1, mergeDone: 0, mergeTotal: 0 };
      clearCheckpoint();
      renderAll();
      return direct;
    }

    var checkpoint = loadCheckpoint(signature);
    var partials = checkpoint ? checkpoint.partials.slice() : [];
    var resumedPending = checkpoint && checkpoint.phase === 'merge' && Array.isArray(checkpoint.pending) && checkpoint.pending.length
      ? checkpoint.pending.slice()
      : null;
    var resumeFrom = partials.length;
    var resumeMergeDone = checkpoint && checkpoint.phase === 'merge' ? clampNumber(checkpoint.mergeDone, 0, 9999, 0) : 0;
    workflowRunState = {
      phase: resumedPending ? 'merge' : 'extract',
      extractionDone: resumeFrom,
      extractionTotal: chunks.length,
      mergeDone: resumeMergeDone,
      mergeTotal: resumedPending ? (resumeMergeDone + countSequentialMergeCalls(resumedPending.length)) : countSequentialMergeCalls(chunks.length)
    };
    if (resumeFrom) writePartialSnapshot(partials, previousEntries, resumeFrom, chunks.length);
    if (resumedPending) {
      setStatus('🧠 检测到合并断点，继续处理剩余 ' + resumedPending.length + ' 个知识包...', '#38bdf8');
    } else {
      setStatus(resumeFrom ? ('🧩 检测到断点，继续处理第 ' + (resumeFrom + 1) + ' / ' + chunks.length + ' 片...') : ('🧩 已拆成 ' + chunks.length + ' 片，开始逐片抽取实体与条目...'), '#38bdf8');
    }
    renderAll();
    for (var i = resumeFrom; i < chunks.length; i++) {
      setStatus('🧩 正在抽取第 ' + (i + 1) + ' / ' + chunks.length + ' 片...', '#38bdf8');
      var partial = await requestChunkPackage(chunks[i], i + 1, chunks.length);
      partials.push(partial);
      workflowRunState.extractionDone = i + 1;
      saveCheckpoint({
        signature: signature,
        sourceHash: hashString(source),
        chunkSize: Number(state.chunkCharLimit) || DEFAULT_CHUNK_CHAR_LIMIT,
        totalChunks: chunks.length,
        phase: 'extract',
        partials: partials,
        updatedAt: new Date().toISOString()
      });
      writePartialSnapshot(partials, previousEntries, i + 1, chunks.length);
      setStatus('✅ 已写入第 ' + (i + 1) + ' / ' + chunks.length + ' 片的临时世界书快照。', '#34d399');
      renderAll();
    }

    var pending = resumedPending ? resumedPending.slice() : partials.slice();
    var mergeDone = resumeMergeDone;
    while (pending.length > 1) {
      workflowRunState.phase = 'merge';
      workflowRunState.mergeTotal = Math.max(workflowRunState.mergeTotal, mergeDone + countSequentialMergeCalls(pending.length));
      renderAll();
      var mergePlan = selectMergeGroup(pending);
      if (mergePlan.finalPass) setStatus('🧠 正在做最终合并去重并生成完整世界书包...', '#38bdf8');
      else setStatus('🧠 正在合并 ' + mergePlan.group.length + ' 个知识分片，尽量压低单次 tokens...', '#38bdf8');
      var merged = await requestMergedPackage(mergePlan.group, { finalPass: mergePlan.finalPass });
      pending = [merged].concat(pending.slice(mergePlan.group.length));
      mergeDone += 1;
      workflowRunState.mergeDone = mergeDone;
      workflowRunState.mergeTotal = Math.max(workflowRunState.mergeTotal, mergeDone + countSequentialMergeCalls(pending.length));
      saveCheckpoint({
        signature: signature,
        sourceHash: hashString(source),
        chunkSize: Number(state.chunkCharLimit) || DEFAULT_CHUNK_CHAR_LIMIT,
        totalChunks: chunks.length,
        phase: 'merge',
        partials: partials,
        pending: pending,
        mergeDone: mergeDone,
        mergeTotal: workflowRunState.mergeTotal,
        updatedAt: new Date().toISOString()
      });
      renderAll();
    }

    workflowRunState.phase = 'inject';
    clearCheckpoint();
    renderAll();
    return pending[0];
  }

  function replaceNovelWorldbookEntries(previousEntries) {
    if (!window.__getWorldbookEntries__ || !window.__setWorldbookEntries__) return;
    var previousComments = [buildGateRuleEntry(state).comment];
    (previousEntries || []).forEach(function(entry) {
      previousComments.push(buildEntryComment(entry));
    });
    var currentEntries = window.__getWorldbookEntries__();
    var kept = currentEntries.filter(function(entry) {
      var comment = String(entry.comment || '');
      return previousComments.indexOf(comment) < 0 && !/^\[小说/.test(comment);
    });
    var nextEntries = [buildGateRuleEntry(state)].concat(state.generatedEntries.map(function(entry) {
      return buildWorldbookEntry(entry, state);
    }));
    window.__setWorldbookEntries__(kept.concat(nextEntries));
  }

  function applyActivationOnly() {
    if (!window.__getWorldbookEntries__ || !window.__setWorldbookEntries__) return;
    var commentsToControl = {};
    commentsToControl[buildGateRuleEntry(state).comment] = true;
    state.generatedEntries.forEach(function(entry) {
      commentsToControl[buildEntryComment(entry)] = isEntryUnlocked(entry, state);
    });
    var nextEntries = window.__getWorldbookEntries__().map(function(entry) {
      if (commentsToControl.hasOwnProperty(entry.comment)) {
        entry.enabled = commentsToControl[entry.comment];
      }
      return entry;
    });
    window.__setWorldbookEntries__(nextEntries);
  }

  function syncVariablesToMvu(message) {
    if (!window.__applyExternalVariableDesign__) throw new Error('MVU 变量桥接尚未就绪');
    var result = window.__applyExternalVariableDesign__({
      source: 'novel-workshop',
      message: message || '已从小说世界书工坊同步 MVU 变量节点',
      design: {
        summary: state.summary || '小说世界书门控变量',
        variables: mergeVariableBlueprint(state)
      }
    });
    return result;
  }

  function setStatus(text, color) {
    statusTextEl.textContent = text;
    statusTextEl.style.color = color || '#34d399';
  }

  function escapeHtml(text) {
    return String(text || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function escapeAttr(text) {
    return escapeHtml(text).replace(/'/g, '&#39;');
  }

  function handleTextFile(file) {
    if (!file) return;
    var reader = new FileReader();
    reader.onload = function(event) {
      importedFileText = String(event.target.result || '');
      importedFileMeta = {
        name: String(file.name || '未命名文件'),
        charCount: importedFileText.length
      };
      sourceFileEl.value = '';
      renderAll();
      setStatus('✅ 已载入文件：' + file.name + '，全文仅保留在内存中。', '#38bdf8');
    };
    reader.readAsText(file, 'utf-8');
  }

