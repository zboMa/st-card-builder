  var narrativeHintEl = document.getElementById('novelNarrativeHint');
  var entryBudgetEl = document.getElementById('novelEntryBudget');
  var chunkSizeEl = document.getElementById('novelChunkSize');
  var focusTagsEl = document.getElementById('novelFocusTags');
  var estimateBarEl = document.getElementById('novelEstimateBar');
  var workflowStepsEl = document.getElementById('novelWorkflowSteps');
  var statusTextEl = document.getElementById('novelStatusText');
  var statsBarEl = document.getElementById('novelStatsBar');
  var managerEl = document.getElementById('novelManager');
  var stageButtonsEl = document.getElementById('novelStageButtons');
  var flagListEl = document.getElementById('novelFlagList');
  var entityPreviewEl = document.getElementById('novelEntityPreview');
  var entityCountEl = document.getElementById('novelEntityCount');
  var summaryTextEl = document.getElementById('novelSummaryText');
  var btnGenerateEl = document.getElementById('btnNovelGenerate');
  var btnResetEl = document.getElementById('btnNovelReset');
  var btnSyncVariablesEl = document.getElementById('btnNovelSyncVariables');

  var state = createDefaultState();
  var suppressReload = false;
  var rawSaveTimer = 0;
  var importedFileText = '';
  var importedFileMeta = null;
  var workflowRunState = {
    phase: 'idle',
    extractionDone: 0,
    extractionTotal: 0,
    mergeDone: 0,
    mergeTotal: 0
  };

  function createDefaultState() {
    return {
      sourceText: '',
      contextText: '',
      gateMode: 'stage_flags',
      narrativeMode: 'story',
      entryBudget: 18,
      chunkCharLimit: DEFAULT_CHUNK_CHAR_LIMIT,
      focus: ['character', 'location', 'faction', 'rule'],
      summary: '',
      stageOrder: DEFAULT_STAGE_ORDER.slice(),
      currentStage: '公开',
      flags: [],
      entityIndex: [],
      generatedEntries: [],
      generatedVariables: [],
      generatedAt: '',
      lastFileName: ''
    };
  }

  function getRawStorageKey() {
    var draftId = window.__getCurrentDraftId__ ? window.__getCurrentDraftId__() : '';
    return RAW_STORAGE_PREFIX + (draftId || 'global');
  }

  function getCheckpointStorageKey() {
    var draftId = window.__getCurrentDraftId__ ? window.__getCurrentDraftId__() : '';
    return CHECKPOINT_PREFIX + (draftId || 'global');
  }

  function saveRawState() {
    try {
      localStorage.setItem(getRawStorageKey(), JSON.stringify({
        sourceText: state.sourceText,
        contextText: state.contextText,
        gateMode: state.gateMode,
        narrativeMode: state.narrativeMode,
        entryBudget: state.entryBudget,
        chunkCharLimit: state.chunkCharLimit,
        focus: state.focus
      }));
    } catch (err) {}
  }

  function clearRawState() {
    try { localStorage.removeItem(getRawStorageKey()); } catch (err) {}
  }

  function clearCheckpoint() {
    try { localStorage.removeItem(getCheckpointStorageKey()); } catch (err) {}
  }

  function saveCheckpoint(checkpoint) {
    try { localStorage.setItem(getCheckpointStorageKey(), JSON.stringify(checkpoint)); } catch (err) {}
  }

  function loadCheckpoint(signature) {
    try {
      var checkpoint = JSON.parse(localStorage.getItem(getCheckpointStorageKey()) || 'null');
      if (!checkpoint || checkpoint.signature !== signature) return null;
      if (!Array.isArray(checkpoint.partials)) return null;
      if (checkpoint.phase === 'merge' && !Array.isArray(checkpoint.pending)) checkpoint.phase = 'extract';
      return checkpoint;
    } catch (err) {
      return null;
    }
  }

  function scheduleRawStateSave() {
    clearTimeout(rawSaveTimer);
    rawSaveTimer = setTimeout(saveRawState, 350);
  }

  function loadRawState() {
    try {
      var raw = JSON.parse(localStorage.getItem(getRawStorageKey()) || 'null');
      if (!raw || typeof raw !== 'object') return;
      state.sourceText = String(raw.sourceText || '').trim();
      state.contextText = String(raw.contextText || '').trim();
      if (['stage_flags', 'stage_only', 'public_only'].indexOf(raw.gateMode) >= 0) state.gateMode = raw.gateMode;
      if (['story', 'lore_only'].indexOf(raw.narrativeMode) >= 0) state.narrativeMode = raw.narrativeMode;
      if (raw.entryBudget) state.entryBudget = Number(raw.entryBudget) || state.entryBudget;
      if (raw.chunkCharLimit) state.chunkCharLimit = Number(raw.chunkCharLimit) || state.chunkCharLimit;
      if (Array.isArray(raw.focus)) {
        state.focus = uniqueStrings(raw.focus).filter(function(id) {
          return FOCUS_OPTIONS.some(function(option) { return option.id === id; });
        });
        if (!state.focus.length) state.focus = ['character', 'location', 'faction', 'rule'];
      }
    } catch (err) {}
  }

  function cloneJSON(value) {
    return JSON.parse(JSON.stringify(value));
  }

  function uniqueStrings(list) {
    var seen = {};
    var out = [];
    (list || []).forEach(function(item) {
      var key = String(item || '').trim();
      if (!key || seen[key]) return;
      seen[key] = true;
      out.push(key);
    });
    return out;
  }

  function clampNumber(value, min, max, fallback) {
    var num = Number(value);
    if (!Number.isFinite(num)) num = fallback;
    return Math.max(min, Math.min(max, num));
  }

  function stableId(prefix, value, index) {
    var base = sanitizeSegment(value || (prefix + '_' + index));
    if (!/^[A-Za-z_\u4e00-\u9fa5]/.test(base)) base = prefix + '_' + base;
    return base || (prefix + '_' + index);
  }

  function hashString(value) {
    var text = String(value || '');
    var hash = 0;
    for (var i = 0; i < text.length; i++) {
      hash = ((hash << 5) - hash) + text.charCodeAt(i);
      hash |= 0;
    }
    return String(hash >>> 0);
  }

  function buildWorkflowSignature(source, chunks) {
    return hashString([
      source.length,
      hashString(source),
      Number(state.chunkCharLimit) || DEFAULT_CHUNK_CHAR_LIMIT,
      state.gateMode,
      state.narrativeMode,
      state.entryBudget,
      state.focus.join(','),
      hashString(state.contextText || ''),
      chunks.length
    ].join('|'));
  }

  function sanitizeSegment(value) {
    return String(value || '')
      .replace(/[^\u4e00-\u9fa5A-Za-z0-9_]+/g, '_')
      .replace(/^_+|_+$/g, '')
      .slice(0, 40) || 'flag';
  }

  function categoryLabel(category) {
    return CATEGORY_LABELS[String(category || '').toLowerCase()] || '条目';
  }

  function narrativeModeLabel(mode) {
    return mode === 'lore_only' ? '只做世界观' : '按剧情推进';
  }

  function buildNarrativeModeRules() {
    if (state.narrativeMode === 'lore_only') {
      return [
        '叙事模式规则：',
        '1. 当前任务只做世界观设定包，尽量剥离剧情先后顺序。',
        '2. 除非某个事件本身已经固化成世界规则、历史背景或长期关系变化，否则不要单独做事件条目。',
        '3. 优先保留稳定信息：人物身份、阵营立场、地点性质、力量体系、社会规则、关键物品用途。',
        '4. 条目正文避免写“后来”“之后”“这一阶段”等时间线表达，改写成静态设定描述。',
        '5. 若原文包含阶段性秘密，只保留不剧透的稳定世界观部分；剧透部分宁可省略也不要强行编排时间线。'
      ].join('\n');
    }
    return [
      '叙事模式规则：',
      '1. 当前任务按剧情推进整理知识包，可以保留会影响扮演的阶段性关系变化、重要真相揭露和关键事件后果。',
      '2. 事件信息不是流水账，而是“到这个阶段后人物/势力/地点发生了什么变化”。',
      '3. 如果同一实体在不同阶段认知不同，可以拆成公开、前期、中期等层次条目。',
      '4. 条目正文仍然要像世界书，不要写章节复述；重点写状态变化、认知边界和行为约束。'
    ].join('\n');
  }

  function getStageIndex(stageOrder, stage) {
    var idx = stageOrder.indexOf(stage);
    return idx >= 0 ? idx : 0;
  }

  function stageOptionsForMode(mode, incoming) {
    if (mode === 'public_only') return ['公开'];
    if (Array.isArray(incoming) && incoming.length) return uniqueStrings(incoming);
    return DEFAULT_STAGE_ORDER.slice();
  }

  function buildEntryComment(entry) {
    var name = String(entry.name || '未命名').trim();
    var stage = String(entry.stage || '公开').trim();
    var aspect = String(entry.aspect || '').trim();
    var label = '[小说' + categoryLabel(entry.category) + ']' + '[' + stage + '] ' + name;
    if (aspect && aspect !== '基础设定' && aspect !== '公开资料') label += '·' + aspect;
    return label;
  }

  function normalizeFlags(flags, prevFlags) {
    var prevMap = {};
    (prevFlags || []).forEach(function(flag) { prevMap[flag.id] = flag; });
    return (flags || []).map(function(flag, index) {
      var id = stableId('flag', flag.id || flag.key || flag.label, index);
      var prev = prevMap[id];
      return {
        id: id,
        label: String(flag.label || flag.name || id).trim(),
        description: String(flag.description || flag.desc || '').trim(),
        value: prev ? !!prev.value : flag.default === true
      };
    }).filter(function(flag, index, list) {
      return list.findIndex(function(item) { return item.id === flag.id; }) === index;
    }).slice(0, 16);
  }

  function normalizeEntries(entries, stageOrder) {
    return (entries || []).map(function(entry, index) {
      var stage = stageOrder.indexOf(entry.stage) >= 0 ? entry.stage : stageOrder[0];
      var name = String(entry.name || entry.title || '未命名条目').trim();
      var category = String(entry.category || 'rule').toLowerCase();
      var strategy = String(entry.strategy || '').toLowerCase();
      if (['constant', 'selective'].indexOf(strategy) < 0) strategy = category === 'rule' ? 'constant' : 'selective';
      return {
        id: stableId('entry', entry.id || name, index),
        entityId: stableId('entity', entry.entity_id || entry.entityId || name, index),
        category: category,
        name: name,
        aspect: String(entry.aspect || entry.slot || '').trim(),
        content: String(entry.content || '').trim(),
        keys: uniqueStrings((entry.keys || []).concat(entry.aliases || [], entry.name ? [entry.name] : [])),
        stage: stage,
        requiredFlags: uniqueStrings(entry.required_flags || entry.requiredFlags || []).map(sanitizeSegment),
        strategy: strategy,
        priority: clampNumber(entry.priority, 100, 1000, 700)
      };
    }).filter(function(entry) {
      return entry.name && entry.content;
    }).filter(function(entry, index, list) {
      var key = [entry.entityId, entry.category, entry.stage, entry.aspect || entry.name].join('|');
      return list.findIndex(function(item) {
        return [item.entityId, item.category, item.stage, item.aspect || item.name].join('|') === key;
      }) === index;
    });
  }

  function normalizeEntityIndex(entityIndex) {
    return (entityIndex || []).map(function(entity, index) {
      var name = String(entity.name || '未命名实体').trim();
      return {
        id: stableId('entity', entity.id || name, index),
        name: name,
        category: String(entity.category || 'character').toLowerCase(),
        aliases: uniqueStrings(entity.aliases || []),
        summary: String(entity.public_summary || entity.summary || '').trim()
      };
    }).filter(function(entity) {
      return entity.id && entity.name;
    }).filter(function(entity, index, list) {
      return list.findIndex(function(item) { return item.id === entity.id || item.name === entity.name; }) === index;
    });
  }

  function normalizeVariables(vars) {
    return (vars || []).map(function(v) {
      var copy = cloneJSON(v || {});
      if (!copy.path) copy.path = copy.name || '';
      return copy;
    }).filter(function(v) {
      return String(v.path || '').trim();
    });
  }

  function normalizePackage(pkg, prevState) {
    var stageOrder = stageOptionsForMode(prevState.gateMode, pkg.stage_order || pkg.stageOrder);
    var flags = prevState.gateMode === 'stage_flags'
      ? normalizeFlags(pkg.reveal_flags || pkg.revealFlags || [], prevState.flags)
      : [];
    var currentStage = stageOrder.indexOf(prevState.currentStage) >= 0 ? prevState.currentStage : stageOrder[0];
    var entries = normalizeEntries(pkg.entries || [], stageOrder)
      .sort(function(a, b) { return b.priority - a.priority; });
    return {
      summary: String(pkg.summary || '已生成小说世界书包').trim(),
      stageOrder: stageOrder,
      currentStage: currentStage,
      flags: flags,
      entityIndex: normalizeEntityIndex(pkg.entity_index || pkg.entityIndex || []),
      generatedEntries: entries,
      generatedVariables: normalizeVariables(pkg.variables || []),
      generatedAt: new Date().toLocaleString('zh-CN', { hour12: false })
    };
  }

  function combinePartialPackages(partials) {
    var combined = {
      summary: '正在分片抽取小说世界书包，已保留可用的中间结果。',
      stage_order: state.stageOrder.slice(),
      reveal_flags: [],
      entity_index: [],
      variables: [],
      entries: []
    };
    (partials || []).forEach(function(pkg) {
      if (!pkg || typeof pkg !== 'object') return;
      if (pkg.summary && combined.summary.indexOf('已处理') < 0) combined.summary = String(pkg.summary || combined.summary).trim();
      combined.stage_order = uniqueStrings(combined.stage_order.concat(pkg.stage_order || pkg.stageOrder || []));
      combined.reveal_flags = combined.reveal_flags.concat(pkg.reveal_flags || pkg.revealFlags || []);
      combined.entity_index = combined.entity_index.concat(pkg.entity_index || pkg.entityIndex || []);
      combined.variables = combined.variables.concat(pkg.variables || []);
      combined.entries = combined.entries.concat(pkg.entries || []);
    });
    return combined;
  }

  function applyWorkshopPackageSnapshot(pkg, previousEntries, options) {
    var opts = options || {};
    var normalized = normalizePackage(pkg, state);
    state.summary = opts.summary || normalized.summary;
    state.stageOrder = normalized.stageOrder;
    state.currentStage = normalized.currentStage;
    state.flags = normalized.flags;
    state.entityIndex = normalized.entityIndex;
    state.generatedEntries = normalized.generatedEntries;
    state.generatedVariables = normalized.generatedVariables;
    state.generatedAt = normalized.generatedAt;
    persistState();
    replaceNovelWorldbookEntries(previousEntries);
    applyActivationOnly();
    renderAll();
    return normalized;
  }

  function writePartialSnapshot(partials, previousEntries, processedCount, totalCount) {
    if (!partials.length) return;
    var snapshot = combinePartialPackages(partials);
    applyWorkshopPackageSnapshot(snapshot, previousEntries, {
      summary: '分片处理中：已处理 ' + processedCount + ' / ' + totalCount + ' 片，当前世界书为临时快照。'
    });
  }

  function buildGateRuleEntry(workshop) {
    var lines = [
      '你正在使用小说世界书工坊导出的知识包。',
      '只允许依据当前已解锁的资料继续扮演，不得主动补完或提前暴露未解锁的剧情真相。',
      '当前阶段：' + workshop.currentStage + '。'
    ];
    if (workshop.flags.length) {
      lines.push('已开启的揭露标记：' + workshop.flags.filter(function(flag) { return flag.value; }).map(function(flag) { return flag.label; }).join('、') + '。');
      lines.push('未开启的揭露标记保持未知，不得自行推断。');
    }
    return {
      comment: '===小说世界书：阅读边界===',
      content: lines.join('\n'),
      keys: [],
      strategy: 'constant',
      position: 4,
      depth: 1,
      role: 0,
      order: 980,
      prob: 100,
      enabled: true
    };
  }

  function isEntryUnlocked(entry, workshop) {
    var currentStageIndex = getStageIndex(workshop.stageOrder, workshop.currentStage);
    var entryStageIndex = getStageIndex(workshop.stageOrder, entry.stage);
    if (entryStageIndex > currentStageIndex) return false;
    if (!entry.requiredFlags.length) return true;
    var flagMap = {};
    workshop.flags.forEach(function(flag) { flagMap[flag.id] = !!flag.value; });
    return entry.requiredFlags.every(function(flagId) { return flagMap[flagId] === true; });
  }

  function buildWorldbookEntry(entry, workshop) {
    var strategy = entry.strategy;
    if (!strategy) strategy = entry.category === 'rule' ? 'constant' : 'selective';
    return {
      comment: buildEntryComment(entry),
      content: entry.content,
      keys: strategy === 'constant' ? [] : uniqueStrings(entry.keys.length ? entry.keys : [entry.name]),
      strategy: strategy,
      position: 4,
      depth: entry.category === 'rule' ? 2 : 4,
      role: 0,
      order: entry.priority,
      prob: 100,
      enabled: isEntryUnlocked(entry, workshop)
    };
  }

  function mergeVariableBlueprint(workshop) {
    var variables = [];
    var stageOptions = workshop.stageOrder.slice();
    if (stageOptions.length > 1) {
      variables.push({
        path: '世界书控制.阶段',
        type: 'enum',
        options: stageOptions,
        default: workshop.currentStage,
        description: '小说世界书当前允许暴露到哪一层知识阶段',
        check: ['仅在阅读进度推进、手动解锁新阶段或导入新版知识包时更新']
      });
    } else {
      variables.push({
        path: '世界书控制.阶段',
        type: 'string',
        default: workshop.currentStage,
        description: '小说世界书当前阶段',
        check: ['仅在重新导入或手动切换时更新']
      });
    }

    variables.push({
      path: '世界书控制.摘要',
      type: 'string',
      default: workshop.summary || '暂无摘要',
      description: '当前导入的小说知识包摘要',
      check: ['仅在重建小说世界书知识包时更新']
    });

    variables.push({
      path: '世界书控制.实体数',
      type: 'number',
      default: workshop.entityIndex.length,
      min: 0,
      description: '当前知识包里的实体数量',
      check: ['仅在导入新知识包后更新']
    });

    workshop.flags.forEach(function(flag) {
      variables.push({
        path: '世界书控制.标记.' + sanitizeSegment(flag.id),
        type: 'boolean',
        default: !!flag.value,
        description: flag.description || ('小说揭露标记：' + flag.label),
        check: ['仅当对应真相、关系或设定在剧情内被正式揭露时切换为 true']
      });
    });

    return normalizeVariables(variables.concat(workshop.generatedVariables || []));
  }

  function getWorkshopStateFromExtension() {
    if (!window.__getCardExtension__) return null;
    return window.__getCardExtension__(STORAGE_KEY) || null;
  }

  function persistState() {
    if (!window.__setCardExtension__) return;
    suppressReload = true;
    window.__setCardExtension__(STORAGE_KEY, cloneJSON({
      summary: state.summary,
      stageOrder: state.stageOrder,
      currentStage: state.currentStage,
      flags: state.flags,
      entityIndex: state.entityIndex,
      generatedEntries: state.generatedEntries,
      generatedVariables: state.generatedVariables,
      generatedAt: state.generatedAt
    }));
    suppressReload = false;
    saveRawState();
  }

  function loadState(data) {
    var next = createDefaultState();
    if (data && typeof data === 'object') {
      next.summary = String(data.summary || '').trim();
      next.stageOrder = stageOptionsForMode(next.gateMode, data.stageOrder);
      next.currentStage = next.stageOrder.indexOf(data.currentStage) >= 0 ? data.currentStage : next.stageOrder[0];
      next.flags = normalizeFlags(data.flags || [], []);
      next.entityIndex = normalizeEntityIndex(data.entityIndex || []);
      next.generatedEntries = normalizeEntries(data.generatedEntries || [], next.stageOrder);
      next.generatedVariables = normalizeVariables(data.generatedVariables || []);
      next.generatedAt = String(data.generatedAt || '').trim();
    }
    state = next;
    loadRawState();
    state.stageOrder = stageOptionsForMode(state.gateMode, state.stageOrder);
    if (state.stageOrder.indexOf(state.currentStage) < 0) state.currentStage = state.stageOrder[0];
    renderAll();
  }

  function loadFromExtension() {
    if (suppressReload) return;
    var data = getWorkshopStateFromExtension();
    loadState(data);
  }

  function renderStats() {
    var chips = [];
    if (state.generatedEntries.length) chips.push('📖 条目 ' + state.generatedEntries.length);
    if (state.entityIndex.length) chips.push('🧬 实体 ' + state.entityIndex.length);
    if (state.flags.length) chips.push('🔐 标记 ' + state.flags.length);
    if (state.generatedVariables.length) chips.push('🧠 AI 变量蓝图 ' + state.generatedVariables.length);
    if (!chips.length) chips.push('等待导入文本');
    statsBarEl.innerHTML = chips.map(function(label) {
      return '<span class="novel-stat-chip">' + escapeHtml(label) + '</span>';
    }).join('');
  }

  function renderFocusTags() {
    focusTagsEl.innerHTML = FOCUS_OPTIONS.map(function(option) {
      var active = state.focus.indexOf(option.id) >= 0;
      return '<button type="button" class="novel-focus-tag' + (active ? ' active' : '') + '" data-focus="' + option.id + '">' + option.label + '</button>';
    }).join('');
    focusTagsEl.querySelectorAll('[data-focus]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var id = btn.getAttribute('data-focus');
        var idx = state.focus.indexOf(id);
        if (idx >= 0) state.focus.splice(idx, 1);
        else state.focus.push(id);
        if (!state.focus.length) state.focus = ['character'];
        persistState();
        renderAll();
      });
    });
  }

  function renderManager() {
    var hasPackage = state.generatedEntries.length > 0;
    managerEl.style.display = hasPackage ? 'block' : 'none';
    if (!hasPackage) return;

    summaryTextEl.textContent = state.summary || '已生成小说世界书包。';
    entityCountEl.textContent = state.entityIndex.length + ' 个实体';

    stageButtonsEl.innerHTML = state.stageOrder.map(function(stage) {
      return '<button type="button" class="novel-stage-btn' + (stage === state.currentStage ? ' active' : '') + '" data-stage="' + escapeAttr(stage) + '">' + escapeHtml(stage) + '</button>';
    }).join('');
    stageButtonsEl.querySelectorAll('[data-stage]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        state.currentStage = btn.getAttribute('data-stage');
        persistState();
        applyActivationOnly();
        renderAll();
      });
    });

    if (!state.flags.length) {
      flagListEl.innerHTML = '<div class="novel-flag-empty">当前工坊没有额外揭露标记，阶段本身就是唯一门控。</div>';
    } else {
      flagListEl.innerHTML = state.flags.map(function(flag) {
        return '<label class="novel-flag-item">' +
          '<input type="checkbox" data-flag-id="' + escapeAttr(flag.id) + '"' + (flag.value ? ' checked' : '') + ' />' +
          '<div class="novel-flag-copy">' +
            '<strong>' + escapeHtml(flag.label) + '</strong>' +
            '<span>' + escapeHtml(flag.description || '达到条件后才允许解锁这组资料。') + '</span>' +
          '</div>' +
        '</label>';
      }).join('');
      flagListEl.querySelectorAll('[data-flag-id]').forEach(function(input) {
        input.addEventListener('change', function() {
          var id = input.getAttribute('data-flag-id');
          state.flags.forEach(function(flag) {
            if (flag.id === id) flag.value = input.checked;
          });
          persistState();
          applyActivationOnly();
          renderAll();
        });
      });
    }

    if (!state.entityIndex.length) {
      entityPreviewEl.innerHTML = '<div class="novel-entity-empty">当前还没有实体索引。</div>';
    } else {
      entityPreviewEl.innerHTML = state.entityIndex.slice(0, 12).map(function(entity) {
        return '<article class="novel-entity-card">' +
          '<span class="novel-entity-meta">' + escapeHtml(categoryLabel(entity.category)) + '</span>' +
          '<strong>' + escapeHtml(entity.name) + '</strong>' +
          '<p>' + escapeHtml(entity.summary || '暂无摘要') + '</p>' +
        '</article>';
      }).join('');
    }
  }

  function formatNumber(num) {
    return Number(num || 0).toLocaleString('zh-CN');
  }

  function estimateTokenCount(text) {
    var value = String(text || '');
    if (!value) return 0;
    var cjkCount = (value.match(/[\u3400-\u9fff]/g) || []).length;
    var otherCount = Math.max(0, value.length - cjkCount);
    return Math.ceil(cjkCount * 1.35 + otherCount / 4);
  }

  function getCombinedSourceText() {
    var parts = [];
    if (importedFileText) parts.push(importedFileText);
    if (state.sourceText) parts.push(state.sourceText);
    return parts.join('\n\n').trim();
  }

  function splitTextIntoChunks(text, maxChars) {
    var clean = String(text || '').trim();
    if (!clean) return [];
    if (clean.length <= maxChars) return [clean];

    var chunks = [];
    var current = '';
    var parts = clean
      .replace(/\r\n/g, '\n')
      .split(/\n{2,}|(?=第[^\n]{1,20}[章节卷回部篇])|(?=chapter\s+\d+)/i)
      .map(function(part) { return String(part || '').trim(); })
      .filter(Boolean);

    parts.forEach(function(part) {
      if (part.length > maxChars) {
        if (current) {
          chunks.push(current.trim());
          current = '';
        }
        for (var start = 0; start < part.length; start += maxChars) {
          chunks.push(part.slice(start, start + maxChars));
        }
        return;
      }
      if (!current) {
        current = part;
        return;
      }
      if ((current.length + 2 + part.length) <= maxChars) {
        current += '\n\n' + part;
      } else {
        chunks.push(current.trim());
        current = part;
      }
    });
    if (current) chunks.push(current.trim());
    return chunks.filter(Boolean);
  }

  function countMergeCalls(itemCount, batchSize) {
    var calls = 0;
    var current = itemCount;
    while (current > 1) {
      current = Math.ceil(current / batchSize);
      calls += current;
    }
    return calls;
  }

  function countSequentialMergeCalls(itemCount) {
    return Math.max(0, Number(itemCount || 0) - 1);
  }

  function buildCallEstimate() {
    var source = getCombinedSourceText();
    var sourceChars = source.length;
    if (!sourceChars) {
      return {
        sourceChars: 0,
        chunkCount: 0,
        mergeCalls: 0,
        totalCalls: 0,
        chunkSize: Number(state.chunkCharLimit) || DEFAULT_CHUNK_CHAR_LIMIT
      };
    }
    var chunkLimit = Number(state.chunkCharLimit) || DEFAULT_CHUNK_CHAR_LIMIT;
    var chunks = splitTextIntoChunks(source, chunkLimit);
    var chunkCount = Math.max(1, chunks.length);
    var mergeCalls = chunkCount > 1 ? Math.min(
      countMergeCalls(chunkCount, MERGE_BATCH_SIZE),
      countSequentialMergeCalls(chunkCount)
    ) : 0;
    return {
      sourceChars: sourceChars,
      chunkCount: chunkCount,
      mergeCalls: mergeCalls,
      totalCalls: chunkCount + mergeCalls,
      chunkSize: chunkLimit
    };
  }

  function renderCallRisk(estimate) {
    if (!estimate.totalCalls) return '先导入文件或补一段摘录，这里才会给出调用预估。';
    if (estimate.totalCalls > MAX_WORKFLOW_CALLS) {
      return '预计调用次数过高，发布版会阻止直接运行。建议按卷/章节分批导入，或提高单次分片字数。';
    }
    if (estimate.totalCalls > 40) {
      return '调用次数偏高，建议先用较小范围试跑，确认模型质量后再处理完整文本。';
    }
    return '调用量处于可控范围，可以生成。';
  }

  function renderFileState() {
    if (importedFileMeta && importedFileText) {
      fileHintEl.textContent = '已载入内存文件：' + importedFileMeta.name;
      fileSummaryEl.style.display = 'block';
      fileSummaryEl.innerHTML =
        '<strong>' + escapeHtml(importedFileMeta.name) + '</strong>' +
        '<span>已加载 ' + escapeHtml(formatNumber(importedFileMeta.charCount)) + ' 字符到内存。生成时会使用全文，但不会把全文渲染到前端输入框里。</span>';
      btnClearFileEl.style.display = 'inline-flex';
      return;
    }
    fileHintEl.textContent = state.sourceText ? '当前仅使用手动摘录 / 摘要' : '支持 txt / md / json';
    fileSummaryEl.style.display = 'none';
    fileSummaryEl.innerHTML = '';
    btnClearFileEl.style.display = 'none';
  }

  function renderEstimate() {
    var estimate = buildCallEstimate();
    estimateBarEl.innerHTML = [
      '<div class="novel-estimate-card is-accent"><strong>' + escapeHtml(estimate.totalCalls ? (estimate.totalCalls + ' 次') : '0 次') + '</strong><span>低调用模式预估总调用次数</span></div>',
      '<div class="novel-estimate-card"><strong>' + escapeHtml(estimate.chunkCount ? (estimate.chunkCount + ' 片') : '未分片') + '</strong><span>按每片约 ' + escapeHtml(formatNumber(estimate.chunkSize)) + ' 字预切分</span></div>',
      '<div class="novel-estimate-card"><strong>' + escapeHtml(estimate.sourceChars ? (formatNumber(estimate.sourceChars) + ' 字') : '未载入') + '</strong><span>导入全文与手动摘录合计字符数</span></div>'
    ].join('');

    var steps = [
      {
        title: '准备资料',
        detail: estimate.sourceChars ? ('已就绪 ' + formatNumber(estimate.sourceChars) + ' 字。' + renderCallRisk(estimate)) : renderCallRisk(estimate)
      },
      {
        title: '分片抽取',
        detail: estimate.chunkCount ? ('预计调用 ' + formatNumber(estimate.chunkCount) + ' 次 AI，把长文本拆成片段抽人物、地点、势力与规则。') : '暂无文本，暂不需要分片抽取。'
      },
      {
        title: '合并去重',
        detail: estimate.mergeCalls ? ('预计再调用 ' + formatNumber(estimate.mergeCalls) + ' 次 AI，把重复实体并回同一知识包。') : '当前文本量可直接整合，不需要额外合并。'
      },
      {
        title: '注入世界书',
        detail: '最后把整合结果写进世界书，并同步真正可管理的 MVU 控制变量。'
      }
    ];

    workflowStepsEl.innerHTML = steps.map(function(step, index) {
      var classes = ['novel-workflow-step'];
      if (workflowRunState.phase === 'idle') {
        if (index === 0 && estimate.sourceChars) classes.push('is-active');
      } else {
        if ((workflowRunState.phase === 'extract' && index === 1) ||
            (workflowRunState.phase === 'merge' && index === 2) ||
            (workflowRunState.phase === 'inject' && index === 3)) classes.push('is-active');
        if ((workflowRunState.phase === 'extract' || workflowRunState.phase === 'merge' || workflowRunState.phase === 'inject' || workflowRunState.phase === 'done') && index === 0) classes.push('is-done');
        if ((workflowRunState.phase === 'merge' || workflowRunState.phase === 'inject' || workflowRunState.phase === 'done') && index === 1) classes.push('is-done');
        if ((workflowRunState.phase === 'inject' || workflowRunState.phase === 'done') && index === 2) classes.push('is-done');
        if (workflowRunState.phase === 'done' && index === 3) classes.push('is-done');
      }
      var detail = step.detail;
      if (index === 1 && workflowRunState.phase === 'extract' && workflowRunState.extractionTotal) {
        detail = '正在处理第 ' + formatNumber(workflowRunState.extractionDone + 1) + ' / ' + formatNumber(workflowRunState.extractionTotal) + ' 片。';
      }
      if (index === 2 && workflowRunState.phase === 'merge' && workflowRunState.mergeTotal) {
        detail = '正在执行第 ' + formatNumber(workflowRunState.mergeDone + 1) + ' / ' + formatNumber(workflowRunState.mergeTotal) + ' 次合并。';
      }
      if (index === 3 && workflowRunState.phase === 'inject') {
        detail = '正在写入世界书条目并同步 MVU 管理变量。';
      }
      return '<div class="' + classes.join(' ') + '">' +
        '<div class="novel-workflow-index">' + (index + 1) + '</div>' +
        '<div class="novel-workflow-copy"><strong>' + escapeHtml(step.title) + '</strong><span>' + escapeHtml(detail) + '</span></div>' +
      '</div>';
    }).join('');
  }

  function renderNarrativeHint() {
    if (!narrativeHintEl) return;
    narrativeHintEl.textContent = state.narrativeMode === 'lore_only'
      ? '只做世界观：尽量去掉剧情时间线，不强调先后推进，优先保留稳定设定。'
      : '按剧情推进：允许保留阶段性关系变化、关键事件后果和阅读顺序。';
  }

  function renderAll() {
    sourceTextEl.value = state.sourceText;
    contextTextEl.value = state.contextText;
    gateModeEl.value = state.gateMode;
    narrativeModeEl.value = state.narrativeMode;
    entryBudgetEl.value = String(state.entryBudget);
    chunkSizeEl.value = String(state.chunkCharLimit || DEFAULT_CHUNK_CHAR_LIMIT);
    renderFileState();
    renderStats();
    renderEstimate();
    renderNarrativeHint();
    renderFocusTags();
    renderManager();
  }

  function syncInputsIntoState() {
    state.sourceText = sourceTextEl.value.trim();
    state.contextText = contextTextEl.value.trim();
    state.gateMode = gateModeEl.value;
    state.narrativeMode = narrativeModeEl.value === 'lore_only' ? 'lore_only' : 'story';
    state.entryBudget = Number(entryBudgetEl.value) || 18;
    state.chunkCharLimit = Number(chunkSizeEl.value) || DEFAULT_CHUNK_CHAR_LIMIT;
    state.stageOrder = stageOptionsForMode(state.gateMode, state.stageOrder);
    if (state.stageOrder.indexOf(state.currentStage) < 0) state.currentStage = state.stageOrder[0];
    if (state.gateMode !== 'stage_flags') state.flags = [];
  }

  function buildExistingPackageSummary() {
    return {
      entity_index: state.entityIndex.map(function(entity) {
        return {
          id: entity.id,
          name: entity.name,
          category: entity.category,
          aliases: entity.aliases,
          public_summary: entity.summary
        };
      }),
      entries: state.generatedEntries.map(function(entry) {
        return {
          id: entry.id,
          entity_id: entry.entityId,
          category: entry.category,
          name: entry.name,
          aspect: entry.aspect,
          stage: entry.stage,
          required_flags: entry.requiredFlags
        };
      })
    };
  }

  function buildPromptEnvelope(lines) {
    return lines.join('\n');
  }

  function buildFinalOutputFormat(budgetHint) {
    return [
      '{',
      '  "summary": "一句中文摘要，80字以内",',
      '  "stage_order": ["公开","前期","中期","后期","终局"],',
      '  "reveal_flags": [',
      '    { "id": "flag_id", "label": "揭露标记名", "description": "何时开启", "default": false }',
      '  ],',
      '  "entity_index": [',
      '    { "id": "char_linmo", "name": "林墨", "category": "character", "aliases": ["墨哥"], "public_summary": "公开可知的身份与定位" }',
      '  ],',
      '  "variables": [',
      '    { "path": "世界书控制.阶段", "type": "enum", "options": ["公开","前期","中期","后期","终局"], "default": "公开", "description": "当前可见阶段", "check": ["仅在阅读推进或手动解锁时更新"] }',
      '  ],',
      '  "entries": [',
      '    {',
      '      "id": "char_linmo_public",',
      '      "entity_id": "char_linmo",',
      '      "category": "character",',
      '      "name": "林墨",',
      '      "aspect": "公开资料",',
      '      "content": "适合直接注入世界书的正文",',
      '      "keys": ["林墨","墨哥","林先生","调查员林墨","林墨医生"],',
      '      "stage": "公开",',
      '      "required_flags": [],',
      '      "strategy": "selective",',
      '      "priority": 820',
      '    }',
      '  ]',
      '}',
      '',
      '要求：',
      '1. entity_index 必须是去重后的实体索引。',
      '2. entries 是整合后的完整快照，而不是增量补丁。',
      '3. 如果某个实体已经在现有知识包里出现，优先复用它的 id。',
      '4. rule 类条目适合 constant，其它条目优先 selective。',
      '5. 条目内容禁止写“根据剧情可能”“也许”等模糊措辞。',
      '6. 如果门控模式不是 stage_flags，就让 reveal_flags 为空数组。',
      '7. 不要为了压缩数量而删除有效条目；只删除明显重复、空泛或无法用于世界书触发的条目。' + (budgetHint ? '当前数字只作为单次抽取密度参考：' + budgetHint + '。' : ''),
      '8. keys 和 comment 只能使用原文中的专有名词或别名，不要写 {{char}}、{{user}} 等宏。',
      '8.1 selective 条目的 keys 要尽量充足：人物条目优先给 4-8 个姓名、别名、称号、身份称呼、关系称呼；地点/势力/物品条目优先给 3-6 个全称、简称、别称、相关地名或组织名。',
      '8.2 keys 不要只写一个名称；除非原文确实没有别名，否则至少给 3 个可触发词。不要编造原文没有依据的现代网络梗或泛词。',
      '9. content 可以自然使用 SillyTavern 宏，但不要为了使用宏刻意插入 {{char}} 或 {{user}}；专有名词、地名、组织名不要宏化。',
      '10. id、entity_id、required_flags 只能使用稳定短标识，不要包含空格、标点或宏。'
    ].join('\n');
  }

  function buildExtractionRules() {
    return [
      '抽取规则：',
      '1. 优先保留与角色扮演直接相关的信息：人物关系、行事准则、地点规则、势力立场、关键物品。',
      '2. 事件流水账只在会影响当前扮演或触发世界书时保留，否则并入摘要。',
      '3. 公开信息和剧透信息必须分层；不确定是否剧透时放到更晚阶段。',
      '4. 不要把同一实体拆成多个近似实体；同名、别名、称号应合并。',
      '5. 条目正文要短而密，适合直接放入 SillyTavern 世界书。',
      '6. 为每个 selective 条目整理更多触发词：原名、别名、称号、身份、关系称呼、地点简称、势力简称、关键物品名都可以进入 keys。'
    ].join('\n');
  }

  function buildDirectPrompt(sourceBody) {
    var gateMode = state.gateMode;
    var allowedCategories = state.focus.map(categoryLabel).join('、');
    var stageGuide = gateMode === 'public_only'
      ? '只允许输出公开资料，不要设计任何揭露标记。'
      : gateMode === 'stage_only'
        ? '可以按阶段拆条目，但不要设计额外揭露标记。'
        : '可以同时使用阶段与揭露标记；揭露标记只在真正需要时创建。';

    return {
      system: [
        '你是小说世界书架构师，负责把小说资料整理成可管理的 SillyTavern 世界书工坊包。',
        '你的目标是输出一个“整合后的快照”，不是追加式聊天回答。',
        '必须避免重复人物、重复地点、重复势力；如果当前文本是在补充旧实体，请复用已有 entity_id，并把新增信息整合进同一实体。',
        '如果信息是否会剧透不确定，优先把它放在更晚的阶段或需要揭露标记的条目里。',
        '条目内容要适合放入世界书：短而密，强调身份、行为准则、关系、用途与触发关键词。',
        '不要输出章节复述；只保留能让角色卡稳定扮演的设定与约束。',
        '只输出严格 JSON 对象，不要包裹 markdown。'
      ].join('\n'),
      user: [
        '【整理模式】' + narrativeModeLabel(state.narrativeMode),
        '【门控模式】' + gateMode,
        '【抽取重点】' + allowedCategories,
        '【条目预算】最多 ' + state.entryBudget + ' 条',
        '【门控要求】' + stageGuide,
        '',
        buildExtractionRules(),
        '',
        buildNarrativeModeRules(),
        '',
        '【现有知识包摘要】',
        JSON.stringify(buildExistingPackageSummary(), null, 2),
        '',
        '【角色卡当前名称】' + (document.getElementById('charName') ? document.getElementById('charName').value.trim() : ''),
        '【世界书当前名称】' + (document.getElementById('wbName') ? document.getElementById('wbName').value.trim() : ''),
        '',
        '【补充说明】',
        state.contextText || '无',
        '',
        '【原始资料】',
        sourceBody || '无',
        '',
        '【输出格式】',
        buildFinalOutputFormat(state.entryBudget)
      ].join('\n')
    };
