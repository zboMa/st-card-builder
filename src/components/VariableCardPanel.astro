---
---
<div class="panel varcard-panel">
  <div id="vcCorruptionGap" class="vc-corruption-gap" hidden role="status">
    <strong>恶堕进度缺失</strong>
    <span id="vcCorruptionGapMsg">已启用恶堕，但 MVU 尚无「恶堕进度」变量。可用「从卡推定变量」勾选补齐，或到状态栏重新生成。</span>
    <button type="button" class="btn btn-ghost adult-btn-compact vc-gap-action" id="vcGapInferBtn">从卡推定补齐</button>
  </div>

  <div class="vc-node-workbench">
    <div class="vc-workbench-head">
      <div>
        <h2>MVU 变量节点</h2>
        <!-- 整套生成在状态栏；本页负责链路与变量查看/编辑 -->
        <p>节点编排与变量查看/编辑。整套变量请在「状态栏」生成并覆盖写入；也可
          <button type="button" class="btn btn-ghost adult-btn-compact" id="btnVcInfer">从卡推定变量</button>
          规则合并。</p>
      </div>
      <div class="vc-workbench-meta">
        <span class="vc-mode-pill">手动链路模式</span>
        <span id="vcStatus" class="vc-status">自动同步角色卡中的 MVU…</span>
      </div>
    </div>

    <div id="vcInferPanel" class="vc-infer-panel" hidden>
      <div class="vc-infer-head">
        <strong>从卡推定 · 候选变量</strong>
        <span id="vcInferCount" class="vc-infer-count">0</span>
        <div class="vc-infer-head-actions">
          <button type="button" class="btn btn-ghost btn-sm" id="vcInferSelectAll">全选新增</button>
          <button type="button" class="btn btn-ghost btn-sm" id="vcInferSelectNone">全不选</button>
          <button type="button" class="btn btn-ghost btn-sm" id="vcInferCancel">关闭</button>
        </div>
      </div>
      <p class="vc-infer-tip">勾选后合并进 <code>zmer_mvu_design</code>（已有路径默认不勾）。不覆盖整套 AI 生成，仅 upsert。</p>
      <div id="vcInferList" class="vc-infer-list"></div>
      <div class="vc-infer-actions">
        <button type="button" class="btn" id="vcInferApply">应用合并</button>
        <button type="button" class="btn btn-primary" id="vcInferApplyInject">应用并注入</button>
      </div>
    </div>

    <div class="vc-node-canvas" id="vcNodeCanvas">
      <div class="vc-graph-toolbar">
        <button type="button" class="vc-graph-btn" id="vcZoomOut" title="缩小">−</button>
        <button type="button" class="vc-graph-btn" id="vcZoomReset" title="适应画布">适应</button>
        <button type="button" class="vc-graph-btn" id="vcZoomIn" title="放大">+</button>
        <button type="button" class="vc-graph-btn vc-graph-btn-arrange" id="vcGraphArrange" title="一键整理节点">整理</button>
        <button type="button" class="vc-graph-btn" id="vcGraphExpand" title="展开编辑">⛶</button>
        <span class="vc-graph-hint">拖节点移动，拖圆点连线，滚轮缩放</span>
      </div>

      <div class="vc-graph-viewport" id="vcGraphViewport">
        <div class="vc-graph-space" id="vcGraphSpace">
          <svg class="vc-node-lines" id="vcGraphSvg" viewBox="0 0 1900 980" preserveAspectRatio="none" aria-hidden="true">
            <g id="vcGraphWires"></g>
            <path class="vc-wire vc-wire-temp" id="vcTempWire" d="" />
          </svg>

      <section class="vc-node vc-flow-node vc-flow-input" data-node="user-message" style="left:48px; top:120px;">
        <div class="vc-node-head" data-drag-handle>
          <span class="vc-node-title">用户发消息</span>
          <span class="vc-port vc-port-out" data-port="user-message:out" data-kind="out"></span>
        </div>
        <p class="vc-node-desc">本轮输入进入 SillyTavern 生成流程。</p>
      </section>

      <section class="vc-node vc-flow-node vc-flow-st" data-node="st-prompt" style="left:310px; top:120px;">
        <div class="vc-node-head" data-drag-handle>
          <span class="vc-port vc-port-in" data-port="st-prompt:in" data-kind="in"></span>
          <span class="vc-node-title">SillyTavern 准备 Prompt</span>
          <span class="vc-port vc-port-out" data-port="st-prompt:out" data-kind="out"></span>
        </div>
        <p class="vc-node-desc">整理角色卡、聊天历史、预设、世界书和扩展注入。</p>
      </section>

      <section class="vc-node vc-flow-node vc-flow-worldbook" data-node="wb-constant" style="left:595px; top:48px;">
        <div class="vc-node-head" data-drag-handle>
          <span class="vc-port vc-port-in" data-port="wb-constant:in" data-kind="in"></span>
          <span class="vc-node-title">世界书常驻条目插入</span>
          <span class="vc-port vc-port-out" data-port="wb-constant:out" data-kind="out"></span>
        </div>
        <p class="vc-node-desc">例如变量更新规则、输出格式、强规则、运行法则。</p>
      </section>

      <section class="vc-node vc-flow-node vc-flow-variable" data-node="stat-data" style="left:595px; top:250px;">
        <div class="vc-node-head" data-drag-handle>
          <span class="vc-port vc-port-in" data-port="stat-data:in" data-kind="in"></span>
          <span class="vc-node-title">变量列表插入 stat_data</span>
          <span class="vc-port vc-port-out" data-port="stat-data:out" data-kind="out"></span>
        </div>
        <p class="vc-node-desc">通过变量列表条目把当前状态喂给模型。</p>
      </section>

      <section class="vc-node vc-flow-node vc-flow-ejs" data-node="ejs-router" style="left:895px; top:48px;">
        <div class="vc-node-head" data-drag-handle>
          <span class="vc-port vc-port-in" data-port="ejs-router:in" data-kind="in"></span>
          <span class="vc-node-title">EJS 控制器动态加载阶段世界书</span>
          <span class="vc-port vc-port-out" data-port="ejs-router:out" data-kind="out"></span>
        </div>
        <p class="vc-node-desc">按好感、阶段、标记决定哪些隐藏剧情条目参与本轮。</p>
      </section>

      <section class="vc-node vc-flow-node vc-flow-rule" data-node="rule-inject" style="left:895px; top:250px;">
        <div class="vc-node-head" data-drag-handle>
          <span class="vc-port vc-port-in" data-port="rule-inject:in" data-kind="in"></span>
          <span class="vc-node-title">Roll / 随机事件 / 阻尼器 / 交易规则注入</span>
          <span class="vc-port vc-port-out" data-port="rule-inject:out" data-kind="out"></span>
        </div>
        <p class="vc-node-desc">把好感 Roll、经济规则、随机事件和防暴走限制写进本轮提示。</p>
      </section>

      <section class="vc-node vc-flow-node vc-flow-model" data-node="model-generate" style="left:1215px; top:150px;">
        <div class="vc-node-head" data-drag-handle>
          <span class="vc-port vc-port-in" data-port="model-generate:in" data-kind="in"></span>
          <span class="vc-node-title">模型生成回复</span>
          <span class="vc-port vc-port-out" data-port="model-generate:out" data-kind="out"></span>
        </div>
        <p class="vc-node-desc">模型同时写剧情正文与变量更新块。</p>
      </section>

      <section class="vc-node vc-flow-node vc-flow-output" data-node="story-output" style="left:1510px; top:54px;">
        <div class="vc-node-head" data-drag-handle>
          <span class="vc-port vc-port-in" data-port="story-output:in" data-kind="in"></span>
          <span class="vc-node-title">输出 &lt;story&gt; 正文</span>
          <span class="vc-port vc-port-out" data-port="story-output:out" data-kind="out"></span>
        </div>
        <p class="vc-node-desc">展示给用户看的剧情文本。</p>
      </section>

      <section class="vc-node vc-flow-node vc-flow-update" data-node="update-output" style="left:1510px; top:250px;">
        <div class="vc-node-head" data-drag-handle>
          <span class="vc-port vc-port-in" data-port="update-output:in" data-kind="in"></span>
          <span class="vc-node-title">输出 &lt;UpdateVariable&gt;</span>
          <span class="vc-port vc-port-out" data-port="update-output:out" data-kind="out"></span>
        </div>
        <p class="vc-node-desc">模型在技术块里给出 JSONPatch 更新命令。</p>
      </section>

      <section class="vc-node vc-flow-node vc-flow-mvu" data-node="mvu-patch" style="left:1215px; top:470px;">
        <div class="vc-node-head" data-drag-handle>
          <span class="vc-port vc-port-in" data-port="mvu-patch:in" data-kind="in"></span>
          <span class="vc-node-title">MVU 解析 JSONPatch</span>
          <span class="vc-port vc-port-out" data-port="mvu-patch:out" data-kind="out"></span>
        </div>
        <p class="vc-node-desc">读取 replace / delta / insert / remove / move 等操作。</p>
      </section>

      <section class="vc-node vc-flow-node vc-flow-zod" data-node="zod-validate" style="left:895px; top:470px;">
        <div class="vc-node-head" data-drag-handle>
          <span class="vc-port vc-port-in" data-port="zod-validate:in" data-kind="in"></span>
          <span class="vc-node-title">Zod Schema 校验和自动处理</span>
          <span class="vc-port vc-port-out" data-port="zod-validate:out" data-kind="out"></span>
        </div>
        <p class="vc-node-desc">类型转换、默认值、范围限制、非法更新兜底。</p>
      </section>

      <section class="vc-node vc-node-varmap vc-flow-node vc-flow-variable" data-node="varmap" style="left:595px; top:470px;">
        <div class="vc-node-head" data-drag-handle>
          <span class="vc-port vc-port-in" data-port="varmap:in" data-kind="in"></span>
          <span class="vc-node-title">状态向量窗口</span>
          <span class="vc-port vc-port-out" data-port="varmap:out" data-kind="out"></span>
        </div>
        <div class="vc-varmap-list" id="vcGraphVarMap">
          <div class="vc-varmap-empty">导入或生成 MVU 后，会在下方展开每个变量节点。</div>
        </div>
      </section>

      <section class="vc-node vc-flow-node vc-flow-event" data-node="status-event" style="left:310px; top:470px;">
        <div class="vc-node-head" data-drag-handle>
          <span class="vc-port vc-port-in" data-port="status-event:in" data-kind="in"></span>
          <span class="vc-node-title">VARIABLE_UPDATE_ENDED</span>
          <span class="vc-port vc-port-out" data-port="status-event:out" data-kind="out"></span>
        </div>
        <p class="vc-node-desc">状态栏收到变量更新结束事件后刷新显示。</p>
      </section>

      <section class="vc-node vc-flow-node vc-flow-regex" data-node="regex-display" style="left:48px; top:470px;">
        <div class="vc-node-head" data-drag-handle>
          <span class="vc-port vc-port-in" data-port="regex-display:in" data-kind="in"></span>
          <span class="vc-node-title">正则隐藏技术内容 / 美化正文和状态栏</span>
        </div>
        <p class="vc-node-desc">隐藏 UpdateVariable，仅显示剧情正文和美化后的状态变化。</p>
      </section>
        </div>
      </div>
    </div>
  </div>

  <!-- ★ 生成结果 — 清单 + 可展开详情 -->
  <div id="vcResult" class="vc-result" style="display:none;">
    <div class="vc-checklist" id="vcChecklist"></div>

    <div class="vc-variable-preview" id="vcVariablePreview" style="display:none;">
      <div class="vc-preview-head">
        <strong>🧭 本次变量预览</strong>
        <span id="vcVariableCount">0 个状态向量</span>
      </div>
      <div class="vc-preview-sub">这些变量会写入角色卡，后续回复会按更新规则维护它们。</div>
      <div class="vc-single-tools">
        <input id="vcSingleRequirement" type="text" placeholder="单独追加变量，例如：埃利安的警惕值、店铺库存、隐藏线索..." />
        <button id="btnVcAddOne" type="button">＋ 生成一条</button>
      </div>
      <div class="vc-preview-grid" id="vcVariablePreviewList"></div>
    </div>

    <!-- 折叠详情 -->
    <details class="vc-details">
      <summary class="vc-details-toggle">📄 查看生成详情 / 逐项复制</summary>
      <div class="vc-details-body">
        <div class="vc-detail-block">
          <div class="vc-detail-head"><strong>📜 变量结构脚本</strong><span class="vc-badge script">酒馆助手脚本</span><button class="vc-copy-btn" data-target="vcCodeSchema">📋</button></div>
          <pre class="vc-pre"><code id="vcCodeSchema"></code></pre>
        </div>
        <div class="vc-detail-block">
          <div class="vc-detail-head"><strong>🎯 变量初始化</strong><span class="vc-badge wb-off">禁用条目</span><button class="vc-copy-btn" data-target="vcCodeInitvar">📋</button></div>
          <pre class="vc-pre"><code id="vcCodeInitvar"></code></pre>
        </div>
        <div class="vc-detail-block">
          <div class="vc-detail-head"><strong>🔄 更新规则</strong><span class="vc-badge wb-on">常驻条目</span><button class="vc-copy-btn" data-target="vcCodeUpdate">📋</button></div>
          <pre class="vc-pre"><code id="vcCodeUpdate"></code></pre>
        </div>
        <div class="vc-detail-block">
          <div class="vc-detail-head"><strong>📤 输出格式</strong><span class="vc-badge wb-on">D0 常驻</span><button class="vc-copy-btn" data-target="vcCodeFormat">📋</button></div>
          <pre class="vc-pre"><code id="vcCodeFormat"></code></pre>
        </div>
        <div class="vc-detail-block">
          <div class="vc-detail-head"><strong>📋 变量列表</strong><span class="vc-badge wb-on">D1 常驻</span><button class="vc-copy-btn" data-target="vcCodeVarlist">📋</button></div>
          <pre class="vc-pre"><code id="vcCodeVarlist"></code></pre>
        </div>
        <div class="vc-detail-block">
          <div class="vc-detail-head"><strong>🔧 正则脚本</strong><span class="vc-badge regex">自动注入</span><button class="vc-copy-btn" data-target="vcCodeRegex">📋</button></div>
          <pre class="vc-pre"><code id="vcCodeRegex"></code></pre>
        </div>
      </div>
    </details>

    <!-- 底栏 -->
    <div class="vc-bottom">
      <span class="vc-summary" id="vcSummary"></span>
      <button id="btnVcClear" class="btn vc-clear-btn" type="button">🧹 清除变量</button>
      <button id="btnVcDelete" class="btn-icon btn-icon--danger vc-delete-btn" type="button" title="删除组件" aria-label="删除组件">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 7h16"/><path d="M9 7V5a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/><path d="M10 11v6M14 11v6"/><path d="M7 7l1 12a1 1 0 0 0 1 .9h6a1 1 0 0 0 1-.9l1-12"/></svg>
      </button>
      <button id="btnVcExport" class="btn vc-export-btn">💾 导出变量卡包</button>
    </div>
  </div>
</div>

<!-- ★★★ 样式 ★★★ -->
<link rel="stylesheet" href="../styles/variable-card-panel.css" />

<!-- ★★★ 脚本 ★★★ -->
<script>
  import { initVariableCardPanel } from '../lib/mvu/variableCardPanel.mjs';
  initVariableCardPanel();
</script>
