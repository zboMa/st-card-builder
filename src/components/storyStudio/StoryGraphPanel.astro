---
/** 创作图谱：对齐小说工坊关系图谱（G6 + 工具栏/图例/右键/弹窗编辑） */
---
<div class="panel story-studio-panel" data-story-panel="graph">
  <div class="ss-panel-header">
    <div class="ss-panel-heading">
      <h2>创作图谱</h2>
      <p class="ss-tip ui-panel-lead">拖拽缩放；点击查看详情；右键节点/边编辑。</p>
    </div>
    <div class="ss-panel-actions" aria-label="图谱操作">
      <button type="button" id="btnSsSeedGraph" class="btn btn-ghost btn-inline">从卡面种子生成</button>
      <button type="button" id="btnSsAddNode" class="btn btn-ghost btn-inline">加节点</button>
      <button type="button" id="btnSsAddEdge" class="btn btn-ghost btn-inline">加关系</button>
      <button type="button" id="btnSsGraphRelayout" class="btn btn-ghost btn-inline">重新布局</button>
      <button type="button" id="btnSsSaveGraph" class="btn btn-ghost btn-inline">保存</button>
    </div>
  </div>

  <div class="novel-graph-wrap ss-graph-wrap">
    <div class="novel-graph-toolbar" aria-label="图谱显示选项">
      <label class="novel-graph-depth" for="ssGraphHighlightDepth" title="选中节点时高亮的关系跳数（0 仅自身）">
        <span>关系层级</span>
        <input id="ssGraphHighlightDepth" type="number" min="0" max="6" step="1" value="2" inputmode="numeric" />
      </label>
      <label class="novel-graph-filter novel-switch" for="ssGraphPersonOnly">
        <input id="ssGraphPersonOnly" type="checkbox" />
        <span>只看人物</span>
      </label>
    </div>
    <div id="ssGraphLegend" class="novel-graph-legend" aria-hidden="true"></div>
    <div id="ssGraphCy" class="novel-graph-cy ss-graph-cy" role="img" aria-label="创作图谱可视化"></div>
  </div>

  <div class="novel-graph-footer ss-graph-footer">
    <div class="novel-graph-footer-meta novel-meta-line" aria-live="polite">
      <span id="ssGraphStats" class="novel-meta-group novel-graph-stats">节点 0 · 边 0</span>
      <span class="novel-meta-group ss-muted">点击节点或边查看详情 · 右键编辑</span>
    </div>
    <div id="ssGraphDetail" class="novel-graph-detail ss-graph-detail">点击节点或边查看详情</div>
  </div>

  <div id="ssGraphStatus" class="ss-status"></div>
</div>
