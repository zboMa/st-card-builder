---
/**
 * 卡级成人配置（NSFW / NTL / 恶堕）
 * 与「角色设定」分离：主角正文不写入此类内容；本配置服务世界书人物与分析管线。
 */
---
<div class="panel area-adult-config">
  <h2>成人配置</h2>
  <p class="ui-hint adult-config-lead">
    整张卡统一配置，<strong>仅世界书管道</strong>：世界书人物条、恶堕档案、小说人物丰满/分析、状态栏 NSFW。
    <strong>主角管道</strong>（角色设定 / 开场白）完全不读、不写此配置。
  </p>

  <div class="form-group char-nsfw-block">
    <div class="char-nsfw-head">
      <span class="char-nsfw-label">情欲 / NSFW</span>
      <span class="ui-hint ui-hint--inline">卡级统一口味，供世界书人物与管线读取</span>
    </div>

    <label class="novel-switch">
      <input id="adultNsfwEnabled" type="checkbox" />
      <span>启用 NSFW</span>
    </label>
    <span class="char-nsfw-subtitle">分析/抽取/丰满/文风/恶堕等统一读取；主角生成不注入</span>

    <section id="adultFlavorSection" class="adult-flavor-section" style="display:none;" aria-labelledby="adultFlavorHeading">
      <div class="char-nsfw-flavor-line" style="margin-bottom:6px;">
        <span id="adultFlavorHeading" class="char-nsfw-sub">口味</span>
        <span class="char-nsfw-subtitle">最多 5 个；首项为主调色盘；每项含必写维度与密度门槛（对齐恶堕丰满标准）</span>
      </div>
      <div id="adultNsfwFlavorList" class="adult-flavor-list"></div>
      <div class="adult-flavor-add-row">
        <select id="adultNsfwFlavorPicker" aria-label="选择要添加的口味">
          <option value="">选择口味…</option>
        </select>
        <button type="button" id="btnAddNsfwFlavor" class="btn btn-ghost">＋添加口味</button>
        <span id="adultNsfwFlavorCap" class="char-nsfw-subtitle"></span>
      </div>
    </section>

    <section class="adult-ntl-section" aria-labelledby="adultNtlHeading">
      <div class="char-nsfw-flavor-line" style="margin-bottom:4px;">
        <span id="adultNtlHeading" class="char-nsfw-sub">NTL 禁忌</span>
        <label class="novel-switch">
          <input id="adultNtlEnabled" type="checkbox" />
          <span>启用</span>
        </label>
        <span class="char-nsfw-subtitle">权力/背德/越界张力。可只开其一，也可叠加</span>
      </div>
      <div id="adultNtlTabooRow" style="display:none;margin-top:4px;">
        <div id="adultNtlTabooTypes" class="adult-ntl-chips"></div>
      </div>
    </section>

    <div id="adultCorruptionBlock" class="char-corruption-block" style="display:none;">
      <div class="char-nsfw-flavor-line" style="margin-bottom:6px;">
        <label class="novel-switch">
          <input id="adultCorruptionEnabled" type="checkbox" />
          <span>恶堕进度</span>
        </label>
        <span class="char-nsfw-subtitle">总则 1 条 + 每名世界书角色 1 条分期档案；状态栏「恶堕进度」变量选阶段</span>
      </div>
      <div id="adultCorruptionBody" style="display:none;">
        <div class="char-nsfw-flavor-line" style="margin-bottom:6px;">
          <span class="char-nsfw-sub">阶数</span>
          <select id="adultCorruptionPreset" style="font-size:0.73rem;padding:3px 8px;border-radius:6px;border:1px solid var(--color-border);background:var(--color-surface);color:var(--color-text);">
            <option value="3">简洁 3 阶</option>
            <option value="5" selected>标准 5 阶（默认）</option>
            <option value="7">细腻 7 阶</option>
            <option value="custom">自定义（描述生成）</option>
          </select>
          <label class="novel-switch" style="margin-left:4px;">
            <input id="adultCorruptionFemaleOnly" type="checkbox" checked />
            <span class="char-nsfw-subtitle">默认仅女角色</span>
          </label>
          <label class="novel-switch">
            <input id="adultCorruptionSyncSb" type="checkbox" checked />
            <span class="char-nsfw-subtitle">同步状态栏模块</span>
          </label>
        </div>
        <div id="adultCorruptionCustomRow" style="display:none;margin-bottom:6px;">
          <textarea id="adultCorruptionCustomBrief" rows="2" placeholder="描述堕落弧光，例如：清纯学妹被一步步引诱，最终主动沉沦……" style="width:100%;font-size:0.75rem;padding:6px 8px;border-radius:6px;border:1px solid var(--color-border);background:var(--color-surface);color:var(--color-text);resize:vertical;"></textarea>
        </div>
        <div class="char-nsfw-subtitle" style="margin-bottom:4px;">生成对象（来自世界书/小说人物；主角自动排除；男角色默认不勾）</div>
        <div id="adultCorruptionTargets" class="char-corruption-targets"></div>
        <div class="char-nsfw-flavor-line" style="margin-top:8px;gap:8px;">
          <button type="button" id="btnRefreshCorruptionTargets" class="btn btn-ghost" style="font-size:0.72rem;padding:4px 10px;">刷新角色列表</button>
          <button type="button" id="btnGenCorruptionLore" class="btn btn-primary" style="font-size:0.72rem;padding:4px 12px;">生成/更新恶堕世界书</button>
          <span id="adultCorruptionTip" class="ui-status-tip" role="status" aria-live="polite"></span>
        </div>
      </div>
    </div>

    <span class="char-nsfw-subtitle" style="margin-top:8px;display:block;">口味决定世界书人物写法风格；NTL 细化禁忌维度。均不进入主角 Description。</span>
  </div>
</div>

<style is:global>
  .adult-config-lead {
    margin: -4px 0 14px;
    font-size: 0.78rem;
    line-height: 1.5;
  }
  .char-nsfw-block {
    padding: 2px 0 6px;
  }
  .char-nsfw-head {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 10px;
  }
  .char-nsfw-label {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-accent);
    white-space: nowrap;
  }
  .adult-flavor-section,
  .adult-ntl-section {
    margin-top: 12px;
    padding-top: 10px;
    border-top: 1px dashed var(--color-border);
  }
  .adult-flavor-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 8px;
  }
  .adult-flavor-item {
    padding: 8px 10px;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-surface);
  }
  .adult-flavor-item-head {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    margin-bottom: 6px;
  }
  .adult-flavor-item-meta {
    flex: 1;
    min-width: 0;
  }
  .adult-flavor-item-title {
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--color-text);
  }
  .adult-flavor-item-title .adult-flavor-primary-tag {
    margin-left: 6px;
    font-size: 0.68rem;
    font-weight: 600;
    color: var(--color-accent);
  }
  .adult-flavor-item-desc {
    font-size: 0.7rem;
    color: var(--color-text-muted);
    line-height: 1.4;
    margin-top: 2px;
  }
  .adult-flavor-item textarea {
    width: 100%;
    font-size: 0.72rem;
    padding: 5px 8px;
    border-radius: 6px;
    border: 1px solid var(--color-border);
    background: var(--color-bg, var(--color-surface));
    color: var(--color-text);
    resize: vertical;
    min-height: 2.4em;
  }
  .adult-flavor-add-row {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  .adult-flavor-add-row select {
    font-size: 0.73rem;
    padding: 4px 8px;
    border-radius: 6px;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text);
    max-width: 220px;
  }
  .adult-ntl-chips {
    display: flex;
    align-items: center;
    gap: 4px;
    flex-wrap: wrap;
  }
  .char-nsfw-flavor-line {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  .char-nsfw-sub {
    font-size: 0.76rem;
    color: var(--color-accent);
    font-weight: 700;
  }
  .char-nsfw-subtitle {
    font-size: 0.7rem;
    color: var(--color-text-muted);
    line-height: 1.4;
  }
  .char-corruption-block {
    margin-top: 12px;
    padding-top: 10px;
    border-top: 1px dashed var(--color-border);
  }
  .char-corruption-targets {
    display: flex;
    flex-wrap: wrap;
    gap: 6px 10px;
    max-height: 140px;
    overflow: auto;
    padding: 4px 0;
  }
  .char-corruption-targets label {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 0.72rem;
    color: var(--color-text);
    cursor: pointer;
  }
</style>
