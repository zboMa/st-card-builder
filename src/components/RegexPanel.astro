---
/**
 * 正则模块：管理当前角色卡 data.extensions.regex_scripts（与 MVU/状态栏注入共存）
 * 编辑实时写入权威数组；测试弹窗按当前选中条目解析
 */
---
<div class="panel regex-panel" id="regexPanel">
  <div class="panel-header rx-hero">
    <div>
      <h2>正则</h2>
      <p class="ui-hint ui-hint--inline rx-hero__sub">管理 SillyTavern <code>regex_scripts</code>：列表选中编辑，修改即时保存。导出仍写原字段。</p>
    </div>
    <div class="rx-hero-actions">
      <button type="button" class="btn-inline btn-ghost" id="rxBtnTest">测试</button>
      <button type="button" class="btn-primary btn-inline" id="rxBtnAdd">新建</button>
    </div>
  </div>

  <div class="rx-layout">
    <section class="rx-list-card" aria-label="正则列表">
      <div class="rx-list-head">
        <span id="rxListCount">0 条</span>
        <span class="rx-tip">按脚本名与 MVU/状态栏注入对齐</span>
      </div>
      <div id="rxList" class="rx-list"></div>
      <p id="rxEmpty" class="rx-empty" hidden>暂无正则。MVU / 状态栏注入后会出现在此；也可手动新建。</p>
    </section>

    <section class="rx-editor-card" id="rxEditor" hidden>
      <div class="rx-editor-head">
        <h3>编辑正则</h3>
        <span id="rxLiveHint" class="rx-live-hint">已实时保存</span>
      </div>

      <!-- id 仅内部保留，界面不展示 -->
      <input type="hidden" id="rxId" value="" />

      <div class="rx-field">
        <label class="rx-label" for="rxScriptName">脚本名称</label>
        <input type="text" id="rxScriptName" autocomplete="off" />
      </div>
      <div class="rx-field">
        <label class="rx-label" for="rxFind">匹配正则</label>
        <textarea id="rxFind" rows="3" spellcheck="false" placeholder="如：&lt;StatusBar&gt;([\\s\\S]*?)&lt;/StatusBar&gt;"></textarea>
      </div>
      <div class="rx-field">
        <label class="rx-label" for="rxReplace">替换内容</label>
        <textarea id="rxReplace" rows="4" spellcheck="false" placeholder="可用 $1 引用捕获组"></textarea>
      </div>

      <!-- 两栏：左作用范围+深度，右其他选项/宏/表层替换 -->
      <div class="rx-editor-cols">
        <div class="rx-col">
          <div class="rx-section-title">作用范围</div>
          <div class="rx-checks rx-checks-stack">
            <label class="rx-check"><input type="checkbox" id="rxPlaceUser" value="1" /><span>用户输入</span></label>
            <label class="rx-check"><input type="checkbox" id="rxPlaceAi" value="2" /><span>AI输出</span></label>
            <label class="rx-check"><input type="checkbox" id="rxPlaceSlash" value="3" /><span>快捷命令</span></label>
            <label class="rx-check"><input type="checkbox" id="rxPlaceWorld" value="5" /><span>世界书</span></label>
            <label class="rx-check"><input type="checkbox" id="rxPlaceReason" value="6" /><span>推理</span></label>
          </div>
          <div class="rx-depth-row">
            <div class="rx-field rx-field-tight">
              <label class="rx-label" for="rxMinDepth">最小深度</label>
              <input type="number" id="rxMinDepth" placeholder="空=不限" />
            </div>
            <div class="rx-field rx-field-tight">
              <label class="rx-label" for="rxMaxDepth">最大深度</label>
              <input type="number" id="rxMaxDepth" placeholder="空=不限" />
            </div>
          </div>
        </div>
        <div class="rx-col">
          <div class="rx-section-title">其他选项</div>
          <div class="rx-checks rx-checks-stack">
            <label class="rx-check"><input type="checkbox" id="rxDisabled" /><span>已禁用</span></label>
            <label class="rx-check"><input type="checkbox" id="rxRunOnEdit" /><span>编辑时运行</span></label>
          </div>
          <div class="rx-section-title">宏</div>
          <div class="rx-checks">
            <label class="rx-check"><input type="checkbox" id="rxSubstitute" /><span>宏查找替换</span></label>
          </div>
          <div class="rx-section-title">表层替换</div>
          <div class="rx-checks rx-checks-stack">
            <label class="rx-check"><input type="checkbox" id="rxMarkdownOnly" /><span>仅显示</span></label>
            <label class="rx-check"><input type="checkbox" id="rxPromptOnly" /><span>仅后端提示词</span></label>
          </div>
        </div>
      </div>

      <div id="rxStatus" class="rx-status"></div>
    </section>
  </div>

  <!-- 测试弹窗：对当前选中正则解析文本 -->
  <div id="rxTestModal" class="rx-modal ui-modal" hidden aria-hidden="true">
    <div class="rx-modal-backdrop ui-modal-backdrop" data-rx-modal-close></div>
    <div class="rx-modal-dialog ui-modal-dialog" role="dialog" aria-modal="true" aria-labelledby="rxTestTitle">
      <div class="rx-modal-head">
        <strong id="rxTestTitle">测试正则</strong>
        <span class="rx-modal-tip" id="rxTestTip">使用当前选中条目</span>
      </div>
      <div class="rx-modal-body">
        <div class="rx-field">
          <label class="rx-label" for="rxTestInput">测试文本</label>
          <textarea id="rxTestInput" rows="6" spellcheck="false" placeholder="粘贴要解析的文本…"></textarea>
        </div>
        <div class="rx-modal-actions-inline">
          <button type="button" class="btn-primary btn-inline" id="rxBtnParse">解析</button>
        </div>
        <div class="rx-field">
          <label class="rx-label" for="rxTestOutput">解析结果</label>
          <textarea id="rxTestOutput" rows="6" spellcheck="false" readonly placeholder="点击「解析」后显示"></textarea>
        </div>
        <p id="rxTestErr" class="rx-test-err" hidden></p>
      </div>
      <div class="rx-modal-actions">
        <button type="button" class="btn-inline btn-ghost" data-rx-modal-close>取消</button>
      </div>
    </div>
  </div>
</div>

<style is:global>
  .rx-hero {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-2);
  }
  .rx-hero__sub {
    margin: 2px 0 0;
    display: block;
  }
  .rx-hero code {
    font-size: 0.72rem;
    color: var(--color-accent-hover);
  }
  .rx-hero-actions {
    display: flex;
    flex-shrink: 0;
    gap: 6px;
    align-items: center;
  }
  .rx-layout {
    display: grid;
    grid-template-columns: minmax(220px, 0.9fr) minmax(280px, 1.2fr);
    gap: var(--space-2);
  }
  @media (max-width: 900px) {
    .rx-layout { grid-template-columns: 1fr; }
  }
  .rx-list-card, .rx-editor-card {
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-md);
    padding: var(--space-3);
    background: var(--color-surface-input);
    box-shadow: var(--shadow-inset);
    min-height: 280px;
  }
  .rx-list-head {
    display: flex;
    justify-content: space-between;
    gap: var(--space-2);
    margin-bottom: var(--space-2);
    font-size: 0.72rem;
    color: var(--color-text-muted);
  }
  .rx-tip { color: var(--color-text-muted); }
  .rx-list {
    display: flex;
    flex-direction: column;
    gap: 6px;
    max-height: min(52vh, 480px);
    overflow-y: auto;
  }
  .rx-item {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: var(--space-2);
    align-items: center;
    padding: 8px 10px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border-subtle);
    background: var(--color-surface-inset);
    cursor: pointer;
    text-align: left;
    color: inherit;
    font: inherit;
    transition: border-color var(--dur-fast) var(--ease-out), background var(--dur-fast) var(--ease-out);
  }
  .rx-toggle {
    width: 16px;
    height: 16px;
    min-width: 16px;
    min-height: 16px;
    margin: 0;
    cursor: pointer;
    flex-shrink: 0;
  }
  .rx-item-actions button {
    position: relative;
    z-index: 1;
  }
  .rx-item.is-active {
    border-color: var(--color-accent-border);
    background: var(--color-entry-active-bg);
    box-shadow: inset 0 0 0 1px var(--color-accent-soft);
  }
  .rx-item.is-disabled { opacity: 0.55; }
  .rx-item-name {
    font-size: 0.8rem;
    font-weight: 650;
    color: var(--color-text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .rx-item-meta {
    font-size: 0.68rem;
    color: var(--color-text-muted);
  }
  .rx-item-actions {
    display: flex;
    gap: 4px;
  }
  .rx-icon-btn {
    width: 26px;
    height: 26px;
    min-width: 26px;
    padding: 0;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border-subtle);
    background: var(--color-surface-inset);
    color: var(--color-text-muted);
    cursor: pointer;
    font: inherit;
    font-size: 0.72rem;
  }
  .rx-icon-btn:hover {
    border-color: var(--color-accent-border);
    background: var(--color-accent-soft);
    color: var(--color-text);
  }
  .rx-icon-btn.is-danger:hover {
    color: var(--color-danger);
    border-color: var(--color-danger-border);
    background: var(--color-danger-soft);
  }
  .rx-empty {
    margin: 24px 8px;
    text-align: center;
    color: var(--color-text-muted);
    font-size: 0.78rem;
  }
  .rx-editor-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-3);
  }
  .rx-editor-head h3 {
    margin: 0;
    font-size: 0.9rem;
    color: var(--color-text);
  }
  .rx-live-hint {
    font-size: 0.68rem;
    color: var(--color-text-muted);
  }
  .rx-live-hint.is-ok { color: var(--color-success); }
  .rx-live-hint.is-err { color: var(--color-danger); }
  .rx-field { margin-bottom: 10px; }
  .rx-field-tight { margin-bottom: 0; }
  .rx-label {
    display: block;
    margin-bottom: 4px;
    font-size: 0.72rem;
    color: var(--color-text-muted);
  }
  .rx-field input[type="text"],
  .rx-field input[type="number"],
  .rx-field textarea {
    width: 100%;
    box-sizing: border-box;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border-subtle);
    background: var(--color-surface-input);
    color: var(--color-text);
    padding: 8px 10px;
    font: inherit;
    font-size: 0.8rem;
  }
  .rx-field textarea { font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; resize: vertical; }
  .rx-editor-cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2);
    margin-top: 4px;
    padding-top: 10px;
    border-top: 1px solid var(--color-border-subtle);
  }
  @media (max-width: 700px) {
    .rx-editor-cols { grid-template-columns: 1fr; }
  }
  .rx-col {
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-sm);
    padding: 10px;
    background: var(--color-surface-elevated);
  }
  .rx-section-title {
    margin: 0 0 8px;
    font-size: 0.72rem;
    font-weight: 650;
    color: var(--color-text-label);
  }
  .rx-col .rx-section-title:not(:first-child) { margin-top: 12px; }
  .rx-checks { display: flex; flex-wrap: wrap; gap: 8px 14px; }
  .rx-checks-stack { flex-direction: column; flex-wrap: nowrap; gap: 6px; }
  .rx-depth-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2);
    margin-top: 12px;
  }
  .rx-check {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.74rem;
    color: var(--color-text-secondary);
    cursor: pointer;
  }
  .rx-check input[type="checkbox"] {
    flex-shrink: 0;
    cursor: pointer;
  }
  .rx-status {
    margin-top: 8px;
    min-height: 1.2em;
    font-size: 0.74rem;
    color: var(--color-success);
  }
  .rx-badge {
    display: inline-block;
    margin-left: 6px;
    padding: 1px 6px;
    border-radius: 999px;
    font-size: 0.62rem;
    background: var(--color-warning-soft);
    color: var(--color-warning);
    border: 1px solid var(--color-warning-border);
  }
  .rx-modal {
    position: fixed;
    inset: 0;
    z-index: 9300;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 16px;
  }
  .rx-modal[hidden] { display: none !important; }
  :global(body.rx-modal-open) {
    overflow: hidden;
  }
  .rx-modal-backdrop {
    position: absolute;
    inset: 0;
  }
  .rx-modal-dialog {
    position: relative;
    z-index: 1;
    width: min(560px, 100%);
    max-height: min(84vh, 720px);
    overflow: auto;
    padding: 14px 16px;
  }
  .rx-modal-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-2);
    margin-bottom: 10px;
  }
  .rx-modal-head strong {
    color: var(--color-text);
    font-size: 0.92rem;
  }
  .rx-modal-tip { font-size: 0.68rem; color: var(--color-text-muted); }
  .rx-modal-body { margin-bottom: 8px; }
  .rx-modal-actions {
    display: flex;
    justify-content: flex-end;
    gap: var(--space-2);
  }
  .rx-modal-actions-inline {
    display: flex;
    justify-content: flex-end;
    margin: 0 0 10px;
  }
  .rx-test-err {
    margin: 0;
    font-size: 0.74rem;
    color: var(--color-danger);
  }
</style>

<script>
  import { initRegexPanel } from '../lib/regexPanelBoot.mjs';
  initRegexPanel();
</script>
