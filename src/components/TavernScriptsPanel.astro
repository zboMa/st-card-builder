---
/**
 * 酒馆脚本模块：管理 data.extensions.tavern_helper.scripts[]（与 MVU/状态栏注入共存）
 * 编辑实时写入权威数组；交互对齐正则面板（不含测试功能）
 */
---
<div class="panel tavern-scripts-panel" id="tavernScriptsPanel">
  <div class="panel-header th-hero">
    <div>
      <h2>酒馆脚本</h2>
      <p class="ui-hint ui-hint--inline th-hero__sub">管理 <code>tavern_helper.scripts</code>：列表选中编辑，修改即时保存。不改动 <code>variables</code> 等其它字段。</p>
    </div>
    <div class="th-hero-actions">
      <button type="button" class="btn-primary btn-inline" id="thBtnAdd">新建</button>
    </div>
  </div>

  <div class="th-layout">
    <section class="th-list-card" aria-label="脚本列表">
      <div class="th-list-head">
        <span id="thListCount">0 条</span>
        <span class="th-tip">按名称与现有注入对齐</span>
      </div>
      <div id="thList" class="th-list"></div>
      <p id="thEmpty" class="th-empty" hidden>暂无脚本。MVU / 状态栏注入后会出现在此；也可手动新建。</p>
    </section>

    <section class="th-editor-card" id="thEditor" hidden>
      <div class="th-editor-head">
        <h3>编辑脚本</h3>
        <span id="thLiveHint" class="th-live-hint">已实时保存</span>
      </div>

      <!-- id 仅内部保留，界面不展示 -->
      <input type="hidden" id="thId" value="" />

      <div class="th-field">
        <label class="th-label" for="thName">名称</label>
        <input type="text" id="thName" autocomplete="off" />
      </div>
      <div class="th-field">
        <label class="th-label" for="thInfo">说明</label>
        <input type="text" id="thInfo" placeholder="脚本用途说明" />
      </div>
      <div class="th-field">
        <label class="th-label" for="thContent">脚本内容</label>
        <textarea id="thContent" rows="12" spellcheck="false" placeholder="脚本源码…"></textarea>
      </div>

      <!-- 两栏：左基本选项，右按钮配置 -->
      <div class="th-editor-cols">
        <div class="th-col">
          <div class="th-section-title">基本选项</div>
          <div class="th-checks th-checks-stack">
            <label class="th-check"><input type="checkbox" id="thEnabled" /><span>启用</span></label>
          </div>
          <div class="th-field th-field-tight" style="margin-top:12px">
            <label class="th-label" for="thType">类型</label>
            <input type="text" id="thType" placeholder="script" />
          </div>
        </div>
        <div class="th-col">
          <div class="th-section-title">按钮</div>
          <div class="th-checks th-checks-stack">
            <label class="th-check"><input type="checkbox" id="thButtonEnabled" /><span>启用按钮</span></label>
          </div>
          <div class="th-field th-field-tight" style="margin-top:12px">
            <label class="th-label" for="thButtonJson">按钮列表（JSON）</label>
            <textarea id="thButtonJson" rows="4" spellcheck="false" placeholder='[]'></textarea>
          </div>
        </div>
      </div>

      <details class="th-advanced">
        <summary>高级：附加数据 data（JSON）</summary>
        <div class="th-field">
          <label class="th-label" for="thDataJson">附加数据</label>
          <textarea id="thDataJson" rows="4" spellcheck="false"></textarea>
        </div>
      </details>

      <div id="thStatus" class="th-status"></div>
    </section>
  </div>
</div>

<style is:global>
  .th-hero {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-2);
  }
  .th-hero__sub {
    margin: 2px 0 0;
    display: block;
  }
  .th-hero code {
    font-size: 0.72rem;
    color: var(--color-accent-hover);
  }
  .th-hero-actions {
    display: flex;
    flex-shrink: 0;
    gap: 6px;
    align-items: center;
  }
  .th-layout {
    display: grid;
    grid-template-columns: minmax(220px, 0.9fr) minmax(280px, 1.2fr);
    gap: var(--space-2);
  }
  @media (max-width: 900px) {
    .th-layout { grid-template-columns: 1fr; }
  }
  .th-list-card, .th-editor-card {
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-md);
    padding: var(--space-3);
    background: var(--color-surface-input);
    box-shadow: var(--shadow-inset);
    min-height: 280px;
  }
  .th-list-head {
    display: flex;
    justify-content: space-between;
    gap: var(--space-2);
    margin-bottom: var(--space-2);
    font-size: 0.72rem;
    color: var(--color-text-muted);
  }
  .th-tip { color: var(--color-text-muted); }
  .th-list {
    display: flex;
    flex-direction: column;
    gap: 6px;
    max-height: min(52vh, 480px);
    overflow-y: auto;
  }
  .th-item {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: var(--space-2);
    align-items: center;
    padding: 8px 10px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border-subtle);
    background: var(--color-surface-inset);
    cursor: pointer;
    text-align: left;
    color: inherit;
    font: inherit;
    transition: border-color var(--dur-fast) var(--ease-out), background var(--dur-fast) var(--ease-out);
  }
  .th-toggle {
    width: 16px;
    height: 16px;
    min-width: 16px;
    min-height: 16px;
    margin: 0;
    cursor: pointer;
    flex-shrink: 0;
  }
  .th-item-actions button {
    position: relative;
    z-index: 1;
  }
  .th-item.is-active {
    border-color: var(--color-accent-border);
    background: var(--color-entry-active-bg);
    box-shadow: inset 0 0 0 1px var(--color-accent-soft);
  }
  .th-item.is-disabled { opacity: 0.55; }
  .th-item-name {
    font-size: 0.8rem;
    font-weight: 650;
    color: var(--color-text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .th-item-meta {
    font-size: 0.68rem;
    color: var(--color-text-muted);
  }
  .th-item-actions { display: flex; gap: 4px; }
  .th-icon-btn {
    width: 26px;
    height: 26px;
    min-width: 26px;
    padding: 0;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border-subtle);
    background: var(--color-surface-inset);
    color: var(--color-text-muted);
    cursor: pointer;
    font: inherit;
    font-size: 0.72rem;
  }
  .th-icon-btn:hover {
    border-color: var(--color-accent-border);
    background: var(--color-accent-soft);
    color: var(--color-text);
  }
  .th-icon-btn.is-danger:hover {
    color: var(--color-danger);
    border-color: var(--color-danger-border);
    background: var(--color-danger-soft);
  }
  .th-empty {
    margin: 24px 8px;
    text-align: center;
    color: var(--color-text-muted);
    font-size: 0.78rem;
  }
  .th-editor-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-3);
  }
  .th-editor-head h3 {
    margin: 0;
    font-size: 0.9rem;
    color: var(--color-text);
  }
  .th-live-hint {
    font-size: 0.68rem;
    color: var(--color-text-muted);
  }
  .th-live-hint.is-ok { color: var(--color-success); }
  .th-live-hint.is-err { color: var(--color-danger); }
  .th-field { margin-bottom: 10px; }
  .th-field-tight { margin-bottom: 0; }
  .th-label {
    display: block;
    margin-bottom: 4px;
    font-size: 0.72rem;
    color: var(--color-text-muted);
  }
  .th-field input[type="text"],
  .th-field textarea {
    width: 100%;
    box-sizing: border-box;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border-subtle);
    background: var(--color-surface-input);
    color: var(--color-text);
    padding: 8px 10px;
    font: inherit;
    font-size: 0.8rem;
  }
  .th-field textarea {
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    resize: vertical;
  }
  .th-editor-cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2);
    margin-top: 4px;
    padding-top: 10px;
    border-top: 1px solid var(--color-border-subtle);
  }
  @media (max-width: 700px) {
    .th-editor-cols { grid-template-columns: 1fr; }
  }
  .th-col {
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-sm);
    padding: 10px;
    background: var(--color-surface-elevated);
  }
  .th-section-title {
    margin: 0 0 8px;
    font-size: 0.72rem;
    font-weight: 650;
    color: var(--color-text-label);
  }
  .th-checks { display: flex; flex-wrap: wrap; gap: 8px 14px; }
  .th-checks-stack { flex-direction: column; flex-wrap: nowrap; gap: 6px; }
  .th-check {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.74rem;
    color: var(--color-text-secondary);
    cursor: pointer;
  }
  .th-check input[type="checkbox"] {
    flex-shrink: 0;
    cursor: pointer;
  }
  .th-advanced {
    margin: 12px 0 0;
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-sm);
    padding: 8px 10px;
    color: var(--color-text-muted);
    font-size: 0.74rem;
    background: var(--color-surface-inset);
  }
  .th-advanced summary { cursor: pointer; margin-bottom: 8px; }
  .th-status {
    margin-top: 8px;
    min-height: 1.2em;
    font-size: 0.74rem;
    color: var(--color-success);
  }
  .th-badge {
    display: inline-block;
    margin-left: 6px;
    padding: 1px 6px;
    border-radius: 999px;
    font-size: 0.62rem;
    background: var(--color-warning-soft);
    color: var(--color-warning);
    border: 1px solid var(--color-warning-border);
  }
</style>

<script>
  import { initTavernScriptsPanel } from '../lib/tavernPanelBoot.mjs';
  initTavernScriptsPanel();
</script>
