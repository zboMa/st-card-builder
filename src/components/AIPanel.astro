---
import AiEngineModal from './AiEngineModal.astro';
---
<!-- AI 配置（侧栏「配置」）：横向三 Tab；一键生成见 AiEngineModal -->
<div class="panel ai-panel area-ai-config">
  <h2>AI 配置</h2>

  <!-- 横向 Tab：默认 API 配置 -->
  <div class="ui-tabs ai-config-tabs" role="tablist" aria-label="AI 配置分区">
    <button type="button" class="ui-tabs__tab ai-config-tab is-active" role="tab" aria-selected="true" data-ai-config-tab="api">API 配置</button>
    <button type="button" class="ui-tabs__tab ai-config-tab" role="tab" aria-selected="false" data-ai-config-tab="preset">酒馆预设</button>
    <button type="button" class="ui-tabs__tab ai-config-tab" role="tab" aria-selected="false" data-ai-config-tab="engine">AI 引擎</button>
  </div>

  <!-- Tab：API 配置（接口 / 密钥 / 模型 / 搜索） -->
  <div class="ai-config-pane is-active" role="tabpanel" data-ai-config-pane="api">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;width:100%;margin-bottom:8px;">
      <div class="form-group" style="margin-bottom:0;">
        <label>API 接口地址</label>
        <input type="text" id="apiUrl" value="https://api.openai.com/v1" placeholder="https://..." style="width:100%;" />
      </div>
      <div class="form-group" style="margin-bottom:0;">
        <label>API 密钥</label>
        <input type="password" id="apiKey" placeholder="sk-..." style="width:100%;" />
      </div>
    </div>

    <div id="apiUrlHint" style="display:none;margin-bottom:8px;"></div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;width:100%;margin-bottom:8px;">
      <button type="button" id="btnFetchModels" class="btn btn-fetch" style="margin:0;">拉取模型</button>
      <div class="form-group" style="margin-bottom:0;">
        <select id="modelSelect" style="width:100%;">
          <option value="">请先获取模型...</option>
        </select>
      </div>
    </div>
    <div id="fetchModelsStatus" class="fetch-models-status" aria-live="polite"></div>

    <hr class="divider" />

    <!-- Embedding / RAG 向量（可独立于上方主 Chat API） -->
    <section class="ai-embed-rag-block" aria-labelledby="aiEmbedRagHeading">
      <h3 id="aiEmbedRagHeading" class="ai-embed-rag-heading">Embedding / RAG 向量</h3>
      <p class="ai-config-field-hint ai-embed-rag-intro">
        可单独配置 Embedding 接口；URL / Key 留空则回退使用上方主 API。
        配置完成后，请到侧栏 <a href="#novel-analyze" class="ai-embed-rag-link">小说分析</a> 点击「重建索引」。
      </p>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;width:100%;margin-bottom:8px;">
        <div class="form-group" style="margin-bottom:0;">
          <label for="embeddingApiUrl">Embedding API URL</label>
          <input type="text" id="embeddingApiUrl" placeholder="留空则使用上方 API 接口地址" style="width:100%;" />
        </div>
        <div class="form-group" style="margin-bottom:0;">
          <label for="embeddingApiKey">Embedding API Key</label>
          <input type="password" id="embeddingApiKey" placeholder="留空则使用上方 API 密钥" style="width:100%;" />
        </div>
      </div>
      <div class="form-group">
        <label for="embeddingModel">Embedding 模型</label>
        <input type="text" id="embeddingModel" placeholder="text-embedding-3-small" style="width:100%;" />
        <p class="ai-config-field-hint">留空使用默认 <code>text-embedding-3-small</code>。若接口不支持向量，会自动降级为关键词检索。</p>
      </div>
      <label class="novel-switch ai-embed-rag-switch" for="assistantNovelRagEnable">
        <input type="checkbox" id="assistantNovelRagEnable" checked />
        <span>助手问答启用小说 RAG</span>
      </label>
      <div class="form-group" style="margin-bottom: 0;">
        <label for="assistantNovelRagBudget">助手 RAG 注入预算（字）</label>
        <input type="number" id="assistantNovelRagBudget" value="12000" min="2000" max="60000" step="1000" style="width:100%;" />
      </div>
    </section>

    <hr class="divider" />

    <div class="ai-debug-box">
      <label class="ai-debug-toggle" for="aiDebugEnable">
        <input type="checkbox" id="aiDebugEnable" />
        <span>AI Debug 模式</span>
      </label>
      <div id="aiDebugStatus" class="ai-debug-status">关闭：仅显示常规错误。开启后可在 F12 Console 查看请求摘要、原始响应和 JSON 解析失败细节。</div>
    </div>

    <hr class="divider" />

    <!-- 联网搜索配置 -->
    <div id="searchConfigBlock" style="margin-bottom: 16px;">
      <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px;">
        <div style="display: flex; align-items: center; gap: 8px;">
          <input type="checkbox" id="searchEnable" />
          <label for="searchEnable" class="search-enable-label">联网搜索增强</label>
        </div>
        <span id="searchModeBadge" style="font-size: 0.62rem; padding: 2px 8px; border-radius: 99px; font-weight: 600; display: none;"></span>
      </div>

      <div id="searchConfigDetail" style="display: none;">
        <p style="font-size: 0.7rem; color: var(--color-text-muted); margin: 0 0 12px 0; line-height: 1.5;">
          开启后，AI 生成角色/世界书前会先搜索相关资料作为参考。<br/>
          <span style="color: var(--color-text-muted);">• 不填搜索 Key → 依赖 AI 模型自带联网能力（Gemini/Perplexity 等）</span><br/>
          <span style="color: var(--color-text-muted);">• 填写搜索 Key → 独立搜索引擎，结果更可靠</span>
        </p>

        <div class="form-group" style="margin-bottom: 10px;">
          <label>搜索引擎</label>
          <select id="searchEngine">
            <option value="none" selected>不使用独立搜索（靠 AI 自身联网）</option>
            <option value="serper">Serper.dev（Google 结果 · 免费 2500次/月）</option>
            <option value="tavily">Tavily（AI 专用 · 免费 1000次/月）</option>
          </select>
        </div>

        <div id="searchKeyGroup" style="display: none;">
          <div class="form-group" style="margin-bottom: 10px;">
            <label id="searchKeyLabel">搜索 API Key</label>
            <input type="password" id="searchApiKey" placeholder="填入搜索引擎的 API Key..." />
          </div>
          <div id="searchRegisterHint" style="font-size: 0.68rem; color: var(--color-text-muted); margin-bottom: 10px; line-height: 1.5;"></div>
        </div>

        <div class="grid-2" style="margin-bottom: 10px;">
          <div class="form-group" style="margin-bottom: 0;">
            <label>搜索结果数量</label>
            <select id="searchResultCount">
              <option value="3">3 条</option>
              <option value="5" selected>5 条</option>
              <option value="8">8 条</option>
              <option value="12">12 条</option>
            </select>
          </div>
          <div class="form-group" style="margin-bottom: 0;">
            <label>搜索语言</label>
            <select id="searchLang">
              <option value="zh-CN" selected>中文</option>
              <option value="en">English</option>
              <option value="ja">日本語</option>
              <option value="auto">自动检测</option>
            </select>
          </div>
        </div>

        <div class="form-group" style="margin-bottom: 10px;">
          <label>自定义搜索词 <span style="font-weight: normal; color: var(--color-text-muted);">（留空则自动从提示词提取）</span></label>
          <input type="text" id="searchCustomQuery" placeholder="例如：赛博朋克 世界观 设定集..." />
        </div>

        <div style="display: flex; gap: 8px; align-items: center;">
          <button id="btnTestSearch" class="btn btn-fetch" style="width: auto; padding: 6px 14px; font-size: 0.78rem; margin: 0;">🔍 测试搜索</button>
          <span id="searchTestStatus" style="font-size: 0.72rem; color: var(--color-text-muted);"></span>
        </div>

        <div id="searchPreview" style="display: none; margin-top: 10px; max-height: 200px; overflow-y: auto; background: rgba(0,0,0,0.3); border-radius: 8px; padding: 10px; font-size: 0.72rem;"></div>
      </div>
    </div>
  </div>

  <!-- Tab：酒馆预设 -->
  <div class="ai-config-pane" role="tabpanel" data-ai-config-pane="preset" hidden>
    <div class="preset-upload">
      <label class="preset-import-label">导入酒馆原生预设 (.json)</label>
      <input type="file" id="presetInput" accept=".json" />
      <!-- 预设勾选列表：在 360px 基础上再增高一半，便于一次看到更多规则 -->
      <div id="presetListContainer" style="display: none; max-height: 540px; overflow-y: auto; margin-top: 10px; background: rgba(0,0,0,0.3); border-radius: 8px; padding: 8px;"></div>
      <div id="presetStatus" style="font-size: 0.75rem; margin-top: 8px; color: var(--color-text-muted);">
        导入预设后，可勾选要注入的文风和规则
      </div>
    </div>
  </div>

  <!-- Tab：AI 引擎选项（非生成区；标签 AI 上下文字数等） -->
  <div class="ai-config-pane" role="tabpanel" data-ai-config-pane="engine" hidden>
    <p class="ai-config-engine-tip">此处为引擎相关选项。一键生成请到「角色设定」右上角「AI 引擎」。</p>
    <div class="form-group">
      <label for="tagContextChars">标签生成上下文字数</label>
      <input type="number" id="tagContextChars" value="12000" min="1000" max="200000" step="1000" style="width:100%;" />
      <p class="ai-config-field-hint">默认 12000（12k）。角色标签 AI 生成时，按此上限截断世界书等上下文。</p>
    </div>
    <p class="ai-config-field-hint">小说向量检索（Embedding 模型、RAG 开关）已移至「API 配置」Tab 的 <strong>Embedding / RAG 向量</strong> 区块。</p>
  </div>
</div>

<AiEngineModal />

<style>
  /* AI 配置 Tab：复用 ui-tabs，局部仅保留 ai-config-* 钩子 */
  .ai-config-tabs { /* ui-tabs 已定义布局 */ }
  .ai-config-tab { /* ui-tabs__tab 已定义 */ }
  .ai-stage-label {
    display: block;
    font-weight: 600;
    margin-bottom: 6px;
  }
  .ai-stage-label--char { color: var(--color-accent-hover); }
  .ai-stage-label--wb { color: var(--color-success); }
  .ai-stage-label--sm { font-size: 0.78rem; margin: 0 0 4px 0; }

  .ai-config-engine-tip {
    font-size: 0.72rem;
    color: var(--color-text-muted);
    margin: 0 0 12px;
    line-height: 1.5;
  }
  .ai-config-field-hint {
    font-size: 0.68rem;
    color: var(--color-text-muted);
    margin: 6px 0 0;
    line-height: 1.45;
  }
  .ai-embed-rag-block {
    margin-bottom: 16px;
    padding: 12px 14px;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-accent-border);
    background: rgba(99, 102, 241, 0.06);
  }
  .ai-embed-rag-heading {
    margin: 0 0 8px;
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--color-accent-hover);
  }
  .ai-embed-rag-intro {
    margin: 0 0 12px;
  }
  .ai-embed-rag-link {
    color: var(--color-accent-hover);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .ai-embed-rag-link:hover {
    color: var(--color-accent);
  }
  .ai-embed-rag-switch {
    display: flex;
    align-items: center;
    gap: 8px;
    margin: 10px 0;
  }

  .ai-debug-box {
    margin: -2px 0 16px;
    padding: 10px 12px;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border-subtle);
    background: var(--color-surface-inset);
  }
  .ai-debug-toggle {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin: 0;
    color: var(--color-accent-hover);
    font-size: 0.8rem;
    font-weight: 700;
    cursor: pointer;
  }
  .ai-debug-status {
    margin-top: 8px;
    font-size: 0.68rem;
    line-height: 1.5;
    color: var(--color-text-muted);
  }

  /* ── 协议提示条 ── */
  .fetch-models-status {
    min-height: 1.2em;
    margin: 0 0 12px 0;
    font-size: 0.72rem;
    line-height: 1.4;
    color: var(--color-text-muted);
  }

  #apiUrlHint {
    width: 100%;
    box-sizing: border-box;
    font-size: 0.72rem;
  }
  #apiUrlHint .hint-bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 5px 10px;
    border-radius: 6px;
    cursor: default;
    line-height: 1.4;
  }
  #apiUrlHint .hint-detail {
    display: none;
    padding: 6px 10px 8px 10px;
    border-radius: 0 0 6px 6px;
    margin-top: -2px;
    font-size: 0.7rem;
    line-height: 1.7;
  }
  #apiUrlHint:hover .hint-detail {
    display: block;
  }

  /* 骨架条数：复用 ui-pill-btn */
  .wb-count-btn {
    /* ui-pill-btn 样式由 ui-patterns 提供 */
  }

  .search-enable-label {
    margin: 0;
    color: var(--color-accent-hover);
    cursor: pointer;
    font-weight: 700;
    font-size: 0.88rem;
  }

  /* 搜索配置块：inset 卡片 */
  #searchConfigBlock {
    background: var(--color-surface-inset);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-md);
    padding: 14px;
    transition: border-color var(--dur-normal) var(--ease-out),
      background var(--dur-normal) var(--ease-out);
    position: relative;
    z-index: 10;
    overflow: visible;
  }
  #searchConfigBlock.active {
    border-color: var(--color-accent-border);
    background: oklch(72% 0.14 305 / 0.06);
  }
  /* 放大镜扫描动画覆盖层 */
  .search-scan-overlay {
    position: absolute;
    inset: 0;
    z-index: 10;
    pointer-events: none;
    overflow: hidden;
    border-radius: inherit;
  }
  .preset-import-label {
    color: var(--color-accent-hover);
    margin-bottom: 8px;
    display: block;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .search-scan-glass {
    position: absolute;
    font-size: 2.2rem;
    filter: drop-shadow(0 0 12px var(--color-accent-glow));
    opacity: 0;
  }
  .search-scan-line {
    position: absolute;
    left: 0;
    width: 100%;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--color-accent-border), var(--color-accent), var(--color-accent-border), transparent);
    box-shadow: 0 0 12px var(--color-accent-glow);
    opacity: 0;
  }
  .search-scan-doc {
    position: absolute;
    font-size: 1.4rem;
    opacity: 0;
    filter: drop-shadow(0 0 8px var(--color-accent-glow));
  }

  /* 搜索结果预览 */
  .search-result-item {
    padding: 8px;
    border-bottom: 1px solid var(--color-border-subtle);
    transition: background var(--dur-fast) var(--ease-out);
  }
  .search-result-item:last-child { border-bottom: none; }
  .search-result-item:hover { background: var(--color-accent-soft); }
  .search-result-title {
    color: var(--color-accent-hover);
    font-weight: 600;
    font-size: 0.75rem;
    margin-bottom: 3px;
  }
  .search-result-snippet {
    color: var(--color-text-muted);
    font-size: 0.7rem;
    line-height: 1.4;
  }
  .search-result-url {
    color: var(--color-text-muted);
    font-size: 0.62rem;
    margin-top: 2px;
    word-break: break-all;
  }
</style>

<script>
  import { initAiConfigPanel } from '../lib/aiConfig/panelBoot.mjs';
  initAiConfigPanel();
</script>
