---
---
<!-- 试聊：右上角仅「配置」；点开自顶部滑出浮层（温度/长度/调试/重置等） -->
<div class="panel chat-playground">
  <div class="chat-panel-header panel-header">
    <h2>角色试聊</h2>
    <div class="chat-header-actions">
      <button type="button" id="btnChatConfig" class="chat-config-link" aria-expanded="false" aria-controls="chatConfigDrawer">配置</button>
    </div>
  </div>

  <div id="chatConfigDrawer" class="chat-config-drawer" hidden aria-hidden="true">
    <div class="chat-config-drawer__backdrop" data-chat-config-close></div>
    <div class="chat-config-drawer__panel" role="dialog" aria-modal="true" aria-labelledby="chatConfigDrawerTitle">
      <div class="chat-config-drawer__head">
        <strong id="chatConfigDrawerTitle">试聊配置</strong>
        <button type="button" class="btn-icon chat-config-drawer__close" data-chat-config-close aria-label="关闭配置">×</button>
      </div>
      <div class="chat-config-drawer__ops">
        <span class="chat-indicator" id="chatWbIndicator" title="世界书触发状态">WB 0</span>
        <span class="chat-indicator" id="chatTokenIndicator" title="估算 Token 数">~0 tok</span>
        <label class="debug-toggle" title="调试模式">
          <input type="checkbox" id="chatShowPrompt" />
          <span>调试</span>
        </label>
        <button id="btnChatReset" class="btn btn-sm btn-ghost btn-chat-ctrl" type="button">重置</button>
        <button id="btnChatRegenerate" class="btn btn-sm btn-ghost btn-chat-ctrl" type="button">重新生成</button>
      </div>
      <div class="chat-controls">
        <div class="chat-settings-bar">
          <div class="chat-setting-group">
            <div class="chat-setting-item">
              <div class="setting-label-row">
                <span class="setting-label">温度</span>
                <span class="setting-value" id="chatTempValue">0.85</span>
              </div>
              <input type="range" id="chatTemperature" min="0" max="2" step="0.05" value="0.85" class="ui-slider setting-slider" />
              <div class="setting-hint-row">
                <span>精确</span>
                <span>狂野</span>
              </div>
            </div>

            <div class="setting-divider"></div>

            <div class="chat-setting-item">
              <div class="setting-label-row">
                <span class="setting-label">回复长度</span>
                <input type="number" id="chatMaxTokensInput" class="token-number-input" value="2000" min="100" max="16000" step="100" />
              </div>
              <input type="range" id="chatMaxTokensSlider" min="100" max="16000" step="100" value="2000" class="setting-slider token-slider" />
              <div class="setting-hint-row">
                <span>精简 100</span>
                <span>16000 极限</span>
              </div>
              <select id="chatMaxTokens" style="display:none;">
                <option value="2000" selected>2000</option>
              </select>
            </div>

            <div class="setting-divider"></div>

            <div class="chat-setting-item">
              <div class="setting-label-row">
                <span class="setting-label" title="ST 1.18：最近 N 条消息作为世界书扫描缓冲">扫描深度</span>
                <input type="number" id="chatScanDepth" class="token-number-input" value="2" min="0" max="100" step="1" title="ST 1.18：最近 N 条" />
              </div>
            </div>

            <div class="chat-setting-item">
              <div class="setting-label-row">
                <span class="setting-label" title="替换 {{user}}">用户名</span>
                <input type="text" id="chatUserName" class="token-number-input chat-user-name-input" value="User" title="用于 {{user}}" />
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- 中间对话区：触发标签 / 调试 / 消息一并内滚，避免撑破面板 -->
  <div class="chat-conversation" id="chatConversation">
    <div id="chatWbTriggerBar" style="display: none;">
      <div id="chatWbTriggerList"></div>
    </div>
    <div id="chatPromptDebug" style="display: none;"></div>
    <div id="chatMessages" class="chat-messages">
      <div class="chat-empty-hint">
        <div style="color: var(--color-text-muted); font-size: 0.82rem;">点击「开始试聊」加载开场白</div>
        <div style="color: var(--color-text-muted); font-size: 0.72rem; margin-top: 4px;">世界书/正则按 SillyTavern 1.18.0 规则试运行</div>
      </div>
    </div>
  </div>

  <!-- 输入区（固定） -->
  <div class="chat-input-area">
    <button id="btnChatStart" class="btn btn-primary btn-chat-start">开始试聊</button>
    <div id="chatInputRow" style="display: none;">
      <div class="chat-compose-row">
        <textarea id="chatInput" class="chat-compose-input" placeholder="说点什么..." rows="2"></textarea>
        <button type="button" id="btnChatSend" class="btn-icon btn-icon--primary chat-btn-send" title="发送" aria-label="发送">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12l14-7-7 14-2-5-5-2z"/></svg>
        </button>
      </div>
      <div class="chat-compose-meta">
        <span class="chat-compose-hint">Enter 发送 · Shift+Enter 换行</span>
        <span id="chatTypingIndicator" class="chat-typing-indicator" style="display: none;">
          <span class="typing-dots">
            <span>.</span><span>.</span><span>.</span>
          </span>
          角色思考中
        </span>
      </div>
    </div>
  </div>
</div>

<style>
  /* 占满主区剩余高度：顶栏 / 中消息滚动 / 下输入固定 */
  .chat-playground {
    display: flex;
    flex-direction: column;
    flex: 1 1 auto;
    min-height: 0;
    height: 100%;
    max-height: none;
    overflow: hidden;
    position: relative;
  }

  .chat-panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    flex-shrink: 0;
    margin-bottom: 10px;
  }
  .chat-panel-header h2 {
    margin: 0;
    flex-shrink: 0;
  }
  .chat-header-actions {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 6px;
    flex-wrap: nowrap;
    min-width: 0;
  }
  .chat-header-actions .btn.btn-chat-ctrl {
    white-space: nowrap;
    width: auto;
    min-width: 0;
    margin: 0;
  }
  .chat-config-link {
    font-size: 0.68rem;
    padding: 2px 0;
    border: none;
    background: transparent;
    color: var(--color-text-muted);
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 2px;
    font-family: inherit;
    line-height: 1.2;
  }
  .chat-config-link:hover {
    color: var(--color-accent);
  }
  .chat-config-link[aria-expanded="true"] {
    color: var(--color-accent-hover);
  }

  .chat-config-drawer[hidden] {
    display: none !important;
  }
  .chat-config-drawer {
    position: absolute;
    inset: 0;
    z-index: 40;
    display: flex;
    flex-direction: column;
    pointer-events: none;
  }
  .chat-config-drawer.is-open {
    pointer-events: auto;
  }
  .chat-config-drawer__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(8, 10, 18, 0.45);
    opacity: 0;
    transition: opacity 0.22s ease;
  }
  .chat-config-drawer.is-open .chat-config-drawer__backdrop {
    opacity: 1;
  }
  .chat-config-drawer__panel {
    position: relative;
    z-index: 1;
    margin: 0;
    padding: 12px 14px 14px;
    border-radius: 0 0 12px 12px;
    border: 1px solid var(--color-border-subtle);
    border-top: none;
    background: var(--color-surface-elevated, var(--color-surface));
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.35);
    transform: translateY(-108%);
    transition: transform 0.28s cubic-bezier(0.22, 1, 0.36, 1);
    max-height: min(78%, 520px);
    overflow-x: hidden;
    overflow-y: auto;
  }
  .chat-config-drawer.is-open .chat-config-drawer__panel {
    transform: translateY(0);
  }
  .chat-config-drawer__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    margin-bottom: 10px;
  }
  .chat-config-drawer__head strong {
    font-size: 0.82rem;
  }
  .chat-config-drawer__close {
    width: 28px;
    height: 28px;
    font-size: 1.1rem;
    line-height: 1;
  }
  .chat-config-drawer__ops {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px;
    margin-bottom: 10px;
  }
  .chat-config-drawer__ops .btn.btn-chat-ctrl {
    white-space: nowrap;
    width: auto;
    min-width: 0;
    margin: 0;
  }

  .chat-controls {
    flex-shrink: 0;
  }

  .chat-indicator {
    font-size: 0.64rem;
    background: var(--color-surface-inset);
    padding: 2px 7px;
    border-radius: var(--radius-pill);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border-subtle);
    white-space: nowrap;
  }
  .chat-indicator.active {
    color: var(--color-success);
    border-color: oklch(72% 0.14 155 / 0.3);
    background: oklch(72% 0.14 155 / 0.08);
  }

  
  .chat-settings-bar {
    background: var(--color-surface-inset);
    border: 1px solid var(--color-border-subtle);
    border-radius: 10px;
    padding: 12px 14px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  /* 抽屉内始终纵向：窄栏/移动端不再横挤四列 */
  .chat-setting-group {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 12px;
  }
  .chat-setting-item {
    flex: none;
    min-width: 0;
    width: 100%;
    display: flex;
    flex-direction: column;
  }
  .chat-setting-item .setting-label-row {
    flex-shrink: 0;
  }
  .chat-setting-item .setting-slider {
    flex-shrink: 0;
  }
  .chat-setting-item .setting-hint-row {
    flex-shrink: 0;
  }
  .setting-divider {
    width: 100%;
    height: 1px;
    background: var(--color-accent-soft);
    align-self: stretch;
    flex-shrink: 0;
  }
  .setting-label-row {
    display: flex;
    align-items: center;
    gap: 4px;
    margin-bottom: 6px;
    min-height: 24px;
  }
  .setting-icon {
    font-size: 0.9rem;
  }
  .setting-label {
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--color-accent-hover);
    letter-spacing: 0.02em;
  }
  .setting-value {
    font-size: 0.75rem;
    color: var(--color-accent-hover);
    font-family: var(--font-mono);
    font-weight: 700;
    margin-left: auto;
    background: var(--color-accent-soft);
    padding: 1px var(--space-2);
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-accent-border);
  }
  .setting-slider {
    /* ui-slider 提供 thumb/track */
  }
  .setting-hint-row {
    display: flex;
    justify-content: space-between;
    font-size: 0.58rem;
    color: var(--color-text-muted);
    margin-top: 3px;
    padding: 0 2px;
  }

  
  .token-number-input {
    width: 58px;
    height: 20px;
    box-sizing: border-box;
    background: var(--color-accent-soft);
    border: 1px solid var(--color-accent-border);
    border-radius: var(--radius-sm);
    color: var(--color-accent-hover);
    font-size: 0.75rem;
    font-family: var(--font-mono);
    font-weight: 700;
    text-align: center;
    outline: none;
    margin-left: auto;
    padding: 0 4px;
    line-height: 18px;
    transition: border-color var(--dur-fast) var(--ease-out),
      box-shadow var(--dur-fast) var(--ease-out);
    -moz-appearance: textfield;
  }
  .token-number-input::-webkit-inner-spin-button,
  .token-number-input::-webkit-outer-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  .token-number-input:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 8px var(--color-accent-glow);
  }
  .token-slider {
    background: var(--color-slider-track) !important;
  }
  .chat-user-name-input {
    width: auto;
    min-width: 5.5rem;
    max-width: 12rem;
    text-align: left;
    padding-left: 8px;
    padding-right: 8px;
  }

  .debug-toggle {
    display: flex;
    align-items: center;
    gap: 3px;
    cursor: pointer;
    font-size: 0.64rem;
    color: var(--color-text-muted);
    margin: 0;
    font-weight: 500;
    text-transform: none;
    letter-spacing: 0;
    transition: color 0.2s;
    padding: 2px 6px;
    border-radius: 6px;
    white-space: nowrap;
  }
  .debug-toggle:hover {
    color: var(--color-text-muted);
    background: var(--color-surface-inset);
  }
  .debug-toggle input {
    margin: 0;
  }

  /* 中间层吃满剩余高度并滚动：触发标签过长不撑破整页 */
  .chat-conversation {
    flex: 1 1 auto;
    min-height: 0;
    overflow-x: hidden;
    overflow-y: auto;
    scroll-behavior: smooth;
    scrollbar-gutter: stable;
    display: flex;
    flex-direction: column;
  }

  #chatWbTriggerBar {
    flex-shrink: 0;
    background: var(--color-success-soft);
    border: 1px solid var(--color-success-border);
    border-radius: var(--radius-sm);
    padding: var(--space-2) 10px;
    margin-bottom: 10px;
  }
  #chatWbTriggerList {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }
  .wb-trigger-tag {
    font-size: 0.62rem;
    padding: 2px 8px;
    border-radius: 99px;
    font-weight: 600;
    animation: wbTagPop 0.3s ease;
  }
  .wb-trigger-tag.active {
    background: oklch(72% 0.14 155 / 0.18);
    color: var(--color-success);
    border: 1px solid var(--color-success-border);
  }
  .wb-trigger-tag.inactive {
    background: var(--color-surface-inset);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border-subtle);
  }
  @keyframes wbTagPop {
    0% { transform: scale(0.8); opacity: 0; }
    100% { transform: scale(1); opacity: 1; }
  }

  /* 调试区随对话区滚动，不再单独占 flex 高度 */
  #chatPromptDebug {
    flex-shrink: 0;
    background: var(--color-overlay);
    border: 1px solid var(--color-accent-border);
    border-radius: 10px;
    padding: 16px;
    margin-bottom: 10px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    white-space: pre-wrap;
    word-break: break-word;
    word-wrap: break-word;
    overflow-wrap: break-word;
  }

  /* 消息列表随内容增高，滚动由 .chat-conversation 承担 */
  .chat-messages {
    flex: 1 1 auto;
    min-height: 0;
    padding: 8px 4px;
  }
  .chat-empty-hint {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 140px;
    height: 100%;
    text-align: center;
  }

  
  .chat-msg {
    display: flex;
    gap: 10px;
    margin-bottom: 14px;
    animation: chatMsgIn 0.35s ease;
  }
  @keyframes chatMsgIn {
    0% { opacity: 0; transform: translateY(12px); }
    100% { opacity: 1; transform: translateY(0); }
  }
  .chat-msg.user { flex-direction: row-reverse; }

  .chat-avatar {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .chat-avatar.char {
    background: var(--color-accent-soft);
    border: 1px solid var(--color-accent-border);
  }
  .chat-avatar.user-av {
    background: var(--color-msg-user-bg);
    border: 1px solid var(--color-msg-user-border);
  }

  .chat-bubble {
    max-width: 78%;
    padding: 10px 14px;
    border-radius: 14px;
    font-size: 0.82rem;
    line-height: 1.6;
    position: relative;
  }
  .chat-bubble.char {
    background: var(--color-msg-char-bg);
    border: 1px solid var(--color-msg-char-border);
    color: var(--color-text-secondary);
    border-top-left-radius: 4px;
  }
  .chat-bubble.user {
    background: var(--color-msg-user-bg);
    border: 1px solid var(--color-msg-user-border);
    color: var(--color-text-secondary);
    border-top-right-radius: 4px;
  }
  .chat-bubble .chat-name {
    font-size: 0.68rem;
    font-weight: 700;
    margin-bottom: 4px;
    display: block;
  }
  .chat-bubble.char .chat-name { color: var(--color-accent-hover); }
  .chat-bubble.user .chat-name { color: var(--color-accent-hover); }
  .chat-bubble .chat-text {
    white-space: pre-wrap;
    word-break: break-word;
  }

  /* 变量更新组件 */
  .chat-var-update {
    margin: 12px 0 6px;
    border-radius: 14px;
    background: var(--color-surface-elevated);
    border: 1px solid var(--color-warning-border);
    box-shadow: 0 16px 40px rgba(2, 6, 23, 0.38);
    overflow: hidden;
    font-family: 'Courier New', monospace;
    position: relative;
  }
  .chat-var-update::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: repeating-linear-gradient(
      180deg,
      transparent,
      transparent 2px,
      transparent 2px,
      transparent 4px
    );
  }
  .cvu-header {
    position: relative;
    z-index: 1;
    padding: 11px 14px;
    background: linear-gradient(90deg, var(--color-warning-soft), transparent);
    color: var(--color-warning);
    font-size: 0.84rem;
    font-weight: 700;
    letter-spacing: 1.6px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    border-bottom: 1px solid var(--color-warning-border);
  }
  .cvu-header-main {
    display: flex;
    align-items: center;
    gap: 10px;
    min-width: 0;
  }
  .cvu-header-dot {
    width: 9px;
    height: 9px;
    border-radius: 999px;
    background: var(--color-warning);
    box-shadow: 0 0 12px var(--color-warning);
    flex-shrink: 0;
  }
  .cvu-header-tag {
    color: var(--color-warning);
    font-size: 0.62rem;
    letter-spacing: 1.2px;
    white-space: nowrap;
  }
  .cvu-body {
    display: block;
    position: relative;
    z-index: 1;
  }
  .cvu-analysis {
    padding: 12px 14px 8px;
    color: var(--color-text);
    font-size: 0.74rem;
    line-height: 1.7;
    white-space: pre-line;
  }
  .cvu-analysis-label {
    display: block;
    margin-bottom: 7px;
    color: var(--color-warning);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
  }
  .cvu-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
    padding: 0 14px 12px;
  }
  .cvu-stat {
    min-width: 0;
    padding: 12px 14px;
    border-radius: 10px;
    border: 1px solid var(--color-warning-border);
    background: var(--color-warning-soft);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.02);
  }
  .cvu-stat-label {
    display: block;
    margin-bottom: 6px;
    color: var(--color-warning);
    font-size: 0.64rem;
    font-weight: 700;
    line-height: 1.4;
  }
  .cvu-stat-value {
    display: block;
    color: var(--color-text);
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.45;
    word-break: break-word;
  }
  .cvu-stat-path {
    display: block;
    margin-top: 6px;
    color: var(--color-text-muted);
    font-size: 0.56rem;
    letter-spacing: 0.4px;
    word-break: break-word;
  }
  .cvu-stat-note {
    display: block;
    margin-top: 6px;
    color: var(--color-warning);
    font-size: 0.62rem;
    line-height: 1.5;
    word-break: break-word;
  }
  .cvu-empty {
    padding: 0 14px 12px;
    color: var(--color-text-secondary);
    font-size: 0.7rem;
  }
  .cvu-debug {
    padding: 0 14px 14px;
  }
  .cvu-debug summary {
    cursor: pointer;
    color: var(--color-warning);
    font-size: 0.7rem;
    font-weight: 700;
  }
  .cvu-patch {
    padding: 12px 14px;
    margin: 10px 0 0;
    color: var(--color-warning);
    font-size: 0.68rem;
    line-height: 1.55;
    overflow-x: auto;
    background: rgba(2, 6, 23, 0.56);
    border: 1px solid var(--color-warning-border);
    border-radius: 10px;
    white-space: pre-wrap;
    font-family: 'Cascadia Code', 'Fira Code', monospace;
  }
  @media (max-width: 640px) {
    .cvu-grid {
      grid-template-columns: 1fr;
    }
  }

  
  .chat-input-area {
    flex-shrink: 0;
    border-top: 1px solid var(--color-accent-soft);
    padding-top: 10px;
  }
  .btn-chat-start {
    width: 100%;
    background: var(--color-accent-strong);
    color: white;
    padding: 12px;
    border: none;
    border-radius: 10px;
