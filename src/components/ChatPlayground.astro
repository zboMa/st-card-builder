---
---
<!-- 试聊：右上角仅「配置」；点开自顶部滑出浮层（温度/长度/调试/重置等） -->
<div class="panel chat-playground">
  <div class="chat-panel-header panel-header">
    <h2>角色试聊</h2>
    <div class="chat-header-actions">
      <button type="button" id="btnChatConfig" class="chat-config-link" aria-expanded="false" aria-controls="chatConfigDrawer">配置</button>
    </div>
  </div>

  <div id="chatConfigDrawer" class="chat-config-drawer" hidden aria-hidden="true">
    <div class="chat-config-drawer__backdrop" data-chat-config-close></div>
    <div class="chat-config-drawer__panel" role="dialog" aria-modal="true" aria-labelledby="chatConfigDrawerTitle">
      <div class="chat-config-drawer__head">
        <strong id="chatConfigDrawerTitle">试聊配置</strong>
        <button type="button" class="btn-icon chat-config-drawer__close" data-chat-config-close aria-label="关闭配置">×</button>
      </div>
      <div class="chat-config-drawer__ops">
        <span class="chat-indicator" id="chatWbIndicator" title="世界书触发状态">WB 0</span>
        <span class="chat-indicator" id="chatTokenIndicator" title="估算 Token 数">~0 tok</span>
        <label class="debug-toggle" title="调试模式">
          <input type="checkbox" id="chatShowPrompt" />
          <span>调试</span>
        </label>
        <button id="btnChatReset" class="btn btn-sm btn-ghost btn-chat-ctrl" type="button">重置</button>
        <button id="btnChatRegenerate" class="btn btn-sm btn-ghost btn-chat-ctrl" type="button">重新生成</button>
      </div>
      <div class="chat-controls">
        <div class="chat-settings-bar">
          <div class="chat-setting-group">
            <div class="chat-setting-item">
              <div class="setting-label-row">
                <span class="setting-label">温度</span>
                <span class="setting-value" id="chatTempValue">0.85</span>
              </div>
              <input type="range" id="chatTemperature" min="0" max="2" step="0.05" value="0.85" class="ui-slider setting-slider" />
              <div class="setting-hint-row">
                <span>精确</span>
                <span>狂野</span>
              </div>
            </div>

            <div class="setting-divider"></div>

            <div class="chat-setting-item">
              <div class="setting-label-row">
                <span class="setting-label">回复长度</span>
                <input type="number" id="chatMaxTokensInput" class="token-number-input" value="2000" min="100" max="16000" step="100" />
              </div>
              <input type="range" id="chatMaxTokensSlider" min="100" max="16000" step="100" value="2000" class="setting-slider token-slider" />
              <div class="setting-hint-row">
                <span>精简 100</span>
                <span>16000 极限</span>
              </div>
              <select id="chatMaxTokens" style="display:none;">
                <option value="2000" selected>2000</option>
              </select>
            </div>

            <div class="setting-divider"></div>

            <div class="chat-setting-item">
              <div class="setting-label-row">
                <span class="setting-label" title="ST 1.18：最近 N 条消息作为世界书扫描缓冲">扫描深度</span>
                <input type="number" id="chatScanDepth" class="token-number-input" value="2" min="0" max="100" step="1" title="ST 1.18：最近 N 条" />
              </div>
            </div>

            <div class="chat-setting-item">
              <div class="setting-label-row">
                <span class="setting-label" title="替换 {{user}}">用户名</span>
                <input type="text" id="chatUserName" class="token-number-input chat-user-name-input" value="User" title="用于 {{user}}" />
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- 中间对话区：触发标签 / 调试 / 消息一并内滚，避免撑破面板 -->
  <div class="chat-conversation" id="chatConversation">
    <div id="chatWbTriggerBar" style="display: none;">
      <div id="chatWbTriggerList"></div>
    </div>
    <div id="chatPromptDebug" style="display: none;"></div>
    <div id="chatMessages" class="chat-messages">
      <div class="chat-empty-hint">
        <div style="color: var(--color-text-muted); font-size: 0.82rem;">点击「开始试聊」加载开场白</div>
        <div style="color: var(--color-text-muted); font-size: 0.72rem; margin-top: 4px;">世界书/正则按 SillyTavern 1.18.0 规则试运行</div>
      </div>
    </div>
  </div>

  <!-- 输入区（固定） -->
  <div class="chat-input-area">
    <button id="btnChatStart" class="btn btn-primary btn-chat-start">开始试聊</button>
    <div id="chatInputRow" style="display: none;">
      <div class="chat-compose-row">
        <textarea id="chatInput" class="chat-compose-input" placeholder="说点什么..." rows="2"></textarea>
        <button type="button" id="btnChatSend" class="btn-icon btn-icon--primary chat-btn-send" title="发送" aria-label="发送">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12l14-7-7 14-2-5-5-2z"/></svg>
        </button>
      </div>
      <div class="chat-compose-meta">
        <span class="chat-compose-hint">Enter 发送 · Shift+Enter 换行</span>
        <span id="chatTypingIndicator" class="chat-typing-indicator" style="display: none;">
          <span class="typing-dots">
            <span>.</span><span>.</span><span>.</span>
          </span>
          角色思考中
        </span>
      </div>
    </div>
  </div>
</div>

<link rel="stylesheet" href="../styles/chat-playground.css" />

<script>
  import { initChatPlayground } from '../lib/chatRuntime/playgroundBoot.mjs';
  initChatPlayground();
</script>
