---
/**
 * 侧栏三段式：顶品牌 / 中可滚菜单 / 底配置
 * 导航项使用统一线性 SVG，不用 emoji
 * 窄屏（≤900px）：左侧滑出抽屉，由顶栏汉堡控制
 */

/** 16px 线性图标 path（stroke 由 CSS currentColor 控制） */
const NAV_ICON = {
  cards: '<rect x="3" y="5" width="18" height="14" rx="2"/><path d="M7 9h10M7 13h6"/>',
  user: '<circle cx="12" cy="8" r="3.5"/><path d="M5 19c0-3.5 3-6 7-6s7 2.5 7 6"/>',
  spark: '<path d="M12 3l1.8 5.5L19 10l-5.2 1.5L12 17l-1.8-5.5L5 10l5.2-1.5L12 3z"/>',
  chat: '<path d="M5 7a3 3 0 0 1 3-3h8a3 3 0 0 1 3 3v6a3 3 0 0 1-3 3H9l-4 3V7z"/>',
  book: '<path d="M5 5h12a2 2 0 0 1 2 2v12H7a2 2 0 0 1-2-2V5z"/><path d="M7 5v12a2 2 0 0 0 2 2h10"/>',
  chart: '<path d="M5 19V9M12 19V5M19 19v-7"/>',
  sliders: '<path d="M4 8h16M4 16h16"/><circle cx="9" cy="8" r="2"/><circle cx="15" cy="16" r="2"/>',
  regex: '<path d="M6 8h4l2 8 2-8h4"/>',
  scroll: '<path d="M8 4h8v16H8z"/><path d="M10 7h4M10 11h4M10 15h2"/>',
  doc: '<path d="M8 4h6l4 4v12H8z"/><path d="M14 4v4h4"/>',
  split: '<path d="M4 6h16M4 12h10M4 18h14"/>',
  id: '<rect x="4" y="6" width="16" height="12" rx="2"/><circle cx="10" cy="12" r="2"/><path d="M14 15h4"/>',
  speak: '<path d="M8 10a4 4 0 0 1 8 0v3a4 4 0 0 1-8 0v-3z"/><path d="M12 17v2"/>',
  people: '<circle cx="9" cy="9" r="2.5"/><circle cx="16" cy="10" r="2"/><path d="M4 19c0-2.5 2.2-4 5-4M13 19c0-2 1.8-3.5 4-3.5"/>',
  pen: '<path d="M12 20h9"/><path d="M15.5 5.5l3 3L8 19l-4 1 1-4 10.5-10.5z"/>',
  code: '<path d="M8 8l-4 4 4 4M16 8l4 4-4 4M13 6l-2 12"/>',
  search: '<circle cx="11" cy="11" r="5"/><path d="M16 16l4 4"/>',
  gear: '<circle cx="12" cy="12" r="3"/><path d="M12 2v2M12 20v2M4.2 4.2l1.4 1.4M18.4 18.4l1.4 1.4M2 12h2M20 12h2M4.2 19.8l1.4-1.4M18.4 5.6l1.4-1.4"/>',
  note: '<path d="M6 4h10l4 4v12H6z"/><path d="M14 4v4h4M9 13h6M9 17h4"/>',
};

/** @typedef {{ view: string; label: string; icon: string }} NavItem */

const GROUPS = [
  {
    title: '角色卡制作',
    items: [
      { view: 'card-manager', label: '角色卡管理', icon: NAV_ICON.cards },
      { view: 'adult-config', label: '世界与限定', icon: NAV_ICON.spark },
      { view: 'character', label: '角色设定', icon: NAV_ICON.user },
      { view: 'greetings', label: '开场白', icon: NAV_ICON.chat },
      { view: 'worldbook', label: '世界书条目', icon: NAV_ICON.book },
      { view: 'statusbar', label: '状态栏', icon: NAV_ICON.chart },
      { view: 'mvu', label: 'MVU 变量节点', icon: NAV_ICON.sliders },
      { view: 'regex', label: '正则', icon: NAV_ICON.regex },
      { view: 'tavern-scripts', label: '酒馆脚本', icon: NAV_ICON.scroll },
    ],
  },
  {
    title: '小说',
    items: [
      { view: 'novel-source', label: '原始资料', icon: NAV_ICON.doc },
      { view: 'novel-chapters', label: '拆章', icon: NAV_ICON.split },
      { view: 'novel-analyze', label: '小说分析', icon: NAV_ICON.search },
      { view: 'novel-character-setup', label: '角色设定', icon: NAV_ICON.id },
      { view: 'novel-greetings', label: '开场白', icon: NAV_ICON.speak },
      { view: 'novel-characters', label: '人物列表', icon: NAV_ICON.people },
      { view: 'novel-worldbook', label: '世界书条目', icon: NAV_ICON.book },
      { view: 'novel-style', label: '文风蒸馏', icon: NAV_ICON.pen },
    ],
  },
  {
    title: '完成制作',
    items: [
      { view: 'chat', label: '角色试聊', icon: NAV_ICON.chat },
      { view: 'preview', label: 'JSON 实时追踪', icon: NAV_ICON.code },
      { view: 'auditor', label: '世界书内容监测', icon: NAV_ICON.search },
    ],
  },
];

const CONFIG_ITEMS = [
  { view: 'ai-config', label: 'AI 配置', icon: NAV_ICON.gear },
  { view: 'prompt-config', label: '提示词配置', icon: NAV_ICON.note },
];
---

<aside class="app-sidebar" id="appSidebar" aria-label="主导航">
  <div class="app-sidebar-brand" id="appSidebarBrand">
    <div class="app-brand">
      <span class="app-logo" aria-hidden="true">
        <svg class="logo-icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="4" y="4" width="16" height="16" rx="3"/>
          <path d="M8 9h8M8 13h5"/>
        </svg>
      </span>
      <div class="app-brand-text">
        <div class="app-title-row">
          <h1 class="app-title">卡片构建器</h1>
          <button type="button" id="aiTaskBadge" class="ai-task-badge" hidden title="打开 AI 任务中心" aria-label="打开 AI 任务中心">0/0</button>
        </div>
        <p class="app-subtitle">一个简单的制卡器</p>
      </div>
    </div>
  </div>

  <div class="app-sidebar-top">
    <button type="button" class="app-sidebar-toggle" id="btnSidebarToggle" aria-expanded="true" aria-controls="appSidebarNav">
      菜单
    </button>
  </div>

  <nav class="app-sidebar-nav" id="appSidebarNav">
    {GROUPS.map((group) => (
      <div class="app-sidebar-group">
        <div class="app-sidebar-group-title">{group.title}</div>
        {group.items.map((item) => (
          <button type="button" class="app-sidebar-item" data-view={item.view}>
            <svg class="app-sidebar-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={item.icon} />
            <span class="app-sidebar-label">{item.label}</span>
          </button>
        ))}
      </div>
    ))}
  </nav>

  <div class="app-sidebar-group app-sidebar-group-config" id="appSidebarConfig">
    <div class="app-sidebar-group-title">配置</div>
    {CONFIG_ITEMS.map((item) => (
      <button type="button" class="app-sidebar-item" data-view={item.view}>
        <svg class="app-sidebar-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={item.icon} />
        <span class="app-sidebar-label">{item.label}</span>
      </button>
    ))}
  </div>
</aside>

<script is:inline>
(function() {
  function initSidebarNav() {
    var DEFAULT_VIEW = 'character';
    var MOBILE_MQ = '(max-width: 900px)';
    var sidebar = document.getElementById('appSidebar');
    var nav = document.getElementById('appSidebarNav');
    var toggle = document.getElementById('btnSidebarToggle');
    var mobileOpenBtn = document.getElementById('btnMobileNavOpen');
    var backdrop = document.getElementById('appShellBackdrop');
    if (!sidebar || !nav) return;

    function isMobileShell() {
      return window.matchMedia(MOBILE_MQ).matches;
    }

    function getViewEls() {
      return document.querySelectorAll('.app-view[data-view]');
    }

    function getNavItems() {
      return sidebar.querySelectorAll('.app-sidebar-item[data-view]');
    }

    function syncBackdropVisibility() {
      if (!backdrop) return;
      var navOpen = document.body.classList.contains('is-mobile-nav-open');
      var asstOpen = document.body.classList.contains('is-mobile-assistant-open');
      var show = isMobileShell() && (navOpen || asstOpen);
      backdrop.hidden = !show;
      backdrop.setAttribute('aria-hidden', show ? 'false' : 'true');
    }

    function setDrawerOpen(open) {
      var on = !!open && isMobileShell();
      sidebar.classList.toggle('is-drawer-open', on);
      document.body.classList.toggle('is-mobile-nav-open', on);
      if (mobileOpenBtn) mobileOpenBtn.setAttribute('aria-expanded', on ? 'true' : 'false');
      if (toggle) toggle.setAttribute('aria-expanded', on ? 'true' : 'false');
      // 兼容旧 class：窄屏抽屉打开时不应 is-collapsed
      if (on) sidebar.classList.remove('is-collapsed');
      syncBackdropVisibility();
    }

    function closeDrawer() {
      setDrawerOpen(false);
    }

    function openDrawer() {
      // 打开导航时关掉助手弹层，避免双层
      if (typeof window.__closeAssistantSheet__ === 'function') {
        try { window.__closeAssistantSheet__(); } catch (e) {}
      }
      setDrawerOpen(true);
    }

    function toggleDrawer() {
      if (sidebar.classList.contains('is-drawer-open')) closeDrawer();
      else openDrawer();
    }

    window.__closeMobileNav__ = closeDrawer;
    window.__openMobileNav__ = openDrawer;
    window.__syncMobileBackdrop__ = syncBackdropVisibility;

    function setActiveView(viewId) {
      var id = viewId || DEFAULT_VIEW;
      getViewEls().forEach(function(el) {
        el.classList.toggle('is-active', el.getAttribute('data-view') === id);
      });
      getNavItems().forEach(function(btn) {
        btn.classList.toggle('is-active', btn.getAttribute('data-view') === id);
      });
      try {
        if (location.hash !== '#' + id) {
          history.replaceState(null, '', '#' + id);
        }
      } catch (e) {}
      window.dispatchEvent(new CustomEvent('app-view-changed', { detail: { view: id } }));
    }
    window.__setAppView__ = setActiveView;

    function readHashView() {
      var hash = (location.hash || '').replace(/^#/, '');
      if (hash === 'novel') hash = 'novel-source';
      if (hash === 'novel-outputs') hash = 'novel-characters';
      if (!hash) return DEFAULT_VIEW;
      var exists = document.querySelector('.app-view[data-view="' + hash + '"]');
      return exists ? hash : DEFAULT_VIEW;
    }

    getNavItems().forEach(function(btn) {
      btn.addEventListener('click', function() {
        setActiveView(btn.getAttribute('data-view'));
        if (isMobileShell()) closeDrawer();
      });
    });

    if (mobileOpenBtn) {
      mobileOpenBtn.addEventListener('click', function() {
        toggleDrawer();
      });
    }

    if (toggle) {
      toggle.addEventListener('click', function() {
        if (isMobileShell()) toggleDrawer();
        else {
          var collapsed = sidebar.classList.toggle('is-collapsed');
          toggle.setAttribute('aria-expanded', collapsed ? 'false' : 'true');
        }
      });
    }

    if (backdrop) {
      backdrop.addEventListener('click', function() {
        if (document.body.classList.contains('is-mobile-nav-open')) closeDrawer();
        else if (typeof window.__closeAssistantSheet__ === 'function') {
          try { window.__closeAssistantSheet__(); } catch (e) {}
        }
      });
    }

    document.addEventListener('keydown', function(e) {
      if (e.key !== 'Escape') return;
      if (document.body.classList.contains('is-mobile-nav-open')) {
        closeDrawer();
        e.preventDefault();
      }
    });

    window.addEventListener('resize', function() {
      if (!isMobileShell()) {
        sidebar.classList.remove('is-drawer-open');
        document.body.classList.remove('is-mobile-nav-open');
        if (mobileOpenBtn) mobileOpenBtn.setAttribute('aria-expanded', 'false');
        syncBackdropVisibility();
      }
    });

    setActiveView(readHashView());
    window.addEventListener('hashchange', function() {
      setActiveView(readHashView());
    });
    syncBackdropVisibility();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSidebarNav);
  } else {
    initSidebarNav();
  }
})();
</script>
