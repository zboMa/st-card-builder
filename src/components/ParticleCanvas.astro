---
---
<!-- ★ 全屏粒子背景 — 支持特效开关 -->
<canvas id="particleCanvas"></canvas>

<style is:global>
  #particleCanvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    pointer-events: none;
    z-index: 0;
    opacity: 0;
  }
  /*
   * 勿给 .app-shell 设 z-index：会把壳内 fixed 侧栏/助手关进 z=1 叠放上下文，
   * 移动端遮罩 #appShellBackdrop(8300) 就会盖住抽屉与 AI 弹层。
   * 桌面：分别抬侧栏/主区/助手，使其高于粒子。
   * 移动：与 Layout / AssistantPanel 对齐 fixed + 高层级（本文件可能后加载，须在此重申）。
   */
  .app-sidebar,
  .app-container,
  .assistant-panel {
    position: relative;
    z-index: 1;
  }
  @media (max-width: 900px) {
    .app-sidebar {
      position: fixed;
      z-index: 8400;
    }
    .assistant-panel {
      position: fixed;
      z-index: 8500;
    }
  }
</style>

<script is:inline>
(function () {
  var canvas = document.getElementById('particleCanvas');
  if (!canvas) return;
  var ctx = canvas.getContext('2d');
  var dpr = Math.min(window.devicePixelRatio || 1, 2);
  var W, H;
  var particles = [];
  var mouse = { x: -9999, y: -9999 };
  var PARTICLE_COUNT = 20;
  var CONNECTION_DIST = 110;
  var MOUSE_DIST = 160;
  var rafId = null;
  var running = false;

  /* 夜庭：仅 accent 两档 + 淡白，避免彩虹粒子 */
  var COLORS = [
    { r: 192, g: 132, b: 252 },
    { r: 216, g: 180, b: 254 },
    { r: 230, g: 220, b: 245 },
  ];

  function resize() {
    W = window.innerWidth;
    H = window.innerHeight;
    canvas.width = W * dpr;
    canvas.height = H * dpr;
    canvas.style.width = W + 'px';
    canvas.style.height = H + 'px';
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  }

  function createParticle() {
    var c = COLORS[Math.floor(Math.random() * COLORS.length)];
    return {
      x: Math.random() * W, y: Math.random() * H,
      vx: (Math.random() - 0.5) * 0.35, vy: (Math.random() - 0.5) * 0.35,
      r: Math.random() * 2 + 0.8, color: c,
      alpha: Math.random() * 0.35 + 0.12,
      pulseSpeed: Math.random() * 0.02 + 0.005,
      pulseOffset: Math.random() * Math.PI * 2,
      _fill: 'rgb(' + c.r + ',' + c.g + ',' + c.b + ')',
      _fillOuter: 'rgb(' + c.r + ',' + c.g + ',' + c.b + ')',
      _lineColor: 'rgb(' + c.r + ',' + c.g + ',' + c.b + ')',
    };
  }

  function init() {
    resize();
    particles = [];
    for (var i = 0; i < PARTICLE_COUNT; i++) particles.push(createParticle());
  }

  var frame = 0;
  var CONNECTION_DIST_SQ = CONNECTION_DIST * CONNECTION_DIST;
  var MOUSE_DIST_SQ = MOUSE_DIST * MOUSE_DIST;
  function animate() {
    if (!running) return;
    frame++;
    ctx.clearRect(0, 0, W, H);

    for (var i = 0; i < particles.length; i++) {
      var p = particles[i];
      p.x += p.vx; p.y += p.vy;
      if (p.x < -10) p.x = W + 10; if (p.x > W + 10) p.x = -10;
      if (p.y < -10) p.y = H + 10; if (p.y > H + 10) p.y = -10;

      var dx = p.x - mouse.x, dy = p.y - mouse.y;
      var distSq = dx * dx + dy * dy;
      if (distSq < MOUSE_DIST_SQ && distSq > 0) {
        var dist = Math.sqrt(distSq);
        var force = (MOUSE_DIST - dist) / MOUSE_DIST * 0.008;
        p.vx += (dx / dist) * force; p.vy += (dy / dist) * force;
      }
      p.vx *= 0.999; p.vy *= 0.999;

      var pulse = Math.sin(frame * p.pulseSpeed + p.pulseOffset) * 0.3 + 0.7;
      var alpha = p.alpha * pulse;

      // 简化：用单圆 + globalAlpha 代替每帧 createRadialGradient
      ctx.globalAlpha = alpha * 0.15;
      ctx.fillStyle = p._fillOuter;
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r * 4, 0, Math.PI * 2);
      ctx.fill();

      ctx.globalAlpha = alpha;
      ctx.fillStyle = p._fill;
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
      ctx.fill();
      ctx.globalAlpha = 1;
    }

    for (var i = 0; i < particles.length; i++) {
      for (var j = i + 1; j < particles.length; j++) {
        var a = particles[i], b = particles[j];
        var ddx = a.x - b.x, ddy = a.y - b.y;
        var dSq = ddx * ddx + ddy * ddy;
        if (dSq < CONNECTION_DIST_SQ) {
          var d = Math.sqrt(dSq);
          var lineAlpha = (1 - d / CONNECTION_DIST) * 0.07;
          ctx.beginPath(); ctx.moveTo(a.x, a.y); ctx.lineTo(b.x, b.y);
          ctx.strokeStyle = a._lineColor;
          ctx.globalAlpha = lineAlpha;
          ctx.lineWidth = 0.6; ctx.stroke();
        }
      }
    }
    ctx.globalAlpha = 1;

    if (mouse.x > 0 && mouse.y > 0) {
      var mGrad = ctx.createRadialGradient(mouse.x, mouse.y, 0, mouse.x, mouse.y, 120);
      mGrad.addColorStop(0, 'rgba(192,132,252,0.035)');
      mGrad.addColorStop(0.55, 'rgba(216,180,254,0.015)');
      mGrad.addColorStop(1, 'transparent');
      ctx.fillStyle = mGrad;
      ctx.fillRect(mouse.x - 120, mouse.y - 120, 240, 240);
    }

    rafId = requestAnimationFrame(animate);
  }

  // 启停控制
  function start() {
    if (running) return;
    running = true;
    canvas.style.display = '';
    animate();
  }
  function stop() {
    running = false;
    if (rafId) { cancelAnimationFrame(rafId); rafId = null; }
    ctx.clearRect(0, 0, W, H);
    canvas.style.display = 'none';
  }

  window.addEventListener('resize', resize);
  var _mouseMoveRAF = 0;
  document.addEventListener('mousemove', function (e) {
    if (_mouseMoveRAF) return;
    _mouseMoveRAF = requestAnimationFrame(function () {
      mouse.x = e.clientX; mouse.y = e.clientY;
      _mouseMoveRAF = 0;
    });
  });
  document.addEventListener('mouseleave', function () { mouse.x = -9999; mouse.y = -9999; });

  init();

  // 读取偏好决定是否启动（精品 scene 主题用 SceneFx Canvas，此处仅夜庭）
  var FX_KEY = 'st_v3_fx_enabled';
  var shouldRun = true;
  try { var s = localStorage.getItem(FX_KEY); if (s !== null) shouldRun = s === '1'; } catch(e) {}
  var sceneAttr = document.documentElement.getAttribute('data-app-scene') || 'none';
  if (sceneAttr !== 'none') shouldRun = false;

  window.__particleFx__ = { start: start, stop: stop };

  window.addEventListener('app-theme-changed', function() {
    var sc = document.documentElement.getAttribute('data-app-scene') || 'none';
    if (sc !== 'none') { stop(); return; }
    var fx = true;
    try { var v = localStorage.getItem(FX_KEY); if (v !== null) fx = v === '1'; } catch (e) {}
    var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (fx && !reduceMotion) start();
    else stop();
  });

  if (shouldRun) {
    var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!reduceMotion) {
      start();
      if (window.gsap) gsap.to(canvas, { opacity: 0.55, duration: 2, ease: 'power2.out', delay: 0.3 });
      else canvas.style.opacity = '0.55';
    }
  }

  // 粒子动画始终开启
})();
</script>
