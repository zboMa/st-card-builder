    });

    // ============================================================
    //  AI 一键生成
    // ============================================================
    btnAiGenerate.addEventListener('click', async function() {
      var url   = apiUrl.value.replace(/\/$/, '') + '/chat/completions';
      var key   = apiKey.value.trim();
      var model = modelSelect.value;
      if (!model) return alert('请先拉取模型！');
      if (!aiPrompt.value.trim()) return alert('请填写角色设定提示词！');

      var skeletonCount = window.__getSkeletonCount__ ? window.__getSkeletonCount__() : 6;
      var searchEnabled = window.__searchConfig__ && window.__searchConfig__.isEnabled();
      var totalSteps    = (searchEnabled ? 1 : 0) + 1 + Math.ceil(skeletonCount / 5);
      var currentStep   = 0;
      var hacker        = window.__hackerAnim__;

      btnAiGenerate.disabled = true;
      cachedSearchResults = null;

      if (hacker) { hacker.start(); hacker.setPhase('⚡ 初始化引擎...'); hacker.setProgress(0, totalSteps); hacker.setDetail(hacker.randomMsg()); }

      try {
        var headers = { 'Content-Type': 'application/json' };
        if (key) headers['Authorization'] = 'Bearer ' + key;
        var presetsStr = getActivePresetsStr();
        var searchInjection = '';

        // 阶段0：联网搜索
        if (searchEnabled) {
          currentStep++;
          if (hacker) { hacker.setPhase('🌐 [阶段 ' + currentStep + '/' + totalSteps + '] 联网搜索资料...'); hacker.setProgress(currentStep, totalSteps); hacker.setDetail('正在扫描互联网数据节点...'); }
          aiStatus.textContent = '🌐 联网搜索中...'; aiStatus.style.color = '#38bdf8';
          var searchResult = await performSearchIfEnabled(aiPrompt.value.trim());
          searchInjection = searchResult.searchText || '';
          if (searchResult.mode === 'engine') { if (hacker) hacker.setDetail('✅ 搜索完成，获取到 ' + searchResult.searchResults.length + ' 条参考资料'); }
          else if (searchResult.mode === 'ai_native') { if (hacker) hacker.setDetail('ℹ️ 使用 AI 自带联网能力'); }
          else if (searchResult.mode === 'ai_fallback') { if (hacker) hacker.setDetail('⚠️ 搜索引擎出错，降级为 AI 联网: ' + (searchResult.error || '')); }
          await sleep(400);
        }

        // 阶段1：生成角色
        currentStep++;
        if (hacker) { hacker.setPhase('🧬 [阶段 ' + currentStep + '/' + totalSteps + '] 构建角色灵魂...'); hacker.setProgress(currentStep, totalSteps); hacker.setDetail(hacker.randomMsg()); }
        aiStatus.textContent = '⏳ [阶段 1] 构思角色设定...'; aiStatus.style.color = '#38bdf8';

        var p1Sys = '生成角色基础属性，仅输出JSON对象。格式：{ "charName": "角色名", "wbName": "世界书名", "charDesc": "详细的角色描述(至少200字，包含外貌、性格、背景、能力)", "firstMes": "沉浸感强的开场白(至少150字)", "creatorNotes": "给使用者的说明", "altGreetings": ["备选开场白1(不同场景或氛围)", "备选开场白2"] }'
          + (presetsStr ? '\n【文风要求】：\n' + presetsStr : '')
          + searchInjection;

        var r1 = await fetch(url, { method: 'POST', headers: headers, body: JSON.stringify({ model: model, messages: [{ role: "system", content: p1Sys }, { role: "user", content: aiPrompt.value.trim() }], temperature: 0.85 }) });
        if (!r1.ok) throw new Error('角色生成失败 HTTP ' + r1.status);
        var charData = extractJsonObj((await r1.json()).choices[0].message.content);

        charName.value     = charData.charName     || '';
        wbName.value       = charData.wbName       || '';
        charDesc.value     = charData.charDesc     || '';
        firstMes.value     = charData.firstMes     || '';
        creatorNotes.value = charData.creatorNotes || '';
        window.__altGreetings__ = (charData.altGreetings && Array.isArray(charData.altGreetings)) ? charData.altGreetings : [];
        if (window.__renderAltGreetings__) window.__renderAltGreetings__();
        worldbookEntries = [];
        debouncedUpdateAndSave();
        if (hacker) hacker.setDetail('✅ 角色「' + (charData.charName || '???') + '」锻造完成');
        await sleep(500);

        // 阶段2+：批量生成世界书骨架
        var wbGoal    = wbPrompt.value.trim();
        var remaining = skeletonCount;
        var batchIndex = 0;

        while (remaining > 0) {
          var batchSize = Math.min(remaining, 5);
          batchIndex++; currentStep++;
          if (hacker) { hacker.setPhase('🦴 [阶段 ' + currentStep + '/' + totalSteps + '] 世界书骨架 (批次 ' + batchIndex + ')'); hacker.setProgress(currentStep, totalSteps); hacker.setDetail(hacker.randomMsg()); }
          aiStatus.textContent = '⏳ 生成世界书骨架... ' + worldbookEntries.length + '/' + skeletonCount;

          var existingTitles = worldbookEntries.map(function(e) { return e.comment; }).join('、');
          var existingRef    = existingTitles ? '\n【已有条目(禁止重复)】：' + existingTitles : '';

          var skSys = '你是一个 SillyTavern 世界书骨架生成器。快速产出【' + batchSize + '条】简短骨架。'
            + '\n每条只需：comment(标题)、content(一句话20-40字)、keys(1-3个触发词)、strategy("selective"或"constant")'
            + '\n【角色】：' + charName.value.trim() + ' | ' + charDesc.value.trim().substring(0, 300)
            + existingRef
            + (wbGoal ? '\n【方向】：' + wbGoal : '')
            + (presetsStr ? '\n【文风】：' + presetsStr.substring(0, 200) : '')
            + searchInjection
            + '\n【输出】：JSON数组 [{ "comment":"===标题===", "content":"一句话", "keys":["词"], "strategy":"selective" }, ...]'
            + '\n要求：极简、不重复、覆盖多维度（地点/人物/组织/物品/事件/规则）';

          try {
            var r2 = await fetch(url, { method: 'POST', headers: headers, body: JSON.stringify({ model: model, messages: [{ role: "system", content: skSys }, { role: "user", content: '生成' + batchSize + '条骨架' }], temperature: 0.9 }) });
            if (!r2.ok) throw new Error('HTTP ' + r2.status);
            var rawC = (await r2.json()).choices[0].message.content;
            var skeletons;
            try { skeletons = extractJsonArray(rawC); } catch(pe) { try { skeletons = [extractJsonObj(rawC)]; } catch(e2) { throw new Error('返回格式异常'); } }
            skeletons.forEach(function(sk) {
              if (!sk || !sk.comment) return;
              worldbookEntries.push({ comment: sk.comment || '未命名', content: sk.content || '(待展开)', keys: Array.isArray(sk.keys) ? sk.keys : [], strategy: sk.strategy || 'selective', position: 4, depth: 4, role: 0, order: 100, prob: 100 });
            });
            renderEntriesList(); debouncedUpdateAndSave();
            if (hacker) hacker.setDetail('✅ 批次 ' + batchIndex + ' 完成，已 ' + worldbookEntries.length + ' 条');
            await sleep(300);
          } catch(bErr) {
            if (hacker) hacker.setDetail('⚠️ 批次 ' + batchIndex + ': ' + bErr.message);
            await sleep(500);
          }
          remaining -= batchSize;
        }

        // 完成
        if (hacker) {
          hacker.stop(); hacker.setPhase('🎉 生成完毕！'); hacker.setProgress(totalSteps, totalSteps);
          var doneMsg = '角色「' + charName.value.trim() + '」+ ' + worldbookEntries.length + ' 条骨架已就绪。';
          if (searchEnabled && cachedSearchResults) doneMsg += ' (参考了 ' + cachedSearchResults.length + ' 条搜索结果)';
          doneMsg += ' 请用「✨ AI重写」逐条展开。';
          hacker.setDetail(doneMsg);
          setTimeout(function() { if (hacker) hacker.hide(); }, 5000);
        }
        aiStatus.textContent = '✅ 完毕！' + worldbookEntries.length + ' 条骨架' + (searchEnabled ? ' (已联网)' : '') + '。请逐条展开。';
        aiStatus.style.color = '#10b981';

      } catch(err) {
        if (hacker) { hacker.stop(); hacker.setPhase('❌ 中止'); hacker.setDetail(err.message); setTimeout(function() { hacker.hide(); }, 3000); }
        aiStatus.textContent = '❌ 中止: ' + err.message; aiStatus.style.color = '#ef4444';
      } finally { btnAiGenerate.disabled = false; }
    });

    // ============================================================
    //  AI 单条追加
