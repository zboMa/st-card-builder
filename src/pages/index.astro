    // ============================================================
    //  世界书条目管理
    // ============================================================
    function escapeHtml(value) {
      return String(value == null ? '' : value)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function getDefaultWBEntry() {
      return {
        comment: '',
        content: '',
        keys: [],
        strategy: 'selective',
        position: 4,
        depth: 4,
        role: 0,
        order: 100,
        prob: 100,
      };
    }

    function normalizeWBEntry(entry) {
      var base = getDefaultWBEntry();
      entry = entry || {};
      return {
        comment: String(entry.comment || ''),
        content: String(entry.content || ''),
        keys: Array.isArray(entry.keys) ? entry.keys.filter(function(k) { return String(k || '').trim(); }) : [],
        strategy: ['constant', 'selective', 'vectorized'].indexOf(entry.strategy) >= 0 ? entry.strategy : base.strategy,
        position: clampInt(entry.position, base.position, 0, 6),
        depth: clampInt(entry.depth, base.depth, 0, 999),
        role: clampInt(entry.role, base.role, 0, 2),
        order: clampInt(entry.order, base.order, 0, 999),
        prob: clampInt(entry.prob, base.prob, 1, 100),
      };
    }

    function renderSelectOptions(options, selectedValue) {
      var selected = String(selectedValue);
      var html = '';
      options.forEach(function(option) {
        html += '<option value="' + escapeHtml(option.value) + '"' + (selected === String(option.value) ? ' selected' : '') + '>' + escapeHtml(option.label) + '</option>';
      });
      return html;
    }

    function renderInlineEditor(index, entry, isNew) {
      entry = normalizeWBEntry(entry);
      var editorId = isNew ? 'wb_editor_new' : 'wb_editor_' + index;
      var title = isNew ? '✍️ 新建世界书条目' : '✍️ 编辑当前条目';
      var subtitle = isNew ? '手动录入会直接插入到条目列表里。' : '保存后会直接覆盖这条世界书条目。';
      var strategyOptions = renderSelectOptions([
        { value: 'constant', label: '常驻' },
        { value: 'selective', label: '关键词' },
        { value: 'vectorized', label: '向量化' },
      ], entry.strategy);
      var positionOptions = renderSelectOptions([
        { value: '0', label: '0 — 之前' },
        { value: '1', label: '1 — 之后' },
        { value: '2', label: '2 — 前 EM' },
        { value: '3', label: '3 — 后 EM' },
        { value: '4', label: '4 — 深度' },
        { value: '5', label: '5 — 之前 AN' },
        { value: '6', label: '6 — 之后 AN' },
      ], entry.position);
      var roleOptions = renderSelectOptions([
        { value: '0', label: '系统' },
        { value: '1', label: '用户' },
        { value: '2', label: '助手' },
      ], entry.role);
      return ''
        + '<div class="wb-inline-editor" id="' + editorId + '" data-editor-index="' + index + '">'
        +   '<div class="wb-inline-editor-head">'
        +     '<div>'
        +       '<div class="wb-inline-editor-title">' + title + '</div>'
        +       '<div class="wb-inline-editor-subtitle">' + subtitle + '</div>'
        +     '</div>'
        +   '</div>'
        +   '<div class="form-group">'
        +     '<label>条目标题</label>'
        +     '<input type="text" data-field="comment" placeholder="例如：===特殊武器===" value="' + escapeHtml(entry.comment) + '" />'
        +   '</div>'
        +   '<div class="form-group">'
        +     '<label>设定内容</label>'
        +     '<textarea data-field="content" placeholder="具体设定详情...">' + escapeHtml(entry.content) + '</textarea>'
        +   '</div>'
        +   '<div class="form-group">'
        +     '<label>触发词 — 多个用英文逗号隔开</label>'
        +     '<input type="text" data-field="keys" placeholder="空为常驻，有词为触发" value="' + escapeHtml((entry.keys || []).join(', ')) + '" />'
        +   '</div>'
        +   '<div class="grid-2">'
        +     '<div class="form-group">'
        +       '<label>触发策略</label>'
        +       '<select data-field="strategy">' + strategyOptions + '</select>'
        +     '</div>'
        +     '<div class="form-group">'
        +       '<label>插入位置</label>'
        +       '<select data-field="position">' + positionOptions + '</select>'
        +     '</div>'
        +   '</div>'
        +   '<div class="grid-3">'
        +     '<div class="form-group">'
        +       '<label>深度</label>'
        +       '<input type="number" data-field="depth" value="' + escapeHtml(entry.depth) + '" min="0" />'
        +     '</div>'
        +     '<div class="form-group">'
        +       '<label>角色</label>'
        +       '<select data-field="role">' + roleOptions + '</select>'
        +     '</div>'
        +     '<div class="form-group">'
        +       '<label>顺序</label>'
        +       '<input type="number" data-field="order" value="' + escapeHtml(entry.order) + '" />'
        +     '</div>'
        +   '</div>'
        +   '<div class="form-group">'
        +     '<label>概率 (%)</label>'
        +     '<input type="number" data-field="prob" value="' + escapeHtml(entry.prob) + '" min="1" max="100" />'
        +   '</div>'
        +   '<div class="wb-inline-editor-actions">'
        +     '<button class="btn btn-add btn-save-inline" data-index="' + index + '">' + (isNew ? '➕ 保存新条目' : '💾 保存修改') + '</button>'
        +     '<button class="btn wb-inline-cancel btn-cancel-inline" data-index="' + index + '">取消</button>'
        +   '</div>'
        + '</div>';
    }

    function getInlineEditorRoot(index) {
      return document.getElementById(index < 0 ? 'wb_editor_new' : 'wb_editor_' + index);
    }

    function readInlineEditorValue(root, field) {
      var el = root ? root.querySelector('[data-field="' + field + '"]') : null;
      return el ? el.value : '';
    }

    function readInlineEditorEntry(root) {
      var base = getDefaultWBEntry();
      return {
        comment: readInlineEditorValue(root, 'comment').trim(),
        content: readInlineEditorValue(root, 'content').trim(),
        keys: readInlineEditorValue(root, 'keys').split(/[,，]/).map(function(k) { return k.trim(); }).filter(function(k) { return k; }),
        strategy: readInlineEditorValue(root, 'strategy') || base.strategy,
        position: clampInt(readInlineEditorValue(root, 'position'), base.position, 0, 6),
        depth: clampInt(readInlineEditorValue(root, 'depth'), base.depth, 0, 999),
        role: clampInt(readInlineEditorValue(root, 'role'), base.role, 0, 2),
        order: clampInt(readInlineEditorValue(root, 'order'), base.order, 0, 999),
        prob: clampInt(readInlineEditorValue(root, 'prob'), base.prob, 1, 100),
      };
    }

    function focusInlineEditor(editorId) {
      setTimeout(function() {
        var editor = document.getElementById(editorId);
        if (!editor) return;
        editor.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        var target = editor.querySelector('[data-field="comment"]');
        if (target) target.focus();
      }, 0);
    }

    function updateCreateEntryButtonState() {
      if (!btnCreateEntry) return;
      btnCreateEntry.textContent = isCreatingEntry ? '收起新建条目' : '➕ 新建手动条目';
    }

    function resetWBForm() {
      editingIndex = -1;
      isCreatingEntry = false;
      updateCreateEntryButtonState();
    }

    function toggleCreateEntryForm() {
      if (isCreatingEntry) {
        resetWBForm();
        renderEntriesList();
        return;
      }
      editingIndex = -1;
      isCreatingEntry = true;
      renderEntriesList();
      updateCreateEntryButtonState();
      focusInlineEditor('wb_editor_new');
    }

    function editEntry(index) {
      if (editingIndex === index && !isCreatingEntry) {
        resetWBForm();
        renderEntriesList();
        return;
      }
      editingIndex = index;
      isCreatingEntry = false;
      renderEntriesList();
      updateCreateEntryButtonState();
      focusInlineEditor('wb_editor_' + index);
    }

    function cancelInlineEdit() {
      resetWBForm();
      renderEntriesList();
    }

    function saveInlineEntry(index) {
      var editorRoot = getInlineEditorRoot(index);
      if (!editorRoot) return;
      var nextEntry = readInlineEditorEntry(editorRoot);
      if (!nextEntry.content.trim()) return alert('内容不能为空！');
      if (index >= 0) worldbookEntries[index] = nextEntry;
      else worldbookEntries.push(nextEntry);
      resetWBForm();
      renderEntriesList();
      debouncedUpdateAndSave();
    }

    async function aiRewriteEntry(index, req, btn) {
      var url = apiUrl.value.replace(/\/$/, '') + '/chat/completions'; var key = apiKey.value.trim(); var model = modelSelect.value;
      if (!model) return alert('请先选择模型！');
      var old = worldbookEntries[index]; var oldText = btn.textContent; btn.disabled = true; btn.textContent = "⏳ 重铸中...";
      var presetsStr = getActivePresetsStr();
      var isSkeleton = old.content.length < 60;
      var expandHint = isSkeleton ? '\n\n【重要】：原条目是骨架概要，请展开为完整详细的世界书设定词条（至少150字），保留方向但大幅扩充。' : '';
      var searchInjection = '';
      if (window.__searchConfig__ && window.__searchConfig__.isEnabled()) {
        var sq = old.comment + ' ' + (req || '');
        var sr = await performSearchIfEnabled(sq);
        searchInjection = sr.searchText || '';
      }
      var sys = '你是一个 SillyTavern 词条润色大师。修改一个【已存在的词条】。\n【原词条】: 标题: ' + old.comment + ' | 策略: ' + old.strategy + ' | 触发词: ' + old.keys.join(',') + '\n内容: ' + old.content + (presetsStr ? '\n【文风】：\n' + presetsStr : '') + expandHint + searchInjection + '\n【任务】：重写。输出JSON：{ "comment": "标题", "content": "详细设定", "keys": ["触发词"], "strategy": "selective 或 constant", "position": ' + old.position + ' }';
      try {
        var h = { 'Content-Type': 'application/json' }; if (key) h['Authorization'] = 'Bearer ' + key;
        var res = await fetch(url, { method: 'POST', headers: h, body: JSON.stringify({ model: model, messages: [{ role: "system", content: sys }, { role: "user", content: isSkeleton ? '将骨架展开为完整设定。' + (req ? ' 额外要求：' + req : '') : '修改要求：' + req }], temperature: 0.8 }) });
        if (!res.ok) throw new Error('HTTP ' + res.status);
        var ed = extractJsonObj((await res.json()).choices[0].message.content);
        worldbookEntries[index].comment = ed.comment || old.comment;
        worldbookEntries[index].content = ed.content || old.content;
        if (ed.keys) worldbookEntries[index].keys = Array.isArray(ed.keys) ? ed.keys : [];
        if (ed.strategy) worldbookEntries[index].strategy = ed.strategy;
        renderEntriesList(); debouncedUpdateAndSave();
      } catch(err) { alert('重写失败: ' + err.message); }
      finally { btn.disabled = false; btn.textContent = oldText || '✨ AI重写'; }
    }

    function renderEntriesList() {
