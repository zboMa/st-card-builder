---
import Layout from '../layouts/Layout.astro';
import AIPanel from '../components/AIPanel.astro';
import CardManagerPanel from '../components/CardManagerPanel.astro';
import CharacterPanel from '../components/CharacterPanel.astro';
import AdultConfigPanel from '../components/AdultConfigPanel.astro';
import GreetingPanel from '../components/GreetingPanel.astro';
import WorldbookPanel from '../components/WorldbookPanel.astro';
import VariableCardPanel from '../components/VariableCardPanel.astro';
import StatusBarPanel from '../components/StatusBarPanel.astro';
import RegexPanel from '../components/RegexPanel.astro';
import TavernScriptsPanel from '../components/TavernScriptsPanel.astro';
import ParticleCanvas from '../components/ParticleCanvas.astro';
import GsapAnimations from '../components/GsapAnimations.astro';
import AppSidebar from '../components/AppSidebar.astro';
import AssistantPanel from '../components/AssistantPanel.astro';
import PromptConfigPanel from '../components/PromptConfigPanel.astro';
import PromptStoreBootstrap from '../components/PromptStoreBootstrap.astro';
import NovelWorkshopApp from '../components/novel/NovelWorkshopApp.astro';
import NovelSourcePanel from '../components/novel/NovelSourcePanel.astro';
import NovelChaptersPanel from '../components/novel/NovelChaptersPanel.astro';
import NovelCharacterSetupPanel from '../components/novel/NovelCharacterSetupPanel.astro';
import NovelGreetingsPanel from '../components/novel/NovelGreetingsPanel.astro';
import NovelAnalyzePanel from '../components/novel/NovelAnalyzePanel.astro';
import NovelCharactersPanel from '../components/novel/NovelCharactersPanel.astro';
import NovelWorldbookPanel from '../components/novel/NovelWorldbookPanel.astro';
import NovelStylePanel from '../components/novel/NovelStylePanel.astro';
import StoryStudioApp from '../components/storyStudio/StoryStudioApp.astro';
import StoryManagePanel from '../components/storyStudio/StoryManagePanel.astro';
import StoryGraphPanel from '../components/storyStudio/StoryGraphPanel.astro';
import StoryOutlinePanel from '../components/storyStudio/StoryOutlinePanel.astro';
import StoryWritePanel from '../components/storyStudio/StoryWritePanel.astro';
import StoryReadPanel from '../components/storyStudio/StoryReadPanel.astro';
import ShareReaderPanel from '../components/storyStudio/ShareReaderPanel.astro';
import AiTaskCenterUI from '../components/AiTaskCenterUI.astro';
import AccountSyncPanel from '../components/AccountSyncPanel.astro';
---

<Layout title="啊哈哈哈制卡器">
  <PromptStoreBootstrap />
  <AiTaskCenterUI />
  <NovelWorkshopApp />
  <StoryStudioApp />
  <ShareReaderPanel />
  <ParticleCanvas />

  <!-- 侧栏（含品牌区）+ 主内容 + 右栏 AI 助手；各 view 常驻 DOM，切换仅显隐 -->
  <!-- 移动端：底栏模块切换；侧栏仍为左滑抽屉（点模块名打开） -->
  <nav class="app-mobile-modbar" id="appMobileModbar" aria-label="模块切换" hidden>
    <button type="button" class="app-mobile-modbar__nav" id="btnMobileModPrev">上一个</button>
    <button type="button" class="app-mobile-modbar__current" id="btnMobileModCurrent" aria-controls="appSidebar" aria-expanded="false" aria-haspopup="dialog">模块</button>
    <button type="button" class="app-mobile-modbar__nav" id="btnMobileModNext">下一个</button>
  </nav>
  <div class="app-shell-backdrop" id="appShellBackdrop" hidden aria-hidden="true"></div>
  <div class="app-shell">
    <AppSidebar />
    <div class="app-container">
      <!-- 视图顺序与侧栏一致；显隐由 data-view 控制 -->
      <div class="app-view" data-view="card-manager"><CardManagerPanel /></div>
      <div class="app-view" data-view="adult-config"><AdultConfigPanel /></div>
      <div class="app-view" data-view="character"><CharacterPanel /></div>
      <div class="app-view" data-view="greetings"><GreetingPanel /></div>
      <div class="app-view" data-view="worldbook"><WorldbookPanel /></div>
      <div class="app-view" data-view="statusbar"><StatusBarPanel /></div>
      <div class="app-view" data-view="mvu"><VariableCardPanel /></div>
      <div class="app-view" data-view="regex"><RegexPanel /></div>
      <div class="app-view" data-view="tavern-scripts"><TavernScriptsPanel /></div>
      <div class="app-view" data-view="novel-source"><NovelSourcePanel /></div>
      <div class="app-view" data-view="novel-chapters"><NovelChaptersPanel /></div>
      <div class="app-view" data-view="novel-character-setup"><NovelCharacterSetupPanel /></div>
      <div class="app-view" data-view="novel-greetings"><NovelGreetingsPanel /></div>
      <div class="app-view" data-view="novel-analyze"><NovelAnalyzePanel /></div>
      <div class="app-view" data-view="novel-characters"><NovelCharactersPanel /></div>
      <div class="app-view" data-view="novel-worldbook"><NovelWorldbookPanel /></div>
      <div class="app-view" data-view="novel-style"><NovelStylePanel /></div>
      <div class="app-view" data-view="story-manage"><StoryManagePanel /></div>
      <div class="app-view" data-view="story-graph"><StoryGraphPanel /></div>
      <div class="app-view" data-view="story-outline"><StoryOutlinePanel /></div>
      <div class="app-view" data-view="story-write"><StoryWritePanel /></div>
      <div class="app-view" data-view="story-read"><StoryReadPanel /></div>
      <div class="app-view" data-view="account-sync"><AccountSyncPanel /></div>
      <div class="app-view" data-view="ai-config">
        <div class="app-view-slot" data-slot="ai-config"></div>
      </div>
      <div class="app-view" data-view="prompt-config"><PromptConfigPanel /></div>
      <!-- 暂存 AI 双面板，脚本立即挂到对应 slot（避免重复拆组件导致脚本分叉） -->
      <div id="aiPanelSource" hidden>
        <AIPanel />
      </div>
    </div>
    <AssistantPanel />
  </div>

  <script is:inline>
  (function() {
    var cfgSlot = document.querySelector('[data-slot="ai-config"]');
    var cfgPanel = document.querySelector('.area-ai-config');
    if (cfgSlot && cfgPanel) cfgSlot.appendChild(cfgPanel);
    /* AI 引擎弹窗挂到 body，避免被主区 overflow 裁切 */
    var modal = document.getElementById('aiEngineModal');
    if (modal) document.body.appendChild(modal);
    var jsonModal = document.getElementById('jsonPreviewModal');
    if (jsonModal) document.body.appendChild(jsonModal);
    var auditModal = document.getElementById('wbAuditorModal');
    if (auditModal) document.body.appendChild(auditModal);
    var exportChecklistModal = document.getElementById('exportChecklistModal');
    if (exportChecklistModal) document.body.appendChild(exportChecklistModal);
    var src = document.getElementById('aiPanelSource');
    if (src) src.remove();
  })();
  </script>

  <GsapAnimations />

  <!-- 角色标签工具挂到 window，供草稿/导入导出内联脚本调用 -->
  <script>
    import {
      normalizeCharTags,
      tagsFromCardJson,
      mergeCharTags,
      buildTagGenContext,
      parseTagsFromAiText,
      clampTagContextChars,
      DEFAULT_TAG_CONTEXT_CHARS,
    } from '../lib/charTags.mjs';
    window.__charTagsLib__ = {
      normalizeCharTags: normalizeCharTags,
      tagsFromCardJson: tagsFromCardJson,
      mergeCharTags: mergeCharTags,
      buildTagGenContext: buildTagGenContext,
      parseTagsFromAiText: parseTagsFromAiText,
      clampTagContextChars: clampTagContextChars,
      DEFAULT_TAG_CONTEXT_CHARS: DEFAULT_TAG_CONTEXT_CHARS,
    };
  </script>

  <!-- NSFW 口味预设 / NTL 数据（供角色设定和 AI 引擎共用） -->
  <script>
    import {
      NSFW_FLAVOR_PRESETS,
      NSFWFLAVOR_IDS,
      FLAVOR_GROUPS,
      NTL_TABOO_TYPES,
      NTL_TABOO_IDS,
      MAX_NSFW_FLAVOR_ITEMS,
      NSFW_FLAVOR_DEFAULT_MIN_CHARS,
      NTL_TABOO_DEFAULT_MIN_CHARS,
      POSTURE_GROUPS,
      SPEECH_GROUPS,
      EROTIC_POSTURE_PRESETS,
      EROTIC_POSTURE_IDS,
      EROTIC_SPEECH_PRESETS,
      EROTIC_SPEECH_IDS,
      normalizeNsfwFlavorItems,
      buildNsfwFlavorHintFromItems,
      normalizeExpressionItems,
      buildPostureHintFromItems,
      buildSpeechHintFromItems,
      evaluateFlavorRichness,
      collectFlavorEnrichment,
      buildNtlTabooHintFromTypes,
      normalizeNtlTabooItems,
      evaluateNtlRichness,
      collectNtlEnrichment,
      WORLDFRAMES,
      WORLDFRAME_IDS,
      inferWorldframe,
      collectVesselEnrichment,
      buildVesselHint,
      evaluateVesselRichness,
    } from '../lib/novel/nsfwSupport.mjs';
    window.__nsfwFlavorData__ = {
      presets: NSFW_FLAVOR_PRESETS,
      ids: NSFWFLAVOR_IDS,
      groups: FLAVOR_GROUPS,
      tabooTypes: NTL_TABOO_TYPES,
      tabooIds: NTL_TABOO_IDS,
      maxItems: MAX_NSFW_FLAVOR_ITEMS,
      defaultMinChars: NSFW_FLAVOR_DEFAULT_MIN_CHARS,
      ntlDefaultMinChars: NTL_TABOO_DEFAULT_MIN_CHARS,
      posturePresets: EROTIC_POSTURE_PRESETS,
      postureIds: EROTIC_POSTURE_IDS,
      postureGroups: POSTURE_GROUPS,
      speechPresets: EROTIC_SPEECH_PRESETS,
      speechIds: EROTIC_SPEECH_IDS,
      speechGroups: SPEECH_GROUPS,
      normalizeItems: normalizeNsfwFlavorItems,
      buildHintFromItems: buildNsfwFlavorHintFromItems,
      normalizeExpressionItems: normalizeExpressionItems,
      buildPostureHintFromItems: buildPostureHintFromItems,
      buildSpeechHintFromItems: buildSpeechHintFromItems,
      evaluateRichness: evaluateFlavorRichness,
      collectEnrichment: collectFlavorEnrichment,
      buildNtlHintFromTypes: buildNtlTabooHintFromTypes,
      normalizeNtlItems: normalizeNtlTabooItems,
      evaluateNtlRichness: evaluateNtlRichness,
      collectNtlEnrichment: collectNtlEnrichment,
      worldframes: WORLDFRAMES,
      worldframeIds: WORLDFRAME_IDS,
      inferWorldframe: inferWorldframe,
      collectVesselEnrichment: collectVesselEnrichment,
      buildVesselHint: buildVesselHint,
      evaluateVesselRichness: evaluateVesselRichness,
    };
  </script>

  <script>
    import { buildPromptCatalogBrowser } from '../lib/promptCatalogBrowser.mjs';
    window.__promptCatalogBrowser__ = buildPromptCatalogBrowser();
  </script>

  <!-- IndexedDB：头像高清图 + 小说大文本（草稿 JSON 仅存轻量标记） -->
  <script>
    import { openIdbDatabase } from '../lib/idbStore.mjs';
    import { waitForLazyPromise } from '../lib/idbReady.mjs';
    import * as avatarIdb from '../lib/avatarIdb.mjs';
    import { removeNovelBucketIdb, copyNovelBucketIdb } from '../lib/novel/state.mjs';

    window.__avatarIdb__ = avatarIdb;
    window.__idbReady__ = openIdbDatabase().catch(function(err) {
      console.warn('[idb] open failed', err);
      return null;
    });
    window.__ensureIdbReady__ = function() {
      return waitForLazyPromise(function() { return window.__idbReady__; });
    };
    window.__novelIdb__ = {
      removeNovelBucketIdb: removeNovelBucketIdb,
      copyNovelBucketIdb: copyNovelBucketIdb,
    };
    window.dispatchEvent(new CustomEvent('st-idb-ready'));
  </script>

  <style is:global>
    .app-confirm-overlay {
      position: fixed;
      inset: 0;
      z-index: 9999;
      display: grid;
      place-items: center;
      padding: 18px;
      background:
        radial-gradient(circle at 50% 32%, rgba(56, 189, 248, 0.14), transparent 34%),
        rgba(2, 6, 23, 0.72);
      backdrop-filter: blur(10px);
      animation: appConfirmFade 0.16s ease;
    }

    .app-confirm-dialog {
      width: min(420px, 100%);
      border: 1px solid rgba(248, 113, 113, 0.28);
      border-radius: 18px;
      background:
        linear-gradient(145deg, rgba(15, 23, 42, 0.98), rgba(7, 12, 24, 0.98)),
        radial-gradient(circle at top left, rgba(239, 68, 68, 0.15), transparent 40%);
      box-shadow: 0 24px 70px rgba(0, 0, 0, 0.48), inset 0 1px 0 rgba(255, 255, 255, 0.06);
      overflow: hidden;
      animation: appConfirmPop 0.18s ease;
    }

    .app-confirm-head {
      display: flex;
      gap: 12px;
      padding: 18px 18px 12px;
      align-items: center;
    }

    .app-confirm-icon {
      width: 42px;
      height: 42px;
      display: grid;
      place-items: center;
      border-radius: 14px;
      border: 1px solid rgba(248, 113, 113, 0.32);
      background: rgba(127, 29, 29, 0.34);
      color: #fecaca;
      font-size: 1.25rem;
      flex: 0 0 auto;
    }

    .app-confirm-title {
      margin: 0 0 4px;
      color: #fee2e2;
      font-size: 0.98rem;
      font-weight: 800;
      letter-spacing: 0.02em;
    }

    .app-confirm-message {
      margin: 0;
      color: var(--color-text-muted);
      font-size: 0.76rem;
      line-height: 1.6;
    }

    .app-confirm-body {
      margin: 0 18px 16px;
      padding: 10px 12px;
      border-radius: 12px;
      border: 1px solid rgba(51, 65, 85, 0.72);
      background: rgba(2, 6, 23, 0.44);
      color: var(--color-text-secondary);
      font-size: 0.74rem;
      line-height: 1.55;
    }

    .app-confirm-checks {
      margin: 0 18px 14px;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .app-confirm-check {
      display: flex;
      align-items: flex-start;
      gap: 8px;
      padding: 10px 12px;
      border-radius: 12px;
      border: 1px solid rgba(51, 65, 85, 0.72);
      background: rgba(2, 6, 23, 0.44);
      color: var(--color-text-secondary);
      font-size: 0.74rem;
      line-height: 1.5;
      cursor: pointer;
      user-select: none;
    }

    .app-confirm-check input {
      margin-top: 2px;
      flex: 0 0 auto;
    }

    .app-confirm-actions {
      display: flex;
      gap: 10px;
      justify-content: flex-end;
      padding: 14px 18px 18px;
      border-top: 1px solid rgba(51, 65, 85, 0.5);
      background: rgba(2, 6, 23, 0.26);
    }

    .app-confirm-btn {
      min-width: 92px;
      min-height: 36px;
      padding: 0 14px;
      border-radius: 10px;
      border: 1px solid rgba(71, 85, 105, 0.75);
      background: rgba(15, 23, 42, 0.84);
      color: var(--color-text-secondary);
      font: inherit;
      font-size: 0.78rem;
      font-weight: 800;
      cursor: pointer;
      transition: all 0.18s ease;
    }

    .app-confirm-btn:hover {
      transform: translateY(-1px);
      border-color: rgba(148, 163, 184, 0.7);
      color: #f8fafc;
    }

    .app-confirm-btn.danger {
      border-color: rgba(248, 113, 113, 0.42);
      background: linear-gradient(135deg, rgba(185, 28, 28, 0.86), rgba(127, 29, 29, 0.92));
      color: #fff1f2;
      box-shadow: 0 10px 24px rgba(127, 29, 29, 0.24);
    }

    .app-confirm-btn.danger:hover {
      border-color: rgba(252, 165, 165, 0.7);
      box-shadow: 0 12px 28px rgba(185, 28, 28, 0.32);
    }

    .app-confirm-btn.primary {
      border-color: rgba(129, 140, 248, 0.45);
      background: linear-gradient(135deg, rgba(99, 102, 241, 0.88), rgba(79, 70, 229, 0.92));
      color: #eef2ff;
      box-shadow: 0 10px 24px rgba(67, 56, 202, 0.22);
    }

    .app-confirm-btn.primary:hover {
      border-color: rgba(165, 180, 252, 0.7);
      box-shadow: 0 12px 28px rgba(79, 70, 229, 0.3);
    }

    .app-prompt-field-wrap {
      margin: 0 18px 8px;
    }

    .app-prompt-input {
      width: 100%;
      box-sizing: border-box;
      min-height: 40px;
      padding: 8px 12px;
      border-radius: 10px;
      border: 1px solid rgba(71, 85, 105, 0.8);
      background: rgba(2, 6, 23, 0.55);
      color: var(--color-text);
      font: inherit;
      font-size: 0.82rem;
    }

    .app-prompt-input:focus {
      outline: none;
      border-color: rgba(129, 140, 248, 0.65);
      box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.18);
    }

    .app-toast-host {
      position: fixed;
      left: 50%;
      bottom: 28px;
      transform: translateX(-50%);
      z-index: 10050;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
      pointer-events: none;
      max-width: min(420px, calc(100vw - 24px));
    }

    .app-toast {
      pointer-events: none;
      padding: 10px 16px;
      border-radius: 12px;
      border: 1px solid rgba(99, 102, 241, 0.35);
      background: rgba(15, 23, 42, 0.94);
      color: #e2e8f0;
      font-size: 0.78rem;
      font-weight: 600;
      box-shadow: 0 12px 32px rgba(0, 0, 0, 0.4);
      animation: appToastIn 0.18s ease;
    }

    .app-toast.is-error {
      border-color: rgba(248, 113, 113, 0.45);
      color: #fecaca;
    }

    .app-toast.is-warn {
      border-color: rgba(251, 191, 36, 0.45);
      color: #fde68a;
    }

    .app-toast.is-leaving {
      opacity: 0;
      transform: translateY(6px);
      transition: opacity 0.2s ease, transform 0.2s ease;
    }

    .app-notify-host {
      position: fixed;
      top: 18px;
      right: 18px;
      z-index: 10060;
      display: flex;
      flex-direction: column;
      gap: 10px;
      width: min(360px, calc(100vw - 24px));
      pointer-events: none;
    }

    .app-notify {
      pointer-events: auto;
      display: flex;
      gap: 10px;
      align-items: flex-start;
      padding: 12px 12px 12px 14px;
      border-radius: 14px;
      border: 1px solid rgba(148, 163, 184, 0.35);
      background: rgba(8, 12, 24, 0.96);
      box-shadow: 0 16px 40px rgba(0, 0, 0, 0.45);
      backdrop-filter: blur(10px);
      animation: appToastIn 0.18s ease;
    }

    .app-notify--error {
      border-color: rgba(248, 113, 113, 0.45);
    }

    .app-notify--warn {
      border-color: rgba(251, 191, 36, 0.45);
    }

    .app-notify__body {
      flex: 1;
      min-width: 0;
    }

    .app-notify__title {
      font-size: 0.78rem;
      font-weight: 800;
      color: #f8fafc;
      margin-bottom: 2px;
    }

    .app-notify__message {
      font-size: 0.72rem;
      line-height: 1.5;
      color: var(--color-text-muted);
      white-space: pre-wrap;
    }

    .app-notify__close {
      flex: 0 0 auto;
      width: 28px;
      height: 28px;
      border: 0;
      border-radius: 8px;
      background: transparent;
      color: var(--color-text-muted);
      font-size: 1.1rem;
      cursor: pointer;
      line-height: 1;
    }

    .app-notify__close:hover {
      background: rgba(148, 163, 184, 0.12);
      color: #f8fafc;
    }

    .app-notify.is-leaving {
      opacity: 0;
      transform: translateY(-6px);
      transition: opacity 0.2s ease, transform 0.2s ease;
    }

    @keyframes appConfirmFade {
      from { opacity: 0; }
      to { opacity: 1; }
    }

    @keyframes appConfirmPop {
      from { opacity: 0; transform: translateY(8px) scale(0.98); }
      to { opacity: 1; transform: translateY(0) scale(1); }
    }

    @keyframes appToastIn {
      from { opacity: 0; transform: translateY(8px); }
      to { opacity: 1; transform: translateY(0); }
    }
  </style>

  
  <script>
    import { initCardBuilder } from '../lib/card-builder/browserApp.mjs';
    initCardBuilder();
  </script></Layout>
