        var saved = {}; try { saved = JSON.parse(localStorage.getItem(AI_KEY)) || {}; } catch(e) {}
        if (saved.model && models.indexOf(saved.model) >= 0) modelSelect.value = saved.model;
        saveAIConfig();
        aiStatus.textContent = '✅ 成功获取 ' + models.length + ' 个模型！'; aiStatus.style.color = '#10b981';
      } catch(err) { aiStatus.textContent = '❌ ' + err.message; aiStatus.style.color = '#ef4444'; }
