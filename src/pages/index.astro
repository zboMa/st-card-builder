    async function generateContextAwareWBEntry(customDirection, stepInfo) {
      if (!stepInfo) stepInfo = '';
      var url   = apiUrl.value.replace(/\/$/, '') + '/chat/completions';
      var key   = apiKey.value.trim();
      var model = modelSelect.value;
      var searchInjection = '';
      if (window.__searchConfig__ && window.__searchConfig__.isEnabled()) {
        var sq = customDirection || charName.value.trim() + ' ' + charDesc.value.trim().substring(0, 100);
        var sr = await performSearchIfEnabled(sq);
        searchInjection = sr.searchText || '';
      }
      var existingCtx = worldbookEntries.map(function(e) { return '[标题:' + e.comment + '] (策略:' + e.strategy + '): ' + e.content; }).join('\n-----\n');
      var ctxStr      = existingCtx ? '\n【已有设定(不可重复)】：\n' + existingCtx : '\n【当前世界书为空】';
      var presetsStr  = getActivePresetsStr();
      var presetBlock = presetsStr ? '\n\n【文风约束】：\n' + presetsStr : '';
      var includeChar = wbIncludeCharData && wbIncludeCharData.checked;
      var charBlock   = includeChar ? '\n【角色】：' + charName.value.trim() + ' | ' + charDesc.value.trim() + '\n' : '';
      var sysPrompt   = '你是一个 SillyTavern 世界书词条构建大师。请生成【仅仅1条】详细完整的设定。' + stepInfo + charBlock + '\n' + ctxStr + '\n' + presetBlock + searchInjection + '\n【输出】：1个JSON对象 { "comment": "标题", "content": "详细设定(至少100字)", "keys": ["触发词"], "strategy": "selective 或 constant", "position": 4 }';
      var userPrompt  = customDirection ? '【方向】：' + customDirection : '【自由发挥，拒绝重复】';
      var headers     = { 'Content-Type': 'application/json' };
      if (key) headers['Authorization'] = 'Bearer ' + key;
      var res = await fetch(url, { method: 'POST', headers: headers, body: JSON.stringify({ model: model, messages: [{ role: "system", content: sysPrompt }, { role: "user", content: userPrompt }], temperature: 0.8 }) });
      if (!res.ok) throw new Error('请求失败 HTTP ' + res.status);
      var entry = extractJsonObj((await res.json()).choices[0].message.content);
      worldbookEntries.push({ comment: entry.comment || '拓展设定', content: entry.content || '', keys: Array.isArray(entry.keys) ? entry.keys : [], strategy: entry.strategy || 'selective', position: parseInt(entry.position) || 4, depth: 4, role: 0, order: 100, prob: 100 });
    }

    btnAiSingleWb.addEventListener('click', async function() {
