      try { await generateContextAwareWBEntry(wbSinglePrompt.value.trim(), "单条补充。"); renderEntriesList(); debouncedUpdateAndSave(); wbSinglePrompt.value = ''; }
      catch(err) { alert('生成失败: ' + err.message); }
