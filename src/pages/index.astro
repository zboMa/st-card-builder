---
import Layout from '../layouts/Layout.astro';
import AIPanel from '../components/AIPanel.astro';
import CharacterPanel from '../components/CharacterPanel.astro';
import WorldbookPanel from '../components/WorldbookPanel.astro';
import StatusBarPanel from '../components/StatusBarPanel.astro';
import PreviewPanel from '../components/PreviewPanel.astro';
import ChatPlayground from '../components/ChatPlayground.astro';
import WorldbookAuditor from '../components/WorldbookAuditor.astro';
import VariableCardPanel from '../components/VariableCardPanel.astro';
import WorkspaceFooterPanel from '../components/WorkspaceFooterPanel.astro';
import ParticleCanvas from '../components/ParticleCanvas.astro';
import GsapAnimations from '../components/GsapAnimations.astro';
---

<Layout title="SillyTavern V4 卡片构建器">
  <ParticleCanvas />
  <div class="app-header">
    <div class="app-brand">
      <span class="app-logo">
        <svg class="logo-icon" viewBox="0 -1 24 26" width="22" height="22" fill="none">
          <g transform="translate(0, 0)">
          <path d="M12 2L14.09 8.26L20 9.27L15.55 13.97L16.91 20L12 16.9L7.09 20L8.45 13.97L4 9.27L9.91 8.26L12 2Z" fill="url(#logoGrad)" stroke="url(#logoStroke)" stroke-width="0.8" />
          <path class="logo-spark" d="M12 2L14.09 8.26L20 9.27L15.55 13.97L16.91 20L12 16.9L7.09 20L8.45 13.97L4 9.27L9.91 8.26L12 2Z" fill="none" stroke="rgba(165,243,252,0.6)" stroke-width="0.6" />
          <defs>
            <linearGradient id="logoGrad" x1="4" y1="2" x2="20" y2="20">
              <stop offset="0%" stop-color="#a78bfa" />
              <stop offset="50%" stop-color="#6366f1" />
              <stop offset="100%" stop-color="#38bdf8" />
            </linearGradient>
            <linearGradient id="logoStroke" x1="4" y1="2" x2="20" y2="20">
              <stop offset="0%" stop-color="#c4b5fd" />
              <stop offset="100%" stop-color="#67e8f9" />
            </linearGradient>
          </defs>
          </g>
        </svg>
      </span>
      <div>
        <h1 class="app-title">V4 卡片构建器</h1>
        <p class="app-subtitle">未完成版本</p>
      </div>
    </div>
    <div class="app-header-actions">
      <span class="app-version-badge">V4 BUILD</span>
      <span id="visitorCount" class="app-version-badge" style="margin-left:6px;background:rgba(139,92,246,0.13);border-color:rgba(139,92,246,0.3);color:#c4b5fd;min-width:60px;text-align:center;">
        👥 <span id="visitorNum" style="font-variant-numeric:tabular-nums;">…</span>
      </span>
    </div>
  </div>

  <div class="app-container">
    <div class="app-stack app-stack-config">
      <AIPanel />
      <StatusBarPanel />
    </div>
    <div class="app-stack app-stack-lore">
      <CharacterPanel />
      <WorldbookPanel />
    </div>
    <div class="app-stack app-stack-play">
      <ChatPlayground />
      <VariableCardPanel />
    </div>
    <div class="app-stack app-stack-inspect">
      <PreviewPanel />
      <WorldbookAuditor />
      <WorkspaceFooterPanel />
    </div>
  </div>

  <GsapAnimations />

  <style is:global>
    .app-confirm-overlay {
      position: fixed;
      inset: 0;
      z-index: 9999;
      display: grid;
      place-items: center;
      padding: 18px;
      background:
        radial-gradient(circle at 50% 32%, rgba(56, 189, 248, 0.14), transparent 34%),
        rgba(2, 6, 23, 0.72);
      backdrop-filter: blur(10px);
      animation: appConfirmFade 0.16s ease;
    }

    .app-confirm-dialog {
      width: min(420px, 100%);
      border: 1px solid rgba(248, 113, 113, 0.28);
      border-radius: 18px;
      background:
        linear-gradient(145deg, rgba(15, 23, 42, 0.98), rgba(7, 12, 24, 0.98)),
        radial-gradient(circle at top left, rgba(239, 68, 68, 0.15), transparent 40%);
      box-shadow: 0 24px 70px rgba(0, 0, 0, 0.48), inset 0 1px 0 rgba(255, 255, 255, 0.06);
      overflow: hidden;
      animation: appConfirmPop 0.18s ease;
    }

    .app-confirm-head {
      display: flex;
      gap: 12px;
      padding: 18px 18px 12px;
      align-items: center;
    }

    .app-confirm-icon {
      width: 42px;
      height: 42px;
      display: grid;
      place-items: center;
      border-radius: 14px;
      border: 1px solid rgba(248, 113, 113, 0.32);
      background: rgba(127, 29, 29, 0.34);
      color: #fecaca;
      font-size: 1.25rem;
      flex: 0 0 auto;
    }

    .app-confirm-title {
      margin: 0 0 4px;
      color: #fee2e2;
      font-size: 0.98rem;
      font-weight: 800;
      letter-spacing: 0.02em;
    }

    .app-confirm-message {
      margin: 0;
      color: #94a3b8;
      font-size: 0.76rem;
      line-height: 1.6;
    }

    .app-confirm-body {
      margin: 0 18px 16px;
      padding: 10px 12px;
      border-radius: 12px;
      border: 1px solid rgba(51, 65, 85, 0.72);
      background: rgba(2, 6, 23, 0.44);
      color: #cbd5e1;
      font-size: 0.74rem;
      line-height: 1.55;
    }

    .app-confirm-actions {
      display: flex;
      gap: 10px;
      justify-content: flex-end;
      padding: 14px 18px 18px;
      border-top: 1px solid rgba(51, 65, 85, 0.5);
      background: rgba(2, 6, 23, 0.26);
    }

    .app-confirm-btn {
      min-width: 92px;
      min-height: 36px;
      padding: 0 14px;
      border-radius: 10px;
      border: 1px solid rgba(71, 85, 105, 0.75);
      background: rgba(15, 23, 42, 0.84);
      color: #cbd5e1;
      font: inherit;
      font-size: 0.78rem;
      font-weight: 800;
      cursor: pointer;
      transition: all 0.18s ease;
    }

    .app-confirm-btn:hover {
      transform: translateY(-1px);
      border-color: rgba(148, 163, 184, 0.7);
      color: #f8fafc;
    }

    .app-confirm-btn.danger {
      border-color: rgba(248, 113, 113, 0.42);
      background: linear-gradient(135deg, rgba(185, 28, 28, 0.86), rgba(127, 29, 29, 0.92));
      color: #fff1f2;
      box-shadow: 0 10px 24px rgba(127, 29, 29, 0.24);
    }

    .app-confirm-btn.danger:hover {
      border-color: rgba(252, 165, 165, 0.7);
      box-shadow: 0 12px 28px rgba(185, 28, 28, 0.32);
    }

    @keyframes appConfirmFade {
      from { opacity: 0; }
      to { opacity: 1; }
    }

    @keyframes appConfirmPop {
      from { opacity: 0; transform: translateY(8px) scale(0.98); }
      to { opacity: 1; transform: translateY(0) scale(1); }
    }
  </style>

  <script is:inline>
    // ============================================================
    //  字段注释字典
    // ============================================================
