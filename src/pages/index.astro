      var includeOthers = !wbIncludeOtherEntries || wbIncludeOtherEntries.checked;
      var existingCtx = includeOthers
        ? worldbookEntries.map(function(e) { return '[标题:' + e.comment + '] (策略:' + e.strategy + '): ' + e.content; }).join('\n-----\n')
        : '';
      var ctxStr = includeOthers
        ? (existingCtx ? '\n【已有设定(不可重复)】：\n' + existingCtx : '\n【当前世界书为空】')
        : '\n【已跳过融合已有世界书条目】';
      var presetsStr  = getActivePresetsStr();
      var presetBlock = presetsStr ? '\n\n【文风约束】：\n' + presetsStr : '';
      var includeChar = wbIncludeCharData && wbIncludeCharData.checked;
      var charBlock   = includeChar ? '\n【角色】：' + charName.value.trim() + ' | ' + charDesc.value.trim() + '\n' : '';
      var sysPrompt   = promptText('wbSingle') + stepInfo + charBlock + '\n' + ctxStr + '\n' + presetBlock + searchInjection + '\n【输出】：1个JSON对象 { "comment": "标题", "content": "详细设定(至少100字)", "keys": ["触发词"], "strategy": "selective 或 constant", "position": 4 }';
      var userPrompt  = customDirection ? '【方向】：' + customDirection : '【自由发挥，拒绝重复】';
      var headers     = { 'Content-Type': 'application/json' };
      if (key) headers['Authorization'] = 'Bearer ' + key;
      var aiResp3 = await fetchAIContent({
        context: '世界书单条生成',
        url: url,
        headers: headers,
        model: model,
        messages: [{ role: "system", content: sysPrompt }, { role: "user", content: userPrompt }],
        temperature: 0.8,
        httpErrorPrefix: '请求失败 HTTP ',
        signal: signal
      });
      var entry = extractJsonObj(aiResp3.content, '世界书单条生成');
      worldbookEntries.push({ comment: entry.comment || '拓展设定', content: entry.content || '', keys: Array.isArray(entry.keys) ? entry.keys : [], strategy: entry.strategy || 'selective', position: parseInt(entry.position) || 4, depth: 4, role: 0, order: 100, prob: 100 });
    }

    btnAiSingleWb.addEventListener('click', async function() {
      if (!modelSelect.value) return alert('请先选择模型！');
      btnAiSingleWb.disabled = true; btnAiSingleWb.textContent = "⏳ Roll中...";
      try {
        await runAiTask({
          type: 'wb_single',
          title: '世界书单条生成',
          target: (wbSinglePrompt.value.trim() || '').slice(0, 40),
        }, async function(task) {
          await generateContextAwareWBEntry(wbSinglePrompt.value.trim(), "单条补充。", task.signal);
        });
        renderEntriesList();
        debouncedUpdateAndSave();
        wbSinglePrompt.value = '';
        closeWbModal('wbModalSingle');
      }
      catch(err) {
        if (!isAiAbort(err)) alert('生成失败: ' + err.message);
      }
      finally { btnAiSingleWb.disabled = false; btnAiSingleWb.textContent = "生成 1 条"; }
    });

    // ============================================================
    //  世界书条目管理
    // ============================================================

    function escapeHtml(value) {
      return String(value == null ? '' : value)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function truncatePreviewLine(text, maxLen) {
      var cap = maxLen || 100;
      var one = String(text || '').replace(/\s+/g, ' ').trim();
      if (!one) return '';
      return one.length > cap ? one.slice(0, cap) + '…' : one;
    }

    // 挂到 body，避免 .panel 的 transform/overflow 把 fixed 遮罩锁在面板内
    var WB_MODAL_IDS = ['wbModalSingle', 'wbModalOrganize', 'wbModalKeygen', 'wbModalEdit'];
    function openWbModal(id) {
      var el = document.getElementById(id);
      if (!el) return;
      if (!el._wbModalHome) el._wbModalHome = el.parentNode;
      document.body.appendChild(el);
      el.hidden = false;
      el.setAttribute('aria-hidden', 'false');
      document.body.classList.add('wb-modal-open');
    }

    function closeWbModal(id) {
      var el = document.getElementById(id);
      if (!el) return;
      el.hidden = true;
      el.setAttribute('aria-hidden', 'true');
      if (el._wbModalHome && el.parentNode !== el._wbModalHome) {
        el._wbModalHome.appendChild(el);
      }
      // 关闭编辑弹窗时清编辑态
      if (id === 'wbModalEdit') {
        editingIndex = -1;
        isCreatingEntry = false;
        updateCreateEntryButtonState();
      }
      var anyOpen = WB_MODAL_IDS.some(function(mid) {
        var m = document.getElementById(mid);
        return m && !m.hidden;
      });
      if (!anyOpen) document.body.classList.remove('wb-modal-open');
    }

    function setStatusBar(el, text, color) {
      if (!el) return;
      if (!text) {
        el.style.display = 'none';
        el.textContent = '';
        return;
      }
      el.style.display = 'flex';
      el.innerHTML = text;
      if (color) el.style.color = color;
    }

    function getDefaultWBEntry() {
      return {
        comment: '',
        content: '',
        keys: [],
        strategy: 'selective',
        position: 4,
        depth: 4,
        role: 0,
        order: 100,
        prob: 100,
      };
    }

    function normalizeWBEntry(entry) {
      var base = getDefaultWBEntry();
      entry = entry || {};
      return {
        comment: String(entry.comment || ''),
        content: String(entry.content || ''),
        keys: Array.isArray(entry.keys) ? entry.keys.filter(function(k) { return String(k || '').trim(); }) : [],
        strategy: ['constant', 'selective', 'vectorized'].indexOf(entry.strategy) >= 0 ? entry.strategy : base.strategy,
        position: clampInt(entry.position, base.position, 0, 6),
        depth: clampInt(entry.depth, base.depth, 0, 999),
        role: clampInt(entry.role, base.role, 0, 2),
        order: clampInt(entry.order, base.order, 0, 999),
        prob: clampInt(entry.prob, base.prob, 1, 100),
      };
    }

    function renderSelectOptions(options, selectedValue) {
      var selected = String(selectedValue);
      var html = '';
      options.forEach(function(option) {
        html += '<option value="' + escapeHtml(option.value) + '"' + (selected === String(option.value) ? ' selected' : '') + '>' + escapeHtml(option.label) + '</option>';
      });
      return html;
    }

    /** UI 中文标签；导出仍用 constant / selective / vectorized */
    function strategyLabelZh(strategy) {
      if (strategy === 'constant') return '常驻';
      if (strategy === 'vectorized') return '向量化';
      return '可选';
    }

    function strategyTagClass(strategy) {
      if (strategy === 'constant') return 'is-constant';
      if (strategy === 'vectorized') return 'is-vectorized';
      return 'is-selective';
    }

    function renderStrategyTag(strategy) {
      var s = strategy || 'selective';
      return '<span class="wb-strategy-tag ' + strategyTagClass(s) + '">'
        + '<span class="wb-strategy-dot" aria-hidden="true"></span>'
        + escapeHtml(strategyLabelZh(s))
        + '</span>';
    }

    /** 弹窗表单字段（不含底部按钮；按钮在弹窗 actions） */
    function renderWbEditorFields(index, entry, isNew) {
      entry = normalizeWBEntry(entry);
      var editorId = isNew ? 'wb_editor_new' : 'wb_editor_' + index;
      var strategyOptions = renderSelectOptions([
        { value: 'constant', label: '常驻' },
        { value: 'selective', label: '可选' },
        { value: 'vectorized', label: '向量化' },
      ], entry.strategy);
      var positionOptions = renderSelectOptions([
        { value: '0', label: '0 — 角色定义之前' },
        { value: '1', label: '1 — 角色定义之后' },
        { value: '2', label: '2 — 示例消息之前' },
        { value: '3', label: '3 — 示例消息之后' },
        { value: '4', label: '4 — 按深度插入' },
        { value: '5', label: '5 — 作者注释之前' },
        { value: '6', label: '6 — 作者注释之后' },
      ], entry.position);
      var roleOptions = renderSelectOptions([
        { value: '0', label: '系统' },
        { value: '1', label: '用户' },
        { value: '2', label: '助手' },
      ], entry.role);
      return ''
        + '<div class="wb-inline-editor" id="' + editorId + '" data-editor-index="' + index + '">'
        +   '<div class="form-group">'
        +     '<label>条目标题</label>'
        +     '<input type="text" data-field="comment" placeholder="例如：===特殊武器===" value="' + escapeHtml(entry.comment) + '" />'
        +   '</div>'
        +   '<div class="form-group">'
        +     '<label>设定内容</label>'
        +     '<textarea data-field="content" placeholder="具体设定详情...">' + escapeHtml(entry.content) + '</textarea>'
        +   '</div>'
        +   '<div class="form-group">'
        +     '<label>触发词 — 多个用英文逗号隔开</label>'
        +     '<input type="text" data-field="keys" placeholder="空为常驻，有词为触发" value="' + escapeHtml((entry.keys || []).join(', ')) + '" />'
        +   '</div>'
        +   '<div class="grid-2">'
        +     '<div class="form-group">'
        +       '<label>触发策略</label>'
        +       '<select data-field="strategy">' + strategyOptions + '</select>'
        +     '</div>'
        +     '<div class="form-group">'
        +       '<label>插入位置</label>'
        +       '<select data-field="position">' + positionOptions + '</select>'
        +     '</div>'
        +   '</div>'
        +   '<div class="grid-3">'
        +     '<div class="form-group">'
        +       '<label>深度</label>'
        +       '<input type="number" data-field="depth" value="' + escapeHtml(entry.depth) + '" min="0" />'
        +     '</div>'
        +     '<div class="form-group">'
        +       '<label>角色</label>'
        +       '<select data-field="role">' + roleOptions + '</select>'
        +     '</div>'
        +     '<div class="form-group">'
        +       '<label>顺序</label>'
        +       '<input type="number" data-field="order" value="' + escapeHtml(entry.order) + '" />'
        +     '</div>'
        +   '</div>'
        +   '<div class="form-group">'
        +     '<label>概率 (%)</label>'
        +     '<input type="number" data-field="prob" value="' + escapeHtml(entry.prob) + '" min="1" max="100" />'
        +   '</div>'
        + '</div>';
    }

    function getInlineEditorRoot(index) {
      return document.getElementById(index < 0 ? 'wb_editor_new' : 'wb_editor_' + index);
    }

    function readInlineEditorValue(root, field) {
      var el = root ? root.querySelector('[data-field="' + field + '"]') : null;
      return el ? el.value : '';
    }

    function readInlineEditorEntry(root) {
      var base = getDefaultWBEntry();
      return {
        comment: readInlineEditorValue(root, 'comment').trim(),
        content: readInlineEditorValue(root, 'content').trim(),
        keys: readInlineEditorValue(root, 'keys').split(/[,，]/).map(function(k) { return k.trim(); }).filter(function(k) { return k; }),
        strategy: readInlineEditorValue(root, 'strategy') || base.strategy,
        position: clampInt(readInlineEditorValue(root, 'position'), base.position, 0, 6),
        depth: clampInt(readInlineEditorValue(root, 'depth'), base.depth, 0, 999),
        role: clampInt(readInlineEditorValue(root, 'role'), base.role, 0, 2),
        order: clampInt(readInlineEditorValue(root, 'order'), base.order, 0, 999),
        prob: clampInt(readInlineEditorValue(root, 'prob'), base.prob, 1, 100),
      };
    }

    function focusWbModalEditor() {
      setTimeout(function() {
        var body = document.getElementById('wbModalEditBody');
        if (!body) return;
        var target = body.querySelector('[data-field="comment"]');
        if (target) target.focus();
      }, 0);
    }

    /** 打开新建/编辑弹窗并填入表单 */
    function openWbEditModal(index, entry, isNew) {
      var titleEl = document.getElementById('wbModalEditTitle');
      var tipEl = document.getElementById('wbModalEditTip');
      var bodyEl = document.getElementById('wbModalEditBody');
      var saveBtn = document.getElementById('btnWbModalSave');
      if (!bodyEl) return;
      if (titleEl) titleEl.textContent = isNew ? '新建世界书条目' : '编辑世界书条目';
      if (tipEl) tipEl.textContent = isNew
        ? '手动录入会插入到条目列表 · Esc / 遮罩关闭'
        : '保存后覆盖本条 · Esc / 遮罩关闭';
      if (saveBtn) saveBtn.textContent = isNew ? '保存新条目' : '保存修改';
      bodyEl.innerHTML = renderWbEditorFields(index, entry, isNew);
      openWbModal('wbModalEdit');
      focusWbModalEditor();
    }

    function updateCreateEntryButtonState() {
      if (!btnCreateEntry) return;
      btnCreateEntry.textContent = isCreatingEntry ? '取消新建' : '新建';
    }

    function resetWBForm() {
      editingIndex = -1;
      isCreatingEntry = false;
      updateCreateEntryButtonState();
    }

    function toggleCreateEntryForm() {
      if (isCreatingEntry) {
        closeWbModal('wbModalEdit');
        return;
      }
      editingIndex = -1;
      isCreatingEntry = true;
      updateCreateEntryButtonState();
      openWbEditModal(-1, getDefaultWBEntry(), true);
    }

    function editEntry(index) {
      if (editingIndex === index && !isCreatingEntry) {
        closeWbModal('wbModalEdit');
        return;
      }
      editingIndex = index;
      isCreatingEntry = false;
      updateCreateEntryButtonState();
      openWbEditModal(index, worldbookEntries[index] || getDefaultWBEntry(), false);
    }

    function cancelInlineEdit() {
      closeWbModal('wbModalEdit');
    }

    function saveInlineEntry(index) {
      var editorRoot = getInlineEditorRoot(index);
      if (!editorRoot) return;
      var nextEntry = readInlineEditorEntry(editorRoot);
      if (!nextEntry.content.trim()) return alert('内容不能为空！');
      if (index >= 0) worldbookEntries[index] = nextEntry;
      else worldbookEntries.push(nextEntry);
      closeWbModal('wbModalEdit');
      renderEntriesList();
      debouncedUpdateAndSave();
    }

    async function aiRewriteEntry(index, req, btn) {
      var url = apiUrl.value.replace(/\/$/, '') + '/chat/completions'; var key = apiKey.value.trim(); var model = modelSelect.value;
      if (!model) {
        alert('请先选择模型！');
        throw new Error('请先选择模型');
      }
      var old = worldbookEntries[index];
      var oldText = btn && btn.textContent;
      if (btn) { btn.disabled = true; btn.textContent = '⏳ 重铸中...'; }
      var isSkeleton = old.content.length < 60;
      var taskType = isSkeleton ? 'wb_expand' : 'wb_rewrite';
      try {
        await runAiTask({
          type: taskType,
          title: isSkeleton ? '世界书扩写' : '世界书重写',
          target: old.comment || ('#' + index),
        }, async function(task) {
          var presetsStr = getActivePresetsStr();
          var expandHint = isSkeleton ? '\n\n【重要】：原条目是骨架概要，请展开为完整详细的世界书设定词条（至少150字），保留方向但大幅扩充。' : '';
          var searchInjection = '';
          if (window.__searchConfig__ && window.__searchConfig__.isEnabled()) {
            var sq = old.comment + ' ' + (req || '');
            var sr = await performSearchIfEnabled(sq);
            searchInjection = sr.searchText || '';
          }
          var sys = promptText('wbRewrite') + '\n【原词条】: 标题: ' + old.comment + ' | 策略: ' + old.strategy + ' | 触发词: ' + old.keys.join(',') + '\n内容: ' + old.content + (presetsStr ? '\n【文风】：\n' + presetsStr : '') + expandHint + searchInjection + '\n【任务】：重写。输出JSON：{ "comment": "标题", "content": "详细设定", "keys": ["触发词"], "strategy": "selective 或 constant", "position": ' + old.position + ' }';
          var h = { 'Content-Type': 'application/json' }; if (key) h['Authorization'] = 'Bearer ' + key;
          var aiResp4 = await fetchAIContent({
            context: '世界书重写/索引' + index,
            url: url,
            headers: h,
            model: model,
            messages: [{ role: "system", content: sys }, { role: "user", content: isSkeleton ? '将骨架展开为完整设定。' + (req ? ' 额外要求：' + req : '') : '修改要求：' + req }],
            temperature: 0.8,
            httpErrorPrefix: 'HTTP ',
            signal: task.signal
          });
          var ed = extractJsonObj(aiResp4.content, '世界书重写/索引' + index);
          worldbookEntries[index].comment = ed.comment || old.comment;
          worldbookEntries[index].content = ed.content || old.content;
          if (ed.keys) worldbookEntries[index].keys = Array.isArray(ed.keys) ? ed.keys : [];
          if (ed.strategy) worldbookEntries[index].strategy = ed.strategy;
          renderEntriesList(); debouncedUpdateAndSave();
        });
      } catch(err) {
        if (!isAiAbort(err)) {
          alert('重写失败: ' + err.message);
          throw err;
        }
      }
      finally {
        if (btn) { btn.disabled = false; btn.textContent = oldText || '✨ AI重写'; }
      }
    }

    function renderEntriesList() {
      entriesList.innerHTML = '';
      // 始终显示列表容器以占满剩余高度；空态用占位避免主区下方大片空白
      entriesList.style.display = '';
      var posMap = ['角色前', '角色后', '示例前', '示例后', '按深度', '注释前', '注释后'];
      if (!worldbookEntries.length) {
        var empty = document.createElement('div');
        empty.className = 'wb-entries-empty';
        empty.textContent = '暂无世界书条目，点击右上「新建」或「单条生成」';
        entriesList.appendChild(empty);
      }
      worldbookEntries.forEach(function(entry, index) {
        entry = normalizeWBEntry(entry);
        var isSk = entry.content.length < 60 || String(entry.content || '').indexOf('待展开') >= 0;
        var safeComment = escapeHtml(entry.comment || '未命名');
        var previewLine = truncatePreviewLine(entry.content);
        var metaLine = '位置: ' + (posMap[entry.position] || entry.position) + ' | 顺序: ' + entry.order + ' | 深度: ' + entry.depth + ' | 概率: ' + entry.prob + '%';
        var skBadge = isSk ? '<span style="font-size:0.6rem;background:rgba(245,158,11,0.15);color:#f59e0b;padding:1px 6px;border-radius:99px;border:1px solid rgba(245,158,11,0.25);">🦴 骨架</span>' : '';
        var strategyBadge = renderStrategyTag(entry.strategy);
        // 右侧图标操作：编辑 / AI重写 / 删除（骨架未扩展：金色提示可展开）
        var aiTitle = isSk ? 'AI 展开（未扩展）' : 'AI 重写';
        var actionsHtml =
          '<div class="entry-actions">' +
            '<button class="entry-icon-btn btn-edit" data-index="' + index + '" type="button" title="编辑" aria-label="编辑">✎</button>' +
            '<button class="entry-icon-btn btn-toggle-reroll' + (isSk ? ' btn-ai-expand' : '') + '" data-index="' + index + '" type="button" title="' + aiTitle + '" aria-label="' + aiTitle + '">✦</button>' +
            '<button class="entry-icon-btn is-danger btn-delete" data-index="' + index + '" type="button" title="删除" aria-label="删除">×</button>' +
          '</div>';
        var div = document.createElement('div');
        div.className = 'entry-item fade-in';
        div.setAttribute('data-entry-index', String(index));
        div.innerHTML =
          '<div class="entry-item-header">' +
            '<div class="entry-info">' +
              '<div class="entry-info-title-row"><button type="button" class="entry-title-btn btn-edit" data-index="' + index + '" title="编辑条目">' + safeComment + '</button>' + strategyBadge + skBadge + '</div>' +
              (previewLine ? '<p class="entry-preview-line">' + escapeHtml(previewLine) + '</p>' : '') +
              '<p class="entry-meta-line">' + escapeHtml(metaLine) + '</p>' +
            '</div>' +
            actionsHtml +
          '</div>' +
          '<div id="reroll_area_' + index + '" style="display:none;width:100%;margin-top:12px;padding-top:12px;border-top:1px dashed var(--color-surface-elevated);">' +
            '<input type="text" id="reroll_prompt_' + index + '" placeholder="' + (isSk ? '可留空直接展开，或输入额外要求...' : '怎么修改？') + '" style="width:100%;padding:8px;margin-bottom:8px;" />' +
            '<button class="btn btn-submit-reroll" data-index="' + index + '" type="button" style="background:linear-gradient(135deg,var(--color-accent),#6d28d9);padding:8px;font-size:0.85rem;">' +
              (isSk ? '🦴→📖 展开为完整设定' : '🎲 确定覆盖重写') +
            '</button>' +
          '</div>';
        entriesList.appendChild(div);
      });
      updateCreateEntryButtonState();

      document.querySelectorAll('.btn-edit').forEach(function(b) {
        b.addEventListener('click', function(e) {
          e.stopPropagation();
          editEntry(parseInt(e.currentTarget.getAttribute('data-index'), 10));
        });
      });
      document.querySelectorAll('.btn-toggle-reroll').forEach(function(b) {
        b.addEventListener('click', function(e) {
          e.stopPropagation();
          var idx = e.currentTarget.getAttribute('data-index');
          var a = document.getElementById('reroll_area_' + idx);
          a.style.display = a.style.display === 'none' ? 'block' : 'none';
        });
      });
      document.querySelectorAll('.btn-submit-reroll').forEach(function(b) {
        b.addEventListener('click', async function(e) {
          e.stopPropagation();
          var idx = parseInt(e.currentTarget.getAttribute('data-index'), 10);
          var req = document.getElementById('reroll_prompt_' + idx).value.trim();
          var isSk = worldbookEntries[idx].content.length < 60;
          if (!isSk && !req) return alert('请填写修改要求！');
          await aiRewriteEntry(idx, req, e.currentTarget);
        });
      });
      document.querySelectorAll('.btn-delete').forEach(function(b) {
        b.addEventListener('click', function(e) {
          e.stopPropagation();
          var idx = parseInt(e.currentTarget.getAttribute('data-index'), 10);
          worldbookEntries.splice(idx, 1);
          // 重建展开索引（删除后序号左移）
          if (editingIndex === idx) closeWbModal('wbModalEdit');
          else if (editingIndex > idx) editingIndex--;
          renderEntriesList();
          flushUpdateAndSave();
        });
      });
      // 通知审计官：世界书条目已变化
      window.dispatchEvent(new CustomEvent('worldbook-changed'));
      // 同步刷新搜索结果
      if (wbSearchInput && wbSearchInput.value) renderWbSearchResults(wbSearchInput.value);
    }

    // ============================================================
    //  世界书搜索（标题 / 触发词 / 内容 → 单列紧凑命中行）
    // ============================================================
    var wbSearchInput   = document.getElementById('wbSearchInput');
    var wbSearchClear   = document.getElementById('wbSearchClear');
    var wbSearchResults = document.getElementById('wbSearchResults');
    var wbSearchCount   = document.getElementById('wbSearchCount');
    var wbScopeTitle    = document.getElementById('wbScopeTitle');
    var wbScopeKeys     = document.getElementById('wbScopeKeys');
    var wbScopeContent  = document.getElementById('wbScopeContent');

    function escapeRegex(s) {
      return String(s).replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    }

    function highlightMatch(text, query) {
      var safeText = escapeHtml(text || '');
      if (!query) return safeText;
      var safeQuery = escapeHtml(query);
      if (!safeQuery) return safeText;
      var re;
      try { re = new RegExp(escapeRegex(safeQuery), 'gi'); }
      catch (e) { return safeText; }
      return safeText.replace(re, function(m) { return '<mark>' + m + '</mark>'; });
    }

    /** 围绕命中位置截取单行摘录 */
    function buildWbHitSnippet(text, q, queryLen) {
      var raw = String(text || '');
      if (!raw) return '';
      var idx = raw.toLowerCase().indexOf(q);
      if (idx === -1) {
        return raw.length > 72 ? raw.substring(0, 72) + '…' : raw;
      }
      var start = Math.max(0, idx - 24);
      var end = Math.min(raw.length, idx + queryLen + 40);
      return (start > 0 ? '…' : '') + raw.substring(start, end) + (end < raw.length ? '…' : '');
    }

    function renderWbSearchResults(query) {
      if (!wbSearchResults) return;
      var trimmed = query ? query.trim() : '';
      if (!trimmed) {
        wbSearchResults.style.display = 'none';
        wbSearchResults.innerHTML = '';
        if (wbSearchCount) wbSearchCount.textContent = '';
        if (wbSearchClear) wbSearchClear.style.display = 'none';
        return;
      }
      if (wbSearchClear) wbSearchClear.style.display = 'flex';
      var q = trimmed.toLowerCase();
      var scopeTitle   = !wbScopeTitle   || wbScopeTitle.checked;
      var scopeKeys    = !wbScopeKeys    || wbScopeKeys.checked;
      var scopeContent = !wbScopeContent || wbScopeContent.checked;
      if (!scopeTitle && !scopeKeys && !scopeContent) {
        scopeTitle = scopeKeys = scopeContent = true;
      }
      var matches = [];
      worldbookEntries.forEach(function(rawEntry, index) {
        var entry = normalizeWBEntry(rawEntry);
        var comment = entry.comment || '';
        var keysText = (entry.keys || []).join(', ');
        var content = entry.content || '';
        var titleMatch   = scopeTitle   && comment.toLowerCase().indexOf(q) !== -1;
        var keysMatch    = scopeKeys    && keysText.toLowerCase().indexOf(q) !== -1;
        var contentMatch = scopeContent && content.toLowerCase().indexOf(q) !== -1;
        if (titleMatch || keysMatch || contentMatch) {
          matches.push({ index: index, entry: entry, keysText: keysText, titleMatch: titleMatch, keysMatch: keysMatch, contentMatch: contentMatch });
        }
      });

      if (wbSearchCount) wbSearchCount.textContent = '命中 ' + matches.length + ' / ' + worldbookEntries.length + ' 条';
      wbSearchResults.style.display = 'flex';

      if (matches.length === 0) {
        wbSearchResults.innerHTML = '<div class="wb-search-empty">无命中</div>';
        return;
      }

      // 紧凑行：标题 + 策略 tag + 命中字段 + 一行高亮摘录；整行可点跳转
      var html = matches.map(function(m) {
        var entry = m.entry;
        var fields = [];
        if (m.titleMatch)   fields.push('<strong>标题</strong>');
        if (m.keysMatch)    fields.push('<strong>触发词</strong>');
        if (m.contentMatch) fields.push('<strong>内容</strong>');
        var snippetSrc = '';
        if (m.contentMatch) snippetSrc = entry.content || '';
        else if (m.keysMatch) snippetSrc = m.keysText || '';
        else snippetSrc = entry.content || m.keysText || '';
        var snippet = buildWbHitSnippet(snippetSrc, q, trimmed.length);
        var titleHtml = highlightMatch(entry.comment || '未命名', trimmed);
        var snippetHtml = highlightMatch(snippet, trimmed);
        return '<div class="wb-search-hit" role="button" tabindex="0" data-jump-index="' + m.index + '" title="跳转并展开该条目">' +
          '<div class="wb-search-hit-main">' +
            '<span class="wb-search-hit-title" title="' + escapeHtml(entry.comment || '') + '">' + titleHtml + '</span>' +
            renderStrategyTag(entry.strategy) +
            '<span class="wb-search-hit-fields">' + fields.join(' · ') + '</span>' +
          '</div>' +
          (snippet ? '<div class="wb-search-hit-snippet">' + snippetHtml + '</div>' : '') +
        '</div>';
      }).join('');
      wbSearchResults.innerHTML = html;

      wbSearchResults.querySelectorAll('.wb-search-hit').forEach(function(row) {
        function go() {
          var idx = parseInt(row.getAttribute('data-jump-index'), 10);
          jumpToWbEntry(idx);
        }
        row.addEventListener('click', go);
        row.addEventListener('keydown', function(e) {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            go();
          }
        });
      });
    }

    function jumpToWbEntry(idx) {
      if (!Number.isFinite(idx) || idx < 0 || idx >= worldbookEntries.length) return;
      renderEntriesList();
      var targetDiv = entriesList.querySelector('.entry-item[data-entry-index="' + idx + '"]');
      if (targetDiv) {
        targetDiv.scrollIntoView({ behavior: 'smooth', block: 'center' });
        targetDiv.classList.add('is-search-focus');
        targetDiv.style.transition = 'box-shadow 0.3s ease';
        targetDiv.style.boxShadow = '0 0 0 2px rgba(56, 189, 248, 0.6)';
        setTimeout(function() {
          targetDiv.style.boxShadow = '';
          targetDiv.classList.remove('is-search-focus');
        }, 1800);
      } else {
        entriesList.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
      editEntry(idx);
    }

    if (wbSearchInput) {
      wbSearchInput.addEventListener('input', function() {
        renderWbSearchResults(wbSearchInput.value);
      });
    }
    if (wbSearchClear) {
      wbSearchClear.addEventListener('click', function() {
        wbSearchInput.value = '';
        renderWbSearchResults('');
        wbSearchInput.focus();
      });
    }
    [wbScopeTitle, wbScopeKeys, wbScopeContent].forEach(function(cb) {
      if (cb) cb.addEventListener('change', function() {
        renderWbSearchResults(wbSearchInput.value);
      });
    });

    if (btnCreateEntry) btnCreateEntry.addEventListener('click', toggleCreateEntryForm);

    // 标题行右上 AI / 新建 → 打开配置弹窗；取消/遮罩关闭
    var btnOpenWbAiSingle = document.getElementById('btnOpenWbAiSingle');
    var btnOpenWbAiOrganize = document.getElementById('btnOpenWbAiOrganize');
    var btnOpenWbAiKeygen = document.getElementById('btnOpenWbAiKeygen');
    if (btnOpenWbAiSingle) btnOpenWbAiSingle.addEventListener('click', function() { openWbModal('wbModalSingle'); });
    if (btnOpenWbAiOrganize) btnOpenWbAiOrganize.addEventListener('click', function() { openWbModal('wbModalOrganize'); });
    if (btnOpenWbAiKeygen) btnOpenWbAiKeygen.addEventListener('click', function() { openWbModal('wbModalKeygen'); });
    document.querySelectorAll('[data-wb-modal-close]').forEach(function(el) {
      el.addEventListener('click', function() {
        closeWbModal(el.getAttribute('data-wb-modal-close'));
      });
    });
    var btnWbModalSave = document.getElementById('btnWbModalSave');
    if (btnWbModalSave) {
      btnWbModalSave.addEventListener('click', function() {
        saveInlineEntry(isCreatingEntry ? -1 : editingIndex);
      });
    }
    document.addEventListener('keydown', function(e) {
      if (e.key !== 'Escape') return;
      WB_MODAL_IDS.forEach(closeWbModal);
    });

    // ============================================================
    //  AI 智能整理世界书参数
    // ============================================================
    var btnAiOrganize    = document.getElementById('btnAiOrganize');
    var organizePreview  = document.getElementById('organizePreview');
    var organizeStatus   = document.getElementById('organizeStatus');
    var btnAiGenerateKeys = document.getElementById('btnAiGenerateKeys');
    var keygenStatus      = document.getElementById('keygenStatus');
    var pendingOrganizeData = null;
    var KEYGEN_BATCH_CHAR_LIMIT = 20000;
    var KEYGEN_BATCH_ITEM_LIMIT = 8;
    var KEYGEN_MAX_RETRY_ROUNDS = 3;

    function sanitizeGeneratedKeys(keys, oldKeys) {
      var source = Array.isArray(keys) ? keys : [];
      var merged = source.concat(Array.isArray(oldKeys) ? oldKeys : []);
      var out = [];
      var seen = {};
      merged.forEach(function(k) {
        var t = String(k || '').trim();
        if (!t) return;
        if (t.length > 24) return;
        var low = t.toLowerCase();
        if (seen[low]) return;
        seen[low] = true;
        out.push(t);
      });
      return out.slice(0, 8);
    }

    function buildKeygenCompactEntries(batch) {
      return batch.map(function(item) {
        return {
          index: item.index,
          comment: item.entry.comment || '',
          current_keys: item.entry.keys || [],
          content_preview: (item.entry.content || '').trim().substring(0, 240),
        };
      });
    }

    function estimateKeygenPayloadChars(charBlock, batch) {
      var compactEntries = buildKeygenCompactEntries(batch);
      var userPrompt = '角色参考：\n' + JSON.stringify(charBlock, null, 2)
        + '\n\n请为以下世界书条目生成更合适的触发词：\n'
        + JSON.stringify(compactEntries, null, 2);
      return userPrompt.length;
    }

    function splitTargetsForKeygen(targets, charBlock) {
      var batches = [];
      var current = [];

      targets.forEach(function(item) {
        var tentative = current.concat([item]);
        var size = estimateKeygenPayloadChars(charBlock, tentative);
        if (current.length > 0 && (size > KEYGEN_BATCH_CHAR_LIMIT || tentative.length > KEYGEN_BATCH_ITEM_LIMIT)) {
          batches.push(current);
          current = [item];
          return;
        }

        current = tentative;
      });

      if (current.length > 0) batches.push(current);
      return batches;
    }

    async function generateTriggerKeysBatch(batch, signal) {
      var url = apiUrl.value.replace(/\/$/, '') + '/chat/completions';
      var key = apiKey.value.trim();
      var model = modelSelect.value;
      if (!model) throw new Error('请先选择 AI 模型！');

      var headers = { 'Content-Type': 'application/json' };
      if (key) headers['Authorization'] = 'Bearer ' + key;

      var charBlock = {
        name: charName.value.trim() || '',
        worldbook: wbName.value.trim() || '',
        description_preview: (charDesc.value || '').trim().substring(0, 300),
      };

      var compactEntries = buildKeygenCompactEntries(batch);

      var sysPrompt = promptText('wbTriggerKeys');

      var userPrompt = '角色参考：\n' + JSON.stringify(charBlock, null, 2)
        + '\n\n请为以下世界书条目生成更合适的触发词：\n'
        + JSON.stringify(compactEntries, null, 2);

      var aiResp5 = await fetchAIContent({
        context: '世界书触发词批次',
        url: url,
        headers: headers,
        model: model,
        messages: [
          { role: 'system', content: sysPrompt },
          { role: 'user', content: userPrompt },
        ],
        temperature: 0.4,
        httpErrorPrefix: 'HTTP ',
        signal: signal
      });
      var raw = aiResp5.content;
      var arr;
      try {
        arr = extractJsonArray(raw, '世界书触发词批次');
      } catch(pe) {
        arr = [extractJsonObj(raw, '世界书触发词批次/fallback')];
      }

      if (!Array.isArray(arr)) throw new Error('AI 返回格式异常');
      return arr;
    }

    function applyTriggerKeySuggestions(suggestions) {
      var applied = 0;
      var matched = {};
      (Array.isArray(suggestions) ? suggestions : []).forEach(function(item) {
        var idx = Number(item && item.index);
        if (!Number.isFinite(idx) || idx < 0 || idx >= worldbookEntries.length) return;
        var prevKeys = (worldbookEntries[idx].keys || []).join('||');
        var nextKeys = sanitizeGeneratedKeys(item.keys, worldbookEntries[idx].keys);
        if (!nextKeys.length) return;
        matched[idx] = true;
        worldbookEntries[idx].keys = nextKeys;
        if (prevKeys !== nextKeys.join('||')) applied++;
      });
      return { applied: applied, matched: matched };
    }

    async function completeTriggerKeysBatch(batch, batchIndex, batchCount, processed, totalTargets, signal) {
      var pending = batch.slice();
      var round = 0;
      var updated = 0;
      var matchedAny = {};

      while (pending.length > 0 && round < KEYGEN_MAX_RETRY_ROUNDS) {
        if (signal && signal.aborted) throw new DOMException('已取消', 'AbortError');
        round++;
        var retryHint = round > 1 ? '，补跑第 ' + round + ' 轮（剩余 ' + pending.length + ' 条）' : '';
        setStatusBar(keygenStatus, '🧠 正在生成触发词... ' + processed + '/' + totalTargets + '（第 ' + (batchIndex + 1) + '/' + batchCount + ' 批' + retryHint + '）', '#38bdf8');
        var suggestions = await generateTriggerKeysBatch(pending, signal);
        var result = applyTriggerKeySuggestions(suggestions);
        updated += result.applied;
        Object.keys(result.matched).forEach(function(idx) { matchedAny[idx] = true; });
        pending = pending.filter(function(item) { return !matchedAny[item.index]; });
      }

      return {
        updated: updated,
        missing: pending
      };
    }

    btnAiGenerateKeys.addEventListener('click', async function() {
      if (worldbookEntries.length === 0) return alert('世界书为空，没有可生成触发词的条目！');
      if (!modelSelect.value) return alert('请先选择 AI 模型！');

      var targets = worldbookEntries
        .map(function(entry, index) { return { entry: entry, index: index }; })
        .filter(function(item) { return item.entry.strategy !== 'constant'; });

      if (targets.length === 0) return alert('当前条目都是常驻条目，没有需要生成触发词的目标。');

      btnAiGenerateKeys.disabled = true;
      btnAiGenerateKeys.textContent = '⏳ 生成中...';
      closeWbModal('wbModalKeygen');
      setStatusBar(keygenStatus, '🧠 正在分析 ' + targets.length + ' 条条目的触发词...', '#38bdf8');

      try {
        await runAiTask({
          type: 'wb_keygen',
          title: '世界书补全触发词',
          target: targets.length + ' 条',
        }, async function(task) {
          var charBlock = {
            name: charName.value.trim() || '',
            worldbook: wbName.value.trim() || '',
            description_preview: (charDesc.value || '').trim().substring(0, 300),
          };
          var batches = splitTargetsForKeygen(targets, charBlock);
          var updated = 0;
          var processed = 0;
          var unresolved = [];
          for (var batchIndex = 0; batchIndex < batches.length; batchIndex++) {
            if (task.signal && task.signal.aborted) throw new DOMException('已取消', 'AbortError');
            var batch = batches[batchIndex];
            processed += batch.length;
            if (window.__aiTaskCenter__) {
              window.__aiTaskCenter__.setProgress(task.id, processed / targets.length, '批次 ' + (batchIndex + 1) + '/' + batches.length);
            }
            var batchResult = await completeTriggerKeysBatch(batch, batchIndex, batches.length, processed, targets.length, task.signal);
            updated += batchResult.updated;
            if (batchResult.missing && batchResult.missing.length > 0) {
              unresolved = unresolved.concat(batchResult.missing.map(function(item) {
                return item.entry.comment || ('#' + item.index);
              }));
            }
          }

          renderEntriesList();
          debouncedUpdateAndSave();
          if (unresolved.length > 0) {
            setStatusBar(
              keygenStatus,
              '⚠️ 已为 <strong>' + updated + '</strong> 条世界书更新触发词，但仍有 <strong>' + unresolved.length + '</strong> 条未返回结果：' + unresolved.slice(0, 3).map(escapeHtml).join('、') + (unresolved.length > 3 ? '…' : ''),
              'var(--color-warning)'
            );
          } else {
            setStatusBar(keygenStatus, '✅ 已为 <strong>' + updated + '</strong> 条世界书更新触发词', '#34d399');
          }
        });
      } catch(err) {
        if (isAiAbort(err)) setStatusBar(keygenStatus, '⏹ 已取消', 'var(--color-text-muted)');
        else setStatusBar(keygenStatus, '❌ 触发词生成失败: ' + escapeHtml(err.message), 'var(--color-danger)');
      } finally {
        btnAiGenerateKeys.disabled = false;
        btnAiGenerateKeys.textContent = '一键补触发词';
      }
    });

    function clampInt(value, fallback, min, max) {
      var n = parseInt(value, 10);
      if (!Number.isFinite(n)) n = fallback;
      if (!Number.isFinite(n)) n = min;
      return Math.max(min, Math.min(max, n));
    }

    function normalizeOrganizeSuggestion(item) {
      var idx = Number(item && item.index);
      if (!Number.isFinite(idx) || idx < 0 || idx >= worldbookEntries.length) return null;
      var entry = worldbookEntries[idx];
      var position = clampInt(item.position, entry.position ?? 4, 0, 6);
      var role = clampInt(item.role, entry.role ?? 0, 0, 2);
      return {
        index: idx,
        position: position,
        role: role,
        depth: clampInt(item.depth, entry.depth ?? 4, 0, 999),
        order: clampInt(item.order, entry.order ?? 100, 0, 999),
        prob: clampInt(item.prob ?? item.probability, entry.prob ?? 100, 1, 100),
        reason: String(item.reason || '').trim() || '—',
      };
    }

    function positionLabel(position) {
      return ({
        0: '↑ Char',
        1: '↓ Char',
        2: '↑ EM',
        3: '↓ EM',
        4: '@D',
        5: '↑ AN',
        6: '↓ AN',
      })[Number(position)] || '@D';
    }

    function roleLabel(role) {
      return ({
        0: '系统⚙',
        1: '用户👤',
        2: 'AI🤖',
      })[Number(role)] || '系统⚙';
    }

    function formatInsertSlot(position, role) {
      position = Number(position);
      if (position === 4) return roleLabel(role) + ' @D';
      return positionLabel(position);
    }

    function renderOrgValue(oldValue, newValue) {
      return oldValue !== newValue
        ? '<span class="org-old">' + oldValue + '</span><span class="org-changed">' + newValue + '</span>'
        : String(oldValue);
    }

    btnAiOrganize.addEventListener('click', async function() {
      if (worldbookEntries.length === 0) return alert('世界书为空，没有可整理的条目！');
      var url = apiUrl.value.replace(/\/$/, '') + '/chat/completions';
      var key = apiKey.value.trim(); var model = modelSelect.value;
      if (!model) return alert('请先选择 AI 模型！');
      btnAiOrganize.disabled = true; btnAiOrganize.textContent = '⏳ AI 分析中...';
      closeWbModal('wbModalOrganize');
      setStatusBar(organizeStatus, '🔍 正在分析 ' + worldbookEntries.length + ' 条世界书条目...', '#38bdf8');
      organizePreview.style.display = 'none'; pendingOrganizeData = null;

      var entrySummaries = worldbookEntries.map(function(e, i) {
        return { index: i, title: e.comment || '未命名', content_preview: (e.content || '').substring(0, 150), strategy: e.strategy, keys: (e.keys || []).join(', '), current_position: e.position, current_role: e.role, current_depth: e.depth, current_order: e.order, current_prob: e.prob };
      });

      var sysPrompt = promptText('wbOrganize');
      var userPrompt = '以下是 ' + worldbookEntries.length + ' 条世界书条目，请分析并优化参数：\n\n' + JSON.stringify(entrySummaries, null, 2);

      try {
        await runAiTask({
          type: 'wb_organize',
          title: '世界书智能整理',
          target: worldbookEntries.length + ' 条',
        }, async function(task) {
          var headers = { 'Content-Type': 'application/json' };
          if (key) headers['Authorization'] = 'Bearer ' + key;
          var aiResp6 = await fetchAIContent({
            context: '世界书整理参数优化',
            url: url,
            headers: headers,
            model: model,
            messages: [{ role: 'system', content: sysPrompt }, { role: 'user', content: userPrompt }],
            temperature: 0.3,
            httpErrorPrefix: 'HTTP ',
            signal: task.signal
          });
          var rawContent = aiResp6.content;
          var suggestions;
          try { suggestions = extractJsonArray(rawContent, '世界书整理参数优化'); } catch(pe) { suggestions = [extractJsonObj(rawContent, '世界书整理参数优化/fallback')]; }
          if (!Array.isArray(suggestions) || suggestions.length === 0) throw new Error('AI 返回格式异常');
          suggestions = suggestions.map(normalizeOrganizeSuggestion).filter(Boolean);
          if (suggestions.length === 0) throw new Error('AI 返回中没有有效条目');
          pendingOrganizeData = suggestions;
          renderOrganizePreview(suggestions);
          setStatusBar(organizeStatus, '✅ 分析完成！请检查下方预览，确认后点击「应用」', '#34d399');
        });
      } catch(err) {
        if (isAiAbort(err)) setStatusBar(organizeStatus, '⏹ 已取消', 'var(--color-text-muted)');
        else setStatusBar(organizeStatus, '❌ 整理失败: ' + escapeHtml(err.message), 'var(--color-danger)');
        organizePreview.style.display = 'none';
      } finally {
        btnAiOrganize.disabled = false;
        btnAiOrganize.textContent = '一键整理';
      }
    });

    function renderOrganizePreview(suggestions) {
      var changeCount = 0;
      suggestions.forEach(function(s) {
        var idx = s.index;
        if (idx === undefined || idx < 0 || idx >= worldbookEntries.length) return;
        var e = worldbookEntries[idx];
        if (e.position !== s.position || e.role !== s.role || e.depth !== s.depth || e.order !== s.order || e.prob !== s.prob) changeCount++;
      });

      var html = '<div class="organize-preview-header">';
      html += '<span class="preview-header-title">📊 参数优化预览</span>';
      html += '<span class="preview-header-badge">共 ' + suggestions.length + ' 条</span>';
      html += '</div>';
      html += '<div class="organize-table-wrap"><table class="organize-table">';
      html += '<thead><tr><th>条目</th><th>插入位置</th><th>深度</th><th>顺序</th><th>概率</th><th>AI 建议</th></tr></thead>';
      html += '<tbody>';
      suggestions.forEach(function(s) {
        var idx = s.index;
        if (idx === undefined || idx < 0 || idx >= worldbookEntries.length) return;
        var e = worldbookEntries[idx];
        var oldSlot = formatInsertSlot(e.position, e.role);
        var newSlot = formatInsertSlot(s.position, s.role);
        var dC = e.depth !== s.depth, oC = e.order !== s.order, pC = e.prob !== s.prob;
        html += '<tr>';
        html += '<td class="org-name-cell" title="' + (e.comment || '').replace(/"/g, '&quot;') + '">' + (e.comment || '未命名') + '</td>';
        html += '<td class="org-value-cell">' + renderOrgValue(oldSlot, newSlot) + '</td>';
        html += '<td class="org-value-cell">' + (dC ? '<span class="org-old">' + e.depth + '</span><span class="org-changed">' + s.depth + '</span>' : e.depth) + '</td>';
        html += '<td class="org-value-cell">' + (oC ? '<span class="org-old">' + e.order + '</span><span class="org-changed">' + s.order + '</span>' : e.order) + '</td>';
        html += '<td class="org-value-cell">' + (pC ? '<span class="org-old">' + e.prob + '%</span><span class="org-changed">' + s.prob + '%</span>' : e.prob + '%') + '</td>';
        html += '<td class="org-reason-cell">' + (s.reason || '—') + '</td>';
        html += '</tr>';
      });
      html += '</tbody></table></div>';
      html += '<div class="organize-footer">';
      html += '<span class="organize-stats">发现 <strong>' + changeCount + '</strong> 处可优化参数</span>';
      html += '<div class="organize-actions">';
      html += '<button class="btn-org-cancel" id="btnOrgCancel">取消</button>';
      html += '<button class="btn-org-apply" id="btnOrgApply">✅ 应用优化</button>';
      html += '</div></div>';

      organizePreview.innerHTML = html;
      organizePreview.style.display = 'block';

      document.getElementById('btnOrgApply').addEventListener('click', function() {
        if (!pendingOrganizeData) return;
        var applied = 0;
        pendingOrganizeData.forEach(function(s) {
          var idx = s.index;
          if (idx === undefined || idx < 0 || idx >= worldbookEntries.length) return;
          var changed = false;
          if (s.position !== undefined && s.position !== worldbookEntries[idx].position) { worldbookEntries[idx].position = s.position; changed = true; }
          if (s.role !== undefined && s.role !== worldbookEntries[idx].role) { worldbookEntries[idx].role = s.role; changed = true; }
          if (s.depth !== undefined && s.depth !== worldbookEntries[idx].depth) { worldbookEntries[idx].depth = s.depth; changed = true; }
          if (s.order !== undefined && s.order !== worldbookEntries[idx].order) { worldbookEntries[idx].order = s.order; changed = true; }
          if (s.prob  !== undefined && s.prob  !== worldbookEntries[idx].prob)  { worldbookEntries[idx].prob  = s.prob;  changed = true; }
          if (changed) applied++;
        });
        renderEntriesList(); debouncedUpdateAndSave();
        organizePreview.style.display = 'none'; pendingOrganizeData = null;
        setStatusBar(organizeStatus, '🎉 已应用 <strong>' + applied + '</strong> 处优化！', '#34d399');
        setTimeout(function() { setStatusBar(organizeStatus, ''); }, 3000);
      });

      document.getElementById('btnOrgCancel').addEventListener('click', function() {
        organizePreview.style.display = 'none'; pendingOrganizeData = null;
        setStatusBar(organizeStatus, '已取消', 'var(--color-text-muted)');
        setTimeout(function() { setStatusBar(organizeStatus, ''); }, 2000);
      });
    }

    /** 助手世界书 AI：复用面板逻辑，可 await，不代导出 */
    window.__assistantWbAi__ = {
      generateEntry: async function(opts) {
        opts = opts || {};
        var before = worldbookEntries.length;
        await runAiTask({
          type: 'wb_single',
          title: '助手·世界书单条生成',
          target: String(opts.direction || opts.instruction || '').slice(0, 40),
        }, async function(task) {
          await generateContextAwareWBEntry(opts.direction || opts.instruction || '', '助手单条补充。', task.signal);
        });
        renderEntriesList();
        debouncedUpdateAndSave();
        var last = worldbookEntries[worldbookEntries.length - 1];
        return {
          added: worldbookEntries.length - before,
          total: worldbookEntries.length,
          entry: last ? { comment: last.comment, contentLen: String(last.content || '').length } : null,
        };
      },
      mutateEntry: async function(opts) {
        opts = opts || {};
        var idx = typeof opts.index === 'number' ? opts.index : -1;
        if (idx < 0 || idx >= worldbookEntries.length) throw new Error('条目索引无效');
        var mode = opts.mode || 'expand';
        var instruction = opts.instruction || opts.direction || '';
        if (mode === 'expand' && !instruction) instruction = '将骨架/短内容展开为完整详细设定';
        if (mode === 'rewrite' && !instruction) instruction = '按原意重写，提升清晰度与可用性';
        if (mode === 'patch' && instruction) instruction = '定向修改：' + instruction + '（保留未要求改动的部分）';
        // 复用 UI 重写；传入伪按钮避免 NPE
        var fakeBtn = { textContent: '', disabled: false };
        await aiRewriteEntry(idx, instruction, fakeBtn);
        var e = worldbookEntries[idx];
        return { index: idx, comment: e.comment, contentLen: String(e.content || '').length, mode: mode };
      },
      organize: async function(opts) {
        opts = opts || {};
        if (worldbookEntries.length === 0) throw new Error('世界书为空');
        var url = apiUrl.value.replace(/\/$/, '') + '/chat/completions';
        var key = apiKey.value.trim();
        var model = modelSelect.value;
        if (!model) throw new Error('请先选择 AI 模型');
        var entrySummaries = worldbookEntries.map(function(e, i) {
          return {
            index: i, title: e.comment || '未命名',
            content_preview: (e.content || '').substring(0, 150),
            strategy: e.strategy, keys: (e.keys || []).join(', '),
            current_position: e.position, current_role: e.role,
            current_depth: e.depth, current_order: e.order, current_prob: e.prob,
          };
        });
        var headers = { 'Content-Type': 'application/json' };
        if (key) headers.Authorization = 'Bearer ' + key;
        var aiResp = await fetchAIContent({
          context: '世界书整理参数优化/助手',
          url: url,
          headers: headers,
          model: model,
          messages: [
            { role: 'system', content: promptText('wbOrganize') },
            { role: 'user', content: '以下是 ' + worldbookEntries.length + ' 条世界书条目，请分析并优化参数：\n\n' + JSON.stringify(entrySummaries, null, 2) },
          ],
          temperature: 0.3,
          httpErrorPrefix: 'HTTP ',
        });
        var suggestions;
        try { suggestions = extractJsonArray(aiResp.content, '世界书整理/助手'); }
        catch (pe) { suggestions = [extractJsonObj(aiResp.content, '世界书整理/助手/fallback')]; }
        suggestions = (suggestions || []).map(normalizeOrganizeSuggestion).filter(Boolean);
        if (!suggestions.length) throw new Error('AI 返回中没有有效条目');
        var preview = suggestions.map(function(s) {
          var e = worldbookEntries[s.index] || {};
          return {
            index: s.index, title: e.comment || '',
            position: s.position, role: s.role, depth: s.depth, order: s.order, prob: s.prob,
            reason: s.reason || '',
          };
        });
        if (opts.apply === false) return { applied: false, preview: preview, changeCount: preview.length };
        var applied = 0;
        suggestions.forEach(function(s) {
          var idx = s.index;
          if (idx === undefined || idx < 0 || idx >= worldbookEntries.length) return;
          var changed = false;
          ['position', 'role', 'depth', 'order', 'prob'].forEach(function(k) {
            if (s[k] !== undefined && s[k] !== worldbookEntries[idx][k]) {
              worldbookEntries[idx][k] = s[k];
              changed = true;
            }
          });
          if (changed) applied++;
        });
        renderEntriesList();
        debouncedUpdateAndSave();
        return { applied: true, appliedCount: applied, preview: preview };
      },
      batchFillKeys: async function(opts) {
        opts = opts || {};
        if (!modelSelect.value) throw new Error('请先选择 AI 模型');
        var targets = worldbookEntries
          .map(function(entry, index) { return { entry: entry, index: index }; })
          .filter(function(item) {
            if (item.entry.strategy === 'constant') return false;
            if (opts.onlyMissing) return !item.entry.keys || !item.entry.keys.length;
            return true;
          });
        if (!targets.length) return { updated: 0, note: '无目标条目' };
        var charBlock = {
          name: charName.value.trim() || '',
          worldbook: wbName.value.trim() || '',
          description_preview: (charDesc.value || '').trim().substring(0, 300),
        };
        var batches = splitTargetsForKeygen(targets, charBlock);
        var updated = 0;
        var processed = 0;
        for (var bi = 0; bi < batches.length; bi++) {
          processed += batches[bi].length;
          var br = await completeTriggerKeysBatch(batches[bi], bi, batches.length, processed, targets.length);
          updated += br.updated;
        }
        renderEntriesList();
        debouncedUpdateAndSave();
        return { updated: updated, targets: targets.length };
      },
    };

    // ============================================================
    //  JSON 生成
    // ============================================================
    /**
     * 由草稿对象生成 ST 角色卡 JSON（不含小说工坊分桶内容）
     * @param {object} d 草稿
     */
    function buildCardJSONFromDraft(d) {
      d = d || {};
      var entries = Array.isArray(d.worldbookEntries) ? d.worldbookEntries : [];
      var fe = entries.map(function(e, i) {
        return { id: i, keys: e.keys || [], secondary_keys: [], comment: e.comment, content: e.content, constant: e.strategy === 'constant', selective: e.strategy === 'selective' || e.strategy === 'vectorized', insertion_order: e.order || 100, enabled: e.enabled !== false, position: "before_char", use_regex: false, extensions: { position: e.position, exclude_recursion: false, display_index: i, probability: e.prob || 100, useProbability: true, depth: e.depth || 4, selectiveLogic: 0, outlet_name: "", group: "", group_override: false, group_weight: 100, prevent_recursion: false, delay_until_recursion: false, role: e.role || 0, vectorized: e.strategy === 'vectorized' } };
      });
      var cn = String(d.charName || '').trim() || '无名角色';
      var wn = String(d.wbName || '').trim() || '无名世界书';
      var ext = Object.assign({}, d.cardBuilderExtensions || {});
      ext.world = wn;
      if (d.regexScripts && d.regexScripts.length > 0) ext.regex_scripts = d.regexScripts;
      else delete ext.regex_scripts;
      // 覆盖 scripts，保留既有 variables 等其它 tavern_helper 字段
      if (d.tavernHelperScripts && d.tavernHelperScripts.length > 0) {
        var prevTh = (ext.tavern_helper && typeof ext.tavern_helper === 'object') ? ext.tavern_helper : {};
        var thVars = (prevTh.variables && typeof prevTh.variables === 'object') ? prevTh.variables : {};
        ext.tavern_helper = Object.assign({}, prevTh, {
          scripts: d.tavernHelperScripts,
          variables: thVars,
        });
      } else if (ext.tavern_helper && ext.tavern_helper.variables
          && typeof ext.tavern_helper.variables === 'object'
          && Object.keys(ext.tavern_helper.variables).length) {
        // 无脚本但仍有 variables：保留扩展对象，scripts 置空
        ext.tavern_helper = Object.assign({}, ext.tavern_helper, { scripts: [] });
      } else {
        delete ext.tavern_helper;
      }
      var altG = (d.altGreetings || []).filter(function(g) { return g && String(g).trim(); });
      var tags = normalizeTags(d.charTags || d.tags || []);
      return {
        name: cn, description: d.charDesc || '', personality: '', scenario: '',
        first_mes: d.firstMes || '', mes_example: '', creatorcomment: d.creatorNotes || '',
        avatar: 'none', talkativeness: '0.5', fav: false, tags: tags,
        spec: 'chara_card_v3', spec_version: '3.0',
        data: {
          name: cn, description: d.charDesc || '', personality: '', scenario: '',
          first_mes: d.firstMes || '', mes_example: '', creator_notes: d.creatorNotes || '',
          system_prompt: '', post_history_instructions: '', tags: tags.slice(),
          creator: '', character_version: '1.0', alternate_greetings: altG,
          extensions: ext, character_book: { name: wn, entries: fe }
        }
      };
    }

    /** 当前编辑态 → ST JSON（同样不含小说工坊） */
    function generateFullJSON() {
      return buildCardJSONFromDraft({
        charName: charName.value,
        wbName: wbName.value,
        charDesc: charDesc.value,
        firstMes: firstMes.value,
        creatorNotes: creatorNotes.value,
        charTags: charTags,
        worldbookEntries: worldbookEntries,
        regexScripts: regexScripts,
        tavernHelperScripts: tavernHelperScripts,
        cardBuilderExtensions: cardBuilderExtensions,
        altGreetings: window.__altGreetings__ || []
      });
    }

    /** 导出指定卡 JSON（非当前卡读草稿箱；不含小说） */
    function exportDraftAsJson(id) {
      if (!id) return;
      var json;
      var name;
      if (id === currentDraftId) {
        saveCurrentDraft();
        json = generateFullJSON();
        name = charName.value.trim() || 'card';
      } else {
        var d = getAllDrafts()[id];
        if (!d) return alert('❌ 找不到该角色卡');
        json = buildCardJSONFromDraft(d);
        name = draftDisplayName(d) || 'card';
      }
      var a = document.createElement('a');
      a.href = 'data:text/json;charset=utf-8,' + encodeURIComponent(JSON.stringify(json, null, 2));
      a.download = name + '.json';
      a.click();
    }

    /** 导出指定卡 PNG（需该卡有头像；chara 块不含小说） */
    async function exportDraftAsPng(id) {
      if (!id) return;
      var json;
      var avatar;
      var name;
      if (id === currentDraftId) {
        saveCurrentDraft();
        json = generateFullJSON();
        name = charName.value.trim() || 'CharacterCard';
        if (currentAvatarInIdb) {
          await ensureIdbReady();
          avatar = window.__avatarIdb__
            ? await window.__avatarIdb__.loadAvatarFullDataUrl(id)
            : '';
        } else {
          avatar = currentAvatarBase64;
        }
      } else {
        var d = getAllDrafts()[id];
        if (!d) return alert('❌ 找不到该角色卡');
        json = buildCardJSONFromDraft(d);
        name = draftDisplayName(d) || 'CharacterCard';
        if (d.avatarInIdb) {
          await ensureIdbReady();
          avatar = window.__avatarIdb__
            ? await window.__avatarIdb__.loadAvatarFullDataUrl(id)
            : '';
        } else {
          avatar = d.avatarBase64 || '';
        }
      }
      if (!avatar) return alert('❌ 该卡尚未上传头像，无法导出 PNG');
      try {
        var ch = createTextChunk('chara', JSON.stringify(json));
        var raw = atob(avatar.split(',')[1]);
        var bytes = new Uint8Array(raw.length);
        for (var i = 0; i < raw.length; i++) bytes[i] = raw.charCodeAt(i);
        var io = bytes.length - 12;
        var bef = bytes.slice(0, io);
        var ie = bytes.slice(io);
        var fin = new Uint8Array(bef.length + ch.length + ie.length);
        fin.set(bef, 0); fin.set(ch, bef.length); fin.set(ie, bef.length + ch.length);
        var blob = new Blob([fin], { type: 'image/png' });
        var a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = name + '.png';
        a.click();
        URL.revokeObjectURL(a.href);
      } catch (err) {
        alert('❌ 导出失败: ' + err.message);
      }
    }

    // ============================================================
    //  预览 & 联动 & 初始化
    // ============================================================
    function updatePreview() {
      var fj = generateFullJSON();
      if (window.updatePreviewPanel) window.updatePreviewPanel(fj);
    }

    [charName, wbName, charDesc, firstMes, creatorNotes].forEach(function(el) {
      el.addEventListener('input', debouncedUpdateAndSave);
    });

    // 角色标签 chip：增删与输入回车
    if (btnAddCharTag) btnAddCharTag.addEventListener('click', addCharTagFromInput);
    if (charTagInput) {
      charTagInput.addEventListener('keydown', function(e) {
        if (e.key === 'Enter') {
          e.preventDefault();
          addCharTagFromInput();
        }
      });
    }
    if (charTagsList) {
      charTagsList.addEventListener('click', function(e) {
        var btn = e.target.closest('[data-tag-action="remove"]');
        if (!btn) return;
        var idx = parseInt(btn.getAttribute('data-tag-index'), 10);
        if (isNaN(idx) || idx < 0 || idx >= charTags.length) return;
        var next = charTags.slice();
        next.splice(idx, 1);
        setCharTags(next);
      });
    }
    renderCharTags();

    /** 标签 AI tip：轻量提示，不打断表单 */
    function setCharTagsAiTip(text, kind) {
      if (!charTagsAiTip) return;
      charTagsAiTip.textContent = text || '';
      charTagsAiTip.classList.remove('is-warn', 'is-ok', 'is-err');
      if (kind) charTagsAiTip.classList.add('is-' + kind);
    }

    // 角色标签 AI 生成：合并进现有 tags，可经任务中心停止
    if (btnAiGenCharTags) {
      btnAiGenCharTags.addEventListener('click', async function() {
        var url = (apiUrl.value || '').replace(/\/$/, '');
        var model = modelSelect.value;
        if (!url || !model) {
          setCharTagsAiTip('请先在「AI 配置」填写接口与模型', 'warn');
          return;
        }
        var lib = window.__charTagsLib__ || {};
        var maxChars = window.__getTagContextChars__
          ? window.__getTagContextChars__()
          : (lib.DEFAULT_TAG_CONTEXT_CHARS || 12000);
        var ctxBuilder = lib.buildTagGenContext;
        var ctx = ctxBuilder
          ? ctxBuilder({
              description: charDesc.value,
              firstMes: firstMes ? firstMes.value : '',
              altGreetings: window.__altGreetings__ || [],
              worldbookEntries: worldbookEntries,
            }, maxChars)
          : String(charDesc.value || '');
        if (!String(ctx || '').trim()) {
          setCharTagsAiTip('请先填写角色设定或开场白等内容', 'warn');
          return;
        }

        var key = apiKey.value.trim();
        var headers = { 'Content-Type': 'application/json' };
        if (key) headers['Authorization'] = 'Bearer ' + key;
        var sysPrompt = promptText('charTagsGen')
          || '根据角色设定与世界书，生成 5-12 个短中文分类标签。只输出 JSON 数组，例如 ["奇幻","恋爱"]。不要解释。';

        btnAiGenCharTags.disabled = true;
        var oldLabel = btnAiGenCharTags.textContent;
        btnAiGenCharTags.textContent = '生成中…';
        setCharTagsAiTip('正在生成标签…', null);

        try {
          await runAiTask({
            type: 'char_tags_generate',
            title: '角色标签 AI 生成',
            target: (charName.value || '').trim().slice(0, 40) || '标签',
          }, async function(task) {
            var aiResp = await fetchAIContent({
              context: '角色标签生成',
              url: url + '/chat/completions',
              headers: headers,
              model: model,
              messages: [
                { role: 'system', content: sysPrompt },
                { role: 'user', content: ctx },
              ],
              temperature: 0.4,
              httpErrorPrefix: '标签生成失败 HTTP ',
              signal: task && task.signal,
            });
            var parsed = lib.parseTagsFromAiText
              ? lib.parseTagsFromAiText(aiResp.content)
              : [];
            if (!parsed.length) throw new Error('未解析到有效标签');
            var merged = lib.mergeCharTags
              ? lib.mergeCharTags(charTags, parsed)
              : normalizeTags(charTags.concat(parsed));
            var added = merged.length - normalizeTags(charTags).length;
            setCharTags(merged);
            setCharTagsAiTip(
              added > 0 ? ('已合并 ' + added + ' 个新标签（共 ' + merged.length + '）') : '无新增（已与现有标签去重）',
              'ok'
            );
          });
        } catch (err) {
          if (isAiAbort(err)) setCharTagsAiTip('已停止', 'warn');
          else setCharTagsAiTip(String(err.message || err), 'err');
        } finally {
          btnAiGenCharTags.disabled = false;
          btnAiGenCharTags.textContent = oldLabel || 'AI 生成';
        }
      });
    }

    // ★ 初始化顺序很重要：先加载 AI 配置（含预设），等 IDB 就绪后再加载草稿
    loadAIConfig();

    ensureIdbReady().then(function() {
      var drafts = getAllDrafts();
      var lastId = localStorage.getItem(CURRENT_KEY);
      if (lastId && drafts[lastId]) loadDraft(lastId);
      else if (Object.keys(drafts).length > 0) loadDraft(Object.keys(drafts)[0]);
      else createBlankDraft({ jumpToCharacter: false });
    });

  </script>
</Layout>
