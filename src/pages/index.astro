      reader.onload = function(ev) {
        var img = new Image();
        img.onload = function() { applyAvatarFromImage(img); };
        img.src = ev.target.result;
      };
      reader.readAsDataURL(file);
    });

    // ============================================================
    //  草稿系统（UI 在「角色卡管理」；存储键与字段语义不变）
    // ============================================================
    function genId() { return 'draft_' + Date.now(); }
    function getAllDrafts() { try { return JSON.parse(localStorage.getItem(DRAFTS_KEY)) || {}; } catch(e) { return {}; } }

    /** 通知小说工坊按 cardId 换桶（小说不进导出 JSON/PNG） */
    function emitCardDraftChanged(cardId) {
      window.dispatchEvent(new CustomEvent('card-draft-changed', {
        detail: { cardId: cardId || currentDraftId || '' }
      }));
    }

    function goToView(viewId) {
      if (typeof window.__setAppView__ === 'function') window.__setAppView__(viewId);
      else location.hash = '#' + viewId;
    }

    function draftDisplayName(d, fallback) {
      var n = (d && d.charName) || fallback || '';
      return n.trim() || '未命名';
    }

    /** 当前编辑态快照（管理页封面与落盘共用） */
    function buildDraftSnapshot() {
      return {
        charName:        charName.value.trim(),
        wbName:          wbName.value.trim(),
        charDesc:        charDesc.value.trim(),
        firstMes:        firstMes.value.trim(),
        creatorNotes:    creatorNotes.value.trim(),
        charTags:        normalizeTags(charTags),
        worldbookEntries: worldbookEntries,
        regexScripts:    regexScripts,
        tavernHelperScripts: tavernHelperScripts,
        cardBuilderExtensions: cardBuilderExtensions,
        avatarInIdb:     !!currentAvatarInIdb,
        avatarBase64:    currentAvatarInIdb ? '' : (currentAvatarBase64 || ''),
        altGreetings:    window.__altGreetings__ || [],
        updatedAt:     new Date().toLocaleTimeString('zh-CN', { hour12: false }),
      };
    }

    /** 合并内存中的当前卡（存储失败时管理页封面仍可用） */
    function getDraftsForDisplay(stored) {
      var dr = stored ? Object.assign({}, stored) : getAllDrafts();
      if (currentDraftId) {
        dr[currentDraftId] = Object.assign({}, dr[currentDraftId] || {}, buildDraftSnapshot());
      }
      return dr;
    }

    /** 管理页卡片底栏：图标操作（左编辑 / 右导出·删除） */
    function buildCardManagerActionsHtml() {
      function iconBtn(action, label, extraClass) {
        var cls = 'btn-icon btn-icon--sm card-mgr-icon' + (extraClass ? ' ' + extraClass : '');
        var icons = {
          dup: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="8" y="8" width="12" height="12" rx="2"/><path d="M16 8V6a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h2"/></svg>',
          rename: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M15.5 5.5l3 3L8 19l-4 1 1-4 10.5-10.5z"/></svg>',
          'export-json': '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 8l-4 4 4 4M16 8l4 4-4 4M13 6l-2 12"/></svg>',
          'export-png': '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="4" y="5" width="16" height="14" rx="2"/><circle cx="9" cy="10" r="1.5"/><path d="M4 16l4.5-4.5 3 3L14 12l6 6"/></svg>',
          delete: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 7h16"/><path d="M9 7V5a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/><path d="M10 11v6M14 11v6"/><path d="M7 7l1 12a1 1 0 0 0 1 .9h6a1 1 0 0 0 1-.9l1-12"/></svg>',
        };
        return '<button type="button" class="' + cls + '" data-card-action="' + action + '" title="' + label + '" aria-label="' + label + '">' + (icons[action] || '') + '</button>';
      }
      return ''
        + '<div class="card-manager-item-actions__group">'
        + iconBtn('dup', '复制')
        + iconBtn('rename', '重命名')
        + '</div>'
        + '<div class="card-manager-item-actions__group">'
        + iconBtn('export-json', '导出 JSON', 'card-mgr-icon--export')
        + iconBtn('export-png', '导出 PNG', 'card-mgr-icon--export')
        + iconBtn('delete', '删除', 'card-mgr-icon--danger btn-icon--danger')
        + '</div>';
    }

    /** 刷新管理页预览卡片网格（存储键与切换逻辑不变） */
    function updateCardManagerUI(storedDrafts) {
      if (!cardManagerList) return;
      revokeManagerThumbs();
      var dr = getDraftsForDisplay(storedDrafts);
      var ks = Object.keys(dr);
      if (!ks.length) {
        cardManagerList.innerHTML = '<p class="card-manager-empty">暂无角色卡，点击右上角「新建」</p>';
        return;
      }
      cardManagerList.innerHTML = '';
      ks.forEach(function(id) {
        var d = dr[id] || {};
        var active = id === currentDraftId;
        var item = document.createElement('div');
        item.className = 'card-manager-item' + (active ? ' is-active' : '');
        item.setAttribute('data-draft-id', id);

        var cover = document.createElement('div');
        cover.className = 'card-manager-cover';
        cover.setAttribute('data-card-action', 'open');
        if (d.avatarBase64) {
          var coverImg = document.createElement('img');
          coverImg.src = d.avatarBase64;
          coverImg.alt = '';
          cover.appendChild(coverImg);
        } else if (d.avatarInIdb) {
          var loadingPh = document.createElement('span');
          loadingPh.className = 'card-manager-cover-placeholder';
          loadingPh.textContent = '…';
          cover.appendChild(loadingPh);
          hydrateManagerCoverThumb(id, cover, loadingPh);
        } else {
          var ph = document.createElement('span');
          ph.className = 'card-manager-cover-placeholder';
          ph.textContent = '无封面';
          cover.appendChild(ph);
        }
        if (active) {
          var badge = document.createElement('span');
          badge.className = 'card-manager-badge';
          badge.textContent = '当前';
          cover.appendChild(badge);
        }

        var main = document.createElement('div');
        main.className = 'card-manager-item-main';
        main.setAttribute('data-card-action', 'open');
        main.innerHTML =
          '<div class="card-manager-item-name">' + escapeHTML(draftDisplayName(d)) + '</div>' +
          '<div class="card-manager-item-meta">更新 ' + escapeHTML(d.updatedAt || '—') + '</div>';

        var actions = document.createElement('div');
        actions.className = 'card-manager-item-actions';
        actions.innerHTML = buildCardManagerActionsHtml();

        item.appendChild(cover);
        item.appendChild(main);
        item.appendChild(actions);
        cardManagerList.appendChild(item);
      });
    }

    /** 旧 avatarBase64 迁入 IDB 并清理草稿内嵌图 */
    async function migrateDraftAvatarToIdb(id, d, dr) {
      if (!d || !d.avatarBase64 || d.avatarInIdb) return false;
      await ensureIdbReady();
      if (!window.__avatarIdb__) return false;
      var ok = await window.__avatarIdb__.migrateAvatarBase64ToIdb(id, d.avatarBase64);
      if (!ok) return false;
      d.avatarInIdb = true;
      d.avatarBase64 = '';
      dr[id] = d;
      try { localStorage.setItem(DRAFTS_KEY, JSON.stringify(dr)); } catch (e) {}
      return true;
    }

    async function loadDraftAsync(id) {
      var dr = getAllDrafts(); if (!dr[id]) return;
      currentDraftId = id; localStorage.setItem(CURRENT_KEY, id);
      var d = dr[id];
      charName.value     = d.charName     || '';
      wbName.value       = d.wbName       || '';
      charDesc.value     = d.charDesc     || '';
      firstMes.value     = d.firstMes     || '';
      creatorNotes.value = d.creatorNotes || '';
      setCharTags(d.charTags || d.tags || [], { save: false });
      worldbookEntries   = d.worldbookEntries || [];
      regexScripts       = d.regexScripts     || [];
      tavernHelperScripts = Array.isArray(d.tavernHelperScripts) ? d.tavernHelperScripts : [];
      cardBuilderExtensions = Object.assign({}, d.cardBuilderExtensions || {});
      currentAvatarInIdb = !!d.avatarInIdb;
      currentAvatarBase64 = d.avatarBase64 || '';
      window.__altGreetings__ = d.altGreetings || [];
      if (window.__renderAltGreetings__) window.__renderAltGreetings__();
      resetWBForm();
      avatarImg.style.display = 'none'; avatarPlaceholder.style.display = 'block';
      if (currentAvatarBase64 && !currentAvatarInIdb) {
        var migrated = await migrateDraftAvatarToIdb(id, d, dr);
        if (migrated) {
          currentAvatarInIdb = true;
          currentAvatarBase64 = '';
        }
      }
      if (currentAvatarInIdb) {
        await ensureIdbReady();
        if (window.__avatarIdb__) {
          var fullUrl = await window.__avatarIdb__.loadAvatarFullDataUrl(id);
          if (fullUrl) {
            avatarImg.src = fullUrl;
            avatarImg.style.display = 'block';
            avatarPlaceholder.style.display = 'none';
          }
        }
      } else if (currentAvatarBase64) {
        avatarImg.src = currentAvatarBase64;
        avatarImg.style.display = 'block';
        avatarPlaceholder.style.display = 'none';
      }
      updateCardManagerUI(); renderEntriesList(); updatePreview();
      window.dispatchEvent(new CustomEvent('card-builder-data-changed'));
      emitCardDraftChanged(id);
    }

    function loadDraft(id) {
      loadDraftAsync(id).catch(function(err) {
        console.warn('[draft] loadDraft failed', err);
      });
    }

    function saveCurrentDraft(opts) {
      opts = opts || {};
      if (!currentDraftId) currentDraftId = genId();
      var dr = getAllDrafts();
      dr[currentDraftId] = buildDraftSnapshot();
      var saved = false;
      try {
        localStorage.setItem(DRAFTS_KEY, JSON.stringify(dr));
        localStorage.setItem(CURRENT_KEY, currentDraftId);
        saved = true;
        if (saveIndicator) {
          saveIndicator.style.display = 'inline';
          setTimeout(function() { saveIndicator.style.display = 'none'; }, 1500);
        }
      } catch (e) {
        var tip = opts.reason === 'avatar'
          ? '草稿元数据保存失败；头像已尝试写入 IndexedDB，请刷新后重试。'
          : '草稿保存失败（内容可能过大），请减少世界书条目或启用 IndexedDB。';
        alert(tip);
      }
      // 无论落盘是否成功，管理页用内存快照刷新（封面即时可见）
      updateCardManagerUI(dr);
      return saved;
    }

    function createBlankDraft(opts) {
      var jump = !opts || opts.jumpToCharacter !== false;
      currentDraftId = genId();
      charName.value = ''; wbName.value = ''; charDesc.value = ''; firstMes.value = ''; creatorNotes.value = '';
      setCharTags([], { save: false });
      worldbookEntries = []; regexScripts = []; tavernHelperScripts = []; cardBuilderExtensions = {};
      currentAvatarBase64 = ''; currentAvatarInIdb = false;
      if (charImageInput) charImageInput.value = '';
      avatarImg.style.display = 'none'; avatarPlaceholder.style.display = 'block';
      window.__altGreetings__ = [];
      if (window.__renderAltGreetings__) window.__renderAltGreetings__();
      resetWBForm(); saveCurrentDraft(); renderEntriesList(); updatePreview();
      window.dispatchEvent(new CustomEvent('card-builder-data-changed'));
      emitCardDraftChanged(currentDraftId);
      if (jump) goToView('character');
    }

    async function deleteDraftById(id, opts) {
      if (!id) return { ok: false, error: '缺少 id' };
      var dr = getAllDrafts();
      if (!dr[id]) return { ok: false, error: '卡不存在' };
      var draftName = draftDisplayName(dr[id], id === currentDraftId ? charName.value : '');
      // 助手 force 跳过 UI 确认（助手自身有 confirm 流）
      if (!(opts && opts.force)) {
        var ok = await showConfirmDialog({
          icon: '🗑️',
          title: '删除角色卡？',
          message: '这会从本地多卡草稿箱中移除该卡。',
          detail: '即将删除：' + draftName + '。此操作不会影响已下载到本地的卡片文件。',
          okText: '删除',
          cancelText: '再想想'
        });
        if (!ok) return { ok: false, cancelled: true };
      }
      delete dr[id];
      localStorage.setItem(DRAFTS_KEY, JSON.stringify(dr));
      // 同步清理 IndexedDB：头像 + 小说桶（并移除 localStorage 同名键）
      ensureIdbReady().then(function() {
        if (window.__avatarIdb__) return window.__avatarIdb__.deleteAvatarDraft(id);
      }).catch(function() {});
      if (window.__novelIdb__) {
        window.__novelIdb__.removeNovelBucketIdb(id, localStorage).catch(function() {});
      }
      var ks = Object.keys(dr);
      if (id === currentDraftId) {
        if (ks.length > 0) loadDraft(ks[0]);
        else createBlankDraft({ jumpToCharacter: false });
      } else {
        updateCardManagerUI();
      }
      return { ok: true, deleted: id, name: draftName };
    }

    async function duplicateDraftById(id) {
      var dr = getAllDrafts();
      var src = dr[id];
      if (!src) return;
      var newId = genId();
      // 深拷贝条目等引用字段，避免与源卡共享数组
      var copy = JSON.parse(JSON.stringify(src));
      copy.charName = draftDisplayName(src) + ' 副本';
      copy.updatedAt = new Date().toLocaleTimeString('zh-CN', { hour12: false });
      copy.avatarInIdb = !!(src.avatarInIdb || src.avatarBase64);
      if (copy.avatarInIdb) copy.avatarBase64 = '';
      dr[newId] = copy;
      localStorage.setItem(DRAFTS_KEY, JSON.stringify(dr));
      await ensureIdbReady();
      if (window.__avatarIdb__) {
        if (src.avatarInIdb) {
          await window.__avatarIdb__.copyAvatarDraft(id, newId);
        } else if (src.avatarBase64) {
          await window.__avatarIdb__.migrateAvatarBase64ToIdb(newId, src.avatarBase64);
        }
      }
      if (window.__novelIdb__) {
        await window.__novelIdb__.copyNovelBucketIdb(id, newId, localStorage);
      }
      loadDraft(newId);
      goToView('character');
    }

    function renameDraftById(id, newName) {
      var dr = getAllDrafts();
      var d = dr[id];
      if (!d) return { ok: false, error: '卡不存在' };
      var next = newName != null ? String(newName) : window.prompt('重命名角色卡', draftDisplayName(d));
      if (next === null) return { ok: false, cancelled: true };
      next = String(next).trim();
      if (!next) return { ok: false, error: '名称为空' };
      d.charName = next;
      d.updatedAt = new Date().toLocaleTimeString('zh-CN', { hour12: false });
      dr[id] = d;
      localStorage.setItem(DRAFTS_KEY, JSON.stringify(dr));
      if (id === currentDraftId) charName.value = next;
      updateCardManagerUI();
      if (id === currentDraftId) updatePreview();
      return { ok: true, id: id, name: next };
    }

    /** 助手多卡 API（无代导出；import 仅接受已解析 JSON） */
    window.__assistantCardApi__ = {
      list: function() {
        var dr = getAllDrafts();
        return {
          currentId: currentDraftId || '',
          cards: Object.keys(dr).map(function(id) {
            return {
              id: id,
              name: draftDisplayName(dr[id]),
              updatedAt: dr[id].updatedAt || '',
              current: id === currentDraftId,
            };
          }),
        };
      },
      switchTo: function(idOrName) {
        var key = String(idOrName || '').trim();
        if (!key) throw new Error('缺少 id 或 name');
        var dr = getAllDrafts();
        if (dr[key]) {
          loadDraft(key);
          return { id: key, name: draftDisplayName(dr[key]) };
        }
        var found = Object.keys(dr).find(function(id) {
          return draftDisplayName(dr[id]) === key;
        });
        if (!found) throw new Error('未找到卡片: ' + key);
        loadDraft(found);
        return { id: found, name: draftDisplayName(dr[found]) };
      },
      create: function(opts) {
        opts = opts || {};
        createBlankDraft({ jumpToCharacter: false });
        if (opts.name) {
          charName.value = String(opts.name);
          saveCurrentDraft();
          updateCardManagerUI();
        }
        return { id: currentDraftId, name: charName.value || '未命名' };
      },
      duplicate: function(id) {
        var src = id || currentDraftId;
        if (!src) throw new Error('无可复制卡片');
        duplicateDraftById(src);
        return { id: currentDraftId, name: charName.value || '副本' };
      },
      rename: function(id, name) {
        return renameDraftById(id || currentDraftId, name);
      },
      delete: async function(id) {
        return deleteDraftById(id || currentDraftId, { force: true });
      },
      importJson: function(cardJson) {
        if (!cardJson || typeof cardJson !== 'object') throw new Error('需要已解析的 cardJson 对象');
        if (typeof window.applyJSONFromEditor !== 'function') throw new Error('导入桥接未就绪');
        // 导入到当前编辑区（与管理页导入一致）
        window.applyJSONFromEditor(cardJson);
        saveCurrentDraft();
        updateCardManagerUI();
        return { id: currentDraftId, name: charName.value || '导入卡' };
      },
      exportCheck: function() {
        try {
          var d = getAllDrafts()[currentDraftId] || {
            charName: charName.value,
            worldbookEntries: worldbookEntries,
            firstMes: firstMes.value,
            charDesc: charDesc.value,
          };
          var json = buildCardJSONFromDraft(d);
          var issues = [];
          if (!json || !json.data) issues.push({ level: 'critical', message: '无法生成导出结构' });
          else {
            if (!json.data.name) issues.push({ level: 'warning', message: '缺少角色名' });
            if (!json.data.first_mes) issues.push({ level: 'warning', message: '缺少开场白' });
            var ents = (json.data.character_book && json.data.character_book.entries) || [];
            if (!ents.length) issues.push({ level: 'info', message: '世界书为空' });
          }
          return {
            ok: issues.filter(function(i) { return i.level === 'critical'; }).length === 0,
            issues: issues,
            name: (json && json.data && json.data.name) || '',
            worldbookCount: ((json && json.data && json.data.character_book && json.data.character_book.entries) || []).length,
            note: '仅校验，不触发下载',
          };
        } catch (e) {
          return { ok: false, issues: [{ level: 'critical', message: e.message }], note: '仅校验，不触发下载' };
        }
      },
    };

    if (btnNewDraft) {
      btnNewDraft.addEventListener('click', function() { createBlankDraft({ jumpToCharacter: true }); });
    }

    if (cardManagerList) {
      cardManagerList.addEventListener('click', function(e) {
        var actionEl = e.target.closest('[data-card-action]');
        var row = e.target.closest('.card-manager-item[data-draft-id]');
        if (!row) return;
        var id = row.getAttribute('data-draft-id');
        var action = actionEl ? actionEl.getAttribute('data-card-action') : 'open';
        if (action === 'delete') {
          e.preventDefault();
          e.stopPropagation();
          deleteDraftById(id);
          return;
        }
        if (action === 'dup') {
          e.preventDefault();
          e.stopPropagation();
          duplicateDraftById(id);
          return;
        }
        if (action === 'rename') {
          e.preventDefault();
          e.stopPropagation();
          renameDraftById(id);
          return;
        }
        if (action === 'export-json') {
          e.preventDefault();
          e.stopPropagation();
          exportDraftAsJson(id);
          return;
        }
        if (action === 'export-png') {
          e.preventDefault();
          e.stopPropagation();
          exportDraftAsPng(id);
          return;
        }
        // 点击封面/卡名区域：切换并进入角色设定
        loadDraft(id);
        goToView('character');
      });
    }

    var autoSaveTimer;
    function debouncedUpdateAndSave() {
      clearTimeout(autoSaveTimer);
      autoSaveTimer = setTimeout(function() { updatePreview(); saveCurrentDraft(); }, 500);
    }
    function flushUpdateAndSave() {
      clearTimeout(autoSaveTimer);
      updatePreview();
      saveCurrentDraft();
    }

    // ============================================================
    //  预设系统
    // ============================================================
    function renderPresetList() {
      if (!parsedPresetList.length) {
        presetListContainer.style.display = 'none';
        presetStatus.textContent = "未找到可用规则";
        return;
      }
      presetListContainer.style.display = 'block';
      presetStatus.textContent = "✅ 预设载入成功！已加载 " + parsedPresetList.length + " 条规则";
      presetListContainer.innerHTML = parsedPresetList.map(function(it, i) {
        var typeBadge = '';
        var nm = (it.name || '').toLowerCase();
        if (nm.indexOf('example') >= 0 || nm.indexOf('dialogue') >= 0 || nm.indexOf('示例') >= 0) {
          typeBadge = ' <span style="font-size:0.6rem;color:#34d399;background:rgba(16,185,129,0.1);padding:1px 5px;border-radius:4px;">示例对话</span>';
        } else if (nm.indexOf('jailbreak') >= 0 || nm.indexOf('nsfw') >= 0 || nm.indexOf('越狱') >= 0) {
          typeBadge = ' <span style="font-size:0.6rem;color:#f59e0b;background:rgba(245,158,11,0.1);padding:1px 5px;border-radius:4px;">JB</span>';
        } else {
          typeBadge = ' <span style="font-size:0.6rem;color:var(--color-text-muted);background:rgba(100,116,139,0.1);padding:1px 5px;border-radius:4px;">system</span>';
        }
        return '<div class="preset-item"><input type="checkbox" id="preset_chk_' + i + '" data-index="' + i + '"' + (it.enabled ? ' checked' : '') + ' /><label for="preset_chk_' + i + '">' + it.name + typeBadge + '</label></div>';
      }).join('');

      presetListContainer.querySelectorAll('input[type="checkbox"]').forEach(function(chk) {
        chk.addEventListener('change', function(e) {
          parsedPresetList[parseInt(e.target.getAttribute('data-index'))].enabled = e.target.checked;
          saveAIConfig();  // ★ 勾选变化时保存
        });
      });
    }

    presetInput.addEventListener('change', function(e) {
      var file = e.target.files[0]; if (!file) return;
      var reader = new FileReader();
      reader.onload = function(ev) {
        try {
          var data = JSON.parse(ev.target.result);
          parsedPresetList = [];
          if (data.prompts) {
            var ao = (data.prompt_order && data.prompt_order.length > 0)
              ? data.prompt_order[data.prompt_order.length - 1].order : [];
            var ei = ao.filter(function(i) { return i.enabled; }).map(function(i) { return i.identifier; });
            data.prompts.forEach(function(p) {
              if (p.content && !p.marker) {
                parsedPresetList.push({
                  id:                 p.identifier,
                  name:               p.name || '规则',
                  content:            p.content,
                  role:               p.role || 'system',
                  injection_position: p.injection_position || 0,
