      "first_mes": { label: "开场白(顶层)", tip: "角色说的第一句话", type: "string" },
      "mes_example": { label: "对话示例(顶层)", tip: "示范角色说话风格", type: "string" },
      "creatorcomment": { label: "作者注释(顶层)", tip: "V2兼容字段", type: "string" },
      "avatar": { label: "头像标记", tip: "头像文件名或none", type: "string" },
