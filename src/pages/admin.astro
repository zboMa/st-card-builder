---
import Layout from '../layouts/Layout.astro';
---
<Layout title="管理端 · ST Card Builder">
  <div class="admin-app" id="adminApp">
    <header class="admin-head">
      <div>
        <strong>管理端</strong>
        <span class="admin-muted" id="adminUserLine">校验中…</span>
      </div>
      <div class="admin-actions">
        <a class="btn btn-ghost btn-sm" href="/">返回应用</a>
        <a class="btn btn-primary btn-sm" href="/api/auth/discord">Discord 登录</a>
      </div>
    </header>
    <p class="admin-muted" id="adminGateTip">仅 ADMIN_DISCORD_IDS 白名单可访问。</p>

    <section class="admin-card" id="adminOverview">
      <h2>总览</h2>
      <pre id="adminOverviewPre" class="admin-pre">—</pre>
    </section>

    <section class="admin-card">
      <h2>用户</h2>
      <div class="admin-row">
        <input id="adminUserQ" type="search" placeholder="搜索 userId / 名 / Discord" />
        <button type="button" id="btnAdminLoadUsers" class="btn btn-sm btn-fetch">刷新</button>
      </div>
      <div id="adminUserList" class="admin-list"></div>
    </section>

    <section class="admin-card">
      <h2>分享</h2>
      <button type="button" id="btnAdminLoadShares" class="btn btn-sm btn-fetch">刷新分享</button>
      <div id="adminShareList" class="admin-list"></div>
    </section>

    <section class="admin-card">
      <h2>审计</h2>
      <button type="button" id="btnAdminLoadAudit" class="btn btn-sm btn-fetch">刷新审计</button>
      <pre id="adminAuditPre" class="admin-pre">—</pre>
    </section>
  </div>
</Layout>

<style is:global>
  html, body { overflow: auto !important; height: auto !important; }
  .admin-app {
    max-width: 960px;
    margin: 0 auto;
    padding: 20px 16px 48px;
    color: var(--color-text, #e8e6f0);
  }
  .admin-head {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    align-items: center;
    margin-bottom: 8px;
  }
  .admin-muted { color: var(--color-text-muted, #9aa0b4); font-size: 0.85rem; margin-left: 8px; }
  .admin-card {
    margin-top: 18px;
    padding: 14px;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    background: rgba(0,0,0,0.22);
  }
  .admin-card h2 { margin: 0 0 10px; font-size: 1rem; }
  .admin-pre {
    white-space: pre-wrap;
    font-size: 0.78rem;
    line-height: 1.45;
    margin: 0;
  }
  .admin-row { display: flex; gap: 8px; margin-bottom: 10px; }
  .admin-row input { flex: 1; }
  .admin-list { display: flex; flex-direction: column; gap: 8px; }
  .admin-item {
    display: flex;
    justify-content: space-between;
    gap: 8px;
    align-items: center;
    padding: 8px 10px;
    border-radius: 8px;
    background: rgba(255,255,255,0.03);
    font-size: 0.82rem;
  }
  .admin-item.is-disabled { opacity: 0.65; }
</style>

<script>
  function $(id) { return document.getElementById(id); }

  function escapeHtml(s) {
    return String(s == null ? '' : s)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  async function api(path, opts) {
    var res = await fetch(path, Object.assign({ credentials: 'include' }, opts || {}));
    var data = await res.json().catch(function() { return {}; });
    if (!res.ok) {
      var err = new Error(data.message || data.error || ('HTTP ' + res.status));
      err.status = res.status;
      err.data = data;
      throw err;
    }
    return data;
  }

  async function boot() {
    var tip = $('adminGateTip');
    var line = $('adminUserLine');
    try {
      var st = await api('/api/auth/status');
      if (!st.user) {
        if (line) line.textContent = '未登录';
        if (tip) tip.textContent = '请先 Discord 登录（须在 ADMIN_DISCORD_IDS 白名单）。';
        return;
      }
      if (!st.isAdmin) {
        if (line) line.textContent = st.user.displayName || st.user.username;
        if (tip) tip.textContent = '当前账号不是管理员（403）。';
        return;
      }
      if (line) line.textContent = (st.user.displayName || st.user.username) + ' · 管理员';
      if (tip) tip.textContent = '';
      await loadOverview();
      await loadUsers();
      await loadShares();
      await loadAudit();
    } catch (e) {
      if (tip) tip.textContent = '无法连接 API：' + (e.message || e);
    }
  }

  async function loadOverview() {
    var pre = $('adminOverviewPre');
    try {
      var data = await api('/api/admin/overview');
      if (pre) pre.textContent = JSON.stringify(data, null, 2);
    } catch (e) {
      if (pre) pre.textContent = String(e.message || e);
    }
  }

  async function loadUsers() {
    var box = $('adminUserList');
    var q = ($('adminUserQ') || {}).value || '';
    try {
      var data = await api('/api/admin/users?q=' + encodeURIComponent(q));
      var users = data.users || [];
      if (!box) return;
      if (!users.length) {
        box.innerHTML = '<div class="admin-muted">无用户注册记录（用户登录后会出现）</div>';
        return;
      }
      box.innerHTML = users.map(function(u) {
        var disabled = !!u.disabled;
        return '<div class="admin-item' + (disabled ? ' is-disabled' : '') + '" data-uid="' + escapeHtml(u.userId) + '">'
          + '<div><strong>' + escapeHtml(u.displayName || u.username || u.userId) + '</strong>'
          + '<div class="admin-muted">' + escapeHtml(u.userId) + (u.discordId ? ' · discord ' + escapeHtml(u.discordId) : '')
          + (disabled ? ' · 已禁用' : '') + '</div></div>'
          + '<button type="button" class="btn btn-sm btn-ghost" data-admin-user="' + (disabled ? 'enable' : 'disable') + '">'
          + (disabled ? '启用' : '禁用') + '</button></div>';
      }).join('');
    } catch (e) {
      if (box) box.innerHTML = '<div class="admin-muted">' + escapeHtml(e.message || e) + '</div>';
    }
  }

  async function loadShares() {
    var box = $('adminShareList');
    try {
      var data = await api('/api/admin/shares');
      var shares = data.shares || [];
      if (!box) return;
      if (!shares.length) {
        box.innerHTML = '<div class="admin-muted">暂无分享</div>';
        return;
      }
      box.innerHTML = shares.map(function(s) {
        return '<div class="admin-item" data-token="' + escapeHtml(s.token) + '">'
          + '<div><strong>' + escapeHtml(s.titleHint || s.token) + '</strong>'
          + '<div class="admin-muted">' + escapeHtml(s.token) + ' · ' + escapeHtml(s.ownerUserId || '')
          + ' · ' + escapeHtml(s.displayVersionHint || '') + '</div></div>'
          + '<button type="button" class="btn btn-sm btn-delete" data-admin-share-stop>停用</button></div>';
      }).join('');
    } catch (e) {
      if (box) box.innerHTML = '<div class="admin-muted">' + escapeHtml(e.message || e) + '</div>';
    }
  }

  async function loadAudit() {
    var pre = $('adminAuditPre');
    try {
      var data = await api('/api/admin/audit');
      if (pre) pre.textContent = JSON.stringify(data.audit || [], null, 2);
    } catch (e) {
      if (pre) pre.textContent = String(e.message || e);
    }
  }

  document.addEventListener('DOMContentLoaded', function() {
    boot();
    $('btnAdminLoadUsers')?.addEventListener('click', loadUsers);
    $('adminUserQ')?.addEventListener('keydown', function(ev) {
      if (ev.key === 'Enter') loadUsers();
    });
    $('btnAdminLoadShares')?.addEventListener('click', loadShares);
    $('btnAdminLoadAudit')?.addEventListener('click', loadAudit);

    $('adminUserList')?.addEventListener('click', async function(ev) {
      var btn = ev.target.closest('[data-admin-user]');
      if (!btn) return;
      var row = btn.closest('[data-uid]');
      if (!row) return;
      var uid = row.getAttribute('data-uid');
      var disable = btn.getAttribute('data-admin-user') === 'disable';
      try {
        await api('/api/admin/users/' + encodeURIComponent(uid) + '/disable', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ disabled: disable }),
        });
        await loadUsers();
        await loadAudit();
        await loadOverview();
      } catch (e) {
        alert(e.message || e);
      }
    });

    $('adminShareList')?.addEventListener('click', async function(ev) {
      var btn = ev.target.closest('[data-admin-share-stop]');
      if (!btn) return;
      var row = btn.closest('[data-token]');
      if (!row) return;
      var token = row.getAttribute('data-token');
      if (!confirm('强制停用分享 ' + token + '？')) return;
      try {
        await api('/api/admin/shares/' + encodeURIComponent(token), { method: 'DELETE' });
        await loadShares();
        await loadAudit();
      } catch (e) {
        alert(e.message || e);
      }
    });
  });
</script>
