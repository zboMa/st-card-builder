---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
    <style is:global>
      @import '../styles/tokens.css';
      @import '../styles/ui-patterns.css';
      @import '../styles/layout-chrome.css';
    </style>
  </head>
  <body>
    <slot />

    <!-- ★ 全局自定义下拉框增强 -->
    <script>
      import { initLayoutChrome } from '../lib/layout/chromeBoot.mjs';
      initLayoutChrome();
    </script>
  </body>
</html>
