---
interface Props {
  title: string;
}

import ThemeGallery from '../components/ThemeGallery.astro';

const { title } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <script is:inline>
      (function () {
        var K = 'st_v3_app_theme';
        var D = 'nocturne';
        var M = { ink: 'sumi-ink', frost: 'frost-shard', jade: 'bamboo-edge', rose: 'nocturne', neon: 'nocturne', slate: 'nocturne', daybreak: 'nocturne' };
        var ids = ['nocturne', 'sumi-ink', 'frost-shard', 'ember-blaze', 'bamboo-edge'];
        function sceneFor(t) { return t === 'nocturne' ? 'none' : t; }
        try {
          var t = localStorage.getItem(K) || D;
          if (M[t]) t = M[t];
          if (ids.indexOf(t) < 0) t = D;
          document.documentElement.setAttribute('data-app-theme', t);
          document.documentElement.setAttribute('data-app-scene', sceneFor(t));
        } catch (e) {
          document.documentElement.setAttribute('data-app-theme', D);
          document.documentElement.setAttribute('data-app-scene', 'none');
        }
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#1e1c24" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
    <style is:global>
      @import '../styles/tokens.css';
      @import '../styles/ui-patterns.css';
      @import '../styles/layout-chrome.css';
    </style>
  </head>
  <body>
    <slot />
    <ThemeGallery />

    <!-- ★ 全局自定义下拉框增强 -->
    <script>
      import { initLayoutChrome } from '../lib/layout/chromeBoot.mjs';
      import { initTheme } from '../lib/theme/themeBoot.mjs';
      import { initThemePicker } from '../lib/theme/themePickerBoot.mjs';
      initTheme();
      initLayoutChrome();
      initThemePicker();
    </script>
  </body>
</html>
